<div class="main-content sidebar-aware-content w-auto px-4 sm:px-6 py-6 sm:py-8" style="min-height: 100vh; background: linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);">
  <div class="w-full rounded-3xl border border-slate-200 bg-white p-6 shadow-xl shadow-slate-200/30 sm:p-8">
    <div class="mb-8 flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-black">Assessment Setup</p>
        <h1 class="text-3xl font-bold text-black">Edit Quiz</h1>
        <p class="mt-2 text-sm text-black">Update quiz details, improve questions, and keep the page full width for easier editing.</p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <%= form_with url: import_quizzes_path, local: true, multipart: true, class: "flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center" do |form| %>
          <%= form.file_field :file, accept: ".xlsx,.xls", class: "block rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm" %>
          <%= form.submit "Upload Excel", class: "inline-flex items-center justify-center rounded-2xl bg-green-300 px-4 py-3 text-sm font-semibold text-black transition hover:bg-green-400" %>
        <% end %>
        <%= link_to "Export Excel", export_quizzes_path(format: :xlsx), class: "rounded-2xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm font-semibold text-blue-700 transition hover:border-blue-300 hover:bg-blue-100" %>
      </div>
    </div>
    <%= render "form", quiz: @quiz, submit_label: "Update Quiz" %>
  </div>
</div>
