<div class="question-block mb-5 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:shadow-md">
  <%= f.hidden_field :id if f.object.persisted? %>
  <%= f.hidden_field :_destroy, value: "0", class: "destroy-flag" %>

  <div class="flex items-center justify-between gap-3 border-b border-slate-200 bg-slate-50 px-5 py-4">
    <div>
      <h3 class="question-title text-base font-semibold text-black">Question</h3>
      <p class="text-xs text-black">Add question text, 4 options, and choose the correct answer.</p>
    </div>
    <button type="button" class="remove-question inline-flex items-center rounded-lg bg-red-50 px-3 py-2 text-xs font-semibold text-red-600 transition hover:bg-red-100 hover:text-red-700">
      Remove
    </button>
  </div>

  <div class="p-5">
  <div class="mb-4">
    <%= f.label :question, "Question Text", class: "mb-1 block text-sm font-medium text-black" %>
    <%= f.text_area :question, rows: 2, class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-black outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" %>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <% [:option_a, :option_b, :option_c, :option_d].each do |field| %>
      <div>
        <%= f.label field, field.to_s.humanize, class: "mb-1 block text-sm font-medium text-black" %>
        <%= f.text_field field, class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-black outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" %>
      </div>
    <% end %>
  </div>

  <div class="mt-3">
    <%= f.label :correct_answer, "Correct Answer", class: "mb-1 block text-sm font-medium text-black" %>
    <%= f.select :correct_answer,
          options_for_select([
            ["Option A", "option_a"],
            ["Option B", "option_b"],
            ["Option C", "option_c"],
            ["Option D", "option_d"]
          ], f.object.correct_answer),
          { include_blank: "Select correct option" },
          class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-black outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" %>
  </div>
  </div>
</div>
