            "Q1 (APR-JUN)" => %w[april may june],
            "Q2 (JUL-SEP)" => %w[july august september],
            "Q3 (OCT-DEC)" => %w[october november december],
            "Q4 (JAN-MAR)" => %w[january february march]
          }
        %>
        <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4">
          <h3 class="mb-4 text-lg font-bold text-gray-800 flex items-center">
            <i class="fas fa-chart-line mr-2 text-gray-600"></i>
            Financial year summary
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <% financial_summary_quarters.each do |quarter_label, quarter_months| %>
              <%
                quarter_target_total = 0.0
                quarter_achievement_total = 0.0
                quarter_l1_remarks = []
                quarter_l2_remarks = []
                quarter_l1_percentages = []
                quarter_l2_percentages = []

                @user_details.each do |detail|
                  achievements_by_month = detail.achievements.index_by(&:month)
                  quarter_months.each do |month|
                    target_value = clean_spreadsheet_display_value(detail.public_send(month))
                    achievement_record = achievements_by_month[month]
                    has_achievement = achievement_record&.achievement.present?
                    if has_achievement
                      quarter_target_total += target_value.to_s.delete(",").to_f if target_value.present? && target_value.to_s.strip != "0"
                      quarter_achievement_total += achievement_record.achievement.to_s.delete(",").to_f
                    end
                    quarter_l1_remarks << achievement_record.achievement_remark.l1_remarks if achievement_record&.achievement_remark&.l1_remarks.present?
                    quarter_l2_remarks << achievement_record.achievement_remark.l2_remarks if achievement_record&.achievement_remark&.l2_remarks.present?
                    quarter_l1_percentages << achievement_record.achievement_remark.l1_percentage.to_f if achievement_record&.achievement_remark&.l1_percentage.present?
                    quarter_l2_percentages << achievement_record.achievement_remark.l2_percentage.to_f if achievement_record&.achievement_remark&.l2_percentage.present?
                  end
                end

                quarter_percentage = quarter_target_total.positive? ? ((quarter_achievement_total / quarter_target_total) * 100.0).round(2) : nil
                quarter_l1_average = quarter_l1_percentages.any? ? (quarter_l1_percentages.sum / quarter_l1_percentages.size).round(1) : nil
                quarter_l2_average = quarter_l2_percentages.any? ? (quarter_l2_percentages.sum / quarter_l2_percentages.size).round(1) : nil
                financial_summary_payload = {
                  quarter: quarter_label,
                  target: quarter_target_total,
                  achievement: quarter_achievement_total,
                  percentage: quarter_percentage,
                  l1_remarks: quarter_l1_remarks.uniq.join("; "),
                  l2_remarks: quarter_l2_remarks.uniq.join("; "),
                  l1_percentage: quarter_l1_average,
                  l2_percentage: quarter_l2_average
                }
              %>
              <button type="button"
                      class="financial-summary-btn rounded-lg border border-gray-200 bg-white p-4 text-left shadow-sm hover:border-gray-400 hover:shadow-md transition"
                      data-financial-summary="<%= financial_summary_payload.to_json.gsub('"', '&quot;') %>">
                <div class="flex items-center justify-between gap-3">
                  <span class="font-semibold text-gray-800"><%= quarter_label %></span>
                  <span class="review-eye-button">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                      <circle cx="12" cy="12" r="2.5" />
                    </svg>
                  </span>
                </div>
                <div class="mt-3 text-sm text-gray-600">
                  <div>Target: <span class="font-semibold text-gray-900"><%= number_with_precision(quarter_target_total, precision: 2, strip_insignificant_zeros: true) %></span></div>
                  <div>Achievement: <span class="font-semibold text-gray-900"><%= number_with_precision(quarter_achievement_total, precision: 2, strip_insignificant_zeros: true) %></span></div>
                  <div>Achievement against target: <span class="font-semibold text-emerald-700"><%= quarter_percentage.present? ? "#{number_with_precision(quarter_percentage, precision: 2, strip_insignificant_zeros: true)}%" : "-" %></span></div>
                  <div class="mt-2 border-t border-gray-100 pt-2">L1 Avg %: <span class="font-semibold text-blue-700"><%= quarter_l1_average.present? ? "#{number_with_precision(quarter_l1_average, precision: 2, strip_insignificant_zeros: true)}%" : "-" %></span></div>
                  <div>L2 Avg %: <span class="font-semibold text-green-700"><%= quarter_l2_average.present? ? "#{number_with_precision(quarter_l2_average, precision: 2, strip_insignificant_zeros: true)}%" : "-" %></span></div>
                </div>
              </button>
            <% end %>
          </div>
        </div>
      </div>
