                        data-detail-id="<%= detail.id %>"
                        data-achievement-value="<%= q4_display %>">
                    <%= q4_display.present? ? (q4_is_quarterly_achievement ? "#{q4_display}%" : (q4_is_target ? q4_display : "#{q4_display}%")) : '-' %>
