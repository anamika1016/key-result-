</style>

<script>
// Global function to handle checkbox changes (called by inline onchange)
function handleCheckboxChange(checkbox) {
  console.log('Inline handler - Checkbox changed:', checkbox.dataset.quarter, 'checked:', checkbox.checked);
  
  const editButton = document.getElementById('edit-quarterly-btn');
  if (!editButton) {
    console.error('Edit button not found in inline handler');
    return;
  }
  
  const checkedBoxes = document.querySelectorAll('.table-quarter-checkbox:checked');
  console.log('Inline handler - Checked boxes:', checkedBoxes.length);
  
  if (checkedBoxes.length > 0) {
    // Enable button
    editButton.disabled = false;
    editButton.style.backgroundColor = '#eab308'; // yellow-500
    editButton.style.color = '#000000'; // black text
    editButton.style.cursor = 'pointer';
    editButton.style.opacity = '1';
    console.log('Inline handler - Button enabled');
    
    // Ensure click handler is attached
    if (!editButton._clickHandlerAttached) {
      console.log('Attaching click handler to button');
      editButton.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        console.log('Edit button clicked!');
        
        const checkedBoxes = document.querySelectorAll('.table-quarter-checkbox:checked');
        console.log('Checked boxes on click:', checkedBoxes.length);
        
        if (checkedBoxes.length === 0) {
          alert('Please select at least one quarter to edit.');
          return false;
        }
        
        // Get selected quarters
        const selectedQuarters = Array.from(checkedBoxes).map(cb => cb.dataset.quarter);
        console.log('Selected quarters:', selectedQuarters);
        
        // Redirect to quarterly edit page with the first selected quarter
        const selectedQuarter = selectedQuarters[0];
        const editUrl = '<%= quarterly_edit_all_user_details_path %>?quarter=' + selectedQuarter;
        
        console.log('Redirecting to:', editUrl);
        window.location.href = editUrl;
        
        return false;
      });
      editButton._clickHandlerAttached = true;
    }
  } else {
    // Disable button
    editButton.disabled = true;
    editButton.style.backgroundColor = '#9ca3af'; // gray-400
    editButton.style.color = '#ffffff'; // white text
    editButton.style.cursor = 'not-allowed';
    editButton.style.opacity = '0.6';
    console.log('Inline handler - Button disabled');
  }
}

// Global function to handle edit button clicks (called by inline onclick)
function handleEditButtonClick(event) {
  event.preventDefault();
  event.stopPropagation();
  
  console.log('Inline button click handler triggered');
  
  const checkedBoxes = document.querySelectorAll('.table-quarter-checkbox:checked');
  console.log('Button clicked - checked boxes:', checkedBoxes.length);
  
  if (checkedBoxes.length === 0) {
    alert('Please select at least one quarter to edit.');
    return false;
  }
  
  // Get selected quarters
  const selectedQuarters = Array.from(checkedBoxes).map(cb => cb.dataset.quarter);
  console.log('Selected quarters:', selectedQuarters);
  
  // Redirect to quarterly edit page with the first selected quarter
  const selectedQuarter = selectedQuarters[0];
  const editUrl = '<%= quarterly_edit_all_user_details_path %>?quarter=' + selectedQuarter;
  
  console.log('Redirecting to:', editUrl);
  window.location.href = editUrl;
  
  return false;
}

// Wait for DOM to be fully loaded
document.addEventListener('DOMContentLoaded', function() {
  console.log('DOM loaded, initializing quarterly edit functionality...');
  
  // Get elements
  const tableCheckboxes = document.querySelectorAll('.table-quarter-checkbox');
  const editButton = document.getElementById('edit-quarterly-btn');
  
  console.log('Found checkboxes:', tableCheckboxes.length);
  console.log('Found edit button:', editButton);
  
  if (!editButton) {
    console.error('Edit button not found!');
    return;
  }
  
  // Function to update edit button state
  function updateEditButton() {
    const checkedBoxes = document.querySelectorAll('.table-quarter-checkbox:checked');
    console.log('Updating button state. Checked boxes:', checkedBoxes.length);
    
    if (checkedBoxes.length > 0) {
      // Enable button - make it yellow and clickable
      editButton.disabled = false;
      editButton.style.backgroundColor = '#eab308'; // yellow-500
      editButton.style.color = '#000000'; // black text
      editButton.style.cursor = 'pointer';
      editButton.style.opacity = '1';
      console.log('Button enabled');
    } else {
      // Disable button - make it gray and not clickable
      editButton.disabled = true;
      editButton.style.backgroundColor = '#9ca3af'; // gray-400
      editButton.style.color = '#ffffff'; // white text
      editButton.style.cursor = 'not-allowed';
      editButton.style.opacity = '0.6';
      console.log('Button disabled');
    }
  }
  
  // Add event listeners to table checkboxes
  tableCheckboxes.forEach((checkbox, index) => {
    console.log(`Adding listener to checkbox ${index}:`, checkbox.dataset.quarter);
    
    // Remove any existing listeners first
    checkbox.removeEventListener('change', checkbox._changeHandler);
    
    // Create new change handler
    checkbox._changeHandler = function() {
      console.log('Checkbox changed:', this.dataset.quarter, 'checked:', this.checked);
      updateEditButton();
    };
    
    // Add the event listener
    checkbox.addEventListener('change', checkbox._changeHandler);
    
    // Also add click event as backup
    checkbox.addEventListener('click', function() {
      console.log('Checkbox clicked:', this.dataset.quarter, 'checked:', this.checked);
      setTimeout(updateEditButton, 10); // Small delay to ensure state is updated
    });
  });
  
  // Add click event listener to edit button
  editButton.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    
    console.log('Edit button clicked!');
    
    const checkedBoxes = document.querySelectorAll('.table-quarter-checkbox:checked');
    console.log('Checked boxes on click:', checkedBoxes.length);
    
    if (checkedBoxes.length === 0) {
      alert('Please select at least one quarter to edit.');
      return false;
    }
    
    // Get selected quarters
    const selectedQuarters = Array.from(checkedBoxes).map(cb => cb.dataset.quarter);
    console.log('Selected quarters:', selectedQuarters);
    
    // Redirect to quarterly edit page with the first selected quarter
    const selectedQuarter = selectedQuarters[0];
    const editUrl = '<%= quarterly_edit_all_user_details_path %>?quarter=' + selectedQuarter;
    
    console.log('Redirecting to:', editUrl);
    window.location.href = editUrl;
    
    return false;
  });
  
  // Initialize button state
  updateEditButton();
  
  // Run additional checks to ensure everything is working
  setTimeout(function() {
    console.log('Running delayed check...');
    updateEditButton();
    
    // Test if button is properly set up
    console.log('Button disabled state:', editButton.disabled);
    console.log('Button background color:', editButton.style.backgroundColor);
    
    // Re-attach event listeners in case they weren't attached properly
    const checkboxes = document.querySelectorAll('.table-quarter-checkbox');
    checkboxes.forEach((checkbox, index) => {
      if (!checkbox._changeHandler) {
        console.log(`Re-attaching listener to checkbox ${index}`);
        checkbox._changeHandler = function() {
          console.log('Checkbox changed (re-attached):', this.dataset.quarter, 'checked:', this.checked);
          updateEditButton();
        };
        checkbox.addEventListener('change', checkbox._changeHandler);
      }
    });
  }, 200);
  
  // Final check after everything should be loaded
  setTimeout(function() {
    console.log('Final initialization check...');
    updateEditButton();
    
    // Force update button state
    const checkedBoxes = document.querySelectorAll('.table-quarter-checkbox:checked');
    console.log('Final check - checked boxes:', checkedBoxes.length);
    if (checkedBoxes.length > 0) {
      editButton.disabled = false;
      editButton.style.backgroundColor = '#eab308';
      editButton.style.cursor = 'pointer';
    }
  }, 1000);
});

// Also run on window load as backup
window.addEventListener('load', function() {
  console.log('Window loaded, running backup initialization...');
  setTimeout(function() {
    const editButton = document.getElementById('edit-quarterly-btn');
    if (editButton) {
      const checkedBoxes = document.querySelectorAll('.table-quarter-checkbox:checked');
      if (checkedBoxes.length > 0) {
        editButton.disabled = false;
        editButton.style.backgroundColor = '#eab308';
        editButton.style.cursor = 'pointer';
      } else {
        editButton.disabled = true;
        editButton.style.backgroundColor = '#9ca3af';
        editButton.style.cursor = 'not-allowed';
      }
    }
  }, 100);
});
</script>

<!-- Quarterly Achievement Details Modal -->
<div id="quarterlyDetailsModal" class="fixed inset-0 hidden z-50 flex items-center justify-center">
  <div class="bg-white rounded-lg shadow-xl max-w-3xl w-full mx-4">
    <!-- Modal Header -->
    <div class="bg-gray-700 text-white px-6 py-4 rounded-t-lg flex justify-between items-center">
      <div>
        <h3 class="text-lg font-semibold">Quarterly Achievement Details</h3>
        <span id="modalQuarterTitle" class="text-sm font-medium"></span>
      </div>
      <button onclick="refreshQuarterlyDetails()" class="text-white hover:text-gray-200 transition-colors" title="Refresh Data">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
        </svg>
      </button>
    </div>
    
    <!-- Modal Body -->
    <div class="p-6 max-h-[70vh] overflow-y-auto">
      <div class="text-xs text-gray-500 text-center mb-4" id="lastUpdated">
        Auto-refreshing every 10 seconds
      </div>
      <div id="modalSummariesContainer" class="space-y-8">
        <!-- Dynamic content will be inserted here by JavaScript -->
        <div class="flex flex-col items-center justify-center py-12">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mb-4"></div>
            <p class="text-gray-500 font-medium">Fetching details...</p>
        </div>
      </div>
    </div>
    
    <!-- Modal Footer -->
    <div class="bg-gray-100 px-6 py-4 rounded-b-lg flex justify-center gap-3">
      <button onclick="refreshQuarterlyDetails()" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
        </svg>
        Refresh
      </button>
      <button onclick="closeQuarterlyDetails()" class="bg-gray-700 text-white px-6 py-2 rounded-lg hover:bg-gray-800 transition-colors">
        Close Details
      </button>
    </div>
  </div>
</div>

<script>
// Global variable to store modal refresh interval
let modalRefreshInterval = null;
let currentModalQuarter = null;

// Function to fetch and update quarterly details
function fetchQuarterlyDetails(quarter, showLoading = true) {
  // Update modal title with correct months for each quarter
  const quarterMonths = {
    'Q1': 'Q1 (APR-MAY-JUN)',
    'Q2': 'Q2 (JUL-AUG-SEP)', 
    'Q3': 'Q3 (OCT-NOV-DEC)',
    'Q4': 'Q4 (JAN-FEB-MAR)'
  };
  document.getElementById('modalQuarterTitle').textContent = quarterMonths[quarter] || quarter;
  
  // Show loading state if requested
  const container = document.getElementById('modalSummariesContainer');
  if (showLoading) {
    container.innerHTML = `
      <div class="flex flex-col items-center justify-center py-12">
          <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mb-4"></div>
          <p class="text-gray-500 font-medium">Fetching details...</p>
      </div>`;
  }
  
  // Fetch real data from server with cache busting
  const timestamp = new Date().getTime();
  fetch(`/quarterly_details?quarter=${quarter}&t=${timestamp}`, {
    method: 'GET',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
      'Cache-Control': 'no-cache'
    }
  })
  .then(response => {
    if (!response.ok) {
      throw new Error('Network response was not ok');
    }
    return response.json();
  })
  .then(data => {
    console.log('Received data:', data);
    
    // Update last updated timestamp
    const now = new Date();
    const timeString = now.toLocaleTimeString();
    const lastUpdatedEl = document.getElementById('lastUpdated');
    if (lastUpdatedEl) {
      lastUpdatedEl.textContent = `Last updated: ${timeString} (Auto-refreshing every 10 seconds)`;
    }
    
    // Clear container
    container.innerHTML = '';
    
    if (!data.summaries || data.summaries.length === 0) {
      container.innerHTML = `
        <div class="text-center py-12 text-gray-500">
          <i class="fas fa-info-circle text-4xl mb-4"></i>
          <p class="text-lg">No data available for ${quarter}</p>
        </div>`;
      return;
    }
    
    // Helper to get status color classes
    const getStatusColorClass = (status) => {
      if (!status) return 'bg-gray-100 text-gray-800';
      const s = status.toLowerCase();
      
      // Success / Approved statuses
      if (s.includes('approved')) return 'bg-green-100 text-green-800 border border-green-200';
      
      // Return / Alert statuses
      if (s.includes('returned') || s.includes('rejected')) {
        if (s.includes('employee')) return 'bg-orange-100 text-orange-800 border border-orange-200';
        return 'bg-red-100 text-red-800 border border-red-200';
      }
      
      // Progress statuses
      if (s.includes('pending')) return 'bg-yellow-100 text-yellow-800 border border-yellow-200';
      if (s.includes('submitted')) return 'bg-blue-100 text-blue-800 border border-blue-200';
      
      // Default
      return 'bg-gray-100 text-gray-800 border border-gray-200';
    };
    
    // Group summaries by employee if needed, but for now just show them
    data.summaries.forEach((summary) => {
      const summaryHtml = `
        <div class="department-summary-block border border-gray-200 rounded-lg overflow-hidden shadow-sm mb-3">
          <div class="bg-gray-50 px-3 py-1.5 border-b border-gray-200 flex justify-between items-center">
            <div class="flex items-center space-x-2">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-tight">${summary.department_name}</span>
              <span class="text-gray-300">|</span>
              <span class="text-gray-700 font-medium text-xs">${summary.employee_name}</span>
            </div>
            <span class="text-[10px] text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded">${summary.activity_count} Activities</span>
          </div>
          <div class="p-2.5">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
              <!-- L1 Compact -->
              <div class="bg-orange-50/50 border border-orange-100 rounded p-2 flex flex-col justify-between h-full">
                <div class="flex justify-between items-center mb-1">
                  <span class="text-[10px] font-bold text-orange-800 uppercase tracking-wider">L1 Summary</span>
                  <span class="text-sm font-black text-orange-700">${summary.l1.percentage}</span>
                </div>
                <div class="bg-blue-50/50 p-1.5 rounded border border-blue-100 mb-1.5 min-h-[30px] flex items-center">
                  <span class="text-blue-700 italic text-[12px] leading-tight font-medium" title="${summary.l1.remarks}">
                    ${summary.l1.remarks && summary.l1.remarks !== 'No remarks' ? `"${summary.l1.remarks}"` : '<span class="text-gray-400">No remarks</span>'}
                  </span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="px-1.5 py-0.5 rounded text-[8px] font-bold uppercase ${getStatusColorClass(summary.l1.status)}">
                    ${summary.l1.status}
                  </span>
                  <i class="fas fa-check-double text-orange-200 text-[10px]"></i>
                </div>
              </div>
              
              <!-- L2 Compact -->
              <div class="bg-purple-50/50 border border-purple-100 rounded p-2 flex flex-col justify-between h-full">
                <div class="flex justify-between items-center mb-1">
                  <span class="text-[10px] font-bold text-purple-800 uppercase tracking-wider">L2 Summary</span>
                  <span class="text-sm font-black text-purple-700">${summary.l2.percentage}</span>
                </div>
                <div class="bg-blue-50/50 p-1.5 rounded border border-blue-100 mb-1.5 min-h-[30px] flex items-center">
                  <span class="text-blue-700 italic text-[12px] leading-tight font-medium" title="${summary.l2.remarks}">
                    ${summary.l2.remarks && summary.l2.remarks !== 'No remarks' ? `"${summary.l2.remarks}"` : '<span class="text-gray-400">No remarks</span>'}
                  </span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="px-1.5 py-0.5 rounded text-[8px] font-bold uppercase ${getStatusColorClass(summary.l2.status)}">
                    ${summary.l2.status}
                  </span>
                  <i class="fas fa-certificate text-purple-200 text-[10px]"></i>
                </div>
              </div>
              
              <!-- L3 Compact -->
              <div class="bg-blue-50/50 border border-blue-100 rounded p-2 flex flex-col justify-between h-full">
                <div class="flex justify-between items-center mb-1">
                  <span class="text-[10px] font-bold text-blue-800 uppercase tracking-wider">L3 Summary</span>
                  <span class="text-sm font-black text-blue-700">${summary.l3.percentage}</span>
                </div>
                <div class="bg-blue-50/50 p-1.5 rounded border border-blue-100 mb-1.5 min-h-[30px] flex items-center">
                  <span class="text-blue-700 italic text-[12px] leading-tight font-medium" title="${summary.l3.remarks}">
                    ${summary.l3.remarks && summary.l3.remarks !== 'No remarks' ? `"${summary.l3.remarks}"` : '<span class="text-gray-400">No remarks</span>'}
                  </span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="px-1.5 py-0.5 rounded text-[8px] font-bold uppercase ${getStatusColorClass(summary.l3.status)}">
                    ${summary.l3.status}
                  </span>
                  <i class="fas fa-shield-alt text-blue-200 text-[10px]"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
      `;
      container.insertAdjacentHTML('beforeend', summaryHtml);
    });
  })
  .catch(error => {
    console.error('Error fetching quarterly details:', error);
    container.innerHTML = `
      <div class="text-center py-12 text-red-500">
        <i class="fas fa-exclamation-triangle text-4xl mb-4"></i>
        <p class="text-lg font-bold">Error loading data</p>
        <p class="text-sm">${error.message}</p>
      </div>`;
  });
}

// Function to show quarterly details modal
function showQuarterlyDetails(quarter) {
  // Check active state from dashboard
  const isDashboardActive = <%= @dashboard_active ? 'true' : 'false' %>;
  
  if (!isDashboardActive) {
    alert('Quarterly Achievement Details viewing has been disabled by the Administrator/HOD.');
    return;
  }

  console.log('Showing details for quarter:', quarter);
  currentModalQuarter = quarter;
  
  // Show the modal first
  document.getElementById('quarterlyDetailsModal').classList.remove('hidden');
  
  // Fetch initial data
  fetchQuarterlyDetails(quarter, true);
  
  // Start auto-refresh every 10 seconds while modal is open
  if (modalRefreshInterval) {
    clearInterval(modalRefreshInterval);
  }
  modalRefreshInterval = setInterval(() => {
    if (!document.getElementById('quarterlyDetailsModal').classList.contains('hidden')) {
      console.log('Auto-refreshing quarterly details for:', quarter);
      fetchQuarterlyDetails(quarter, false); // Don't show loading on auto-refresh
    }
  }, 10000); // Refresh every 10 seconds
  
  // Listen for real-time updates from other tabs/pages
  window.addEventListener('storage', function(e) {
    if (e.key === 'quarterly_details_updated' && e.newValue === quarter) {
      console.log('Quarterly details updated from another tab, refreshing...');
      fetchQuarterlyDetails(quarter, false);
    }
  });
  
  // Listen for custom events (same tab updates)
  window.addEventListener('quarterlyDetailsUpdated', function(e) {
    if (e.detail.quarter === quarter) {
      console.log('Quarterly details updated, refreshing...');
      fetchQuarterlyDetails(quarter, false);
    }
  });
}

// Function to manually refresh modal data
function refreshQuarterlyDetails() {
  if (currentModalQuarter) {
    console.log('Manually refreshing quarterly details for:', currentModalQuarter);
    fetchQuarterlyDetails(currentModalQuarter, true);
  }
}

// Function to close quarterly details modal
function closeQuarterlyDetails() {
  document.getElementById('quarterlyDetailsModal').classList.add('hidden');
  
  // Stop auto-refresh when modal is closed
  if (modalRefreshInterval) {
    clearInterval(modalRefreshInterval);
    modalRefreshInterval = null;
  }
  currentModalQuarter = null;
}

// Close modal when clicking outside
document.getElementById('quarterlyDetailsModal').addEventListener('click', function(e) {
  if (e.target === this) {
    closeQuarterlyDetails();
  }
});

// Close modal with Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    closeQuarterlyDetails();
  }
});

// Function to calculate and update total weightage dynamically
function updateTotalWeightage() {
  let totalWeightage = 0;
  
  // Get all weightage values from the table (6th column)
  const weightageCells = document.querySelectorAll('tbody tr:not(.bg-green-100) td:nth-child(6)');
  weightageCells.forEach(cell => {
    const weightageText = cell.textContent.trim();
    if (weightageText && !isNaN(parseFloat(weightageText))) {
      totalWeightage += parseFloat(weightageText);
    }
  });
  
  // Update the display
  const totalWeightageDisplay = document.getElementById('total-weightage-display');
  if (totalWeightageDisplay) {
    totalWeightageDisplay.textContent = Math.round(totalWeightage) + '%';
    
    // Add animation effect
    totalWeightageDisplay.style.transform = 'scale(1.1)';
    totalWeightageDisplay.style.transition = 'transform 0.2s ease';
    
    setTimeout(() => {
      totalWeightageDisplay.style.transform = 'scale(1)';
    }, 200);
  }
}

// Function to calculate and update achievement totals dynamically
function updateAchievementTotals() {
  // Calculate Q1 achievement total
  let q1Total = 0;
  const q1Cells = document.querySelectorAll('tbody tr:not(.bg-green-100) td:nth-child(7)'); // Q1 achievement column
  q1Cells.forEach(cell => {
    const cellText = cell.textContent.trim();
    const percentage = cellText.replace('%', '');
    if (percentage && !isNaN(parseFloat(percentage))) {
      q1Total += parseFloat(percentage);
    }
  });
  
  // Update Q1 total
  const q1Display = document.getElementById('q1-achievement-total');
  if (q1Display) {
    q1Display.textContent = Math.round(q1Total) + '%';
    animateUpdate(q1Display);
  }
  
  // Calculate Q2 achievement total
  let q2Total = 0;
  const q2Cells = document.querySelectorAll('tbody tr:not(.bg-green-100) td:nth-child(10)'); // Q2 achievement column
  q2Cells.forEach(cell => {
    const cellText = cell.textContent.trim();
    const percentage = cellText.replace('%', '');
    if (percentage && !isNaN(parseFloat(percentage))) {
      q2Total += parseFloat(percentage);
    }
  });
  
  // Update Q2 total
  const q2Display = document.getElementById('q2-achievement-total');
  if (q2Display) {
    q2Display.textContent = Math.round(q2Total) + '%';
    animateUpdate(q2Display);
  }
  
  // Calculate Q3 achievement total
  let q3Total = 0;
  const q3Cells = document.querySelectorAll('tbody tr:not(.bg-green-100) td:nth-child(13)'); // Q3 achievement column
  q3Cells.forEach(cell => {
    const cellText = cell.textContent.trim();
    const percentage = cellText.replace('%', '');
    if (percentage && !isNaN(parseFloat(percentage))) {
      q3Total += parseFloat(percentage);
    }
  });
  
  // Update Q3 total
  const q3Display = document.getElementById('q3-achievement-total');
  if (q3Display) {
    q3Display.textContent = Math.round(q3Total) + '%';
    animateUpdate(q3Display);
  }
  
  // Calculate Q4 achievement total
  let q4Total = 0;
  const q4Cells = document.querySelectorAll('tbody tr:not(.bg-green-100) td:nth-child(16)'); // Q4 achievement column
  q4Cells.forEach(cell => {
    const cellText = cell.textContent.trim();
    const percentage = cellText.replace('%', '');
    if (percentage && !isNaN(parseFloat(percentage))) {
      q4Total += parseFloat(percentage);
    }
  });
  
  // Update Q4 total
  const q4Display = document.getElementById('q4-achievement-total');
  if (q4Display) {
    q4Display.textContent = Math.round(q4Total) + '%';
    animateUpdate(q4Display);
  }
}

// Helper function for animation
function animateUpdate(element) {
  element.style.transform = 'scale(1.1)';
  element.style.transition = 'transform 0.2s ease';
  
  setTimeout(() => {
    element.style.transform = 'scale(1)';
  }, 200);
}

// Initialize dynamic weightage calculation on page load
document.addEventListener('DOMContentLoaded', function() {
  // Update total weightage when page loads
  updateTotalWeightage();
  
  // Update achievement totals when page loads
  updateAchievementTotals();
  
  // Add event listeners for any dynamic changes
  const table = document.querySelector('.table');
  if (table) {
    // Use MutationObserver to watch for changes in the table
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.type === 'childList' || mutation.type === 'characterData') {
          updateTotalWeightage();
          updateAchievementTotals();
        }
      });
    });
    
    observer.observe(table, {
      childList: true,
      subtree: true,
      characterData: true
    });
  }
});
</script>


