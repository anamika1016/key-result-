        <!-- Modal Content -->
        <div class="p-6 bg-gray-50">
          <div id="reviewMetricSummary" class="mb-6 grid grid-cols-1 sm:grid-cols-4 gap-3"></div>
          <div id="monthlyEmployeeSummary" class="hidden mb-6 rounded-lg border border-sky-200 bg-sky-50 p-5">
            <h4 class="text-sky-700 font-semibold text-lg mb-4 flex items-center">
              <i class="fas fa-eye mr-2"></i>Month details
            </h4>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div>
                <span class="text-sm text-gray-600">Activity:</span>
                <div id="monthActivityName" class="mt-1 font-bold text-gray-800">N/A</div>
              </div>
              <div>
                <span class="text-sm text-gray-600">Employee remarks:</span>
                <div id="monthEmployeeRemarks" class="mt-1 font-bold text-gray-800">No remarks</div>
              </div>
              <div>
                <span class="text-sm text-gray-600">Reporting manager remarks:</span>
                <div id="monthReportingManagerRemarks" class="mt-1 font-bold text-gray-800">No remarks</div>
              </div>
              <div>
                <span class="text-sm text-gray-600">Status:</span>
                <div id="monthReviewStatus" class="mt-1 font-bold text-gray-800">Pending</div>
              </div>
            </div>
          </div>
          <!-- L1 and L2 Summary Cards -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <!-- L1 Summary Card -->
            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
              <h4 class="text-red-600 font-semibold text-lg mb-4 flex items-center">
                <i class="fas fa-user-tie mr-2"></i><span id="l1SummaryTitle">L1 Summary</span>
              </h4>
              <div class="space-y-3">
                <div>
                  <span class="text-sm text-gray-600">Percentage:</span>
                  <span id="l1Percentage" class="ml-2 font-bold text-gray-800">N/A</span>
                </div>
                <div>
                  <span class="text-sm text-gray-600">Remarks:</span>
                  <div id="l1Remarks" class="mt-1 font-bold text-gray-800">No remarks</div>
                </div>
              </div>
            </div>
            
            <!-- L2 Summary Card -->
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
              <h4 class="text-purple-600 font-semibold text-lg mb-4 flex items-center">
                <i class="fas fa-user-shield mr-2"></i><span id="l2SummaryTitle">L2 Summary</span>
              </h4>
              <div class="space-y-3">
                <div>
                  <span class="text-sm text-gray-600">Percentage:</span>
                  <span id="l2Percentage" class="ml-2 font-bold text-gray-800">N/A</span>
                </div>
                <div>
                  <span class="text-sm text-gray-600">Remarks:</span>
                  <div id="l2Remarks" class="mt-1 font-bold text-gray-800">No remarks</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="bg-gray-50 px-6 py-4 rounded-b-lg">
          <button id="closeModalBtn" class="w-full bg-gray-600 hover:bg-gray-700 text-white px-6 py-3 rounded-lg transition-all duration-200 flex items-center justify-center">
            Close details
          </button>
        </div>
      </div>
    </div>

    <script>
      // Enhanced modal functionality that works without page refresh
      function initializeQuarterlyModal() {
        const modal = document.getElementById('detailsModal');
        const closeModal = document.getElementById('closeModal');
        const closeModalBtn = document.getElementById('closeModalBtn');
        const detailButtons = document.querySelectorAll('.details-btn, .monthly-details-btn, .financial-summary-btn');

        console.log('Initializing modal...');
        console.log('Modal found:', !!modal);
        console.log('Close modal found:', !!closeModal);
        console.log('Close modal btn found:', !!closeModalBtn);
        console.log('Detail buttons found:', detailButtons.length);

        if (!modal) {
          console.log('Modal not found, retrying...');
          setTimeout(initializeQuarterlyModal, 100);
          return;
        }

        function getStatusConfig(status) {
          switch(status) {
            case 'l2_approved':
              return { color: 'bg-emerald-100 text-emerald-800', text: 'L2 Approved', icon: 'fas fa-check-double' };
            case 'l1_approved':
              return { color: 'bg-green-100 text-green-800', text: 'L1 Approved', icon: 'fas fa-check-circle' };
            case 'l2_returned':
              return { color: 'bg-orange-100 text-orange-800', text: 'L2 Returned', icon: 'fas fa-exclamation-triangle' };
            case 'l1_returned':
              return { color: 'bg-red-100 text-red-800', text: 'L1 Returned', icon: 'fas fa-exclamation-triangle' };
            case 'submitted':
              return { color: 'bg-blue-100 text-blue-800', text: 'Submitted', icon: 'fas fa-paper-plane' };
            default:
              return { color: 'bg-yellow-100 text-yellow-800', text: 'Pending', icon: 'fas fa-clock' };
          }
        }

        function openModal(button) {
          const data = button.dataset;

          function hasDisplayValue(value) {
            return value !== null &&
              value !== undefined &&
              value.toString().trim() !== '' &&
              value.toString().trim().toLowerCase() !== 'null' &&
              value.toString().trim().toLowerCase() !== 'undefined' &&
              value.toString().trim().toLowerCase() !== 'nil';
          }
          
          const metricSummary = document.getElementById('reviewMetricSummary');
          const monthlyEmployeeSummary = document.getElementById('monthlyEmployeeSummary');
          const monthActivityName = document.getElementById('monthActivityName');
          const monthEmployeeRemarks = document.getElementById('monthEmployeeRemarks');
          const monthReportingManagerRemarks = document.getElementById('monthReportingManagerRemarks');
          const monthReviewStatus = document.getElementById('monthReviewStatus');

          function parseDatasetJson(value) {
            return JSON.parse(value.replace(/&amp;quot;/g, '"').replace(/&quot;/g, '"'));
          }

          function parseReviewNumber(value) {
            const number = parseFloat((value ?? '').toString().replace(/,/g, ''));
            return Number.isFinite(number) ? number : null;
          }

          function titleizeMonth(value) {
            const labels = {
              april: 'APR',
              may: 'MAY',
              june: 'JUN',
              july: 'JUL',
              august: 'AUG',
              september: 'SEP',
              october: 'OCT',
              november: 'NOV',
              december: 'DEC',
              january: 'JAN',
              february: 'FEB',
              march: 'MAR'
            };
            const key = `${value || ''}`.toLowerCase();
            return labels[key] || 'Month';
          }

          function formatNumber(value) {
            const number = parseReviewNumber(value);
            if (!Number.isFinite(number)) return '-';
            return Number.isInteger(number) ? number.toString() : number.toFixed(2).replace(/\.?0+$/, '');
          }

          function formatPercent(value) {
            return hasDisplayValue(value) ? `${formatNumber(value)}%` : 'N/A';
          }

          function setMonthlySummaryVisibility(visible) {
            if (!monthlyEmployeeSummary) return;
            monthlyEmployeeSummary.classList.toggle('hidden', !visible);
          }

          function renderMetricSummary(title, target, achievement, percentage) {
            if (!metricSummary) return;
            const displayPercentage = hasDisplayValue(percentage) ? `${formatNumber(percentage)}%` : '-';
            metricSummary.innerHTML = `
              <div class="rounded-lg border border-gray-200 bg-white p-3">
                <div class="text-xs font-semibold text-gray-500">Period</div>
                <div class="mt-1 font-bold text-gray-900">${title || '-'}</div>
              </div>
              <div class="rounded-lg border border-gray-200 bg-white p-3">
                <div class="text-xs font-semibold text-gray-500">Target</div>
                <div class="mt-1 font-bold text-gray-900">${formatNumber(target)}</div>
              </div>
              <div class="rounded-lg border border-gray-200 bg-white p-3">
                <div class="text-xs font-semibold text-gray-500">Achievement</div>
                <div class="mt-1 font-bold text-gray-900">${formatNumber(achievement)}</div>
              </div>
              <div class="rounded-lg border border-gray-200 bg-white p-3">
                <div class="text-xs font-semibold text-gray-500">Achievement against target</div>
                <div class="mt-1 font-bold text-emerald-700">${displayPercentage}</div>
              </div>
            `;
          }

          if (data.monthReview) {
            const monthData = parseDatasetJson(data.monthReview);
            const target = parseReviewNumber(monthData.target);
            const achievement = parseReviewNumber(monthData.achievement);
            const achievementPercentage = target && target > 0 && achievement !== null ? ((achievement / target) * 100).toFixed(2) : null;
            const monthTitle = titleizeMonth(monthData.month);
            const statusConfig = getStatusConfig(monthData.status);

            document.getElementById('modalQuarter').textContent = monthTitle;
            const l1SummaryTitle = document.getElementById('l1SummaryTitle');
            const l2SummaryTitle = document.getElementById('l2SummaryTitle');
            if (l1SummaryTitle) l1SummaryTitle.textContent = `L1 Monthly Summary - ${monthData.l1_name || 'N/A'}`;
            if (l2SummaryTitle) l2SummaryTitle.textContent = `L2 Monthly Summary - ${monthData.l2_name || 'N/A'}`;
            renderMetricSummary(monthTitle, target, achievement, achievementPercentage);
            setMonthlySummaryVisibility(true);
            if (monthActivityName) monthActivityName.textContent = hasDisplayValue(monthData.activity) ? monthData.activity : 'N/A';
            if (monthEmployeeRemarks) monthEmployeeRemarks.textContent = hasDisplayValue(monthData.remarks) ? monthData.remarks : 'No remarks';
            if (monthReportingManagerRemarks) monthReportingManagerRemarks.textContent = hasDisplayValue(monthData.reporting_manager_remarks) ? monthData.reporting_manager_remarks : 'No remarks';
            if (monthReviewStatus) {
              monthReviewStatus.innerHTML = `<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold ${statusConfig.color}"><i class="${statusConfig.icon} mr-1 text-xs"></i>${statusConfig.text}</span>`;
            }
            document.getElementById('l1Percentage').textContent = formatPercent(monthData.l1_percentage);
            document.getElementById('l1Remarks').textContent = hasDisplayValue(monthData.l1_remarks) ? monthData.l1_remarks : 'No remarks';
            document.getElementById('l2Percentage').textContent = formatPercent(monthData.l2_percentage);
            document.getElementById('l2Remarks').textContent = hasDisplayValue(monthData.l2_remarks) ? monthData.l2_remarks : 'No remarks';

            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            return;
          }

          if (data.financialSummary) {
            const summaryData = parseDatasetJson(data.financialSummary);
            document.getElementById('modalQuarter').textContent = summaryData.quarter || 'Financial Summary';
            const l1SummaryTitle = document.getElementById('l1SummaryTitle');
            const l2SummaryTitle = document.getElementById('l2SummaryTitle');
            if (l1SummaryTitle) l1SummaryTitle.textContent = 'L1 Quarter Summary';
            if (l2SummaryTitle) l2SummaryTitle.textContent = 'L2 Quarter Summary';
            setMonthlySummaryVisibility(false);
            renderMetricSummary(summaryData.quarter, summaryData.target, summaryData.achievement, summaryData.percentage);
            document.getElementById('l1Percentage').textContent = formatPercent(summaryData.l1_percentage);
            document.getElementById('l1Remarks').textContent = hasDisplayValue(summaryData.l1_remarks) ? summaryData.l1_remarks : 'No remarks';
            document.getElementById('l2Percentage').textContent = formatPercent(summaryData.l2_percentage);
            document.getElementById('l2Remarks').textContent = hasDisplayValue(summaryData.l2_remarks) ? summaryData.l2_remarks : 'No remarks';

            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            return;
          }

          // Populate quarter info
          document.getElementById('modalQuarter').textContent = data.quarter || 'N/A';
          const l1SummaryTitle = document.getElementById('l1SummaryTitle');
          const l2SummaryTitle = document.getElementById('l2SummaryTitle');
          if (l1SummaryTitle) l1SummaryTitle.textContent = `L1 Summary - ${data.l1Name || 'N/A'}`;
          if (l2SummaryTitle) l2SummaryTitle.textContent = `L2 Summary - ${data.l2Name || 'N/A'}`;
          setMonthlySummaryVisibility(false);
          
          // Get quarterly data based on which quarter was clicked
          let quarterData = [];
          console.log('Button dataset:', data);
          
          if (data.q3Data) {
            quarterData = parseDatasetJson(data.q3Data);
            console.log('Using Q3 data, length:', quarterData.length);
          } else if (data.q4Data) {
            quarterData = parseDatasetJson(data.q4Data);
            console.log('Using Q4 data, length:', quarterData.length);
          } else if (data.q1Data) {
            quarterData = parseDatasetJson(data.q1Data);
            console.log('Using Q1 data, length:', quarterData.length);
          } else if (data.q2Data) {
            quarterData = parseDatasetJson(data.q2Data);
            console.log('Using Q2 data, length:', quarterData.length);
          }
          
          console.log('Quarter data:', quarterData);
          
          let totalTarget = 0;
          let totalAchievement = 0;
          let quarterStatuses = [];
          
          // Collect all L1 and L2 data for overall summary
          let allL1Remarks = [];
          let allL1Percentages = [];
          let allL2Remarks = [];
          let allL2Percentages = [];
          
          console.log('Processing quarter data:', quarterData);
          
          quarterData.forEach((monthData, index) => {
            console.log(`Month ${index}:`, monthData);
            
            const target = parseReviewNumber(monthData.target) || 0;
            const achievement = parseReviewNumber(monthData.achievement) || 0;
            const hasAchievementValue = hasDisplayValue(monthData.achievement);
            const percentage = target > 0 ? ((achievement / target) * 100).toFixed(1) : '0';
            
            if (hasAchievementValue) {
              totalTarget += target;
              totalAchievement += achievement;
            }
            quarterStatuses.push(monthData.status);
            
            // Collect L1 and L2 data - be more inclusive and handle different data sources
            console.log(`Month ${monthData.month} - L1 Remarks: "${monthData.l1_remarks}", L1 Percentage: "${monthData.l1_percentage}"`);
            console.log(`Month ${monthData.month} - L2 Remarks: "${monthData.l2_remarks}", L2 Percentage: "${monthData.l2_percentage}"`);
            console.log(`Month ${monthData.month} - Status: "${monthData.status}"`);
            
            // Collect L1 data - include any non-empty remarks from achievement_remark or achievement table
            const l1Remarks = monthData.l1_remarks;
            const l1Percentage = monthData.l1_percentage;
            
            if (hasDisplayValue(l1Remarks)) {
              allL1Remarks.push(l1Remarks.toString().trim());
            }
            
            if (hasDisplayValue(l1Percentage) && parseReviewNumber(l1Percentage) !== null) {
              allL1Percentages.push(parseReviewNumber(l1Percentage));
            }
            
            // Collect L2 data - include any non-empty remarks from achievement_remark or achievement table
            const l2Remarks = monthData.l2_remarks;
            const l2Percentage = monthData.l2_percentage;
            
            if (hasDisplayValue(l2Remarks)) {
              allL2Remarks.push(l2Remarks.toString().trim());
            }
            
            if (hasDisplayValue(l2Percentage) && parseReviewNumber(l2Percentage) !== null) {
              allL2Percentages.push(parseReviewNumber(l2Percentage));
            }
          });
          
          console.log('Collected L1 Remarks:', allL1Remarks);
          console.log('Collected L1 Percentages:', allL1Percentages);
          console.log('Collected L2 Remarks:', allL2Remarks);
          console.log('Collected L2 Percentages:', allL2Percentages);
          
          // Calculate overall L1 and L2 averages
          const derivedQuarterPercentage = totalTarget > 0 ? ((totalAchievement / totalTarget) * 100).toFixed(1) : null;
          let overallL1Percentage = allL1Percentages.length > 0 ?
            (allL1Percentages.reduce((a, b) => a + b, 0) / allL1Percentages.length).toFixed(1) : derivedQuarterPercentage;
          let overallL2Percentage = allL2Percentages.length > 0 ?
            (allL2Percentages.reduce((a, b) => a + b, 0) / allL2Percentages.length).toFixed(1) : derivedQuarterPercentage;
          
          // Combine all L1 and L2 remarks - show unique remarks only once
          let uniqueL1Remarks = [...new Set(allL1Remarks)];
          let uniqueL2Remarks = [...new Set(allL2Remarks)];
          
          let overallL1Remarks = uniqueL1Remarks.length > 0 ? uniqueL1Remarks.join('; ') : 'No remarks';
          let overallL2Remarks = uniqueL2Remarks.length > 0 ? uniqueL2Remarks.join('; ') : 'No remarks';
          
          // Only show data if it exists, otherwise show appropriate message
          if (overallL1Remarks === 'No remarks' && overallL2Remarks === 'No remarks' &&
              overallL1Percentage === null &&
              overallL2Percentage === null) {
            // Check if any achievements have been submitted for this quarter
            const hasAnyAchievements = quarterData.some(monthData => hasDisplayValue(monthData.achievement));
            
            if (hasAnyAchievements) {
              // Check the status of achievements to determine appropriate message
              const hasSubmitted = quarterStatuses.includes('submitted');
              const hasL1Approved = quarterStatuses.includes('l1_approved');
              const hasL1Returned = quarterStatuses.includes('l1_returned');
              const hasL2Approved = quarterStatuses.includes('l2_approved');
              const hasL2Returned = quarterStatuses.includes('l2_returned');
              
              if (hasL2Approved) {
                overallL1Remarks = 'L1 Review Completed';
                overallL2Remarks = 'L2 Review Completed';
              } else if (hasL2Returned) {
                overallL1Remarks = 'L1 Review Completed';
                overallL2Remarks = 'L2 Review Completed - Returned for Revision';
              } else if (hasL1Approved) {
                overallL1Remarks = 'L1 Review Completed';
                overallL2Remarks = 'Pending L2 Review';
              } else if (hasL1Returned) {
                overallL1Remarks = 'L1 Review Completed - Returned for Revision';
                overallL2Remarks = 'Pending L2 Review';
              } else if (hasSubmitted) {
                overallL1Remarks = 'Pending L1 Review';
                overallL2Remarks = 'Pending L2 Review';
              } else {
                overallL1Remarks = 'Pending L1 Review';
                overallL2Remarks = 'Pending L2 Review';
              }
            } else {
              // No achievements submitted yet
              overallL1Remarks = 'No achievements submitted';
              overallL2Remarks = 'No achievements submitted';
            }
            console.log('No L1/L2 data found, showing appropriate status');
          }
          
          console.log('Final L1 Remarks:', overallL1Remarks);
          console.log('Final L2 Remarks:', overallL2Remarks);
          renderMetricSummary(data.quarter || 'Quarter', totalTarget, totalAchievement, derivedQuarterPercentage);
          
          // Update L1 Summary
          document.getElementById('l1Percentage').textContent = overallL1Percentage !== null ? overallL1Percentage + '%' : 'N/A';
          document.getElementById('l1Remarks').textContent = overallL1Remarks;
          
          // Update L2 Summary
          document.getElementById('l2Percentage').textContent = overallL2Percentage !== null ? overallL2Percentage + '%' : 'N/A';
          document.getElementById('l2Remarks').textContent = overallL2Remarks;
          
          
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }

        function closeModalFunction() {
          modal.classList.add('hidden');
          document.body.style.overflow = 'auto';
        }

        // Add click event listeners to all detail buttons
        console.log('Found detail buttons:', detailButtons.length);
        detailButtons.forEach((button, index) => {
          console.log(`Setting up button ${index}:`, button);
          
          // Simple click handler
          button.onclick = function(e) {
            e.preventDefault();
            e.stopPropagation();
            console.log('Button clicked, opening modal');
            openModal(this);
          };
        });

        // Close modal event listeners
        if (closeModal) {
          closeModal.onclick = closeModalFunction;
        }
        
        if (closeModalBtn) {
          closeModalBtn.onclick = closeModalFunction;
        }

        // Close on outside click
        modal.onclick = function(e) {
          if (e.target === modal) {
            closeModalFunction();
          }
        };

        // Close on escape key
        document.onkeydown = function(e) {
          if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
            closeModalFunction();
          }
        };

        console.log('Quarterly modal initialized successfully');
        

      }

      // Initialize modal on multiple events to ensure it works
      document.addEventListener('DOMContentLoaded', initializeQuarterlyModal);
      document.addEventListener('turbo:load', initializeQuarterlyModal);
      document.addEventListener('turbo:render', initializeQuarterlyModal);
      
      // Also initialize when the page is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeQuarterlyModal);
      } else {
        initializeQuarterlyModal();
      }
    </script>
    <% else %>
      <!-- No submitted data message -->
      <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
        <div class="flex justify-between items-center">
          <h2 class="text-4xl font-bold text-gray-800 flex items-center">
            <i class="fas fa-check-circle me-3 text-green-600 text-2xl"></i>
            Submitted view achievements
          </h2>
          <%= form_with url: submitted_view_data_path, method: :get, local: true, class: "flex items-center gap-2" do |form| %>
            <%= form.label :financial_year, "Financial year", class: "text-sm font-semibold text-gray-700" %>
            <%= form.select :financial_year,
                options_for_select(@financial_years, @selected_financial_year),
                {},
                class: "bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-700",
                onchange: "this.form.submit();" %>
          <% end %>
        </div>
      </div>
      
      <div class="p-6">
        <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-12 text-center no-data-container">
          <!-- No Data Icon -->
          <div class="mb-6">
            <div class="inline-flex items-center justify-center mb-4 no-data-icon">
              <i class="fas fa-file-alt text-6xl text-gray-400"></i>
            </div>
          </div>
          
          <!-- No Data Message -->
          <h3 class="text-2xl font-bold text-gray-800 mb-4 no-data-title">No submitted data available</h3>
          <p class="text-gray-600 text-lg mb-8 max-w-md mx-auto no-data-description">
            You haven't submitted any quarterly achievements for <%= @selected_financial_year %> yet. Please submit your achievements first to view them here.
          </p>
          
          <!-- Submit Button -->
          <div class="flex justify-center">
            <%= link_to get_user_detail_user_details_path(year: @selected_financial_year), 
                        class: "bg-gray-600 hover:bg-gray-700 text-white px-8 py-3 rounded-lg transition-all duration-300 flex items-center shadow-md hover:shadow-lg transform hover:scale-105 no-data-button" do %>
              <i class="fas fa-plus mr-2"></i>
              <span class="font-semibold">Submit your achievements</span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
</div>
<style>
.review-eye-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  margin-top: 0.5rem;
  border-radius: 9999px;
  border: 1px solid #7dd3fc;
  background: #e0f2fe;
  color: #0369a1;
  box-shadow: 0 2px 8px rgba(3, 105, 161, 0.18);
  transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
}

.review-eye-button:hover {
  background: #bae6fd;
  transform: scale(1.05);
  box-shadow: 0 4px 12px rgba(3, 105, 161, 0.24);
}

.review-eye-button svg {
  width: 1rem;
  height: 1rem;
}

.monthly-details-btn.review-eye-button,
.details-btn.review-eye-button,
.financial-summary-btn .review-eye-button {
  margin-top: 0;
}

.main-content {
  margin-left: 240px;
  padding: 2rem;
  overflow-x: auto;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
}

.table-wrapper {
  overflow-x: auto;
  border-radius: 0.75rem;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.table {
  min-width: 2300px;
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
}

.table th, .table td {
  padding: 12px 16px;
  text-align: center;
  border-right: 1px solid #e5e7eb;
  white-space: nowrap;
  vertical-align: middle;
}

.table .activity-column,
.table .activity-cell {
  width: 220px;
  min-width: 220px;
  max-width: 220px;
}

.table .measurement-column,
.table .measurement-cell {
  width: 260px;
  min-width: 260px;
  max-width: 260px;
  white-space: normal;
  word-break: break-word;
  overflow-wrap: anywhere;
  text-align: left;
  line-height: 1.5;
}

.table .activity-cell {
  white-space: normal;
  word-break: break-word;
