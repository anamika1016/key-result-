<div class="main-content bg-gray-50 min-h-screen">
<% if @user_details.any? %>
  <script>
    // Initialize dynamic update listener without auto-refresh
    document.addEventListener('DOMContentLoaded', function() {
      // Clear any cached data if needed (without auto-refresh)
      if ('caches' in window) {
        caches.keys().then(function(names) {
          names.forEach(function(name) {
            caches.delete(name);
          });
        });
      }
      
      // DYNAMIC UPDATE: Listen for real-time updates from edit form
      setupDynamicUpdateListener();
    });
    
    // Function to set up dynamic update listener
    function setupDynamicUpdateListener() {
      try {
        // Listen for localStorage changes (from other tabs)
        window.addEventListener('storage', function(e) {
          if (e.key === 'dynamic_quarterly_update') {
            const updateData = JSON.parse(e.newValue);
            updateViewDynamically(updateData);
          }
        });
        
        // Listen for custom events (same tab)
        window.addEventListener('quarterlyDataUpdated', function(e) {
          updateViewDynamically(e.detail);
        });
        
        // Check for immediate updates on page load
        const liveUpdateData = sessionStorage.getItem('live_update_data');
        if (liveUpdateData) {
          const updateData = JSON.parse(liveUpdateData);
          updateViewDynamically(updateData);
          sessionStorage.removeItem('live_update_data');
        }
        
      } catch (error) {
        // Ignore errors
      }
    }
    
    // Function to update view dynamically with new data
    function updateViewDynamically(updateData) {
      try {
        const { quarter, detailId, achievement, inputValue } = updateData;
        
        // Find the corresponding display element in this view
        const quarterSelector = `[data-quarter="${quarter}"]`;
        const achievementDisplay = document.querySelector(`${quarterSelector} [data-detail-id="${detailId}"]`);
        
        if (achievementDisplay) {
          // Update the display value
          const cleanValue = parseFloat(inputValue) || 0;
          achievementDisplay.textContent = cleanValue > 0 ? `${cleanValue}%` : '-';
          
          // Add visual feedback
          achievementDisplay.style.backgroundColor = '#d4edda';
          achievementDisplay.style.transition = 'background-color 0.3s ease';
          
          // Remove highlight after 2 seconds
          setTimeout(() => {
            achievementDisplay.style.backgroundColor = '';
          }, 2000);
          
          // Show update notification
          showDynamicUpdateNotification(`Updated ${quarter.toUpperCase()} achievement: ${cleanValue}%`);
        }
        
        // Update totals if they exist
        updateTotalsIfPresent();
        
      } catch (error) {
        // Ignore errors
      }
    }
    
    // Function to update totals if present
    function updateTotalsIfPresent() {
      try {
        // Try to find and update total elements
        const totalElements = document.querySelectorAll('[id*="total"], [class*="total"]');
        totalElements.forEach(element => {
          if (element.textContent.includes('%')) {
            element.style.backgroundColor = '#fff3cd';
            setTimeout(() => {
              element.style.backgroundColor = '';
            }, 1000);
          }
        });
      } catch (error) {
        // Ignore errors
      }
    }
    
    // Function to show dynamic update notification
    function showDynamicUpdateNotification(message) {
      try {
        const notification = document.createElement('div');
        notification.className = 'fixed top-4 right-4 z-50 px-4 py-2 rounded-lg shadow-lg text-white font-medium bg-green-500 transition-all duration-300 text-sm';
        notification.textContent = message;
        document.body.appendChild(notification);
        
        setTimeout(() => {
          if (notification.parentNode) {
            notification.parentNode.removeChild(notification);
          }
        }, 2000);
      } catch (error) {
        // Ignore errors
      }
    }
  </script>
