      <div class="p-6">
        <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200 shadow-sm">
          <table class="table table-hover w-full min-w-full">
            <thead class="bg-gray-800">
              <tr>
                <th rowspan="3" class="px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">S.No</th>
                <th rowspan="3" class="activity-column px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600">Key result areas</th>
                <th rowspan="3" class="measurement-column px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600">Measurement description</th>
                <th rowspan="3" class="px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600">Unit of measurement</th>
                <th rowspan="3" class="px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600"><%= annual_target_fy_label(@selected_financial_year) %></th>
                <th colspan="20" class="px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-orange-700">Q1 (APR-JUN)</th>
                <th colspan="20" class="px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-purple-700">Q2 (JUL-SEP)</th>
                <th colspan="20" class="px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-blue-700">Q3 (OCT-DEC)</th>
                <th colspan="20" class="px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-green-700">Q4 (JAN-MAR)</th>
              </tr>
              <tr class="bg-gray-700">
                <!-- Q1 Months -->
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">APR</th>
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">MAY</th>
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">JUN</th>
                <th colspan="2" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Quarter</th>
                
                <!-- Q2 Months -->
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">JUL</th>
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">AUG</th>
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">SEP</th>
                <th colspan="2" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Quarter</th>
                
                <!-- Q3 Months -->
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">OCT</th>
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">NOV</th>
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">DEC</th>
                <th colspan="2" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Quarter</th>
                
                <!-- Q4 Months -->
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">JAN</th>
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">FEB</th>
                <th colspan="6" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">MAR</th>
                <th colspan="2" class="px-2 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Quarter</th>
              </tr>
              <tr class="bg-gray-600">
                <% 4.times do %>
                  <!-- Monthly Columns -->
                  <% 3.times do %>
                    <th class="px-2 py-1 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Target</th>
                    <th class="px-2 py-1 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Achievement</th>
                    <th class="px-2 py-1 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">% Progress</th>
                    <th class="px-2 py-1 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Employee remarks</th>
                    <th class="px-2 py-1 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Reporting manager remarks</th>
                    <th class="px-2 py-1 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Details</th>
                  <% end %>
                  <!-- Quarter Columns -->
                  <th class="px-2 py-1 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Details</th>
                  <th class="px-2 py-1 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Status</th>
                <% end %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% 
                # Calculate quarter statuses based on ALL activities across ALL rows
                all_q1_statuses = []
                all_q2_statuses = []
                all_q3_statuses = []
                all_q4_statuses = []
                
                @user_details.each do |detail|
                  achievements = detail.achievements.index_by(&:month)
                  # Q1 (APR-JUN)
                  ['april', 'may', 'june'].each do |month|
                    all_q1_statuses << achievements[month]&.status if achievements[month]&.status.present?
                  end
                  # Q2 (JUL-SEP)
                  ['july', 'august', 'september'].each do |month|
                    all_q2_statuses << achievements[month]&.status if achievements[month]&.status.present?
                  end
                  # Q3 (OCT-DEC)
                  ['october', 'november', 'december'].each do |month|
                    all_q3_statuses << achievements[month]&.status if achievements[month]&.status.present?
                  end
                  # Q4 (JAN-MAR)
                  ['january', 'february', 'march'].each do |month|
                    all_q4_statuses << achievements[month]&.status if achievements[month]&.status.present?
                  end
                end
                
                # Determine overall quarter statuses based on highest priority
                def calculate_overall_quarter_status(statuses)
                  return "pending" if statuses.empty?
                  # Priority: L2 Returned > L1 Returned > L2 Approved > L1 Approved > Submitted > Pending
                  if statuses.include?("l2_returned")
                    "l2_returned"
                  elsif statuses.include?("l1_returned")
                    "l1_returned"
                  elsif statuses.include?("l2_approved")
                    "l2_approved"
                  elsif statuses.include?("l1_approved")
                    "l1_approved"
                  elsif statuses.include?("submitted")
                    "submitted"
                  else
                    "pending"
                  end
                end
                
                overall_q1_status = calculate_overall_quarter_status(all_q1_statuses)
                overall_q2_status = calculate_overall_quarter_status(all_q2_statuses)
                overall_q3_status = calculate_overall_quarter_status(all_q3_statuses)
                overall_q4_status = calculate_overall_quarter_status(all_q4_statuses)

                submitted_months = %w[april may june july august september october november december january february march]
                monthly_summary_totals = submitted_months.each_with_object({}) do |month, totals|
                  totals[month] = { target: 0.0, achievement: 0.0, has_target: false, has_achievement: false }
                end
                add_monthly_summary = lambda do |month, target, achievement|
                  target_number = target.to_s.delete(",").to_f
                  achievement_number = achievement.to_s.delete(",").to_f

                  if target.present? && target.to_s.strip != "0" && target_number.positive?
                    monthly_summary_totals[month][:target] += target_number
                    monthly_summary_totals[month][:has_target] = true
                  end

                  if achievement.present?
                    monthly_summary_totals[month][:achievement] += achievement_number
                    monthly_summary_totals[month][:has_achievement] = true
                  end
                end
              %>
              
              <% @user_details.each_with_index do |detail, index| %>
                <% existing_achievements = detail.achievements.index_by(&:month) %>
                <tr class="<%= index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200" data-detail-id="<%= detail.id %>">
                  <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= index + 1 %></td>
                  <td class="activity-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.theme_name.presence || detail.activity.activity_name %></td>
                  <td class="measurement-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.activity_name %></td>
                  <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= detail.activity.unit %></td>
                  <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= annual_target_display(detail) %></td>

                    <!-- Q1 (APR-JUN) -->
                    <%
                      q1_months = ['april', 'may', 'june']
                      # Use overall quarter status instead of calculating per row
                      q1_status = overall_q1_status
                      
                      q1_targets = []
                      q1_achievements = []
                      q1_remarks = []
                    %>
                    
                    <% q1_months.each do |month| %>
                      <% target_value = clean_spreadsheet_display_value(detail.send(month.to_sym)) %>
                      <% achievement_record = existing_achievements[month] %>
                      <% achievement = achievement_record&.achievement %>
                      <% remarks = achievement_record&.employee_remarks %>
                      <% l1_remarks = achievement_record&.achievement_remark&.l1_remarks %>
                      <% l2_remarks = achievement_record&.achievement_remark&.l2_remarks %>
                      <% reporting_manager_remarks = achievement_record&.achievement_remark&.reporting_manager_remarks.presence || l1_remarks %>
                      <% l1_percentage = achievement_record&.achievement_remark&.l1_percentage %>
                      <% l2_percentage = achievement_record&.achievement_remark&.l2_percentage %>
                      <% progress_percentage = target_value.present? && target_value.to_s.strip != "0" && target_value.to_s.delete(",").to_f.positive? && achievement.present? ? ((achievement.to_s.delete(",").to_f / target_value.to_s.delete(",").to_f) * 100.0).round(2) : nil %>
                      <% month_status = achievement_record&.status || 'pending' %>
                      
                      <% q1_targets << target_value.to_f %>
                      <% q1_achievements << achievement.to_f %>
                      <% q1_remarks << {month: month, target: target_value, achievement: achievement, remarks: remarks, reporting_manager_remarks: reporting_manager_remarks, l1_remarks: l1_remarks, l2_remarks: l2_remarks, l1_percentage: l1_percentage, l2_percentage: l2_percentage, status: month_status} %>
                      <% month_review_payload = { month: month, activity: detail.activity.activity_name, target: target_value, achievement: achievement, remarks: remarks, reporting_manager_remarks: reporting_manager_remarks, l1_remarks: l1_remarks, l2_remarks: l2_remarks, l1_percentage: l1_percentage, l2_percentage: l2_percentage, status: month_status, employee: detail.employee_detail&.employee_name, l1_name: detail.employee_detail&.l1_employer_name, l2_name: detail.employee_detail&.l2_employer_name } %>
                      <% add_monthly_summary.call(month, target_value, achievement) %>
                      
                      <td class="px-2 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-orange-50">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-orange-50">
                        <span class="<%= achievement.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-orange-50">
                        <span class="<%= progress_percentage ? 'text-emerald-700 font-semibold bg-emerald-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= progress_percentage ? "#{format('%.2f', progress_percentage)}%" : '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-orange-50">
                        <span class="<%= remarks.presence ? 'text-orange-700 font-medium bg-orange-50 px-2 py-1 rounded text-xs' : 'text-gray-400' %>">
                          <%= remarks.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-orange-50">
                        <span class="<%= reporting_manager_remarks.presence ? 'text-indigo-700 font-medium bg-indigo-50 px-2 py-1 rounded text-xs' : 'text-gray-400' %>">
                          <%= reporting_manager_remarks.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-orange-50">
                        <button type="button"
                                class="monthly-details-btn review-eye-button"
                                title="View <%= short_month_label(month) %> L1/L2 Details"
                                data-quarter="Month"
                                data-month-review="<%= month_review_payload.to_json.gsub('"', '&quot;') %>">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                            <circle cx="12" cy="12" r="2.5" />
                          </svg>
                        </button>
                      </td>
                    <% end %>
                    
                    <!-- Q1 Details -->
                    <td class="px-2 py-3 text-center border-r border-gray-200 bg-orange-50">
                      <button
                        type="button"
                        class="review-eye-button details-btn"
                        title="View Q1 Details"
                        data-quarter="Q1 (APR-JUN)"
                        data-months="<%= q1_months.join(',') %>"
                        data-activity-name="<%= detail.activity.activity_name %>"
                        data-employee-name="<%= detail.employee_detail&.employee_name || 'N/A' %>"
                        data-l1-name="<%= detail.employee_detail&.l1_employer_name || 'N/A' %>"
                        data-l2-name="<%= detail.employee_detail&.l2_employer_name || 'N/A' %>"
                        data-department="<%= detail.department.department_type %>"
                        data-detail-id="<%= detail.id %>"
                        data-q1-data="<%= q1_remarks.to_json.gsub('"', '&quot;') %>">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                      </button>
                    </td>
                    
                    <!-- Q1 Status -->
                    <td class="px-2 py-3 text-center border-r border-gray-200 bg-orange-50">
                      <%
                        q1_status_config = case q1_status
                        when "pending"
                          { color: "bg-yellow-100 text-yellow-800", text: "Pending", icon: "fas fa-clock" }
                        when "l1_approved"
                          { color: "bg-green-100 text-green-800", text: "L1 Approved", icon: "fas fa-check-circle" }
                        when "l1_returned"
                          { color: "bg-red-100 text-red-800", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
                        when "l2_approved"
                          { color: "bg-emerald-100 text-emerald-800", text: "L2 Approved", icon: "fas fa-check-double" }
                        when "l2_returned"
                          { color: "bg-orange-100 text-orange-800", text: "L2 Returned", icon: "fas fa-exclamation-triangle" }
                        when "submitted"
                          { color: "bg-blue-100 text-blue-800", text: "Submitted", icon: "fas fa-paper-plane" }
                        else
                          { color: "bg-gray-100 text-gray-600", text: "No Status", icon: "fas fa-question-circle" }
                        end
                      %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold <%= q1_status_config[:color] %>">
                        <i class="<%= q1_status_config[:icon] %> mr-1 text-xs"></i>
                        <%= q1_status_config[:text] %>
                      </span>
                    </td>

                    <!-- Q2 (JUL-SEP) -->
                    <%
                      q2_months = ['july', 'august', 'september']
                      # Use overall quarter status instead of calculating per row
                      q2_status = overall_q2_status
                      
                      q2_targets = []
                      q2_achievements = []
                      q2_remarks = []
                    %>
                    
                    <% q2_months.each do |month| %>
                      <% target_value = clean_spreadsheet_display_value(detail.send(month.to_sym)) %>
                      <% achievement_record = existing_achievements[month] %>
                      <% achievement = achievement_record&.achievement %>
                      <% remarks = achievement_record&.employee_remarks %>
                      <% l1_remarks = achievement_record&.achievement_remark&.l1_remarks %>
                      <% l2_remarks = achievement_record&.achievement_remark&.l2_remarks %>
                      <% reporting_manager_remarks = achievement_record&.achievement_remark&.reporting_manager_remarks.presence || l1_remarks %>
                      <% l1_percentage = achievement_record&.achievement_remark&.l1_percentage %>
                      <% l2_percentage = achievement_record&.achievement_remark&.l2_percentage %>
                      <% progress_percentage = target_value.present? && target_value.to_s.strip != "0" && target_value.to_s.delete(",").to_f.positive? && achievement.present? ? ((achievement.to_s.delete(",").to_f / target_value.to_s.delete(",").to_f) * 100.0).round(2) : nil %>
                      <% month_status = achievement_record&.status || 'pending' %>
                      
                      <% q2_targets << target_value.to_f %>
                      <% q2_achievements << achievement.to_f %>
                      <% q2_remarks << {month: month, target: target_value, achievement: achievement, remarks: remarks, reporting_manager_remarks: reporting_manager_remarks, l1_remarks: l1_remarks, l2_remarks: l2_remarks, l1_percentage: l1_percentage, l2_percentage: l2_percentage, status: month_status} %>
                      <% month_review_payload = { month: month, activity: detail.activity.activity_name, target: target_value, achievement: achievement, remarks: remarks, reporting_manager_remarks: reporting_manager_remarks, l1_remarks: l1_remarks, l2_remarks: l2_remarks, l1_percentage: l1_percentage, l2_percentage: l2_percentage, status: month_status, employee: detail.employee_detail&.employee_name, l1_name: detail.employee_detail&.l1_employer_name, l2_name: detail.employee_detail&.l2_employer_name } %>
                      <% add_monthly_summary.call(month, target_value, achievement) %>
                      
                      <td class="px-2 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-purple-50">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-purple-50">
                        <span class="<%= achievement.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-purple-50">
                        <span class="<%= progress_percentage ? 'text-emerald-700 font-semibold bg-emerald-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= progress_percentage ? "#{format('%.2f', progress_percentage)}%" : '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-purple-50">
                        <span class="<%= remarks.presence ? 'text-purple-700 font-medium bg-purple-50 px-2 py-1 rounded text-xs' : 'text-gray-400' %>">
                          <%= remarks.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-purple-50">
                        <span class="<%= reporting_manager_remarks.presence ? 'text-indigo-700 font-medium bg-indigo-50 px-2 py-1 rounded text-xs' : 'text-gray-400' %>">
                          <%= reporting_manager_remarks.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-purple-50">
                        <button type="button"
                                class="monthly-details-btn review-eye-button"
                                title="View <%= short_month_label(month) %> L1/L2 Details"
                                data-quarter="Month"
                                data-month-review="<%= month_review_payload.to_json.gsub('"', '&quot;') %>">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                            <circle cx="12" cy="12" r="2.5" />
                          </svg>
                        </button>
                      </td>
                    <% end %>
                    
                    <!-- Q2 Details -->
                    <td class="px-2 py-3 text-center border-r border-gray-200 bg-purple-50">
                      <button
                        type="button"
                        class="review-eye-button details-btn"
                        title="View Q2 Details"
                        data-quarter="Q2 (JUL-SEP)"
                        data-months="<%= q2_months.join(',') %>"
                        data-activity-name="<%= detail.activity.activity_name %>"
