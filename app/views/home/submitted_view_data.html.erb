    <%
      # Helper method to calculate quarterly achievement percentage
      def calculate_quarterly_achievement_percentage(user_detail, months)
        return "" unless user_detail

        total_target = 0
        total_achievement = 0

        months.each do |month|
          target_value = user_detail.send(month.to_sym) if user_detail.respond_to?(month.to_sym)
          if target_value.present?
            begin
              total_target += target_value.to_f
            rescue
              # Skip invalid values
            end
          end

          # Get achievement from achievements table (case-insensitive)
          achievement = user_detail.achievements.find { |a| a.month.to_s.downcase == month.to_s.downcase }
          if achievement&.achievement.present?
            begin
              total_achievement += achievement.achievement.to_f
            rescue
              # Skip invalid values
            end
          end
        end

        return "" if total_target == 0

        percentage = (total_achievement / total_target * 100).round(1)
        percentage.to_s
      end

      # Helper method to calculate weightage score
      def calculate_weightage_score(weightage, achievement_percentage)
        return "" if weightage.blank? || achievement_percentage.blank?
        
        weight = weightage.to_f
        achievement = achievement_percentage.to_f
        
        # Convert weightage to decimal if it's a percentage (e.g., 25 -> 0.25)
        weight_decimal = weight > 1 ? weight / 100 : weight
        weightage_score = (weight_decimal * achievement).round(2)
        weightage_score.to_s
      end

      # Helper method to get quarterly remarks
      def get_quarterly_remarks(user_detail, months)
        remarks = []
        months.each do |month|
          achievement = user_detail.achievements.find { |a| a.month.to_s.downcase == month.to_s.downcase }
          if achievement&.employee_remarks.present?
            remarks << achievement.employee_remarks
          end
        end
        remarks.uniq.join('; ').presence || '-'
      end
