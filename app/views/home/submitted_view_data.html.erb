                  <span class="<%= q3_remarks != '-' ? 'text-blue-700 font-medium bg-blue-50 px-2 py-1 rounded text-xs' : 'text-gray-400' %>">
                    <%= q3_remarks %>
                  </span>
                </td>
                <td class="px-3 py-3 text-sm text-center border-r border-gray-200">
                  <% 
                    # For weightage score calculation, we need the percentage value, not the raw target
                    q3_achievement_for_score = q3_is_target ? nil : (q3_is_quarterly_achievement ? q3_display : q3_display)
                    q3_weightage_score = calculate_weightage_score(detail.activity.weight, q3_achievement_for_score) 
                  %>
                  <span class="<%= q3_weightage_score.present? ? 'text-green-700 font-semibold bg-green-50 px-3 py-1 rounded-full' : 'text-gray-400' %>">
                    <%= q3_weightage_score.present? ? q3_weightage_score : '-' %>
                  </span>
                </td>

                <!-- Q4 Columns -->
                <td class="px-3 py-3 text-sm text-center border-r border-gray-200">
                  <% 
                    # Check for quarterly achievement first (case-insensitive), then quarterly target, then calculated achievement
                    q4_quarterly_achievement = detail.achievements.find { |a| a.month.to_s.downcase == 'q4' }
                    if q4_quarterly_achievement&.achievement.present?
                      q4_display = q4_quarterly_achievement.achievement.to_f.to_i
                      q4_is_target = false
                      q4_is_quarterly_achievement = true
                    elsif detail.q4.present?
                      q4_display = detail.q4
                      q4_is_target = true
                      q4_is_quarterly_achievement = false
                    else
                      q4_display = calculate_quarterly_achievement_percentage(detail, ['january', 'february', 'march'])
