<%
  dashboard_time = Time.current.in_time_zone("Asia/Kolkata")
  dashboard_time_label = dashboard_time.strftime("%B %d, %Y at %I:%M:%S %p IST")
  financial_year_label = display_financial_year(@selected_year)
  l1_total = @l1_approved_count + @l1_pending_count + @l1_returned_count
  l2_total = @l2_approved_count + @l2_pending_count + @l2_returned_count
  l3_total = @l3_approved_count + @l3_pending_count + @l3_returned_count
%>

<div class="dashboard-shell">
  <section class="dashboard-hero">
    <div class="dashboard-hero__copy">
      <span class="dashboard-eyebrow">Performance Command Center</span>
      <h1>KRA Analytics Dashboard</h1>
      <p>
        Live operational summary for users, verticals, KPI data, and approval movement across
        L1, L2, and L3.
      </p>
    </div>

    <div class="dashboard-hero__actions">
      <div class="dashboard-toggle-card">
        <div>
          <div class="dashboard-toggle-card__label">Dashboard Access</div>
          <div class="dashboard-toggle-card__value" id="toggle-label"><%= @dashboard_active ? "Active" : "Inactive" %></div>
        </div>
        <div class="relative inline-flex h-10 w-20 items-center rounded-full transition-colors focus:outline-none cursor-pointer <%= @dashboard_active ? 'bg-green-500' : 'bg-gray-400' %>"
             id="active-inactive-toggle"
             data-active="<%= @dashboard_active %>"
             onclick="handleToggleClick(event)">
          <span class="inline-block h-8 w-8 transform rounded-full bg-white transition-transform shadow-sm z-20 pointer-events-none <%= @dashboard_active ? 'translate-x-11' : 'translate-x-1' %>"
                id="toggle-slider"></span>
        </div>
      </div>

      <%= link_to export_quarterly_xlsx_employee_details_path(year: @selected_year),
                  class: "dashboard-download",
                  target: "_blank" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 16V4m0 12l-4-4m4 4l4-4M4 20h16"></path>
        </svg>
        <span>Download Report</span>
      <% end %>
    </div>
  </section>

  <section class="dashboard-spotlights">
    <article class="spotlight-card spotlight-card--time">
      <div class="spotlight-card__label">Live Time</div>
      <div class="spotlight-card__value" id="dashboard-live-clock"><%= dashboard_time.strftime("%I:%M:%S %p") %></div>
      <div class="spotlight-card__meta" id="dashboard-live-date"><%= dashboard_time.strftime("%A, %d %B %Y") %></div>
    </article>

    <article class="spotlight-card spotlight-card--year">
      <div class="spotlight-card__label">Working Financial Year</div>
      <div class="spotlight-card__value"><%= financial_year_label %></div>
      <div class="spotlight-card__meta">Current dashboard data is grouped year-wise.</div>
    </article>

    <article class="spotlight-card spotlight-card--snapshot">
      <div class="spotlight-card__label">Data Snapshot</div>
      <div class="spotlight-card__value"><%= @total_user_details %></div>
      <div class="spotlight-card__meta">Year-wise target records currently available.</div>
    </article>
  </section>

  <section class="metric-grid">
    <article class="metric-card metric-card--blue">
      <div class="metric-card__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path stroke-linecap="round" stroke-linejoin="round" d="M23 21v-2a4 4 0 00-3-3.87"></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 3.13a4 4 0 010 7.75"></path>
        </svg>
      </div>
      <div class="metric-card__title">Total Users</div>
      <div class="metric-card__count"><%= @total_users %></div>
      <div class="metric-card__hint">All registered users in the system</div>
    </article>

    <article class="metric-card metric-card--green">
      <div class="metric-card__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 21V19a4 4 0 00-4-4H8a4 4 0 00-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>
      <div class="metric-card__title">Employee Role</div>
      <div class="metric-card__count"><%= @employee_count %></div>
      <div class="metric-card__hint">Active employee users mapped in KRA</div>
    </article>

    <article class="metric-card metric-card--violet">
      <div class="metric-card__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"></path>
        </svg>
      </div>
      <div class="metric-card__title">Super Admin</div>
      <div class="metric-card__count"><%= @hod_count %></div>
      <div class="metric-card__hint">HOD and top-level administrative access</div>
    </article>

    <article class="metric-card metric-card--rose">
      <div class="metric-card__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18"></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 21V7l8-4 6 4v14"></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 11h1m4 0h1m-6 4h1m4 0h1"></path>
        </svg>
      </div>
      <div class="metric-card__title">Verticals</div>
      <div class="metric-card__count"><%= @total_departments %></div>
      <div class="metric-card__hint">Configured business verticals and departments</div>
    </article>
  </section>

  <section class="approval-grid">
    <article class="approval-panel approval-panel--l1">
      <div class="approval-panel__head">
        <div>
          <div class="approval-panel__label">L1 Level Status</div>
          <h3>L1 Review Flow</h3>
        </div>
        <div class="approval-panel__total">
          <span>Total</span>
          <strong><%= l1_total %></strong>
        </div>
      </div>

      <div class="approval-panel__ring">
        <svg class="status-ring" viewBox="0 0 36 36">
          <% l1_approved_percentage = l1_total.positive? ? (@l1_approved_count.to_f / l1_total * 100) : 0 %>
          <% l1_pending_percentage = l1_total.positive? ? (@l1_pending_count.to_f / l1_total * 100) : 0 %>
          <% l1_returned_percentage = l1_total.positive? ? (@l1_returned_count.to_f / l1_total * 100) : 0 %>
          <path class="status-ring__bg" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" />
          <path class="status-ring__segment status-ring__segment--approved" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-dasharray="<%= l1_approved_percentage %>, 100" stroke-dashoffset="0" />
          <path class="status-ring__segment status-ring__segment--pending" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-dasharray="<%= l1_pending_percentage %>, 100" stroke-dashoffset="<%= -l1_approved_percentage %>" />
          <path class="status-ring__segment status-ring__segment--returned" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-dasharray="<%= l1_returned_percentage %>, 100" stroke-dashoffset="<%= -(l1_approved_percentage + l1_pending_percentage) %>" />
        </svg>
        <div class="status-ring__center">
          <strong><%= l1_total %></strong>
          <span>records</span>
        </div>
      </div>

      <div class="approval-breakdown">
        <div class="approval-breakdown__item">
          <span class="approval-dot approval-dot--approved"></span>
          <span>L1 Approved</span>
          <strong><%= @l1_approved_count %></strong>
        </div>
        <div class="approval-breakdown__item">
          <span class="approval-dot approval-dot--pending"></span>
          <span>L1 Pending</span>
          <strong><%= @l1_pending_count %></strong>
        </div>
        <div class="approval-breakdown__item">
          <span class="approval-dot approval-dot--returned"></span>
          <span>L1 Returned</span>
          <strong><%= @l1_returned_count %></strong>
        </div>
      </div>
    </article>

    <article class="approval-panel approval-panel--l2">
      <div class="approval-panel__head">
        <div>
          <div class="approval-panel__label">L2 Level Status</div>
          <h3>L2 Approval Flow</h3>
        </div>
        <div class="approval-panel__total">
          <span>Total</span>
          <strong><%= l2_total %></strong>
        </div>
      </div>

      <div class="approval-panel__ring">
        <svg class="status-ring" viewBox="0 0 36 36">
          <% l2_approved_percentage = l2_total.positive? ? (@l2_approved_count.to_f / l2_total * 100) : 0 %>
          <% l2_pending_percentage = l2_total.positive? ? (@l2_pending_count.to_f / l2_total * 100) : 0 %>
          <% l2_returned_percentage = l2_total.positive? ? (@l2_returned_count.to_f / l2_total * 100) : 0 %>
          <path class="status-ring__bg" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" />
          <path class="status-ring__segment status-ring__segment--approved-l2" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-dasharray="<%= l2_approved_percentage %>, 100" stroke-dashoffset="0" />
          <path class="status-ring__segment status-ring__segment--pending" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-dasharray="<%= l2_pending_percentage %>, 100" stroke-dashoffset="<%= -l2_approved_percentage %>" />
          <path class="status-ring__segment status-ring__segment--returned" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-dasharray="<%= l2_returned_percentage %>, 100" stroke-dashoffset="<%= -(l2_approved_percentage + l2_pending_percentage) %>" />
        </svg>
        <div class="status-ring__center">
          <strong><%= l2_total %></strong>
          <span>records</span>
        </div>
      </div>

      <div class="approval-breakdown">
        <div class="approval-breakdown__item">
          <span class="approval-dot approval-dot--approved-l2"></span>
          <span>L2 Approved</span>
          <strong><%= @l2_approved_count %></strong>
        </div>
        <div class="approval-breakdown__item">
          <span class="approval-dot approval-dot--pending"></span>
          <span>L2 Pending</span>
          <strong><%= @l2_pending_count %></strong>
        </div>
        <div class="approval-breakdown__item">
          <span class="approval-dot approval-dot--returned"></span>
          <span>L2 Returned</span>
          <strong><%= @l2_returned_count %></strong>
        </div>
      </div>
    </article>

    <article class="approval-panel approval-panel--l3">
      <div class="approval-panel__head">
        <div>
          <div class="approval-panel__label">L3 Level Status</div>
          <h3>L3 Final Review Flow</h3>
        </div>
        <div class="approval-panel__total">
          <span>Total</span>
          <strong><%= l3_total %></strong>
        </div>
      </div>

      <div class="approval-panel__ring">
        <svg class="status-ring" viewBox="0 0 36 36">
          <% l3_approved_percentage = l3_total.positive? ? (@l3_approved_count.to_f / l3_total * 100) : 0 %>
          <% l3_pending_percentage = l3_total.positive? ? (@l3_pending_count.to_f / l3_total * 100) : 0 %>
          <% l3_returned_percentage = l3_total.positive? ? (@l3_returned_count.to_f / l3_total * 100) : 0 %>
          <path class="status-ring__bg" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" />
          <path class="status-ring__segment status-ring__segment--approved-l3" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-dasharray="<%= l3_approved_percentage %>, 100" stroke-dashoffset="0" />
          <path class="status-ring__segment status-ring__segment--pending" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-dasharray="<%= l3_pending_percentage %>, 100" stroke-dashoffset="<%= -l3_approved_percentage %>" />
          <path class="status-ring__segment status-ring__segment--returned" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-dasharray="<%= l3_returned_percentage %>, 100" stroke-dashoffset="<%= -(l3_approved_percentage + l3_pending_percentage) %>" />
        </svg>
        <div class="status-ring__center">
          <strong><%= l3_total %></strong>
          <span>records</span>
        </div>
      </div>

      <div class="approval-breakdown">
        <div class="approval-breakdown__item">
          <span class="approval-dot approval-dot--approved-l3"></span>
          <span>L3 Approved</span>
          <strong><%= @l3_approved_count %></strong>
        </div>
        <div class="approval-breakdown__item">
          <span class="approval-dot approval-dot--pending"></span>
          <span>L3 Pending</span>
          <strong><%= @l3_pending_count %></strong>
        </div>
        <div class="approval-breakdown__item">
          <span class="approval-dot approval-dot--returned"></span>
          <span>L3 Returned</span>
          <strong><%= @l3_returned_count %></strong>
        </div>
      </div>
    </article>
  </section>

  <section class="insight-grid">
    <article class="insight-card insight-card--amber">
      <div class="insight-card__label">KPI Count</div>
      <div class="insight-card__value"><%= @total_activities %></div>
      <p>All KPI rows currently configured for the dashboard ecosystem.</p>
    </article>

    <article class="insight-card insight-card--emerald">
      <div class="insight-card__label">Indicator Count</div>
      <div class="insight-card__value"><%= @total_activities %></div>
      <p>Indicators mapped into activity definitions for year-wise tracking.</p>
    </article>

    <article class="insight-card insight-card--violet">
      <div class="insight-card__label">Weightage Count</div>
      <div class="insight-card__value"><%= Activity.where('weight > 0').count %></div>
      <p>Activities carrying non-zero weightage in the current KRA structure.</p>
    </article>
  </section>
</div>

<style>
  body, html {
    margin: 0;
    padding: 0;
    min-height: 100%;
    overflow-x: hidden;
  }

  .dashboard-shell {
    margin-left: 16rem;
    min-height: 100vh;
    width: calc(100vw - 16rem);
    padding: 2rem;
    background:
      radial-gradient(circle at top right, rgba(254, 240, 138, 0.35), transparent 24%),
      radial-gradient(circle at top left, rgba(191, 219, 254, 0.4), transparent 28%),
      linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
    overflow-y: auto;
  }

  .dashboard-hero {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 2rem;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(12px);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    margin-bottom: 1.5rem;
  }

  .dashboard-hero__copy {
    max-width: 46rem;
  }

  .dashboard-eyebrow {
    display: inline-flex;
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    background: #e2e8f0;
    color: #334155;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dashboard-hero h1 {
    margin: 1rem 0 0.6rem;
    font-size: clamp(2rem, 3vw, 3.2rem);
    line-height: 1.05;
    color: #0f172a;
    font-weight: 800;
  }

  .dashboard-hero p {
    margin: 0;
    color: #475569;
    font-size: 1rem;
    line-height: 1.7;
  }

  .dashboard-hero__actions {
    min-width: 18rem;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
  }

  .dashboard-toggle-card,
  .dashboard-download,
  .spotlight-card,
  .metric-card,
  .approval-panel,
  .insight-card {
    transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
  }

  .dashboard-toggle-card:hover,
  .dashboard-download:hover,
  .spotlight-card:hover,
  .metric-card:hover,
  .approval-panel:hover,
  .insight-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 35px rgba(15, 23, 42, 0.10);
  }

  .dashboard-toggle-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    border-radius: 22px;
    background: linear-gradient(135deg, #ffffff, #f8fafc);
    border: 1px solid rgba(148, 163, 184, 0.25);
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
  }

  .dashboard-toggle-card__label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #64748b;
  }

  .dashboard-toggle-card__value {
    font-size: 1.05rem;
    font-weight: 800;
    color: #0f172a;
    margin-top: 0.2rem;
  }

  .dashboard-download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 22px;
    font-weight: 800;
    color: #134e4a;
    text-decoration: none;
    border: 1px solid rgba(16, 185, 129, 0.16);
    background: linear-gradient(135deg, #d1fae5, #a7f3d0);
    box-shadow: 0 16px 30px rgba(16, 185, 129, 0.18);
  }

  .dashboard-spotlights,
  .metric-grid,
  .approval-grid,
  .insight-grid {
    display: grid;
    gap: 1.25rem;
  }

  .dashboard-spotlights {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-bottom: 1.5rem;
  }

  .spotlight-card {
    padding: 1.35rem 1.5rem;
    border-radius: 24px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
  }

  .spotlight-card--time {
    background: linear-gradient(135deg, rgba(219, 234, 254, 0.9), rgba(255, 255, 255, 0.95));
  }

  .spotlight-card--year {
    background: linear-gradient(135deg, rgba(220, 252, 231, 0.92), rgba(255, 255, 255, 0.95));
  }

  .spotlight-card--snapshot {
    background: linear-gradient(135deg, rgba(243, 232, 255, 0.92), rgba(255, 255, 255, 0.95));
  }

  .spotlight-card__label,
  .metric-card__title,
  .approval-panel__label,
  .insight-card__label {
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 800;
    color: #64748b;
  }

  .spotlight-card__value {
    margin-top: 0.5rem;
    font-size: clamp(1.6rem, 2.4vw, 2.5rem);
    font-weight: 800;
    color: #0f172a;
  }

  .spotlight-card__meta {
    margin-top: 0.45rem;
    color: #475569;
    font-size: 0.95rem;
  }

  .metric-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: 1.5rem;
  }

  .metric-card {
    padding: 1.5rem;
    border-radius: 24px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.06);
  }

  .metric-card__icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    margin-bottom: 1rem;
  }

  .metric-card__icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  .metric-card--blue .metric-card__icon {
    background: linear-gradient(135deg, #dbeafe, #bfdbfe);
    color: #1d4ed8;
  }

  .metric-card--green .metric-card__icon {
    background: linear-gradient(135deg, #dcfce7, #bbf7d0);
    color: #15803d;
  }

  .metric-card--violet .metric-card__icon {
    background: linear-gradient(135deg, #f3e8ff, #ddd6fe);
    color: #7c3aed;
  }

  .metric-card--rose .metric-card__icon {
    background: linear-gradient(135deg, #ffe4e6, #fecdd3);
    color: #be123c;
  }

  .metric-card__count {
    margin-top: 0.55rem;
    font-size: 2.2rem;
    line-height: 1;
    color: #0f172a;
    font-weight: 800;
  }

  .metric-card__hint {
    margin-top: 0.45rem;
    color: #64748b;
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .approval-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-bottom: 1.5rem;
  }

  .approval-panel {
    padding: 1.5rem;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.06);
  }

  .approval-panel--l1 {
    background: linear-gradient(180deg, rgba(239, 246, 255, 0.96), rgba(255, 255, 255, 0.96));
  }

  .approval-panel--l2 {
    background: linear-gradient(180deg, rgba(236, 253, 245, 0.96), rgba(255, 255, 255, 0.96));
  }

  .approval-panel--l3 {
    background: linear-gradient(180deg, rgba(250, 245, 255, 0.96), rgba(255, 255, 255, 0.96));
  }

  .approval-panel__head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  .approval-panel__head h3 {
    margin: 0.25rem 0 0;
    font-size: 1.3rem;
    color: #0f172a;
    font-weight: 800;
  }

  .approval-panel__total {
    text-align: right;
  }

  .approval-panel__total span {
    display: block;
    font-size: 0.74rem;
    text-transform: uppercase;
    color: #64748b;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .approval-panel__total strong {
    font-size: 1.8rem;
    color: #0f172a;
    font-weight: 800;
  }

  .approval-panel__ring {
    position: relative;
    display: flex;
    justify-content: center;
    margin: 1.2rem 0 1rem;
  }

  .status-ring {
    width: 10.5rem;
    height: 10.5rem;
    transform: rotate(-90deg);
  }

  .status-ring__bg,
  .status-ring__segment {
    fill: none;
    stroke-width: 3.6;
    transition: stroke-width 0.2s ease;
  }

  .status-ring__bg {
    stroke: #e2e8f0;
  }

  .status-ring__segment:hover {
    stroke-width: 5;
  }

  .status-ring__segment--approved {
    stroke: #38bdf8;
  }

  .status-ring__segment--approved-l2 {
    stroke: #22c55e;
  }

  .status-ring__segment--approved-l3 {
    stroke: #a855f7;
  }

  .status-ring__segment--pending {
    stroke: #fbbf24;
  }

  .status-ring__segment--returned {
    stroke: #f87171;
  }

  .status-ring__center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .status-ring__center strong {
    font-size: 1.7rem;
    color: #0f172a;
    line-height: 1;
    font-weight: 800;
  }

  .status-ring__center span {
    margin-top: 0.25rem;
    font-size: 0.84rem;
    color: #64748b;
  }

  .approval-breakdown {
    display: grid;
    gap: 0.8rem;
  }

  .approval-breakdown__item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(148, 163, 184, 0.14);
    color: #334155;
    font-weight: 600;
  }

  .approval-breakdown__item strong {
    color: #0f172a;
    font-size: 1.05rem;
  }

  .approval-dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
  }

  .approval-dot--approved {
    background: #38bdf8;
  }

  .approval-dot--approved-l2 {
    background: #22c55e;
  }

  .approval-dot--approved-l3 {
    background: #a855f7;
  }

  .approval-dot--pending {
    background: #fbbf24;
  }

  .approval-dot--returned {
    background: #f87171;
  }

  .insight-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .insight-card {
    padding: 1.5rem;
    border-radius: 24px;
    color: #0f172a;
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.06);
  }

  .insight-card__value {
    margin-top: 0.5rem;
    font-size: 2.15rem;
    font-weight: 800;
  }

  .insight-card p {
    margin: 0.55rem 0 0;
    color: #475569;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .insight-card--amber {
    background: linear-gradient(135deg, #fffbeb, #ffffff);
    border: 1px solid rgba(245, 158, 11, 0.18);
  }

  .insight-card--emerald {
    background: linear-gradient(135deg, #ecfdf5, #ffffff);
    border: 1px solid rgba(16, 185, 129, 0.18);
  }

  .insight-card--violet {
    background: linear-gradient(135deg, #faf5ff, #ffffff);
    border: 1px solid rgba(139, 92, 246, 0.18);
  }

  @media (max-width: 1280px) {
    .metric-grid,
    .dashboard-spotlights,
    .approval-grid,
    .insight-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 1024px) {
    .dashboard-shell {
      margin-left: 0;
      width: 100vw;
      padding: 1rem;
    }

    .dashboard-hero {
      flex-direction: column;
      padding: 1.5rem;
    }

    .dashboard-hero__actions {
      min-width: 0;
    }
  }

  @media (max-width: 767px) {
    .dashboard-spotlights,
    .metric-grid,
    .approval-grid,
    .insight-grid {
      grid-template-columns: 1fr;
    }

    .dashboard-hero h1 {
      font-size: 2rem;
    }

    .approval-panel,
    .metric-card,
    .spotlight-card,
    .insight-card {
      padding: 1.2rem;
    }
  }
</style>

<script>
  let isActive = <%= @dashboard_active ? 'true' : 'false' %>;

  function updateToggleState(active, shouldSave = true) {
    isActive = active;
    localStorage.setItem('dashboardActiveState', isActive);

    const toggle = document.getElementById('active-inactive-toggle');
    const slider = document.getElementById('toggle-slider');
    const label = document.getElementById('toggle-label');

    if (!toggle || !slider || !label) return;

    if (isActive) {
      toggle.classList.remove('bg-gray-400');
      toggle.classList.add('bg-green-500');
      slider.classList.remove('translate-x-1');
      slider.classList.add('translate-x-11');
      label.textContent = 'Active';
    } else {
      toggle.classList.remove('bg-green-500');
      toggle.classList.add('bg-gray-400');
      slider.classList.remove('translate-x-11');
      slider.classList.add('translate-x-1');
      label.textContent = 'Inactive';
    }

    if (shouldSave) {
      const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

      fetch('/update_dashboard_status', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        body: JSON.stringify({ active: isActive })
      })
      .then(response => response.json())
      .then(data => {
        if (!data.success) {
          alert('Failed to update status. Please try again.');
          updateToggleState(!isActive, false);
        }
      })
      .catch(() => {
        alert('An error occurred while updating the status.');
        updateToggleState(!isActive, false);
      });
    }
  }

  function handleToggleClick(event) {
    const toggle = document.getElementById('active-inactive-toggle');
    const rect = toggle.getBoundingClientRect();
    const clickX = event.clientX - rect.left;
    const midpoint = rect.width / 2;

    if (clickX < midpoint) {
      setInactive();
    } else {
      setActive();
    }
  }

  function setActive() {
    if (isActive) return;
    if (confirm('Are you sure you want to activate?')) {
      updateToggleState(true);
    }
  }

  function setInactive() {
    if (!isActive) return;
    updateToggleState(false);
  }

  function initializeToggle() {
    const toggle = document.getElementById('active-inactive-toggle');
    if (toggle) {
      isActive = toggle.getAttribute('data-active') === 'true';
      updateToggleState(isActive, false);
    }
  }

  function updateDashboardClock() {
    const now = new Date();
    const timeElement = document.getElementById('dashboard-live-clock');
    const dateElement = document.getElementById('dashboard-live-date');
    if (!timeElement || !dateElement) return;

    const timeText = now.toLocaleTimeString('en-IN', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: true,
      timeZone: 'Asia/Kolkata'
    });

    const dateText = now.toLocaleDateString('en-IN', {
      weekday: 'long',
      day: '2-digit',
      month: 'long',
      year: 'numeric',
      timeZone: 'Asia/Kolkata'
    });

    timeElement.textContent = timeText;
    dateElement.textContent = dateText;
  }

  function initializeDashboard() {
    initializeToggle();
    updateDashboardClock();
    if (window.dashboardClockInterval) clearInterval(window.dashboardClockInterval);
    window.dashboardClockInterval = setInterval(updateDashboardClock, 1000);
  }

  document.addEventListener('DOMContentLoaded', initializeDashboard);
  document.addEventListener('turbo:load', initializeDashboard);
</script>
