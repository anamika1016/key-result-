<!-- app/views/home/dashboard.html.erb -->
<div class="dashboard-container">
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">KRA Analytics Dashboard</h1>
        <p class="text-sm text-gray-500 mt-1"><%= Time.current.in_time_zone("Asia/Kolkata").strftime("%B %d, %Y at %I:%M %p IST") %></p>
      </div>
      <div class="flex items-center space-x-4">
        <!-- Active/Inactive Toggle Button -->
        <div class="flex items-center space-x-3 bg-white px-4 py-2 rounded-xl shadow-md">
          <span class="text-base font-medium <%= @dashboard_active ? 'text-gray-700' : 'text-gray-500' %>" id="toggle-label"><%= @dashboard_active ? 'Active' : 'Inactive' %></span>
          <div class="relative inline-flex h-10 w-20 items-center rounded-full transition-colors focus:outline-none cursor-pointer <%= @dashboard_active ? 'bg-green-500' : 'bg-gray-400' %>" 
               id="active-inactive-toggle" 
               data-active="<%= @dashboard_active %>"
               onclick="handleToggleClick(event)">
            <!-- Toggle slider -->
            <span class="inline-block h-8 w-8 transform rounded-full bg-white transition-transform shadow-sm z-20 pointer-events-none <%= @dashboard_active ? 'translate-x-11' : 'translate-x-1' %>" id="toggle-slider"></span>
          </div>
        </div>
        
        <%= link_to export_quarterly_xlsx_employee_details_path, 
                    class: "inline-flex items-center px-8 py-4 text-gray-700 font-bold rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1",
                    style: "background: linear-gradient(135deg, #d1fae5, #a7f3d0);",
                    target: "_blank" do %>
          <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
          </svg>
          <span class="text-lg">Download</span>
        <% end %>
      </div>
    </div>
  </div>

    <!-- Key Metrics Cards Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      <!-- Total Users -->
      <div class="bg-white rounded-xl p-6 shadow-lg border-l-4 min-w-[140px]" style="border-left-color: #bfdbfe;">
        <div class="flex flex-col items-center text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: linear-gradient(135deg, #bfdbfe, #93c5fd);">
            <svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-600 mb-1">Total Users</p>
          <p class="text-3xl font-bold text-gray-900"><%= @total_users %></p>
        </div>
      </div>

      <!-- Employees -->
      <div class="bg-white rounded-xl p-6 shadow-lg border-l-4 min-w-[140px]" style="border-left-color: #d1fae5;">
        <div class="flex flex-col items-center text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: linear-gradient(135deg, #d1fae5, #a7f3d0);">
            <svg class="w-6 h-6 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-600 mb-1">Employee Role</p>
          <p class="text-3xl font-bold text-gray-900"><%= @employee_count %></p>
        </div>
      </div>

      <!-- HOD Role -->
      <div class="bg-white rounded-xl p-6 shadow-lg border-l-4 min-w-[140px]" style="border-left-color: #e9d5ff;">
        <div class="flex flex-col items-center text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: linear-gradient(135deg, #e9d5ff, #ddd6fe);">
            <svg class="w-6 h-6 text-purple-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-600 mb-1">Super Admin</p>
          <p class="text-3xl font-bold text-gray-900"><%= @hod_count %></p>
        </div>
      </div>

      <!-- Verticals -->
      <div class="bg-white rounded-xl p-6 shadow-lg border-l-4 min-w-[140px]" style="border-left-color: #fecaca;">
        <div class="flex flex-col items-center text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: linear-gradient(135deg, #fecaca, #fca5a5);">
            <svg class="w-6 h-6 text-red-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-600 mb-1">Verticals</p>
          <p class="text-3xl font-bold text-gray-900"><%= @total_departments %></p>
        </div>
      </div>

    </div>

    <!-- Charts Section - Full Width L1, L2, L3 -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">

      <!-- L1 Level Status -->
      <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-200">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-base font-semibold text-gray-900">L1 Level Status</h3>
          <div class="text-right">
            <p class="text-lg font-bold text-gray-900"><%= @l1_approved_count + @l1_pending_count + @l1_returned_count %></p>
            <p class="text-xs text-gray-500">Total L1</p>
          </div>
        </div>
        
        <!-- L1 Donut Chart -->
        <div class="flex items-center justify-center mb-4">
          <div class="relative w-48 h-48 chart-container">
            <svg class="w-48 h-48 transform -rotate-90 drop-shadow-lg" viewBox="0 0 36 36">
              <defs>
                <linearGradient id="l1BgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#f8fafc;stop-opacity:1" />
                  <stop offset="100%" style="stop-color:#e2e8f0;stop-opacity:1" />
                </linearGradient>
              </defs>
              
              <!-- Background circle -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="url(#l1BgGradient)" stroke-width="3"/>
              
              <% l1_total = @l1_approved_count + @l1_pending_count + @l1_returned_count %>
              <% l1_approved_percentage = l1_total > 0 ? (@l1_approved_count.to_f / l1_total * 100) : 0 %>
              <% l1_pending_percentage = l1_total > 0 ? (@l1_pending_count.to_f / l1_total * 100) : 0 %>
              <% l1_returned_percentage = l1_total > 0 ? (@l1_returned_count.to_f / l1_total * 100) : 0 %>
              
              <!-- L1 Approved segment -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="#a7f3d0" stroke-width="4" 
                    stroke-dasharray="<%= l1_approved_percentage %>, 100" 
                    stroke-dashoffset="0"
                    class="chart-segment"/>
              
              <!-- L1 Pending segment -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="#fdba74" stroke-width="4" 
                    stroke-dasharray="<%= l1_pending_percentage %>, 100" 
                    stroke-dashoffset="<%= -l1_approved_percentage %>"
                    class="chart-segment"/>
              
              <!-- L1 Returned segment -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="#fca5a5" stroke-width="4" 
                    stroke-dasharray="<%= l1_returned_percentage %>, 100" 
                    stroke-dashoffset="<%= -(l1_approved_percentage + l1_pending_percentage) %>"
                    class="chart-segment"/>
            </svg>
          </div>
        </div>
        
        <!-- L1 Legend -->
        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-4 h-4 rounded-full mr-2" style="background-color: #a7f3d0;"></div>
              <span class="text-sm font-medium text-gray-700">L1 Approved</span>
            </div>
            <span class="text-lg font-bold text-gray-900"><%= @l1_approved_count %></span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-4 h-4 rounded-full mr-2" style="background-color: #fdba74;"></div>
              <span class="text-sm font-medium text-gray-700">L1 Pending</span>
            </div>
            <span class="text-lg font-bold text-gray-900"><%= @l1_pending_count %></span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-4 h-4 rounded-full mr-2" style="background-color: #fca5a5;"></div>
              <span class="text-sm font-medium text-gray-700">L1 Return</span>
            </div>
            <span class="text-lg font-bold text-gray-900"><%= @l1_returned_count %></span>
          </div>
        </div>
      </div>

      <!-- L2 Level Status -->
      <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-200">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-base font-semibold text-gray-900">L2 Level Status</h3>
          <div class="text-right">
            <p class="text-lg font-bold text-gray-900"><%= @l2_approved_count + @l2_pending_count + @l2_returned_count %></p>
            <p class="text-xs text-gray-500">Total L2</p>
          </div>
        </div>
        
        <!-- L2 Donut Chart -->
        <div class="flex items-center justify-center mb-4">
          <div class="relative w-48 h-48 chart-container">
            <svg class="w-48 h-48 transform -rotate-90 drop-shadow-lg" viewBox="0 0 36 36">
              <defs>
                <linearGradient id="l2BgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#f8fafc;stop-opacity:1" />
                  <stop offset="100%" style="stop-color:#e2e8f0;stop-opacity:1" />
                </linearGradient>
              </defs>
              
              <!-- Background circle -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="url(#l2BgGradient)" stroke-width="3"/>
              
              <% l2_total = @l2_approved_count + @l2_pending_count + @l2_returned_count %>
              <% l2_approved_percentage = l2_total > 0 ? (@l2_approved_count.to_f / l2_total * 100) : 0 %>
              <% l2_pending_percentage = l2_total > 0 ? (@l2_pending_count.to_f / l2_total * 100) : 0 %>
              <% l2_returned_percentage = l2_total > 0 ? (@l2_returned_count.to_f / l2_total * 100) : 0 %>
              
              <!-- L2 Approved segment -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="#93c5fd" stroke-width="4" 
                    stroke-dasharray="<%= l2_approved_percentage %>, 100" 
                    stroke-dashoffset="0"
                    class="chart-segment"/>
              
              <!-- L2 Pending segment -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="#fdba74" stroke-width="4" 
                    stroke-dasharray="<%= l2_pending_percentage %>, 100" 
                    stroke-dashoffset="<%= -l2_approved_percentage %>"
                    class="chart-segment"/>
              
              <!-- L2 Returned segment -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="#fca5a5" stroke-width="4" 
                    stroke-dasharray="<%= l2_returned_percentage %>, 100" 
                    stroke-dashoffset="<%= -(l2_approved_percentage + l2_pending_percentage) %>"
                    class="chart-segment"/>
            </svg>
          </div>
        </div>
        
        <!-- L2 Legend -->
        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-4 h-4 rounded-full mr-2" style="background-color: #93c5fd;"></div>
              <span class="text-sm font-medium text-gray-700">L2 Approved</span>
            </div>
            <span class="text-lg font-bold text-gray-900"><%= @l2_approved_count %></span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-4 h-4 rounded-full mr-2" style="background-color: #fdba74;"></div>
              <span class="text-sm font-medium text-gray-700">L2 Pending</span>
            </div>
            <span class="text-lg font-bold text-gray-900"><%= @l2_pending_count %></span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-4 h-4 rounded-full mr-2" style="background-color: #fca5a5;"></div>
              <span class="text-sm font-medium text-gray-700">L2 Return</span>
            </div>
            <span class="text-lg font-bold text-gray-900"><%= @l2_returned_count %></span>
          </div>
        </div>
      </div>

      <!-- L3 Level Status -->
      <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-200">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-base font-semibold text-gray-900">L3 Level Status</h3>
          <div class="text-right">
            <p class="text-lg font-bold text-gray-900"><%= @l3_approved_count + @l3_pending_count + @l3_returned_count %></p>
            <p class="text-xs text-gray-500">Total L3</p>
          </div>
        </div>
        
        <!-- L3 Donut Chart -->
        <div class="flex items-center justify-center mb-4">
          <div class="relative w-48 h-48 chart-container">
            <svg class="w-48 h-48 transform -rotate-90 drop-shadow-lg" viewBox="0 0 36 36">
              <defs>
                <linearGradient id="l3BgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#f8fafc;stop-opacity:1" />
                  <stop offset="100%" style="stop-color:#e2e8f0;stop-opacity:1" />
                </linearGradient>
              </defs>
              
              <!-- Background circle -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="url(#l3BgGradient)" stroke-width="3"/>
              
              <% l3_total = @l3_approved_count + @l3_pending_count + @l3_returned_count %>
              <% l3_approved_percentage = l3_total > 0 ? (@l3_approved_count.to_f / l3_total * 100) : 0 %>
              <% l3_pending_percentage = l3_total > 0 ? (@l3_pending_count.to_f / l3_total * 100) : 0 %>
              <% l3_returned_percentage = l3_total > 0 ? (@l3_returned_count.to_f / l3_total * 100) : 0 %>
              
              <!-- L3 Approved segment -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="#ddd6fe" stroke-width="4" 
                    stroke-dasharray="<%= l3_approved_percentage %>, 100" 
                    stroke-dashoffset="0"
                    class="chart-segment"/>
              
              <!-- L3 Pending segment -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="#fdba74" stroke-width="4" 
                    stroke-dasharray="<%= l3_pending_percentage %>, 100" 
                    stroke-dashoffset="<%= -l3_approved_percentage %>"
                    class="chart-segment"/>
              
              <!-- L3 Returned segment -->
              <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" 
                    fill="none" stroke="#fca5a5" stroke-width="4" 
                    stroke-dasharray="<%= l3_returned_percentage %>, 100" 
                    stroke-dashoffset="<%= -(l3_approved_percentage + l3_pending_percentage) %>"
                    class="chart-segment"/>
            </svg>
          </div>
        </div>
        
        <!-- L3 Legend -->
        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-4 h-4 rounded-full mr-2" style="background-color: #ddd6fe;"></div>
              <span class="text-sm font-medium text-gray-700">L3 Approved</span>
            </div>
            <span class="text-lg font-bold text-gray-900"><%= @l3_approved_count %></span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-4 h-4 rounded-full mr-2" style="background-color: #fdba74;"></div>
              <span class="text-sm font-medium text-gray-700">L3 Pending</span>
            </div>
            <span class="text-lg font-bold text-gray-900"><%= @l3_pending_count %></span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-4 h-4 rounded-full mr-2" style="background-color: #fca5a5;"></div>
              <span class="text-sm font-medium text-gray-700">L3 Return</span>
            </div>
            <span class="text-lg font-bold text-gray-900"><%= @l3_returned_count %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Metrics Cards Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      <!-- KPI Count -->
      <div class="bg-white rounded-xl p-6 shadow-lg border-l-4 min-w-[140px]" style="border-left-color: #fbbf24;">
        <div class="flex flex-col items-center text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: linear-gradient(135deg, #fef3c7, #fde68a);">
            <svg class="w-6 h-6 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-600 mb-1">KPI Count</p>
          <p class="text-3xl font-bold text-gray-900"><%= @total_activities %></p>
        </div>
      </div>

      <!-- Indicator Count -->
      <div class="bg-white rounded-xl p-6 shadow-lg border-l-4 min-w-[140px]" style="border-left-color: #10b981;">
        <div class="flex flex-col items-center text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: linear-gradient(135deg, #d1fae5, #a7f3d0);">
            <svg class="w-6 h-6 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-600 mb-1">Indicator Count</p>
          <p class="text-3xl font-bold text-gray-900"><%= @total_activities %></p>
        </div>
      </div>

      <!-- Weightage Count -->
      <div class="bg-white rounded-xl p-6 shadow-lg border-l-4 min-w-[140px]" style="border-left-color: #8b5cf6;">
        <div class="flex flex-col items-center text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: linear-gradient(135deg, #ede9fe, #ddd6fe);">
            <svg class="w-6 h-6 text-violet-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-600 mb-1">Weightage Count</p>
          <p class="text-3xl font-bold text-gray-900"><%= Activity.where('weight > 0').count %></p>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  /* Reset body and html margins */
  body, html {
    margin: 0;
    padding: 0;
    height: 100%;
    overflow-x: hidden;
  }
  
  /* Dashboard responsive layout */
  .dashboard-container {
    margin-left: 16rem;
    padding: 1.5rem;
    min-height: 100vh;
    height: 100vh;
    background-color: #f8fafc;
    width: calc(100vw - 16rem);
    overflow-y: auto;
  }
  
  /* Mobile responsive */
  @media (max-width: 1024px) {
    .dashboard-container {
      margin-left: 0;
      padding: 1rem;
      width: 100vw;
      height: 100vh;
      min-height: 100vh;
    }
  }
  
  /* Ensure sidebar is visible */
  #hs-application-sidebar {
    display: block !important;
    position: fixed !important;
    left: 0 !important;
    top: 0 !important;
    height: 100vh !important;
    width: 16rem !important;
    z-index: 50 !important;
  }
  
  /* Professional chart styling */
  .chart-container {
    position: relative;
  }
  
  /* Chart segment styling */
  .chart-segment {
    transition: stroke-width 0.2s ease;
    cursor: pointer;
  }
  
  .chart-segment:hover {
    stroke-width: 6;
  }
  
  /* Card hover effects */
  .bg-white {
    transition: box-shadow 0.2s ease;
  }
  
  .bg-white:hover {
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }
  
  /* Legend item hover effects */
  .space-y-2 > div {
    transition: background-color 0.2s ease;
  }
  
  .space-y-2 > div:hover {
    background-color: #f9fafb;
  }
</style>

<script>
  // Initialize toggle state from the backend value
  let isActive = <%= @dashboard_active ? 'true' : 'false' %>;
  
  // Update toggle UI state and notify the backend
  function updateToggleState(active, shouldSave = true) {
    isActive = active;
    
    // Fallback to storing in localStorage just in case
    localStorage.setItem('dashboardActiveState', isActive);
    
    const toggle = document.getElementById('active-inactive-toggle');
    const slider = document.getElementById('toggle-slider');
    const label = document.getElementById('toggle-label');
    
    if (isActive) {
      toggle.classList.remove('bg-gray-400');
      toggle.classList.add('bg-green-500');
      slider.classList.remove('translate-x-1');
      slider.classList.add('translate-x-11');
      label.textContent = 'Active';
      label.classList.remove('text-gray-500');
      label.classList.add('text-gray-700');
    } else {
      toggle.classList.remove('bg-green-500');
      toggle.classList.add('bg-gray-400');
      slider.classList.remove('translate-x-11');
      slider.classList.add('translate-x-1');
      label.textContent = 'Inactive';
      label.classList.remove('text-gray-700');
      label.classList.add('text-gray-500');
    }
    
    if (shouldSave) {
      // Create request to save this setting to the backend
      const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      
      fetch('/update_dashboard_status', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        body: JSON.stringify({ active: isActive })
      })
      .then(response => response.json())
      .then(data => {
        if (!data.success) {
          console.error('Failed to update dashboard status:', data);
          // Revert UI if server update fails
          alert('Failed to update status. Please try again.');
          // Revert the state without calling server again
          updateToggleState(!isActive, false); 
        } else {
          console.log('Dashboard status successfully updated to', isActive);
        }
      })
      .catch((error) => {
        console.error('Error:', error);
        alert('An error occurred while updating the status.');
        // Revert UI safely
        updateToggleState(!isActive, false); 
      });
    }
  }
  
  // Handle toggle click - detect which side was clicked
  function handleToggleClick(event) {
    const toggle = document.getElementById('active-inactive-toggle');
    const rect = toggle.getBoundingClientRect();
    const clickX = event.clientX - rect.left;
    const toggleWidth = rect.width;
    const midpoint = toggleWidth / 2;
    
    // Left side clicked (Inactive)
    if (clickX < midpoint) {
      setInactive();
    } 
    // Right side clicked (Active)
    else {
      setActive();
    }
  }
  
  // Set to Active (right side click) - with confirmation
  function setActive() {
    // If already active, do nothing
    if (isActive) {
      return;
    }
    
    // Ask for confirmation before activating
    if (confirm('Are you sure you want to activate?')) {
      updateToggleState(true);
    }
  }
  
  // Set to Inactive (left side click) - no confirmation needed
  function setInactive() {
    // If already inactive, do nothing
    if (!isActive) {
      return;
    }
    
    updateToggleState(false);
  }
  
  // Set initial state on page load
  function initializeToggle() {
    const toggle = document.getElementById('active-inactive-toggle');
    if (toggle) {
      isActive = toggle.getAttribute('data-active') === 'true';
      updateToggleState(isActive, false);
    }
  }
  
  // Handle both standard load and Turbo load
  document.addEventListener('DOMContentLoaded', initializeToggle);
  document.addEventListener('turbo:load', initializeToggle);
</script>
