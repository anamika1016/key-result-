<!-- app/views/user_details/new.html.erb -->
<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <h2 class="mb-4 text-dark">Department Activity Data Entry</h2>
      
      <!-- Department Selection at Top -->
      <div class="card mb-4">
        <div class="card-header bg-dark text-white">
          <h5 class="mb-0"><i class="fas fa-building me-2"></i>Select Department</h5>
        </div>
        <div class="card-body">
          <%= form_with model: @user_detail, local: true, id: "user_detail_form", class: "needs-validation", novalidate: true do |form| %>
            <div class="row mb-3">
              <div class="col-md-6">
                <%= form.label :department_id, "Department", class: "form-label fw-bold" %>
                <%= form.select :department_id, 
                    options_from_collection_for_select(@departments, :id, :department_type, @user_detail.department_id),
                    { prompt: "-- Select Department --" }, 
                    { class: "form-select form-select-lg", id: "department_select", required: true } %>
                <div class="invalid-feedback">
                  Please select a department.
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Activities and Monthly Data Table -->
      <div class="card">
        <div class="card-header bg-secondary text-white">
          <h5 class="mb-0"><i class="fas fa-table me-2"></i>Activities & Monthly Data</h5>
        </div>
        <div class="card-body p-0">
          <div id="activities_container" style="display: none;">
            <div class="table-responsive">
              <table class="table table-bordered table-striped mb-0">
                <thead class="table-dark">
                  <tr>
                    <th rowspan="2" class="sticky-col activity-col">Activity</th>
                    <th rowspan="2" class="sticky-col theme-col">Theme</th>
                    <th rowspan="2" class="sticky-col unit-col">Unit</th>
                    <th colspan="12" class="text-center">Monthly Data Entry</th>
                  </tr>
                  <tr>
                    <th class="month-header">April</th>
                    <th class="month-header">May</th>
                    <th class="month-header">June</th>
                    <th class="month-header">July</th>
                    <th class="month-header">August</th>
                    <th class="month-header">September</th>
                    <th class="month-header">October</th>
                    <th class="month-header">November</th>
                    <th class="month-header">December</th>
                    <th class="month-header">January</th>
                    <th class="month-header">February</th>
                    <th class="month-header">March</th>
                  </tr>
                </thead>
                <tbody id="activities_table_body">
                  <!-- Activities will be populated here via JavaScript -->
                </tbody>
              </table>
            </div>
            
            <div class="p-3 text-center bg-light border-top">
              <button type="button" id="save_all_data" class="btn btn-success btn-lg px-4">
                <i class="fas fa-save me-2"></i>Save All Data
              </button>
            </div>
          </div>
          
          <div id="no_department_message" class="alert alert-info m-3">
            <i class="fas fa-info-circle me-2"></i>Please select a department to view activities.
          </div>
        </div>
      </div>

      <!-- Existing Data Display -->
      <% if @user_details.any? %>
        <div class="card mt-4">
          <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="fas fa-database me-2"></i>Existing Data</h5>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-bordered table-sm">
                <thead class="table-dark">
                  <tr>
                    <th>Department</th>
                    <th>Activity</th>
                    <th>Theme</th>
                    <th>Unit</th>
                    <th>April</th>
                    <th>May</th>
                    <th>June</th>
                    <th>July</th>
                    <th>August</th>
                    <th>September</th>
                    <th>October</th>
                    <th>November</th>
                    <th>December</th>
                    <th>January</th>
                    <th>February</th>
                    <th>March</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @user_details.each do |detail| %>
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.department.department_type %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.activity.activity_name %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.department.theme_name.present? ? detail.department.theme_name : 'No Theme' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.activity.unit %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.april.present? ? detail.april : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.may.present? ? detail.may : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.june.present? ? detail.june : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.july.present? ? detail.july : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.august.present? ? detail.august : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.september.present? ? detail.september : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.october.present? ? detail.october : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.november.present? ? detail.november : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.december.present? ? detail.december : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.january.present? ? detail.january : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.february.present? ? detail.february : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= detail.march.present? ? detail.march : '-' %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm">
                        <%= link_to "Edit", edit_user_detail_path(detail), class: "btn btn-sm btn-outline-secondary me-1" %>
                        <%= link_to "Delete", user_detail_path(detail), method: :delete, 
                            confirm: "Are you sure?", class: "btn btn-sm btn-outline-danger" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const departmentSelect = document.getElementById('department_select');
  const activitiesContainer = document.getElementById('activities_container');
  const activitiesTableBody = document.getElementById('activities_table_body');
  const noDepartmentMessage = document.getElementById('no_department_message');
  const saveAllButton = document.getElementById('save_all_data');
  
  let activitiesData = [];
  let departmentTheme = '';
  
  // Handle department selection
  departmentSelect.addEventListener('change', function() {
    const departmentId = this.value;
    
    if (departmentId) {
      // Show loading state
      activitiesTableBody.innerHTML = '<tr><td colspan="15" class="text-center"><i class="fas fa-spinner fa-spin me-2"></i>Loading activities...</td></tr>';
      activitiesContainer.style.display = 'block';
      noDepartmentMessage.style.display = 'none';
      
      // Get department theme from the selected option
      const selectedOption = departmentSelect.options[departmentSelect.selectedIndex];
      const selectedDepartments = <%= @departments.to_json.html_safe %>;
      const selectedDept = selectedDepartments.find(dept => dept.id == departmentId);
      departmentTheme = selectedDept ? (selectedDept.theme_name || 'No Theme') : 'No Theme';
      
      // Fetch activities for selected department
      fetch(`/user_details/get_activities?department_id=${departmentId}`, {
        method: 'GET',
        headers: {
          'Accept': 'application/json',
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
        }
      })
      .then(response => {
        if (!response.ok) {
          throw new Error('Network response was not ok');
        }
        return response.json();
      })
      .then(activities => {
        activitiesData = activities;
        populateActivitiesTable(activities);
      })
      .catch(error => {
        console.error('Error fetching activities:', error);
        activitiesTableBody.innerHTML = '<tr><td colspan="15" class="text-center text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Error loading activities. Please try again.</td></tr>';
      });
    } else {
      activitiesContainer.style.display = 'none';
      noDepartmentMessage.style.display = 'block';
      activitiesData = [];
      departmentTheme = '';
    }
  });
  
  // Populate activities table
  function populateActivitiesTable(activities) {
    activitiesTableBody.innerHTML = '';
    
    if (activities.length === 0) {
      activitiesTableBody.innerHTML = '<tr><td colspan="15" class="text-center text-muted"><i class="fas fa-info-circle me-2"></i>No activities found for this department.</td></tr>';
      return;
    }
    
    activities.forEach(activity => {
      const row = document.createElement('tr');
      row.innerHTML = `
        <td class="sticky-col activity-col">
          <div class="fw-bold text-dark">${activity.activity_name}</div>
          <input type="hidden" name="activity_ids[]" value="${activity.id}">
        </td>
        <td class="sticky-col theme-col">
          <span class="badge bg-light text-dark border">${departmentTheme}</span>
        </td>
        <td class="sticky-col unit-col">
          <span class="badge bg-secondary">${activity.unit}</span>
        </td>
        <td><input type="text" name="april_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="may_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="june_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="july_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="august_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="september_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="october_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="november_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="december_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="january_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="february_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
        <td><input type="text" name="march_${activity.id}" class="form-control form-control-sm text-center" placeholder="Target/Task" value=""></td>
      `;
      activitiesTableBody.appendChild(row);
    });
  }
  
  // Handle save all data
  saveAllButton.addEventListener('click', function() {
    const departmentId = departmentSelect.value;
    
    if (!departmentId) {
      showAlert('Please select a department first.', 'warning');
      return;
    }
    
    if (activitiesData.length === 0) {
      showAlert('No activities found for the selected department.', 'warning');
      return;
    }
    
    // Collect all form data
    const formData = new FormData();
    formData.append('department_id', departmentId);
    formData.append('authenticity_token', document.querySelector('[name="csrf-token"]').content);
    
    let hasData = false;
    
    activitiesData.forEach(activity => {
      const months = ['april', 'may', 'june', 'july', 'august', 'september', 
                     'october', 'november', 'december', 'january', 'february', 'march'];
      
      const activityData = {};
      let activityHasData = false;
      
      months.forEach(month => {
        const input = document.querySelector(`[name="${month}_${activity.id}"]`);
        const value = input ? input.value.trim() : '';
        activityData[month] = value;
        if (value && value !== '') activityHasData = true;
      });
      
      if (activityHasData) {
        hasData = true;
        formData.append(`user_details[${activity.id}][activity_id]`, activity.id);
        months.forEach(month => {
          formData.append(`user_details[${activity.id}][${month}]`, activityData[month] || '');
        });
      }
    });
    
    if (!hasData) {
      showAlert('Please enter data for at least one activity.', 'warning');
      return;
    }
    
    // Show loading state
    saveAllButton.disabled = true;
    saveAllButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Saving...';
    
    // Submit data
    fetch('/user_details/bulk_create', {
      method: 'POST',
      body: formData,
      headers: {
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      }
    })
    .then(response => {
      if (response.ok) {
        showAlert('Data saved successfully!', 'success');
        setTimeout(() => location.reload(), 1500);
      } else {
        throw new Error('Save failed');
      }
    })
    .catch(error => {
      console.error('Error saving data:', error);
      showAlert('Error saving data. Please try again.', 'danger');
    })
    .finally(() => {
      saveAllButton.disabled = false;
      saveAllButton.innerHTML = '<i class="fas fa-save me-2"></i>Save All Data';
    });
  });
  
  // Show alert function
  function showAlert(message, type) {
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
    alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
    alertDiv.innerHTML = `
      ${message}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    document.body.appendChild(alertDiv);
    
    setTimeout(() => {
      if (alertDiv.parentNode) {
        alertDiv.parentNode.removeChild(alertDiv);
      }
    }, 5000);
  }
});
</script>

