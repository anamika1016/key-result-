<!-- Fixed Quarterly Edit Form - Dynamic with Sidebar Support -->
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<div class="min-h-screen bg-gray-50 content-wrapper">
  <div class="w-full px-4 py-6">
    <!-- Header Section -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-lg mb-8">
      <div class="bg-gradient-to-r from-gray-600 to-gray-700 text-white px-6 py-4 rounded-t-xl">
        <div class="flex justify-between items-center">
          <h1 class="text-3xl font-bold flex items-center">
            <i class="fas fa-edit me-3 text-2xl"></i>
            Quarterly Achievement Editor
          </h1>
          <div class="text-sm font-semibold bg-white/10 rounded-full px-4 py-2">
            Year: <%= @selected_year %>
          </div>
        </div>
      </div>
    </div>

    <!-- Department Filter Section - Moved to top with dark theme -->
    <% if @user_details.any? %>
        <div class="bg-white border-2 border-red-500 rounded-xl shadow-2xl mb-6 p-6">
        <div class="flex items-center space-x-4">
          <label for="departmentFilter" class="text-sm font-bold text-gray-800">Select Department:</label>
          <select id="departmentFilter" class="border-2 border-gray-400 rounded-lg px-4 py-3 bg-white text-black font-semibold focus:ring-2 focus:ring-red-500 focus:border-red-500" onchange="console.log('Dropdown changed to:', this.value); filterTableByDepartment(this.value);">
            <option value="">All Departments (NOT RECOMMENDED)</option>
            <% @user_details.map(&:department).map(&:department_type).uniq.each do |dept| %>
              <option value="<%= dept %>" <%= 'selected' if @selected_department == dept %>><%= dept %></option>
            <% end %>
          </select>
          <button type="button" id="applyDepartmentFilther" class="bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-lg font-bold text-lg shadow-lg">
            Apply Filter
          </button>
        </div>
      </div>
    <% end %>

    <!-- Quarterly Edit Form -->
    <% if @user_details.any? %>
      <%= form_with url: update_quarterly_achievements_user_details_path, method: :patch, local: true, class: "quarterly-form w-full", multipart: true, data: { disable_with: "Updating..." }, id: "quarterly-form-#{Time.current.to_i}" do |form| %>
        <%= hidden_field_tag :selected_quarter, @selected_quarter.presence || params[:quarter] || "Q1", id: "selected_quarter_field" %>
        <%= hidden_field_tag :selected_department, @selected_department, id: "selected_department_field" %>
        <%= hidden_field_tag :year, @selected_year %>
        

        <!-- KPI List - Same as Submit Page -->
        <div id="activitiesList" class="w-full">
          <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200 shadow-sm">
            <table class="table table-hover w-full min-w-full" id="activityTable">
              <thead class="bg-gray-800">
                <tr class="bg-gray-800">
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-800">Department</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-800">Employee Name</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-800">Indicator</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-800">KPI</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-800">Unit</th>
                  <th rowspan="2" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-800">Weightage</th>
                  <% if params[:quarter] == 'Q1' || params[:quarter].blank? %>
                    <th colspan="3" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 quarter-header" data-quarter="q1">Q1</th>
                  <% end %>
                  <% if params[:quarter] == 'Q2' || params[:quarter].blank? %>
                    <th colspan="3" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 quarter-header" data-quarter="q2">Q2</th>
                  <% end %>
                  <% if params[:quarter] == 'Q3' || params[:quarter].blank? %>
                    <th colspan="3" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 quarter-header" data-quarter="q3">Q3</th>
                  <% end %>
                  <% if params[:quarter] == 'Q4' || params[:quarter].blank? %>
                    <th colspan="3" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 quarter-header" data-quarter="q4">Q4</th>
                  <% end %>
                </tr>
                <tr class="bg-gray-700">
                  <% if params[:quarter] == 'Q1' || params[:quarter].blank? %>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Achievement (%)</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Remarks</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Weightage Score</th>
                  <% end %>
                  <% if params[:quarter] == 'Q2' || params[:quarter].blank? %>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Achievement (%)</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Remarks</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Weightage Score</th>
                  <% end %>
                  <% if params[:quarter] == 'Q3' || params[:quarter].blank? %>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Achievement (%)</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Remarks</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Weightage Score</th>
                  <% end %>
                  <% if params[:quarter] == 'Q4' || params[:quarter].blank? %>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Achievement (%)</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Remarks</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Weightage Score</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @user_details.each_with_index do |detail, index| %>
                  <%
                  # Get existing achievements for this detail - Force fresh data loading
                  existing_achievements = {}
                  
                  # Force reload achievements to get the latest data
                  detail.achievements.reload
                  
                  
                  if detail.achievements.present?
                    # FIXED: Get quarterly achievements directly (stored as q1, q2, q3, q4)
                    ['q1', 'q2', 'q3', 'q4'].each do |quarter|
                      # Look for achievements with the quarter name directly (case-insensitive)
                      quarterly_achievement = detail.achievements.find { |a| a.month.to_s.downcase == quarter.to_s.downcase }
                      
                      if quarterly_achievement && quarterly_achievement.achievement.present?
                        # Create a virtual achievement object with the actual achievement value
                        existing_achievements[quarter] = OpenStruct.new(
                          achievement: quarterly_achievement.achievement.to_f,
                          employee_remarks: quarterly_achievement.employee_remarks || ''
                        )
                      end
                    end
                  end
                  
                %>

                  <tr class="<%= index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200 activity-row" 
                      data-activity="<%= detail.activity.activity_name %>" 
                      data-department="<%= detail.department.department_type %>">
                    
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200">
                      <span class="<%= 'bg-yellow-100 px-2 py-1 rounded' if @selected_department.present? && detail.department.department_type == @selected_department %>">
                        <%= detail.department.department_type %>
                        <% if @selected_department.present? && detail.department.department_type == @selected_department %>
                          <span class="text-xs text-yellow-700 ml-1">(EDITING)</span>
                        <% end %>
                      </span>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200"><%= detail.employee_detail&.employee_name || 'N/A' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.activity_name %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.theme_name.presence || 'No Theme' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= detail.activity.unit %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center font-semibold"><%= detail.activity.weight.present? ? "#{detail.activity.weight.to_i}%" : '0%' %></td>

                    <!-- Q1 Quarter -->
                    <% if params[:quarter] == 'Q1' || params[:quarter].blank? %>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q1">
                        <input 
                          type="text" 
                          name="achievements[<%= detail.id %>][q1][achievement]" 
                          placeholder="Q1 %" 
                          value="<%= existing_achievements['q1']&.achievement&.to_f&.to_i || '' %>"
                          data-timestamp="<%= Time.current.to_i %>"
                          data-cache-bust="<%= Time.current.to_f %>"
                          data-refresh="<%= params[:refresh] || Time.current.to_f %>"
                          data-updated="<%= params[:updated] || 'false' %>"
                          data-timestamp-param="<%= params[:timestamp] || Time.current.to_i %>"
                          class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm text-black"
                          onchange="calculateWeightageScore(this)" oninput="calculateWeightageScore(this)"
                          data-weight="<%= detail.activity.weight.present? ? detail.activity.weight : 0 %>"
                          autocomplete="off"
                        />
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q1">
                        <textarea 
                          name="achievements[<%= detail.id %>][q1][employee_remarks]" 
                          placeholder="Remarks" 
                          rows="1"
                          class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none text-black"
                        ><%= existing_achievements['q1']&.employee_remarks || '' %></textarea>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q1">
                        <%
                          # Calculate weightage score for Q1
                          q1_achievement = existing_achievements['q1']&.achievement
                          q1_achievement_float = q1_achievement.present? ? q1_achievement.to_f : 0
                          weight = detail.activity.weight.present? ? detail.activity.weight.to_f : 0
                          weight_decimal = weight > 1 ? weight / 100 : weight
                          q1_score = q1_achievement_float > 0 && weight > 0 ? (weight_decimal * q1_achievement_float).round(2) : 0
                        %>
                        <input 
                          type="text" 
                          readonly
                          class="weightage-score border border-gray-300 p-1 rounded-lg w-full bg-green-50 text-green-800 text-xs font-semibold text-center" 
                          id="q1-score-<%= detail.id %>" 
                          value="<%= q1_score > 0 ? "#{q1_score}%" : '' %>"
                          placeholder="Score"
                        />
                      </td>
                    <% end %>

                    <!-- Q2 Quarter -->
                    <% if params[:quarter] == 'Q2' || params[:quarter].blank? %>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q2">
                        <input 
                          type="text" 
                          name="achievements[<%= detail.id %>][q2][achievement]" 
                          placeholder="Q2 %" 
                          value="<%= existing_achievements['q2']&.achievement&.to_f&.to_i || '' %>"
                          data-timestamp="<%= Time.current.to_i %>"
                          data-cache-bust="<%= Time.current.to_f %>"
                          data-refresh="<%= params[:refresh] || Time.current.to_f %>"
                          data-updated="<%= params[:updated] || 'false' %>"
                          data-timestamp-param="<%= params[:timestamp] || Time.current.to_i %>"
                          class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm text-black"
                          onchange="calculateWeightageScore(this)" oninput="calculateWeightageScore(this)"
                          data-weight="<%= detail.activity.weight.present? ? detail.activity.weight : 0 %>"
                        />
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q2">
                        <textarea 
                          name="achievements[<%= detail.id %>][q2][employee_remarks]" 
                          placeholder="Remarks" 
                          rows="1"
                          class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none text-black"
                        ><%= existing_achievements['q2']&.employee_remarks || '' %></textarea>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q2">
                        <%
                          # Calculate weightage score for Q2
                          q2_achievement = existing_achievements['q2']&.achievement
                          q2_achievement_float = q2_achievement.present? ? q2_achievement.to_f : 0
                          weight = detail.activity.weight.present? ? detail.activity.weight.to_f : 0
                          weight_decimal = weight > 1 ? weight / 100 : weight
                          q2_score = q2_achievement_float > 0 && weight > 0 ? (weight_decimal * q2_achievement_float).round(2) : 0
                        %>
                        <input 
                          type="text" 
                          readonly
                          class="weightage-score border border-gray-300 p-1 rounded-lg w-full bg-green-50 text-green-800 text-xs font-semibold text-center" 
                          id="q2-score-<%= detail.id %>" 
                          value="<%= q2_score > 0 ? "#{q2_score}%" : '' %>"
                          placeholder="Score"
                        />
                      </td>
                    <% end %>

                    <!-- Q3 Quarter -->
                    <% if params[:quarter] == 'Q3' || params[:quarter].blank? %>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q3">
                        <input 
                          type="text" 
                          name="achievements[<%= detail.id %>][q3][achievement]" 
                          placeholder="Q3 %" 
                          value="<%= existing_achievements['q3']&.achievement&.to_f&.to_i || '' %>"
                          data-timestamp="<%= Time.current.to_i %>"
                          data-cache-bust="<%= Time.current.to_f %>"
                          data-refresh="<%= params[:refresh] || Time.current.to_f %>"
                          data-updated="<%= params[:updated] || 'false' %>"
                          data-timestamp-param="<%= params[:timestamp] || Time.current.to_i %>"
                          class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm text-black"
                          onchange="calculateWeightageScore(this)" oninput="calculateWeightageScore(this)"
                          data-weight="<%= detail.activity.weight.present? ? detail.activity.weight : 0 %>"
                        />
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q3">
                        <textarea 
                          name="achievements[<%= detail.id %>][q3][employee_remarks]" 
                          placeholder="Remarks" 
                          rows="1"
                          class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none text-black"
                        ><%= existing_achievements['q3']&.employee_remarks || '' %></textarea>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q3">
                        <%
                          # Calculate weightage score for Q3
                          q3_achievement = existing_achievements['q3']&.achievement
                          q3_achievement_float = q3_achievement.present? ? q3_achievement.to_f : 0
                          weight = detail.activity.weight.present? ? detail.activity.weight.to_f : 0
                          weight_decimal = weight > 1 ? weight / 100 : weight
                          q3_score = q3_achievement_float > 0 && weight > 0 ? (weight_decimal * q3_achievement_float).round(2) : 0
                        %>
                        <input 
                          type="text" 
                          readonly
                          class="weightage-score border border-gray-300 p-1 rounded-lg w-full bg-green-50 text-green-800 text-xs font-semibold text-center" 
                          id="q3-score-<%= detail.id %>" 
                          value="<%= q3_score > 0 ? "#{q3_score}%" : '' %>"
                          placeholder="Score"
                        />
                      </td>
                    <% end %>

                    <!-- Q4 Quarter -->
                    <% if params[:quarter] == 'Q4' || params[:quarter].blank? %>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q4">
                        <input 
                          type="text" 
                          name="achievements[<%= detail.id %>][q4][achievement]" 
                          placeholder="Q4 %" 
                          value="<%= existing_achievements['q4']&.achievement&.to_f&.to_i || '' %>"
                          data-timestamp="<%= Time.current.to_i %>"
                          data-cache-bust="<%= Time.current.to_f %>"
                          data-refresh="<%= params[:refresh] || Time.current.to_f %>"
                          data-updated="<%= params[:updated] || 'false' %>"
                          data-timestamp-param="<%= params[:timestamp] || Time.current.to_i %>"
                          class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm text-black"
                          onchange="calculateWeightageScore(this)" oninput="calculateWeightageScore(this)"
                          data-weight="<%= detail.activity.weight.present? ? detail.activity.weight : 0 %>"
                        />
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q4">
                        <textarea 
                          name="achievements[<%= detail.id %>][q4][employee_remarks]" 
                          placeholder="Remarks" 
                          rows="1"
                          class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none text-black"
                        ><%= existing_achievements['q4']&.employee_remarks || '' %></textarea>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q4">
                        <%
                          # Calculate weightage score for Q4
                          q4_achievement = existing_achievements['q4']&.achievement
                          q4_achievement_float = q4_achievement.present? ? q4_achievement.to_f : 0
                          weight = detail.activity.weight.present? ? detail.activity.weight.to_f : 0
                          weight_decimal = weight > 1 ? weight / 100 : weight
                          q4_score = q4_achievement_float > 0 && weight > 0 ? (weight_decimal * q4_achievement_float).round(2) : 0
                        %>
                        <input 
                          type="text" 
                          readonly
                          class="weightage-score border border-gray-300 p-1 rounded-lg w-full bg-green-50 text-green-800 text-xs font-semibold text-center" 
                          id="q4-score-<%= detail.id %>" 
                          value="<%= q4_score > 0 ? "#{q4_score}%" : '' %>"
                          placeholder="Score"
                        />
                      </td>
                    <% end %>
                  </tr>
                <% end %>
                
                <!-- TOTAL COUNT ROW -->
                <tr class="bg-green-100 border-t-2 border-green-300">
                  <td class="px-4 py-3 text-sm font-bold text-green-800 border-r border-gray-200" colspan="5">
                    TOTAL COUNT
                  </td>
                  <td class="px-4 py-3 text-sm text-center border-r border-gray-200">
                    <% 
                      # Calculate total weightage
                      total_weightage = 0
                      @user_details.each do |detail|
                        if detail.activity.weight.present?
                          total_weightage += detail.activity.weight.to_f
                        end
                      end
                    %>
                    <span id="total-weightage-display" class="text-green-700 font-bold bg-green-50 px-3 py-1 rounded-full">
                      <%= total_weightage.to_i %>%
                    </span>
                  </td>
                  <% if params[:quarter] == 'Q1' || params[:quarter].blank? %>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200">
                      <% 
                        # Calculate total sum of achievements
                        total_achievement_sum = 0
                        total_q1_count = 0
                        @user_details.each do |detail|
                          # Check for quarterly achievement first, then monthly achievements
                          q1_quarterly_achievement = detail.achievements.find { |a| a.month.to_s.downcase == 'q1' }
                          if q1_quarterly_achievement&.achievement.present? && q1_quarterly_achievement.achievement.to_f > 0
                            total_achievement_sum += q1_quarterly_achievement.achievement.to_f
                            total_q1_count += 1
                          else
                            # Check monthly achievements for Q1 (case-insensitive)
                            q1_months = ['april', 'may', 'june']
                            q1_monthly_achievements = detail.achievements.select { |a| q1_months.include?(a.month.to_s.downcase) }
                            if q1_monthly_achievements.any? { |a| a.achievement.present? && a.achievement.to_f > 0 }
                              # Convert string values to numeric first
                              achievement_values = q1_monthly_achievements.select { |a| a.achievement.present? }.map { |a| a.achievement.to_f rescue 0 }.compact
                              avg_monthly = achievement_values.any? ? (achievement_values.sum / achievement_values.size) : nil
                              if avg_monthly
                                total_achievement_sum += avg_monthly
                                total_q1_count += 1
                              end
                            end
                          end
                        end
                      %>
                      <span id="q1-achievement-total" class="text-green-700 font-bold bg-green-50 px-3 py-1 rounded-full">
                        <%= total_achievement_sum.to_i %>%
                      </span>
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200">
                      <span class="text-blue-700 font-bold bg-blue-50 px-3 py-1 rounded-full">
                        <%= total_q1_count %>
                      </span>
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200">
                      <% 
                        # Calculate total Q1 weightage score
                        total_q1_weightage = 0
                        @user_details.each do |detail|
                          q1_quarterly_achievement = detail.achievements.find { |a| a.month.to_s.downcase == 'q1' }
                          achievement_value = nil
                          
                          if q1_quarterly_achievement&.achievement.present?
                            achievement_value = q1_quarterly_achievement.achievement.to_f
                          else
                            # Check monthly achievements for Q1 (case-insensitive)
                            q1_months = ['april', 'may', 'june']
