  // Function to calculate weightage score
  function calculateWeightageScore(input) {
    try {
      // Add safety checks
      if (!input) {
        console.log('calculateWeightageScore: No input provided');
        return;
      }
      
      const achievement = parseFloat(input.value) || 0;
      const weight = parseFloat(input.dataset.weight) || 0;
      
      console.log('calculateWeightageScore: achievement=', achievement, 'weight=', weight);
      
      // Find the corresponding score input with safety checks
      const row = input.closest('tr');
      if (!row) {
        console.log('calculateWeightageScore: No row found');
        return;
      }
      
      const quarterCell = input.closest('td[data-quarter]');
      if (!quarterCell) {
        console.log('calculateWeightageScore: No quarter cell found');
        return;
      }
      
      const quarter = quarterCell.dataset.quarter;
      if (!quarter) {
        console.log('calculateWeightageScore: No quarter data found');
        return;
      }
      
      const nameMatch = input.name ? input.name.match(/\[(\d+)\]/) : null;
      if (!nameMatch) {
        console.log('calculateWeightageScore: No detail ID found in name');
        return;
      }
      
      const detailId = nameMatch[1];
      const scoreInput = row.querySelector(`#${quarter}-score-${detailId}`);
      
      console.log('calculateWeightageScore: Looking for score input with ID:', `${quarter}-score-${detailId}`);
      console.log('calculateWeightageScore: Found score input:', scoreInput);
      
      if (scoreInput && weight > 0) {
        const score = (achievement * weight / 100).toFixed(2);
        scoreInput.value = score + '%';
        console.log('calculateWeightageScore: Updated score to:', score + '%');
      } else {
        console.log('calculateWeightageScore: No score input found or weight is 0');
      }
      
      // Update total weightage dynamically
      updateTotalWeightage();
      
      // Update achievement totals dynamically
      updateAchievementTotals();
      
      // DYNAMIC UPDATE: Broadcast changes to other views immediately
      broadcastDynamicUpdate(input, achievement, quarter, detailId);
      
    } catch (error) {
      console.error('Error in calculateWeightageScore:', error);
    }
  }
  
  // Function to broadcast dynamic updates to other views
  function broadcastDynamicUpdate(input, achievement, quarter, detailId) {
    try {
      // Store the updated value in localStorage for cross-tab communication
      const updateData = {
        timestamp: Date.now(),
        quarter: quarter,
        detailId: detailId,
        achievement: achievement,
        inputName: input.name,
        inputValue: input.value
      };
      
      localStorage.setItem('dynamic_quarterly_update', JSON.stringify(updateData));
      
      // Also store in sessionStorage for immediate same-tab updates
      sessionStorage.setItem('live_update_data', JSON.stringify(updateData));
      
      // Trigger custom event for same-tab listeners
      window.dispatchEvent(new CustomEvent('quarterlyDataUpdated', {
        detail: updateData
      }));
      
    } catch (error) {
      // Ignore errors
    }
  }
  
  // Function to calculate and update total weightage dynamically
  function updateTotalWeightage() {
    try {
      let totalWeightage = 0;
      
      // Get all weightage values from the table
      const weightageCells = document.querySelectorAll('td:nth-child(6)'); // 6th column is weightage
      if (weightageCells) {
        weightageCells.forEach(cell => {
          if (cell && cell.textContent) {
            const weightageText = cell.textContent.trim();
            if (weightageText && weightageText !== 'TOTAL COUNT' && !isNaN(parseFloat(weightageText))) {
              totalWeightage += parseFloat(weightageText);
            }
          }
        });
      }
      
      // Update the display
      const totalWeightageDisplay = document.getElementById('total-weightage-display');
      if (totalWeightageDisplay) {
        totalWeightageDisplay.textContent = Math.round(totalWeightage) + '%';
        
        // Add animation effect
        totalWeightageDisplay.style.transform = 'scale(1.1)';
        totalWeightageDisplay.style.transition = 'transform 0.2s ease';
        
        setTimeout(() => {
          if (totalWeightageDisplay) {
            totalWeightageDisplay.style.transform = 'scale(1)';
          }
        }, 200);
      }
    } catch (error) {
      // Error handling
    }
  }
  
