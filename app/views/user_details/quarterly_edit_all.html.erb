<script>
  // Cache buster: v2.2 - Fixed JavaScript errors and function definitions
  
  // Handle Turbo.js errors gracefully
  document.addEventListener('turbo:before-render', function(event) {
    try {
      // Prevent any potential errors during rendering
      event.preventDefault = function() {
      };
    } catch (error) {
      // Error handling
    }
  });
  
  document.addEventListener('turbo:render', function(event) {
    try {
      // Re-initialize functions after turbo render
      if (typeof window.calculateWeightageScore !== 'function') {
        window.calculateWeightageScore = function(input) {
          if (!input) return;
          try {
            const achievement = parseFloat(input.value) || 0;
