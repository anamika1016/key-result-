  // Global function to filter table rows by department
  function filterTableByDepartment(selectedDepartment) {
    const tableRows = document.querySelectorAll('.activity-row');
    
    if (tableRows.length === 0) {
      return;
    }
    
    let visibleCount = 0;
    
    tableRows.forEach((row, index) => {
      const departmentCell = row.querySelector('td:first-child');
      if (departmentCell) {
        // Get the department name from the span or the cell text, removing extra text
        let departmentName = departmentCell.textContent.trim();
        // Remove "(EDITING)" text if present
        departmentName = departmentName.replace(/\s*\(EDITING\)\s*/, '').trim();
        
        // Alternative: try to get department name from data attribute
        const dataDepartment = row.getAttribute('data-department');
        if (dataDepartment) {
          departmentName = dataDepartment;
        }
        
        if (selectedDepartment === '' || departmentName === selectedDepartment) {
          row.style.display = '';
          row.style.opacity = '1';
          visibleCount++;
          // Add highlight for selected department
          if (selectedDepartment && departmentName === selectedDepartment) {
            row.style.backgroundColor = '#fef3c7'; // Light yellow background
            row.style.border = '2px solid #f59e0b'; // Orange border
          } else {
            row.style.backgroundColor = '';
            row.style.border = '';
          }
        } else {
          row.style.display = 'none';
          row.style.opacity = '0';
        }
      }
    });
  }







