      });
      
      if (!hasAnyValue) {
        e.preventDefault();
        alert(`Please enter at least one achievement value for ${selectedQuarter}.`);
        return false;
      }
      
      // Add cache-busting parameters to form action
      const form = e.target;
      const currentUrl = new URL(form.action);
      currentUrl.searchParams.set('t', Date.now());
      currentUrl.searchParams.set('refresh', 'true');
      currentUrl.searchParams.set('cache_bust', Math.random());
      form.action = currentUrl.toString();
      
