          header.style.display = 'none';
        } else {
          header.style.display = 'table-cell';
        }
      });
    }
  }
  
  // Run quarter selection maintenance multiple times
  setTimeout(maintainQuarterSelection, 100);
  setTimeout(maintainQuarterSelection, 300);
  setTimeout(maintainQuarterSelection, 500);
  
  // Form submission
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('.quarterly-form');
    if (form) {
      form.addEventListener('submit', function(e) {
        // Add cache-busting parameters to form action
        const currentUrl = new URL(form.action);
        currentUrl.searchParams.set('t', Date.now());
        currentUrl.searchParams.set('refresh', 'true');
        currentUrl.searchParams.set('cache_bust', Math.random());
        form.action = currentUrl.toString();
      });
    }
  });

  // Initialize the page when DOM is loaded
  document.addEventListener('DOMContentLoaded', function() {
    // Check if this is a post-update redirect
    const urlParams = new URLSearchParams(window.location.search);
    const isUpdated = urlParams.get('updated') === 'true';
    const timestamp = urlParams.get('timestamp');
    
    if (isUpdated) {
      // Clear browser cache for this page
      if ('caches' in window) {
        caches.keys().then(function(names) {
          names.forEach(function(name) {
            caches.delete(name);
          });
        });
      }
      
      // Force refresh all achievement inputs to show updated values
      setTimeout(function() {
        const achievementInputs = document.querySelectorAll('.achievement-input');
        
        achievementInputs.forEach(function(input) {
          // Get the current value from the server (this should be the updated value)
          const serverValue = input.getAttribute('value') || input.defaultValue || '';
          const currentDisplayValue = input.value;
          
          // Force the input to show the server value
          if (serverValue !== currentDisplayValue) {
            input.value = serverValue;
          }
          
          // Clear any browser autofill/cache
          input.setAttribute('autocomplete', 'off');
          input.setAttribute('data-cache-bust', Date.now());
          
          // Trigger change event to update dependent calculations
          input.dispatchEvent(new Event('change', { bubbles: true }));
          input.dispatchEvent(new Event('input', { bubbles: true }));
          
          // Also call calculateWeightageScore to update the score
          if (typeof window.calculateWeightageScore === 'function') {
            window.calculateWeightageScore(input);
          }
        });
        
        // Also refresh weightage score calculations
        if (typeof updateTotalWeightage === 'function') {
          updateTotalWeightage();
        }
        if (typeof updateAchievementTotals === 'function') {
          updateAchievementTotals();
        }
        
        // Force refresh totals after a short delay
        setTimeout(() => {
          if (typeof updateAchievementTotals === 'function') {
            updateAchievementTotals();
          }
        }, 200);
      }, 100);
      
      // Additional refresh after a longer delay to ensure all data is loaded
      setTimeout(function() {
        const achievementInputs = document.querySelectorAll('.achievement-input');
        achievementInputs.forEach(function(input) {
          // Force refresh the input value
          const currentValue = input.value;
          input.value = '';
          input.value = currentValue;
          input.dispatchEvent(new Event('change', { bubbles: true }));
        });
        updateTotalWeightage();
        updateAchievementTotals();
      }, 1000);
      
      // Final fallback: if data still seems stale, reload the page
      setTimeout(function() {
        const achievementInputs = document.querySelectorAll('.achievement-input');
        let hasStaleData = false;
        
        achievementInputs.forEach(function(input) {
          // Check if input has a value but it might be stale
          if (input.value && input.value.trim() !== '') {
            // If the input has a value, check if it's the same as before
            const dataTimestamp = input.getAttribute('data-timestamp-param');
            const currentTimestamp = new URLSearchParams(window.location.search).get('timestamp');
            
            if (dataTimestamp && currentTimestamp && dataTimestamp !== currentTimestamp) {
              hasStaleData = true;
            }
          }
        });
        
        if (hasStaleData) {
          // Remove the updated parameter to prevent infinite reload
          const url = new URL(window.location);
          url.searchParams.delete('updated');
          url.searchParams.delete('timestamp');
          url.searchParams.set('t', Date.now());
          window.location.href = url.toString();
        } else {
          // If no stale data detected, try one more aggressive refresh
          achievementInputs.forEach(function(input) {
            // Force a complete refresh of the input
            const originalValue = input.value;
            input.value = '';
            setTimeout(() => {
              input.value = originalValue;
              input.dispatchEvent(new Event('change', { bubbles: true }));
              if (typeof window.calculateWeightageScore === 'function') {
                window.calculateWeightageScore(input);
              }
            }, 50);
          });
        }
      }, 2000);
    }
    
    // Wait a bit for the table to be fully rendered
    setTimeout(function() {
      const departmentFilter = document.getElementById('departmentFilter');
      if (departmentFilter && departmentFilter.value) {
        filterTableByDepartment(departmentFilter.value);
      }
    }, 500);
  });
  
</script>
