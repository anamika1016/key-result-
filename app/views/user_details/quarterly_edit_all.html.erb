<!-- Fixed Quarterly Edit Form -->
<div class="main-content container-fluid px-4 py-6 bg-gray-50 min-h-screen">
  <div class="max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-lg mb-8">
      <div class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-6 py-4 rounded-t-xl">
        <div class="flex justify-between items-center">
          <h1 class="text-3xl font-bold flex items-center">
            <i class="fas fa-edit me-3 text-2xl"></i>
            Quarterly Achievement Editor
          </h1>
          <%= link_to user_details_path, class: "bg-white bg-opacity-20 hover:bg-opacity-30 text-white px-4 py-2 rounded-lg transition-all duration-200 flex items-center" do %>
            <i class="fas fa-arrow-left me-2"></i>Back to List
          <% end %>
        </div>
      </div>
      
      <div class="p-6">
        <div class="text-gray-600 mb-4">
          <p class="mb-4">Select a quarter to edit achievements and remarks for ALL activities in that quarter.</p>
        </div>
        
        <!-- Quarter Filter Dropdown -->
        <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
          <div class="flex flex-wrap items-center gap-4">
            <label class="text-sm font-medium text-gray-700">Choose Quarter to Edit:</label>
            <select id="quarterFilter" class="bg-white border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent min-w-[200px]">
              <option value="">Select Quarter</option>
              <option value="Q1">Q1 (April, May, June)</option>
              <option value="Q2">Q2 (July, August, September)</option>
              <option value="Q3">Q3 (October, November, December)</option>
              <option value="Q4">Q4 (January, February, March)</option>
            </select>
            
            <div class="ml-4">
              <span id="selectedQuarterInfo" class="text-sm text-gray-600 hidden"></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- No Quarter Selected Message -->
    <div id="selectQuarterMessage" class="bg-blue-50 border border-blue-200 rounded-lg p-8 text-center mb-6">
      <i class="fas fa-hand-point-up text-4xl text-blue-500 mb-4"></i>
      <h3 class="text-lg font-semibold text-blue-800 mb-2">Please Select a Quarter</h3>
      <p class="text-blue-600">Choose a quarter from the dropdown above to edit achievements and remarks for all activities.</p>
    </div>

    <!-- Quarterly Edit Form -->
    <% if @user_details.any? %>
      <%= form_with url: update_quarterly_achievements_user_details_path, method: :patch, local: true, class: "quarterly-form hidden" do |form| %>
        <%= hidden_field_tag :selected_quarter, "", id: "selected_quarter_field" %>
        
        <!-- Quarter Header -->
        <div id="quarterHeader" class="bg-white border border-gray-200 rounded-xl shadow-lg mb-6 hidden">
          <div id="quarterHeaderContent" class="bg-gradient-to-r from-green-500 to-green-600 text-white px-6 py-4 rounded-t-xl">
            <h2 class="text-2xl font-bold flex items-center">
              <i class="fas fa-calendar-alt me-3"></i>
              <span id="quarterTitle"></span>
            </h2>
            <p class="text-green-100 mt-2">Edit achievements and remarks for all activities in this quarter</p>
          </div>
          <div class="p-4">
            <div id="monthHeaders" class="grid grid-cols-4 gap-4 text-center">
              <div class="font-semibold text-gray-600">Activity Details</div>
              <div id="month1Header" class="bg-blue-100 text-blue-800 py-2 rounded font-semibold"></div>
              <div id="month2Header" class="bg-green-100 text-green-800 py-2 rounded font-semibold"></div>
              <div id="month3Header" class="bg-orange-100 text-orange-800 py-2 rounded font-semibold"></div>
            </div>
          </div>
        </div>

        <!-- Activities List -->
        <div id="activitiesList">
          <% @user_details.each_with_index do |detail, detail_index| %>
            <div class="activity-row bg-white border border-gray-200 rounded-xl shadow-lg mb-4" data-activity-id="<%= detail.id %>">
              <div class="grid grid-cols-4 gap-4 p-6">
                
                <!-- Activity Details Column -->
                <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
                  <div class="mb-2">
                    <h3 class="text-lg font-semibold text-gray-800"><%= detail.employee_detail&.employee_name || 'N/A' %></h3>
                    <p class="text-sm text-gray-600"><%= detail.department.department_type %></p>
                  </div>
                  <div class="mb-2">
                    <h4 class="text-md font-medium text-gray-800"><%= detail.activity.activity_name %></h4>
                    <p class="text-sm text-gray-600">Unit: <%= detail.activity.unit %></p>
                  </div>
                  <div class="mb-2">
                    <p class="text-sm text-gray-600">Theme: <%= detail.department.theme_name.presence || 'No Theme' %></p>
                  </div>
                  <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded-full text-xs font-semibold">
                    Activity #<%= detail_index + 1 %>
                  </span>
                </div>

                <% 
                  # Define all quarters and months - FIXED ORDER
                  all_quarters = {
                    'Q1' => ['april', 'may', 'june'],           # Q1: Apr-Jun
                    'Q2' => ['july', 'august', 'september'],     # Q2: Jul-Sep  
                    'Q3' => ['october', 'november', 'december'], # Q3: Oct-Dec
                    'Q4' => ['january', 'february', 'march']     # Q4: Jan-Mar
                  }
                  
                  # Get existing achievements for this detail
                  existing_achievements = detail.achievements.index_by(&:month)
                %>

                <% all_quarters.each do |quarter_name, months| %>
                  <% months.each_with_index do |month, month_index| %>
                    <% 
                      target_value = detail.send(month.to_sym)
                      existing_achievement = existing_achievements[month]
                      # FIXED: Handle both text and numeric achievement values
                      achievement_value = existing_achievement&.achievement || ""
                      employee_remarks = existing_achievement&.employee_remarks || ""
                    %>
                    
                    <!-- Month Column -->
                    <div class="month-column <%= quarter_name.downcase %> hidden bg-gray-50 p-4 rounded-lg border border-gray-200" 
                         data-quarter="<%= quarter_name %>" data-month="<%= month %>" data-month-index="<%= month_index %>">
                      
                      <!-- Target Display -->
                      <div class="mb-3">
                        <label class="block text-xs font-medium text-gray-600 mb-1">Target</label>
                        <div class="bg-blue-50 border border-blue-200 rounded px-2 py-1 text-blue-800 font-semibold text-sm text-center">
                          <%= target_value.presence || '0' %>
                        </div>
                      </div>

                      <!-- Achievement Input -->
                      <div class="mb-3">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Achievement</label>
                        <%= text_field_tag "achievements[#{detail.id}][#{month}][achievement]", 
                                           achievement_value,
                                           class: "achievement-input w-full border border-gray-300 rounded px-2 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
                                           placeholder: "Enter value",
                                           data: {
                                             target: target_value,
                                             detail_id: detail.id,
                                             month: month,
                                             quarter: quarter_name
                                           } %>
                      </div>

                      <!-- Employee Remarks -->
                      <div class="mb-3">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Remarks</label>
                        <%= text_area_tag "achievements[#{detail.id}][#{month}][employee_remarks]", 
                                         employee_remarks,
                                         class: "w-full border border-gray-300 rounded px-2 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
                                         rows: 2,
                                         placeholder: "Add remarks..." %>
                      </div>

                      <!-- Achievement Status -->
                      <div class="text-center">
                        <div class="progress-indicator">
                          <% if target_value.present? && achievement_value.present? && achievement_value != "" %>
                            <% 
                              # FIXED: Handle both numeric and text achievements
                              begin
                                numeric_target = target_value.to_f
                                numeric_achievement = achievement_value.to_f
                                if numeric_target > 0 && numeric_achievement > 0
                                  percentage = ((numeric_achievement / numeric_target) * 100).round(1)
                                else
                                  percentage = nil
                                end
                              rescue
                                percentage = nil
                              end
                            %>
                            <% if percentage %>
                              <span class="inline-block px-2 py-1 rounded text-xs font-semibold
                                <%= percentage >= 100 ? 'bg-green-100 text-green-800' :
                                    percentage >= 75 ? 'bg-blue-100 text-blue-800' :
                                    percentage >= 50 ? 'bg-yellow-100 text-yellow-800' :
                                    'bg-red-100 text-red-800' %>">
                                <%= percentage %>%
                              </span>
                            <% else %>
                              <span class="inline-block px-2 py-1 rounded text-xs font-semibold bg-blue-100 text-blue-800">
                                Set
                              </span>
                            <% end %>
                          <% else %>
                            <span class="inline-block px-2 py-1 rounded text-xs font-semibold bg-gray-100 text-gray-600">
                              Not Set
                            </span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                <% end %>

              </div>
            </div>
          <% end %>
        </div>

        <!-- Submit Section -->
        <div id="submitSection" class="bg-white border border-gray-200 rounded-xl shadow-lg p-6 hidden">
          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <%= submit_tag "Update All Achievements", 
                          class: "bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 text-white px-8 py-3 rounded-lg font-semibold transition-all duration-200 flex items-center transform hover:scale-105 shadow-lg",
                          id: "submitBtn" %>
            
            <%= link_to "Cancel", user_details_path, 
                        class: "bg-gradient-to-r from-gray-500 to-gray-600 hover:from-gray-600 hover:to-gray-700 text-white px-8 py-3 rounded-lg font-semibold transition-all duration-200 flex items-center" %>
          </div>
          
          <div class="text-center mt-4 text-sm text-gray-600">
            <i class="fas fa-info-circle me-1"></i>
            <span id="submitInfo">Fill achievements and remarks for the selected quarter</span>
          </div>
        </div>
      <% end %>

    <% else %>
      <!-- No Data State -->
      <div class="bg-white border border-gray-200 rounded-xl shadow-lg p-12 text-center">
        <i class="fas fa-inbox text-6xl text-gray-300 mb-4"></i>
        <h3 class="text-xl font-semibold text-gray-800 mb-2">No Activities Found</h3>
        <p class="text-gray-600 mb-6">There are no user details available for quarterly editing.</p>
        <%= link_to "Go to User Details", user_details_path, 
                    class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg transition-colors duration-200" %>
      </div>
    <% end %>
  </div>
</div>

<style>
  .month-column {
    transition: all 0.3s ease;
  }
  
  .month-column.hidden {
    display: none;
  }
  
  .activity-row:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  .achievement-input:focus {
    transform: scale(1.02);
    transition: transform 0.2s ease;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const quarterFilter = document.getElementById('quarterFilter');
    const selectQuarterMessage = document.getElementById('selectQuarterMessage');
    const quarterlyForm = document.querySelector('.quarterly-form');
    const quarterHeader = document.getElementById('quarterHeader');
    const submitSection = document.getElementById('submitSection');
    const selectedQuarterField = document.getElementById('selected_quarter_field');
    
    const quarterData = {
      'Q1': {
        title: 'Q1 Quarter (April - May - June)',
        months: ['April', 'May', 'June'],
        colors: ['blue', 'green', 'orange']
      },
      'Q2': {
        title: 'Q2 Quarter (July - August - September)',
        months: ['July', 'August', 'September'],
        colors: ['blue', 'green', 'orange']
      },
      'Q3': {
        title: 'Q3 Quarter (October - November - December)',
        months: ['October', 'November', 'December'],
        colors: ['blue', 'green', 'orange']
      },
      'Q4': {
        title: 'Q4 Quarter (January - February - March)',
        months: ['January', 'February', 'March'],
        colors: ['blue', 'green', 'orange']
      }
    };

    // Handle quarter filter change
    quarterFilter.addEventListener('change', function() {
      const selectedQuarter = this.value;
      
      if (selectedQuarter === '') {
        // Show select message, hide form
        selectQuarterMessage.classList.remove('hidden');
        quarterlyForm.classList.add('hidden');
        quarterHeader.classList.add('hidden');
        submitSection.classList.add('hidden');
        selectedQuarterField.value = '';
        return;
      }
      
      // Hide select message, show form
      selectQuarterMessage.classList.add('hidden');
      quarterlyForm.classList.remove('hidden');
      quarterHeader.classList.remove('hidden');
      submitSection.classList.remove('hidden');
      selectedQuarterField.value = selectedQuarter;
      
      // Update header
      const quarterInfo = quarterData[selectedQuarter];
      document.getElementById('quarterTitle').textContent = quarterInfo.title;
      document.getElementById('submitInfo').textContent = `Fill achievements and remarks for ${quarterInfo.title}`;
      
      // Update month headers
      document.getElementById('month1Header').textContent = quarterInfo.months[0];
      document.getElementById('month2Header').textContent = quarterInfo.months[1];
      document.getElementById('month3Header').textContent = quarterInfo.months[2];
      
      // Hide all month columns
      document.querySelectorAll('.month-column').forEach(col => {
        col.classList.add('hidden');
      });
      
      // Show only selected quarter columns
      document.querySelectorAll(`.month-column[data-quarter="${selectedQuarter}"]`).forEach(col => {
        col.classList.remove('hidden');
      });
      
      // Update submit button text
      document.getElementById('submitBtn').value = `Update ${quarterInfo.title} Achievements`;
    });

    // Auto-calculate percentages when achievement values change
    document.querySelectorAll('.achievement-input').forEach(input => {
      input.addEventListener('input', function() {
        const target = parseFloat(this.dataset.target) || 0;
        const achievement = parseFloat(this.value) || 0;
        const progressIndicator = this.closest('.month-column').querySelector('.progress-indicator span');
        
        if (target > 0 && achievement > 0) {
          const percentage = Math.round((achievement / target) * 100 * 10) / 10;
          let colorClass = 'bg-gray-100 text-gray-600';
          
          if (percentage >= 100) {
            colorClass = 'bg-green-100 text-green-800';
          } else if (percentage >= 75) {
            colorClass = 'bg-blue-100 text-blue-800';
          } else if (percentage >= 50) {
            colorClass = 'bg-yellow-100 text-yellow-800';
          } else if (percentage > 0) {
            colorClass = 'bg-red-100 text-red-800';
          }
          
          progressIndicator.className = `inline-block px-2 py-1 rounded text-xs font-semibold ${colorClass}`;
          progressIndicator.textContent = `${percentage}%`;
        } else if (this.value.trim() !== '') {
          // If there's a value but it's not numeric, show "Set"
          progressIndicator.className = 'inline-block px-2 py-1 rounded text-xs font-semibold bg-blue-100 text-blue-800';
          progressIndicator.textContent = 'Set';
        } else {
          progressIndicator.className = 'inline-block px-2 py-1 rounded text-xs font-semibold bg-gray-100 text-gray-600';
          progressIndicator.textContent = 'Not Set';
        }
      });
    });

    // Form validation
    document.querySelector('.quarterly-form')?.addEventListener('submit', function(e) {
      const selectedQuarter = quarterFilter.value;
      if (!selectedQuarter) {
        e.preventDefault();
        alert('Please select a quarter first.');
        return false;
      }
      
      const visibleInputs = document.querySelectorAll(`.month-column[data-quarter="${selectedQuarter}"]:not(.hidden) .achievement-input`);
      let hasAnyValue = false;
      
      visibleInputs.forEach(input => {
        if (input.value && input.value.trim() !== '') {
          hasAnyValue = true;
        }
      });
      
      if (!hasAnyValue) {
        e.preventDefault();
        alert(`Please enter at least one achievement value for ${quarterData[selectedQuarter].title}.`);
        return false;
      }
      
      return confirm(`Are you sure you want to update all achievements for ${quarterData[selectedQuarter].title}?`);
    });
  });
</script>