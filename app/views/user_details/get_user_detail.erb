<div class="main-content bg-gray-50 min-h-screen">
  <!-- Filter Section - Added without changing your existing code -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-lg mb-4">
    <div class="bg-blue-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
      <h2 class="text-2xl font-bold text-gray-800 flex items-center">
        <i class="fas fa-filter me-2 text-blue-600"></i>
        Filter Activities
      </h2>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Select Activity</label>
          <select id="activityFilter" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Activities</option>
          </select>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Select Month</label>
          <select id="monthFilter" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Months</option>
            <option value="april">April</option>
            <option value="may">May</option>
            <option value="june">June</option>
            <option value="july">July</option>
            <option value="august">August</option>
            <option value="september">September</option>
            <option value="october">October</option>
            <option value="november">November</option>
            <option value="december">December</option>
            <option value="january">January</option>
            <option value="february">February</option>
            <option value="march">March</option>
          </select>
        </div>
        
        <div class="flex gap-2">
          <button id="showSelected" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
            <i class="fas fa-eye me-1"></i> Show Selected
          </button>
          <button id="showAll" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors">
            <i class="fas fa-list me-1"></i> Show All
          </button>
        </div>
      </div>
    </div>
  </div>

  <% if @user_details.any? %>
    <!-- ======================== FORM TO SUBMIT ACHIEVEMENTS ======================== -->
    <%= form_with url: submit_achievements_user_details_path, method: :post, local: true do %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-lg mt-4">
        <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
          <h2 class="text-3xl font-bold text-gray-800 flex items-center">
            <i class="fas fa-users me-2 text-indigo-600"></i>
            Monthly Activity Target Submit 
          </h2>
        </div>

        <div class="p-6">
          <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200 shadow-sm">
            <table class="table table-hover w-full min-w-full" id="activityTable">
              <thead class="bg-gray-800">
                <tr>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Department</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Employee Name</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Activity</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Theme</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Unit</th>
                  <% ["April", "May", "June", "July", "August", "September", "October", "November", "December", "January", "February", "March"].each do |month| %>
                    <th colspan="3" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 month-header" data-month="<%= month.downcase %>"><%= month %></th>
                  <% end %>
                </tr>
                <tr class="bg-gray-700">
                  <% 12.times do %>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 month-subheader">Target</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 month-subheader">Achievement</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 month-subheader">Remarks</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @user_details.each_with_index do |detail, index| %>
                  <%
                    # Create target data for JavaScript filtering
                    months = [:april, :may, :june, :july, :august, :september, :october, :november, :december, :january, :february, :march]
                    target_data = {}
                    has_any_target = false
                    
                    months.each do |month|
                      target_value = detail.send(month)
                      # Consider a target valid if it's not nil, not empty, and not 0
                      is_valid_target = target_value.present? && target_value.to_s != '0'
                      target_data[month.to_s] = is_valid_target ? target_value.to_s : ''
                      has_any_target = true if is_valid_target
                    end
                  %>
                  
                  <tr class="<%= index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200 activity-row" 
                      data-activity="<%= detail.activity.activity_name %>" 
                      data-targets='<%= target_data.to_json.html_safe %>'
                      data-has-any-target="<%= has_any_target %>">
                    
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200"><%= detail.department.department_type %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200"><%= detail.employee_detail&.employee_name || 'N/A' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.activity_name %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.department.theme_name.presence || 'No Theme' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= detail.activity.unit %></td>

                    <% months.each do |month| %>
                      <% target_value = detail.send(month) %>
                      <% has_target = target_value.present? && target_value.to_s != '0' %>
                      
                      <td class="px-3 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50 month-cell" data-month="<%= month %>" data-has-target="<%= has_target %>">
                        <span class="<%= has_target ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= has_target ? target_value : '-' %>
                        </span>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 month-cell" data-month="<%= month %>" data-has-target="<%= has_target %>">
                        <input 
                          type="text" 
                          name="achievement[<%= detail.id %>][<%= month %>][achievement]" 
                          placeholder="Achievement" 
                          class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-sm"
                          <%= 'disabled' unless has_target %>
                        />
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 month-cell" data-month="<%= month %>" data-has-target="<%= has_target %>">
                        <textarea 
                          name="achievement[<%= detail.id %>][<%= month %>][employee_remarks]" 
                          placeholder="Remarks" 
                          rows="1"
                          class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none"
                          <%= 'disabled' unless has_target %>
                        ></textarea>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="mt-6 flex justify-center">
        <%= submit_tag "Submit Achievements", class: "inline-flex items-center px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-md transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
      </div>
    <% end %>
  <% else %>
    <div class="flex justify-center mt-10">
      <div class="w-full max-w-lg bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 border border-indigo-100 rounded-3xl shadow-xl p-10 text-center">

        <!-- Lottie Animation -->
        <div class="mb-6 flex justify-center">
          <lottie-player 
            src="https://assets9.lottiefiles.com/packages/lf20_t24tpvcu.json" 
            background="transparent"  
            speed="1"  
            style="width: 1000px !important;  height: 300px;"  
            loop  
            autoplay>
          </lottie-player>
        </div>

        <!-- Heading -->
        <h2 class="text-3xl font-extrabold text-gray-800 mb-3">
          No User Details Found
        </h2>

        <!-- Sub-text -->
        <p class="text-gray-600 text-base mb-6 leading-relaxed">
          It looks like there are no user details available to submit achievements.<br>
          Please check with your HOD or try again later.
        </p>
      </div>
    </div>

    <!-- Lottie Script -->
    <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
  <% end %>

<style>
  /* Hide rows that have no valid targets when filtering by month */
  .activity-row[data-filtered-hidden="true"] {
    display: none !important;
  }
  
  /* Hide month columns when month filter is active */
  .month-header[data-month-hidden="true"],
  .month-subheader[data-month-hidden="true"] {
    display: none !important;
  }
  
  .month-cell[data-month-hidden="true"] {
    display: none !important;
  }
  
  /* Hide rows that have no valid targets at all */
  .activity-row[data-has-any-target="false"] {
    display: none !important;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const activityFilter = document.getElementById('activityFilter');
    const monthFilter = document.getElementById('monthFilter');
    const showSelectedBtn = document.getElementById('showSelected');
    const showAllBtn = document.getElementById('showAll');
    const activityRows = document.querySelectorAll('.activity-row');
    const monthHeaders = document.querySelectorAll('.month-header');
    const monthSubheaders = document.querySelectorAll('.month-subheader');
    const monthCells = document.querySelectorAll('.month-cell');

    // Populate activity filter dropdown
    function populateActivityFilter() {
        const activities = new Set();
        activityRows.forEach(row => {
            const activity = row.dataset.activity;
            if (activity && row.dataset.hasAnyTarget === 'true') {
                activities.add(activity);
            }
        });

        // Clear existing options except "All Activities"
        activityFilter.innerHTML = '<option value="">All Activities</option>';
        
        // Add unique activities
        Array.from(activities).sort().forEach(activity => {
            const option = document.createElement('option');
            option.value = activity;
            option.textContent = activity;
            activityFilter.appendChild(option);
        });
    }

    // Filter functions
    function filterByActivity(selectedActivity) {
        activityRows.forEach(row => {
            if (!selectedActivity || row.dataset.activity === selectedActivity) {
                row.removeAttribute('data-activity-hidden');
            } else {
                row.setAttribute('data-activity-hidden', 'true');
            }
        });
    }

    function filterByMonth(selectedMonth) {
        const months = ['april', 'may', 'june', 'july', 'august', 'september', 'october', 'november', 'december', 'january', 'february', 'march'];
        
        if (!selectedMonth) {
            // Show all months
            monthHeaders.forEach(header => header.removeAttribute('data-month-hidden'));
            monthSubheaders.forEach(subheader => subheader.removeAttribute('data-month-hidden'));
            monthCells.forEach(cell => cell.removeAttribute('data-month-hidden'));
            
            // Show all rows that have any valid target
            activityRows.forEach(row => {
                row.removeAttribute('data-filtered-hidden');
            });
        } else {
            // Hide all months except selected
            months.forEach(month => {
                const shouldHide = month !== selectedMonth;
                
                monthHeaders.forEach(header => {
                    if (header.dataset.month === month) {
                        if (shouldHide) {
                            header.setAttribute('data-month-hidden', 'true');
                        } else {
                            header.removeAttribute('data-month-hidden');
                        }
                    }
                });
                
                monthSubheaders.forEach(subheader => {
                    if (subheader.dataset && subheader.dataset.month === month) {
                        if (shouldHide) {
                            subheader.setAttribute('data-month-hidden', 'true');
                        } else {
                            subheader.removeAttribute('data-month-hidden');
                        }
                    }
                });
                
                monthCells.forEach(cell => {
                    if (cell.dataset.month === month) {
                        if (shouldHide) {
                            cell.setAttribute('data-month-hidden', 'true');
                        } else {
                            cell.removeAttribute('data-month-hidden');
                        }
                    }
                });
            });

            // Filter rows based on selected month target
            activityRows.forEach(row => {
                try {
                    const targets = JSON.parse(row.dataset.targets || '{}');
                    const hasTargetForMonth = targets[selectedMonth] && targets[selectedMonth] !== '' && targets[selectedMonth] !== '0';
                    
                    if (hasTargetForMonth) {
                        row.removeAttribute('data-filtered-hidden');
                    } else {
                        row.setAttribute('data-filtered-hidden', 'true');
                    }
                } catch (e) {
                    console.error('Error parsing targets:', e);
                    row.setAttribute('data-filtered-hidden', 'true');
                }
            });
        }
    }

    function applyFilters() {
        const selectedActivity = activityFilter.value;
        const selectedMonth = monthFilter.value;

        // Reset all filters first
        activityRows.forEach(row => {
            row.removeAttribute('data-activity-hidden');
            row.removeAttribute('data-filtered-hidden');
        });

        monthHeaders.forEach(header => header.removeAttribute('data-month-hidden'));
        monthSubheaders.forEach(subheader => subheader.removeAttribute('data-month-hidden'));
        monthCells.forEach(cell => cell.removeAttribute('data-month-hidden'));

        // Apply filters
        filterByActivity(selectedActivity);
        filterByMonth(selectedMonth);

        // Update visibility
        updateRowVisibility();
    }

    function updateRowVisibility() {
        activityRows.forEach(row => {
            const isActivityHidden = row.hasAttribute('data-activity-hidden');
            const isFilteredHidden = row.hasAttribute('data-filtered-hidden');
            const hasAnyTarget = row.dataset.hasAnyTarget === 'true';

            if (!hasAnyTarget || isActivityHidden || isFilteredHidden) {
                row.style.display = 'none';
            } else {
                row.style.display = '';
            }
        });
    }

    function showAll() {
        activityFilter.value = '';
        monthFilter.value = '';
        applyFilters();
    }

    // Event listeners
    showSelectedBtn.addEventListener('click', applyFilters);
    showAllBtn.addEventListener('click', showAll);
    
    activityFilter.addEventListener('change', applyFilters);
    monthFilter.addEventListener('change', applyFilters);

    // Initialize
    populateActivityFilter();
    
    // Initially hide rows with no targets
    updateRowVisibility();
});
</script>

  <!-- ======================== READ-ONLY VIEW WITH ACTIVITY-WISE STATUS ======================== -->
<% if @user_details.any? && @user_details.any? { |detail| detail.achievements.any?(&:achievement?) } %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-lg mt-8">
      <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
        <h2 class="text-4xl font-bold text-gray-800 flex items-center">
          <i class="fas fa-check-circle me-3 text-green-600 text-2xl"></i>
          Submitted Achievements
        </h2>
      </div>

      <div class="p-6">
        <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200 shadow-sm">
          <table class="table table-hover w-full min-w-full">
            <thead class="bg-gray-800">
              <tr>
                <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Department</th>
                <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Employee Name</th>
                <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Activity</th>
                <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Theme</th>
                <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Unit</th>
                <th rowspan="2" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Status</th>
                <% ["April", "May", "June", "July", "August", "September", "October", "November", "December", "January", "February", "March"].each do |month| %>
                  <th colspan="4" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 submitted-month-header" data-month="<%= month.downcase %>"><%= month %></th>
                <% end %>
              </tr>
              <tr class="bg-gray-700">
                <% 12.times do %>
                  <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 submitted-month-subheader">Target</th>
                  <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 submitted-month-subheader">Achievement</th>
                  <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 submitted-month-subheader">Remarks</th>
                  <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 submitted-month-subheader">Details</th>
                <% end %>   
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @user_details.each_with_index do |detail, index| %>
                <% existing_achievements = detail.achievements.index_by(&:month) %>
                <% if existing_achievements.values.any? { |a| a.achievement.present? } %>
                  <%
                    # Calculate status for this specific activity - FIXED LOGIC
                    activity_statuses = []
                    detail.achievements.each do |ach|
                      activity_statuses << (ach.status || "pending") if ach.achievement.present?
                    end
                    
                    # Determine activity status priority
                    activity_status = "pending"
                    if activity_statuses.include?("l2_approved")
                      activity_status = "l2_approved"
                    elsif activity_statuses.include?("l1_approved")
                      activity_status = "l1_approved"
                    elsif activity_statuses.include?("l2_returned")
                      activity_status = "l2_returned"
                    elsif activity_statuses.include?("l1_returned")
                      activity_status = "l1_returned"
                    elsif activity_statuses.include?("submitted")
                      activity_status = "submitted"
                    else
                      activity_status = "pending"
                    end
                    
                    status_config = case activity_status
                    when "pending"
                      { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
                    when "l1_approved"
                      { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved", icon: "fas fa-check-circle" }
                    when "l1_returned"
                      { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
                    when "l2_approved"
                      { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved", icon: "fas fa-check-double" }
                    when "l2_returned"
                      { color: "bg-orange-100 text-orange-800 border-orange-300", text: "L2 Returned", icon: "fas fa-exclamation-triangle" }
                    when "submitted"
                      { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
                    else
                      { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status", icon: "fas fa-question-circle" }
                    end
                  %>
                  
                  <tr class="<%= index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200 submitted-activity-row" data-activity="<%= detail.activity.activity_name %>" 
                      data-detail-id="<%= detail.id %>"
                      <% detail.achievements.each do |ach| %>
                        data-<%= ach.month %>-status="<%= ach.status || 'no_data' %>"
                      <% end %>
                      >
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200"><%= detail.department.department_type %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200"><%= detail.employee_detail&.employee_name || 'N/A' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.activity_name %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.department.theme_name.presence || 'No Theme' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= detail.activity.unit %></td>
                    
                    <!-- Activity-wise Status Column -->
                    <td class="px-3 py-3 text-center border-r border-gray-200 status-column">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border <%= status_config[:color] %>">
                        <i class="<%= status_config[:icon] %> mr-1 text-xs"></i>
                        <%= status_config[:text] %>
                      </span>
                    </td>

                    <% [:april, :may, :june, :july, :august, :september, :october, :november, :december, :january, :february, :march].each do |month| %>
                      <% target_value = detail.send(month) %>
                      <% achievement_record = existing_achievements[month.to_s] %>
                      <% achievement = achievement_record&.achievement %>
                      <% remarks = achievement_record&.employee_remarks %>
                      
                      <td class="px-3 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50 submitted-month-cell" data-month="<%= month %>">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 submitted-month-cell" data-month="<%= month %>">
                        <span class="<%= achievement.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 submitted-month-cell" data-month="<%= month %>">
                        <div class="text-center">
                          <span class="<%= remarks.presence ? 'text-blue-700 font-medium bg-blue-50 px-2 py-1 rounded text-xs inline-block mb-1' : 'text-gray-400' %>">
                            <%= remarks.presence || '-' %>
                          </span>
                        </div>
                      </td>
                      
                      <!-- New Details Column with Eye Icon -->
                      <td class="px-3 py-3 text-center border-r border-gray-200 submitted-month-cell" data-month="<%= month %>">
                        <% if achievement_record && (achievement_record.achievement_remark&.l1_remarks.present? || achievement_record.achievement_remark&.l2_remarks.present? || target_value.present? || achievement.present?) %>
                          <button
                            type="button"
                            class="inline-flex items-center justify-center w-8 h-8 bg-blue-100 hover:bg-blue-200 text-blue-600 rounded-full transition-all duration-200 hover:scale-105 details-btn"
                            title="View Details"
                            aria-label="View details"
                            data-detail-id="<%= detail.id %>"
                            data-month="<%= month %>"
                            data-target="<%= target_value %>"
                            data-achievement="<%= achievement %>"
                            data-l1-remarks="<%= achievement_record&.achievement_remark&.l1_remarks %>"
                            data-l2-remarks="<%= achievement_record&.achievement_remark&.l2_remarks %>"
                            data-l1-percentage="<%= achievement_record&.achievement_remark&.l1_percentage %>"
                            data-l2-percentage="<%= achievement_record&.achievement_remark&.l2_percentage %>"
                            data-employee-remarks="<%= remarks %>"
                            data-activity-name="<%= detail.activity.activity_name %>"
                            data-employee-name="<%= detail.employee_detail&.employee_name || 'N/A' %>"
                            data-department="<%= detail.department.department_type %>"
                            data-status="<%= achievement_record&.status %>">
                            <!-- Eye icon (Heroicons outline style) -->
                            <svg xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="w-4 h-4 pointer-events-none">
                              <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                              <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                          </button>
                        <% else %>
                          <span class="text-gray-400 inline-flex items-center justify-center w-8 h-8">
                            <!-- Minus icon -->
                            <svg xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                class="w-4 h-4">
                              <path fill-rule="evenodd" d="M5.25 12a.75.75 0 01.75-.75h12a.75.75 0 010 1.5h-12a.75.75 0 01-.75-.75z" clip-rule="evenodd"/>
                            </svg>
                          </span>
                        <% end %>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Enhanced Details Modal -->
    <div id="detailsModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center">
      <div class="bg-white rounded-lg shadow-xl max-w-4xl w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-6 py-4 rounded-t-lg">
          <div class="flex justify-between items-center">
            <h3 class="text-xl font-semibold flex items-center">
              <i class="fas fa-info-circle mr-3"></i>
              Achievement Details
            </h3>
            <button id="closeModal" class="text-white hover:text-gray-200 transition-colors">
              <i class="fas fa-times text-xl"></i>
            </button>
          </div>
        </div>
        
        <div class="p-6">
          <!-- Employee & Activity Information -->
          <div class="bg-gray-50 p-4 rounded-lg mb-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="text-sm font-medium text-gray-600">Employee Name</label>
                <div id="modalEmployeeName" class="text-gray-800 font-semibold"></div>
              </div>
              <div>
                <label class="text-sm font-medium text-gray-600">Department</label>
                <div id="modalDepartment" class="text-gray-800 font-semibold"></div>
              </div>
              <div>
                <label class="text-sm font-medium text-gray-600">Activity</label>
                <div id="modalActivityName" class="text-gray-800 font-semibold"></div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Performance Summary -->
            <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-5 rounded-lg border border-blue-200">
              <h4 class="font-semibold text-blue-800 mb-4 flex items-center">
                <i class="fas fa-chart-bar mr-2 text-blue-600"></i>
                Performance Summary
              </h4>
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <span class="text-gray-700 font-medium">Month:</span>
                  <span id="modalMonth" class="bg-blue-100 px-3 py-1 rounded-full text-blue-800 font-semibold capitalize"></span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-700 font-medium">Target:</span>
                  <span id="modalTarget" class="bg-yellow-100 px-3 py-1 rounded-full text-yellow-800 font-semibold"></span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-700 font-medium">Achievement:</span>
                  <span id="modalAchievement" class="bg-green-100 px-3 py-1 rounded-full text-green-800 font-semibold"></span>
                </div>
                <div class="flex justify-between items-center border-t pt-3">
                  <span class="text-gray-700 font-medium">Achievement %:</span>
                  <span id="modalPercentage" class="text-xl font-bold"></span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-700 font-medium">Status:</span>
                  <span id="modalStatus" class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold"></span>
                </div>
              </div>
            </div>

            <!-- Quick Stats Card -->
            <div class="bg-gradient-to-br from-purple-50 to-pink-50 p-5 rounded-lg border border-purple-200">
              <h4 class="font-semibold text-purple-800 mb-4 flex items-center">
                <i class="fas fa-trophy mr-2 text-purple-600"></i>
                Performance Metrics
              </h4>
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <span class="text-gray-700">L1 Rating:</span>
                  <span id="modalL1PercentageDisplay" class="bg-green-100 px-3 py-1 rounded-full text-green-800 font-semibold"></span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-700">L2 Rating:</span>
                  <span id="modalL2PercentageDisplay" class="bg-purple-100 px-3 py-1 rounded-full text-purple-800 font-semibold"></span>
                </div>
              </div>
            </div>
          </div>

          <!-- Remarks Section -->
          <div class="mt-6 space-y-4">
            <!-- Employee Remarks -->
            <div class="bg-gradient-to-r from-blue-50 to-blue-100 p-5 rounded-lg border border-blue-200">
              <h4 class="font-semibold text-blue-800 mb-3 flex items-center">
                <i class="fas fa-user mr-2"></i>
                Employee Remarks
              </h4>
              <div id="modalEmployeeRemarks" class="text-blue-700 bg-white p-4 rounded-lg border border-blue-300 min-h-[70px] shadow-sm"></div>
            </div>

            <!-- L1 & L2 Remarks in a Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
              <!-- L1 Remarks -->
              <div class="bg-gradient-to-r from-green-50 to-emerald-50 p-5 rounded-lg border border-green-200">
                <h4 class="font-semibold text-green-800 mb-3 flex items-center">
                  <i class="fas fa-user-check mr-2"></i>
                  L1 Authority Feedback
                </h4>
                <div id="modalL1Remarks" class="text-green-700 bg-white p-4 rounded-lg border border-green-300 min-h-[70px] shadow-sm mb-3"></div>
                <div class="flex justify-between items-center">
                  <span class="text-green-600 text-sm font-medium">L1 Percentage:</span>
                  <span id="modalL1Percentage" class="bg-green-200 px-3 py-1 rounded-full text-green-800 font-bold"></span>
                </div>
              </div>

              <!-- L2 Remarks -->
              <div class="bg-gradient-to-r from-purple-50 to-indigo-50 p-5 rounded-lg border border-purple-200">
                <h4 class="font-semibold text-purple-800 mb-3 flex items-center">
                  <i class="fas fa-user-tie mr-2"></i>
                  L2 Authority Feedback
                </h4>
                <div id="modalL2Remarks" class="text-purple-700 bg-white p-4 rounded-lg border border-purple-300 min-h-[70px] shadow-sm mb-3"></div>
                <div class="flex justify-between items-center">
                  <span class="text-purple-600 text-sm font-medium">L2 Percentage:</span>
                  <span id="modalL2Percentage" class="bg-purple-200 px-3 py-1 rounded-full text-purple-800 font-bold"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="bg-gray-50 px-6 py-4 rounded-b-lg">
          <button id="closeModalBtn" class="w-full bg-gradient-to-r from-gray-600 to-gray-700 hover:from-gray-700 hover:to-gray-800 text-white px-6 py-3 rounded-lg transition-all duration-200 flex items-center justify-center">
            <i class="fas fa-times mr-2"></i>Close Details
          </button>
        </div>
      </div>
    </div>

    <!-- JavaScript for Modal Functionality -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const modal = document.getElementById('detailsModal');
        const closeModal = document.getElementById('closeModal');
        const closeModalBtn = document.getElementById('closeModalBtn');
        const detailButtons = document.querySelectorAll('.details-btn');

        // Open modal function
        function openModal(button) {
          const data = button.dataset;
          
          // Calculate percentage
          const target = parseFloat(data.target) || 0;
          const achievement = parseFloat(data.achievement) || 0;
          const percentage = target > 0 ? ((achievement / target) * 100).toFixed(1) : '0';
          
          // Populate modal fields
          document.getElementById('modalEmployeeName').textContent = data.employeeName || 'N/A';
          document.getElementById('modalDepartment').textContent = data.department || 'N/A';
          document.getElementById('modalActivityName').textContent = data.activityName || 'N/A';
          document.getElementById('modalMonth').textContent = data.month || 'N/A';
          document.getElementById('modalTarget').textContent = data.target || 'N/A';
          document.getElementById('modalAchievement').textContent = data.achievement || 'N/A';
          document.getElementById('modalPercentage').textContent = percentage + '%';
          
          // Set percentage color
          const percentageElement = document.getElementById('modalPercentage');
          if (percentage >= 100) {
            percentageElement.className = 'text-xl font-bold text-green-600';
          } else if (percentage >= 75) {
            percentageElement.className = 'text-xl font-bold text-blue-600';
          } else if (percentage >= 50) {
            percentageElement.className = 'text-xl font-bold text-yellow-600';
          } else {
            percentageElement.className = 'text-xl font-bold text-red-600';
          }

          // Status
          const statusElement = document.getElementById('modalStatus');
          const status = data.status || 'pending';
          let statusConfig;
          
          switch(status) {
            case 'l2_approved':
              statusConfig = { color: 'bg-emerald-100 text-emerald-800 border-emerald-300', text: 'L2 Approved', icon: 'fas fa-check-double' };
              break;
            case 'l1_approved':
              statusConfig = { color: 'bg-green-100 text-green-800 border-green-300', text: 'L1 Approved', icon: 'fas fa-check-circle' };
              break;
            case 'l2_returned':
              statusConfig = { color: 'bg-orange-100 text-orange-800 border-orange-300', text: 'L2 Returned', icon: 'fas fa-exclamation-triangle' };
              break;
            case 'l1_returned':
              statusConfig = { color: 'bg-red-100 text-red-800 border-red-300', text: 'L1 Returned', icon: 'fas fa-exclamation-triangle' };
              break;
            case 'submitted':
              statusConfig = { color: 'bg-blue-100 text-blue-800 border-blue-300', text: 'Submitted', icon: 'fas fa-paper-plane' };
              break;
            default:
              statusConfig = { color: 'bg-yellow-100 text-yellow-800 border-yellow-300', text: 'Pending', icon: 'fas fa-clock' };
          }
          
          statusElement.className = `inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border ${statusConfig.color}`;
          statusElement.innerHTML = `<i class="${statusConfig.icon} mr-1 text-xs"></i>${statusConfig.text}`;

          // Remarks
          document.getElementById('modalEmployeeRemarks').textContent = data.employeeRemarks || 'No remarks provided';
          document.getElementById('modalL1Remarks').textContent = data.l1Remarks || 'No L1 remarks provided';
          document.getElementById('modalL2Remarks').textContent = data.l2Remarks || 'No L2 remarks provided';
          
          // Percentages
          document.getElementById('modalL1Percentage').textContent = (data.l1Percentage || 'N/A') + (data.l1Percentage ? '%' : '');
          document.getElementById('modalL2Percentage').textContent = (data.l2Percentage || 'N/A') + (data.l2Percentage ? '%' : '');
          document.getElementById('modalL1PercentageDisplay').textContent = (data.l1Percentage || 'N/A') + (data.l1Percentage ? '%' : '');
          document.getElementById('modalL2PercentageDisplay').textContent = (data.l2Percentage || 'N/A') + (data.l2Percentage ? '%' : '');
          
          // Show modal
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }

        // Close modal function
        function closeModalFunction() {
          modal.classList.add('hidden');
          document.body.style.overflow = 'auto';
        }

        // Event listeners
        detailButtons.forEach(button => {
          button.addEventListener('click', function() {
            openModal(this);
          });
        });

        closeModal.addEventListener('click', closeModalFunction);
        closeModalBtn.addEventListener('click', closeModalFunction);

        // Close modal when clicking outside
        modal.addEventListener('click', function(e) {
          if (e.target === modal) {
            closeModalFunction();
          }
        });

        // Close modal with Escape key
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
            closeModalFunction();
          }
        });
      });
    </script>

<% end %>
</div>

