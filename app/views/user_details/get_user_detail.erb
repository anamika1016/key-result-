<%
  month_options = @month_options.presence || [
    [ "APR", "april" ], [ "MAY", "may" ], [ "JUN", "june" ],
    [ "JUL", "july" ], [ "AUG", "august" ], [ "SEPT", "september" ],
    [ "OCT", "october" ], [ "NOV", "november" ], [ "DEC", "december" ],
    [ "JAN", "january" ], [ "FEB", "february" ], [ "MAR", "march" ]
  ]
  selected_month = (@selected_month.presence || params[:month].presence || "april").to_s
  selected_month_label = month_options.find { |(_, value)| value == selected_month }&.first || selected_month.titleize

  selected_month_details = @user_details.select do |detail|
    detail.public_send(selected_month).present?
  end

  target_total = selected_month_details.sum { |detail| detail.public_send(selected_month).to_f }
  achievement_total = selected_month_details.sum do |detail|
    achievement = detail.achievements.find { |item| item.month.to_s.downcase == selected_month }
    achievement&.achievement.to_f
  end
  progress_total = target_total.positive? ? ((achievement_total / target_total) * 100).round : 0
%>

<div class="main-content monthly-kra-page">
  <section class="monthly-toolbar">
    <%= form_with url: get_user_detail_user_details_path, method: :get, local: true, class: "monthly-filter-form" do %>
      <div class="monthly-filter">
        <label for="year">Financial year</label>
        <%= select_tag :year,
            options_for_select(@available_years.map { |year| [display_financial_year(year), year] }, @selected_year),
            class: "monthly-select" %>
      </div>

      <div class="monthly-filter">
        <label for="month">Select month</label>
        <%= select_tag :month,
            options_for_select(month_options, selected_month),
            class: "monthly-select" %>
      </div>

      <button type="submit" class="monthly-btn monthly-btn-primary">Show Month</button>
    <% end %>
  </section>

  <section class="monthly-heading">
    <div>
      <h1>Monthly key result areas submit</h1>
      <p>Clean month-wise entry sheet with saved achievements visible and ready for update.</p>
    </div>
    <%= link_to submitted_view_data_path(year: @selected_year), class: "monthly-btn monthly-btn-dark" do %>
      Submitted view
    <% end %>
  </section>

  <% if @user_details.any? %>
    <% if selected_month_details.any? %>
      <%= form_with url: submit_achievements_user_details_path, method: :post, local: true, id: "monthly-achievement-form", class: "monthly-form" do %>
        <%= hidden_field_tag :year, @selected_year %>
        <%= hidden_field_tag :month, selected_month %>

        <div id="monthly-flash" class="monthly-flash" hidden></div>

        <div class="monthly-table-wrap">
          <table class="monthly-table">
            <thead>
              <tr>
                <th rowspan="2">S.No</th>
                <th rowspan="2">Key result areas</th>
                <th rowspan="2">Unit of measurement</th>
                <th rowspan="2">Annual target FY <%= display_financial_year_short(@selected_year) %></th>
                <th colspan="4"><%= selected_month_label %></th>
              </tr>
              <tr>
                <th>Target</th>
                <th>Achievement</th>
                <th>% Progress</th>
                <th>Employee remarks</th>
              </tr>
            </thead>
            <tbody>
              <% selected_month_details.each_with_index do |detail, index| %>
                <%
                  achievement = detail.achievements.find { |item| item.month.to_s.downcase == selected_month }
                  target_value = detail.public_send(selected_month)
                  achievement_value = achievement&.achievement
                  progress = target_value.to_f.positive? && achievement_value.present? ? ((achievement_value.to_f / target_value.to_f) * 100).round : nil
                %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td class="monthly-table-text"><%= detail.activity&.activity_name || detail.activity&.theme_name || "-" %></td>
                  <td><%= detail.activity&.unit.presence || "-" %></td>
                  <td><%= detail.annual_target.presence || "-" %></td>
                  <td><%= target_value %></td>
                  <td>
                    <input
                      type="text"
                      name="achievement[<%= detail.id %>][<%= selected_month %>][achievement]"
                      value="<%= achievement_value %>"
                      class="monthly-input monthly-achievement-input"
                      data-target="<%= target_value.to_f %>"
                    />
                  </td>
                  <td>
                    <% if progress.present? %>
                      <span class="monthly-progress monthly-row-progress"><%= progress %>%</span>
                    <% else %>
                      <span class="monthly-muted monthly-row-progress">-</span>
                    <% end %>
                  </td>
                  <td>
                    <input
                      type="text"
                      name="achievement[<%= detail.id %>][<%= selected_month %>][employee_remarks]"
                      value="<%= achievement&.employee_remarks %>"
                      class="monthly-input monthly-remarks"
                    />
                  </td>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="4">Total</td>
                <td id="monthly-total-target"><%= target_total.to_i == target_total ? target_total.to_i : target_total.round(2) %></td>
                <td id="monthly-total-achievement"><%= achievement_total.to_i == achievement_total ? achievement_total.to_i : achievement_total.round(2) %></td>
                <td><span class="monthly-progress" id="monthly-total-progress"><%= progress_total %>%</span></td>
                <td>-</td>
              </tr>
            </tfoot>
          </table>
        </div>

        <div class="monthly-actions">
          <%= submit_tag "Submit #{selected_month_label}", class: "monthly-btn monthly-btn-primary", id: "monthly-submit-btn" %>
        </div>
      <% end %>
    <% else %>
      <div class="monthly-empty">
        <h2>No target found for <%= selected_month_label %></h2>
        <p>Please choose another month or ask Super Admin to upload target data for this month.</p>
      </div>
    <% end %>
  <% else %>
    <div class="monthly-empty">
      <h2>No user details found</h2>
      <p>Please check with your Super Admin or try again later.</p>
    </div>
  <% end %>
</div>

<style>
  .monthly-kra-page {
    margin-left: 240px;
    min-height: 100vh;
    background: #f4f7fb;
    color: #172033;
  }

  .monthly-toolbar {
    background: #e5f4ff;
    border-bottom: 1px solid #d7e4f0;
    padding: 28px 32px;
  }

  .monthly-filter-form {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(220px, 1fr) auto;
    gap: 18px;
    align-items: end;
    max-width: 980px;
  }

  .monthly-filter label {
    display: block;
    margin-bottom: 8px;
    font-size: 12px;
    font-weight: 700;
    color: #40516a;
  }

  .monthly-select,
  .monthly-input {
    width: 100%;
    border: 1px solid #c8d4e3;
    border-radius: 10px;
    background: #f8fbff;
    color: #172033;
    padding: 12px 14px;
    font-size: 14px;
  }

  .monthly-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 28px 32px 18px;
  }

  .monthly-heading h1 {
    margin: 0;
    font-size: 28px;
    font-weight: 800;
  }

  .monthly-heading p {
    margin: 8px 0 0;
    color: #40516a;
  }

  .monthly-btn {
    border: 0;
    border-radius: 10px;
    padding: 12px 22px;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
  }

  .monthly-btn-primary {
    background: #0f777d;
    color: #fff;
  }

  .monthly-btn-dark {
    background: #263247;
    color: #fff;
  }

  .monthly-form {
    padding: 4px 32px 32px;
  }

  .monthly-table-wrap {
    overflow: auto;
    border-radius: 16px;
    border: 1px solid #dbe3ee;
    background: #fff;
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
  }

  .monthly-table {
    width: 100%;
    min-width: 1120px;
    border-collapse: separate;
    border-spacing: 0;
  }

  .monthly-table th {
    background: #263247;
    color: #fff;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-align: center;
    padding: 14px 10px;
    border-right: 1px solid #d7e1ec;
  }

  .monthly-table td {
    padding: 12px 10px;
    border-right: 1px solid #d7e1ec;
    text-align: center;
    vertical-align: middle;
  }

  .monthly-table tbody tr:nth-child(even) {
    background: #f7f9fc;
  }

  .monthly-table-text {
    text-align: left !important;
    min-width: 320px;
  }

  .monthly-remarks {
    min-width: 240px;
  }

  .monthly-progress {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 58px;
    border-radius: 6px;
    background: #dff8ea;
    color: #007a42;
    padding: 6px 10px;
    font-weight: 800;
  }

  .monthly-muted {
    color: #94a3b8;
  }

  .monthly-table tfoot td {
    background: #172033;
    color: #fff;
    font-weight: 800;
  }

  .monthly-actions {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  .monthly-flash {
    margin-bottom: 16px;
    border-radius: 10px;
    padding: 14px 16px;
    font-weight: 700;
  }

  .monthly-flash.success {
    border: 1px solid #86efac;
    background: #dcfce7;
    color: #166534;
  }

  .monthly-flash.error {
    border: 1px solid #fecaca;
    background: #fee2e2;
    color: #991b1b;
  }

  .monthly-empty {
    margin: 32px;
    border: 1px solid #dbe3ee;
    border-radius: 14px;
    background: #fff;
    padding: 40px;
    text-align: center;
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
  }

  @media (max-width: 900px) {
    .monthly-kra-page {
      margin-left: 0;
    }

    .monthly-filter-form,
    .monthly-heading {
      grid-template-columns: 1fr;
      display: grid;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const form = document.getElementById("monthly-achievement-form");
    if (!form) return;

    const submitBtn = document.getElementById("monthly-submit-btn");
    const flash = document.getElementById("monthly-flash");
    const achievementInputs = Array.from(document.querySelectorAll(".monthly-achievement-input"));
    const totalTargetCell = document.getElementById("monthly-total-target");
    const totalAchievementCell = document.getElementById("monthly-total-achievement");
    const totalProgressCell = document.getElementById("monthly-total-progress");

    function parseNumber(value) {
      const number = parseFloat(String(value || "").replace(/,/g, ""));
      return Number.isFinite(number) ? number : 0;
    }

    function formatNumber(value) {
      return Number.isInteger(value) ? String(value) : value.toFixed(2).replace(/\.?0+$/, "");
    }

    function updateMonthlyProgress() {
      let totalTarget = 0;
      let totalAchievement = 0;

      achievementInputs.forEach(function(input) {
        const target = parseNumber(input.dataset.target);
        const achievement = parseNumber(input.value);
        const row = input.closest("tr");
        const progressElement = row ? row.querySelector(".monthly-row-progress") : null;
        const progress = target > 0 ? Math.round((achievement / target) * 100) : 0;

        totalTarget += target;
        totalAchievement += achievement;

        if (progressElement) {
          progressElement.textContent = achievement > 0 && target > 0 ? progress + "%" : "-";
          progressElement.classList.toggle("monthly-progress", achievement > 0 && target > 0);
          progressElement.classList.toggle("monthly-muted", !(achievement > 0 && target > 0));
        }
      });

      const totalProgress = totalTarget > 0 ? Math.round((totalAchievement / totalTarget) * 100) : 0;
      if (totalTargetCell) totalTargetCell.textContent = formatNumber(totalTarget);
      if (totalAchievementCell) totalAchievementCell.textContent = formatNumber(totalAchievement);
      if (totalProgressCell) totalProgressCell.textContent = totalProgress + "%";
    }

    achievementInputs.forEach(function(input) {
      input.addEventListener("input", updateMonthlyProgress);
    });
    updateMonthlyProgress();

    form.addEventListener("submit", function(event) {
      event.preventDefault();
      const originalText = submitBtn.value;
      submitBtn.disabled = true;
      submitBtn.value = "Submitting...";

      fetch(form.action, {
        method: "POST",
        headers: {
          "X-CSRF-Token": document.querySelector("meta[name='csrf-token']").content,
          "Accept": "application/json"
        },
        body: new FormData(form)
      })
        .then(response => response.json().then(data => ({ ok: response.ok, data: data })))
        .then(({ ok, data }) => {
          flash.hidden = false;
          flash.className = "monthly-flash " + (ok && data.success ? "success" : "error");
          flash.textContent = data.message || data.error || (ok ? "Saved successfully." : "Unable to submit achievements.");

          if (ok && data.success) {
            window.setTimeout(function() {
              window.location.href = "<%= get_user_detail_user_details_path(year: @selected_year, month: selected_month) %>";
            }, 700);
          }
        })
        .catch(() => {
          flash.hidden = false;
          flash.className = "monthly-flash error";
          flash.textContent = "Network error while submitting achievements.";
        })
        .finally(() => {
          submitBtn.disabled = false;
          submitBtn.value = originalText;
        });
    });
  });
</script>
