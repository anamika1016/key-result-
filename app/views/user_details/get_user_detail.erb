      <div class="bg-white rounded-lg shadow-xl max-w-7xl w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-6 py-4 rounded-t-lg">
          <div class="flex justify-between items-center">
            <h3 class="text-xl font-semibold flex items-center">
              <i class="fas fa-info-circle mr-3"></i>
              Quarterly Achievement Details
            </h3>
            <button id="closeModal" class="text-white hover:text-gray-200 transition-colors">
              <i class="fas fa-times text-xl"></i>
            </button>
          </div>
