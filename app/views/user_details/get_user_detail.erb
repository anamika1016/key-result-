<%
  # FIXED: Allow submission for different departments - don't block submission based on existing achievements
  # The system should allow users to submit data for different departments in the same quarter
  submitted_quarters = []
  # Note: We're not blocking submission based on existing achievements anymore
  # Users can submit data for multiple departments in the same quarter
%>

<div class="main-content bg-gray-50 min-h-screen">
  <div class="bg-white border border-gray-200 rounded-xl shadow-lg mb-4">
    <div class="p-4 flex flex-wrap items-center justify-between gap-3">
      <div class="text-lg font-semibold text-gray-800">Active Year: <%= @selected_year %></div>
      <%= form_with url: get_user_detail_user_details_path, method: :get, local: true, class: "flex items-center gap-3" do |form| %>
        <label class="text-sm font-medium text-gray-700">Change Year</label>
        <%= select_tag :year, options_for_select(@available_years, @selected_year), class: "border border-gray-300 rounded-lg px-3 py-2 bg-white text-gray-800", onchange: "this.form.submit();" %>
      <% end %>
    </div>
  </div>

  <!-- Filter Section - Added without changing your existing code -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-lg mb-4">
    <div class="bg-blue-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
      <h2 class="text-2xl font-bold text-gray-800 flex items-center">
        <i class="fas fa-filter me-2" style="color: #2d374b;"></i>
        Filter KPI
      </h2>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Select Vertical</label>
          <select id="departmentFilter" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Verticals</option>
          </select>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Select Quarter</label>
          <select id="quarterFilter" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Quarters</option>
            <option value="q1" selected>Q1</option>
            <option value="q2">Q2</option>
            <option value="q3">Q3</option>
            <option value="q4">Q4</option>
          </select>
        </div>
        
        <div class="flex gap-2">
          <button id="showSelected" class="px-4 py-2 text-white rounded-lg transition-colors" style="background-color: #2d374b;" onmouseover="this.style.backgroundColor='#1a202c'" onmouseout="this.style.backgroundColor='#2d374b'">
            <i class="fas fa-eye me-1"></i> Show Selected
          </button>
        </div>
      </div>
    </div>
  </div>

  <% if @user_details.any? %>
    <!-- ======================== FORM TO SUBMIT ACHIEVEMENTS ======================== -->
    <%= form_with url: submit_achievements_user_details_path, method: :post, local: true, id: "achievementForm" do %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <!-- Success Message Display -->
      <div id="successMessage" class="hidden bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <i class="fas fa-check-circle text-green-400 text-xl"></i>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-green-800" id="successTitle">Success!</h3>
            <div class="mt-2 text-sm text-green-700" id="successText">
              Achievements have been submitted successfully.
            </div>
          </div>
          <div class="ml-auto pl-3">
            <button type="button" class="text-green-400 hover:text-green-600" onclick="hideMessage('successMessage')">
              <i class="fas fa-times text-lg"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Error Message Display -->
      <div id="errorMessage" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <i class="fas fa-exclamation-triangle text-red-400 text-xl"></i>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800" id="errorTitle">Error!</h3>
            <div class="mt-2 text-sm text-red-700" id="errorText">
              There was an error submitting achievements. Please try again.
            </div>
          </div>
          <div class="ml-auto pl-3">
            <button type="button" class="text-red-400 hover:text-red-600" onclick="hideMessage('errorMessage')">
              <i class="fas fa-times text-lg"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Warning Message Display -->
      <div id="warningMessage" class="hidden bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <i class="fas fa-exclamation-circle text-yellow-400 text-xl"></i>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-yellow-800" id="warningTitle">Warning!</h3>
            <div class="mt-2 text-sm text-yellow-700" id="warningText">
              Please review your input before submitting.
            </div>
          </div>
          <div class="ml-auto pl-3">
            <button type="button" class="text-yellow-400 hover:text-yellow-600" onclick="hideMessage('warningMessage')">
              <i class="fas fa-times text-lg"></i>
            </button>
          </div>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-lg mt-4">
        <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
          <h2 class="text-3xl font-bold text-gray-800 flex items-center">
            <i class="fas fa-users me-2 text-indigo-600"></i>
            Quarterly Activity Achievement Submit 
          </h2>
        </div>

        <div class="p-6">
          <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200 shadow-sm">
            <table class="table table-hover w-full min-w-full" id="activityTable">
              <thead class="bg-gray-800">
                <tr>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Vertical</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Employee Name</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Indicator</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">KPI</th>
                  <th rowspan="2" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Unit</th>
                  <th rowspan="2" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Weightage</th>
                  <th colspan="3" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 quarter-header" data-quarter="q1">Q1</th>
                  <th colspan="3" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 quarter-header" data-quarter="q2">Q2</th>
                  <th colspan="3" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 quarter-header" data-quarter="q3">Q3</th>
                  <th colspan="3" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700 quarter-header" data-quarter="q4">Q4</th>
                </tr>
                <tr class="bg-gray-700">
                  <% 4.times do %>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Achievement (%)</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Remarks</th>
                    <th class="px-3 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 quarter-subheader">Weightage Score</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @user_details.each_with_index do |detail, index| %>
                  <%
                    # Get existing achievements for this detail
                    existing_achievements = {}
                    
                    if detail.achievements.present?
                      # First, check for direct quarterly achievements (q1, q2, q3, q4)
                      ['q1', 'q2', 'q3', 'q4'].each do |quarter|
                        quarterly_achievement = detail.achievements.find_by(month: quarter)
                        if quarterly_achievement
                          existing_achievements[quarter] = quarterly_achievement
                        end
                      end
                      
                      # Then, calculate quarterly achievements from monthly data if no quarterly data exists
                      ['q1', 'q2', 'q3', 'q4'].each do |quarter|
                        next if existing_achievements[quarter] # Skip if already has quarterly data
                        
                        case quarter
                        when 'q1'
                          monthly_achievements = detail.achievements.where(month: ['april', 'may', 'june'])
                        when 'q2'
                          monthly_achievements = detail.achievements.where(month: ['july', 'august', 'september'])
                        when 'q3'
                          monthly_achievements = detail.achievements.where(month: ['october', 'november', 'december'])
                        when 'q4'
                          monthly_achievements = detail.achievements.where(month: ['january', 'february', 'march'])
                        end
                        
                        if monthly_achievements.any? { |a| a.achievement.present? }
                          # Calculate average achievement - convert string values to numeric first
                          achievement_values = monthly_achievements.where.not(achievement: [nil, '']).pluck(:achievement).map { |val| val.to_f rescue 0 }.compact
                          avg_achievement = achievement_values.any? ? (achievement_values.sum / achievement_values.size) : nil
                          
                          # Get remarks from the first monthly achievement that has remarks
                          remarks = monthly_achievements.find { |a| a.employee_remarks.present? }&.employee_remarks
                          
                          if avg_achievement
                            # Create a virtual achievement object
                            existing_achievements[quarter] = OpenStruct.new(
                              achievement: avg_achievement.round(2),
                              employee_remarks: remarks || ''
                            )
                          end
                        end
                      end
                    end

                    # Create target data for JavaScript filtering
                    months = [:april, :may, :june, :july, :august, :september, :october, :november, :december, :january, :february, :march]
                    target_data = {}
                    has_any_target = false
                    
                    months.each do |month|
                      target_value = detail.send(month)
                      # Consider a target valid if it's not nil, not empty, and not 0
                      is_valid_target = target_value.present? && target_value.to_s != '0'
                      target_data[month.to_s] = is_valid_target ? target_value.to_s : ''
                      has_any_target = true if is_valid_target
                    end
                  %>
                  
                  <tr class="<%= index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200 activity-row" 
                      data-activity="<%= detail.activity.activity_name %>" 
                      data-department="<%= detail.department.department_type %>"
                      data-has-any-target="<%= has_any_target %>">
                    
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200"><%= detail.department.department_type %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200"><%= detail.employee_detail&.employee_name || 'N/A' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.activity_name %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.theme_name.presence || 'No Theme' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= detail.activity.unit %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center font-semibold"><%= detail.activity.weight.present? ? "#{detail.activity.weight.to_i}%" : '0%' %></td>

                    <!-- Q1 Quarter -->
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q1">
                      <input 
                        type="text" 
                        name="achievement[<%= detail.id %>][q1][achievement]" 
                        placeholder="Q1 %" 
                        value="<%= existing_achievements['q1']&.achievement || '' %>"
                        class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm"
                        onchange="calculateWeightageScore(this)" oninput="calculateWeightageScore(this)"
                        data-weight="<%= detail.activity.weight.present? ? detail.activity.weight : 0 %>"
                      />
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q1">
                      <textarea 
                        name="achievement[<%= detail.id %>][q1][employee_remarks]" 
                        placeholder="Remarks" 
                        rows="1"
                        class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none"
                      ><%= existing_achievements['q1']&.employee_remarks || '' %></textarea>
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q1">
                      <%
                        # Calculate weightage score for Q1
                        q1_achievement = existing_achievements['q1']&.achievement
                        q1_achievement_float = q1_achievement.present? ? q1_achievement.to_f : 0
                        weight = detail.activity.weight.present? ? detail.activity.weight.to_f : 0
                        weight_decimal = weight > 1 ? weight / 100 : weight
                        q1_score = q1_achievement_float > 0 && weight > 0 ? (weight_decimal * q1_achievement_float).round(2) : 0
                      %>
                      <input 
                        type="text" 
                        readonly
                        class="weightage-score border border-gray-300 p-1 rounded-lg w-full bg-green-50 text-green-800 text-xs font-semibold text-center" 
                        id="q1-score-<%= detail.id %>" 
                        value="<%= q1_score %>"
                        placeholder="Score"
                      />
                    </td>

                    <!-- Q2 Quarter -->
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q2">
                      <input 
                        type="text" 
                        name="achievement[<%= detail.id %>][q2][achievement]" 
                        placeholder="Q2 %" 
                        value="<%= existing_achievements['q2']&.achievement || '' %>"
                        class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm"
                        onchange="calculateWeightageScore(this)" oninput="calculateWeightageScore(this)"
                        data-weight="<%= detail.activity.weight.present? ? detail.activity.weight : 0 %>"
                      />
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q2">
                      <textarea 
                        name="achievement[<%= detail.id %>][q2][employee_remarks]" 
                        placeholder="Remarks" 
                        rows="1"
                        class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none"
                      ><%= existing_achievements['q2']&.employee_remarks || '' %></textarea>
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q2">
                      <%
                        # Calculate weightage score for Q2
                        q2_achievement = existing_achievements['q2']&.achievement
                        q2_achievement_float = q2_achievement.present? ? q2_achievement.to_f : 0
                        weight = detail.activity.weight.present? ? detail.activity.weight.to_f : 0
                        weight_decimal = weight > 1 ? weight / 100 : weight
                        q2_score = q2_achievement_float > 0 && weight > 0 ? (weight_decimal * q2_achievement_float).round(2) : 0
                      %>
                      <input 
                        type="text" 
                        readonly
                        class="weightage-score border border-gray-300 p-1 rounded-lg w-full bg-green-50 text-green-800 text-xs font-semibold text-center" 
                        id="q2-score-<%= detail.id %>" 
                        value="<%= q2_score %>"
                        placeholder="Score"
                      />
                    </td>

                    <!-- Q3 Quarter -->
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q3">
                      <input 
                        type="text" 
                        name="achievement[<%= detail.id %>][q3][achievement]" 
                        placeholder="Q3 %" 
                        value="<%= existing_achievements['q3']&.achievement || '' %>"
                        class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm"
                        onchange="calculateWeightageScore(this)" oninput="calculateWeightageScore(this)"
                        data-weight="<%= detail.activity.weight.present? ? detail.activity.weight : 0 %>"
                      />
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q3">
                      <textarea 
                        name="achievement[<%= detail.id %>][q3][employee_remarks]" 
                        placeholder="Remarks" 
                        rows="1"
                        class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none"
                      ><%= existing_achievements['q3']&.employee_remarks || '' %></textarea>
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q3">
                      <%
                        # Calculate weightage score for Q3
                        q3_achievement = existing_achievements['q3']&.achievement
                        q3_achievement_float = q3_achievement.present? ? q3_achievement.to_f : 0
                        weight = detail.activity.weight.present? ? detail.activity.weight.to_f : 0
                        weight_decimal = weight > 1 ? weight / 100 : weight
                        q3_score = q3_achievement_float > 0 && weight > 0 ? (weight_decimal * q3_achievement_float).round(2) : 0
                      %>
                      <input 
                        type="text" 
                        readonly
                        class="weightage-score border border-gray-300 p-1 rounded-lg w-full bg-green-50 text-green-800 text-xs font-semibold text-center" 
                        id="q3-score-<%= detail.id %>" 
                        value="<%= q3_score %>"
                        placeholder="Score"
                      />
                    </td>

                    <!-- Q4 Quarter -->
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q4">
                      <input 
                        type="text" 
                        name="achievement[<%= detail.id %>][q4][achievement]" 
                        placeholder="Q4 %" 
                        value="<%= existing_achievements['q4']&.achievement || '' %>"
                        class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm"
                        onchange="calculateWeightageScore(this)" oninput="calculateWeightageScore(this)"
                        data-weight="<%= detail.activity.weight.present? ? detail.activity.weight : 0 %>"
                      />
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q4">
                      <textarea 
                        name="achievement[<%= detail.id %>][q4][employee_remarks]" 
                        placeholder="Remarks" 
                        rows="1"
                        class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none"
                      ><%= existing_achievements['q4']&.employee_remarks || '' %></textarea>
                    </td>
                    <td class="px-3 py-3 text-sm text-center border-r border-gray-200 quarter-cell" data-quarter="q4">
                      <%
                        # Calculate weightage score for Q4
                        q4_achievement = existing_achievements['q4']&.achievement
                        q4_achievement_float = q4_achievement.present? ? q4_achievement.to_f : 0
                        weight = detail.activity.weight.present? ? detail.activity.weight.to_f : 0
                        weight_decimal = weight > 1 ? weight / 100 : weight
                        q4_score = q4_achievement_float > 0 && weight > 0 ? (weight_decimal * q4_achievement_float).round(2) : 0
                      %>
                      <input 
                        type="text" 
                        readonly
                        class="weightage-score border border-gray-300 p-1 rounded-lg w-full bg-green-50 text-green-800 text-xs font-semibold text-center" 
                        id="q4-score-<%= detail.id %>" 
                        value="<%= q4_score %>"
                        placeholder="Score"
                      />
                    </td>
                  </tr>
                <% end %>
              </tbody>
              
              <!-- Summary Row -->
              <tfoot class="bg-green-100 border-t-2 border-green-300">
                <tr class="font-bold text-gray-800">
                  <td colspan="5" class="px-4 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span class="text-lg font-extrabold text-green-800">TOTAL COUNT</span>
                  </td>
                  <td class="px-4 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span id="total-weightage-count" class="text-green-700 font-bold text-lg">0</span>
                  </td>
                  
                  <!-- Q1 Summary -->
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span id="q1-total-achievement" class="text-blue-700 font-bold">0</span>
                  </td>
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span class="text-gray-600">-</span>
                  </td>
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span id="q1-total-weightage-score" class="text-green-700 font-bold">0</span>
                  </td>
                  
                  <!-- Q2 Summary -->
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span id="q2-total-achievement" class="text-blue-700 font-bold">0</span>
                  </td>
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span class="text-gray-600">-</span>
                  </td>
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span id="q2-total-weightage-score" class="text-green-700 font-bold">0</span>
                  </td>
                  
                  <!-- Q3 Summary -->
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span id="q3-total-achievement" class="text-blue-700 font-bold">0</span>
                  </td>
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span class="text-gray-600">-</span>
                  </td>
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span id="q3-total-weightage-score" class="text-green-700 font-bold">0</span>
                  </td>
                  
                  <!-- Q4 Summary -->
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span id="q4-total-achievement" class="text-blue-700 font-bold">0</span>
                  </td>
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span class="text-gray-600">-</span>
                  </td>
                  <td class="px-3 py-3 text-center border-r border-gray-200 bg-green-200">
                    <span id="q4-total-weightage-score" class="text-green-700 font-bold">0</span>
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      </div>

      <div class="mt-6 flex justify-center">
