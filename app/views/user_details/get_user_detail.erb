                    <th class="px-4 py-3 text-center text-sm font-medium text-gray-700">L1 Remarks</th>
                    <th class="px-4 py-3 text-center text-sm font-medium text-gray-700">L2 Remarks</th>
                    <th class="px-4 py-3 text-center text-sm font-medium text-gray-700">L1 %</th>
                    <th class="px-4 py-3 text-center text-sm font-medium text-gray-700">L2 %</th>
                    <th class="px-4 py-3 text-center text-sm font-medium text-gray-700">Status</th>
                  </tr>
                </thead>
                <tbody id="monthlyDetailsTable" class="divide-y divide-gray-200">
                  <!-- Monthly data will be populated here -->
                </tbody>
              </table>
            </div>
          </div>

          <!-- Quarter Summary -->
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-5 rounded-lg border border-blue-200">
            <h4 class="font-semibold text-blue-800 mb-4 flex items-center">
              <i class="fas fa-chart-bar mr-2 text-blue-600"></i>
              Quarter Summary
            </h4>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div class="text-center">
                <div class="text-2xl font-bold text-gray-800" id="quarterTotalTarget">0</div>
                <div class="text-sm text-gray-600">Total Target</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-green-600" id="quarterTotalAchievement">0</div>
                <div class="text-sm text-gray-600">Total Achievement</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold" id="quarterPercentage">0%</div>
                <div class="text-sm text-gray-600">Overall %</div>
              </div>
              <div class="text-center">
                <span id="quarterStatus" class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold">
                  <!-- Status will be populated -->
                </span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="bg-gray-50 px-6 py-4 rounded-b-lg">
          <button id="closeModalBtn" class="w-full bg-gradient-to-r from-gray-600 to-gray-700 hover:from-gray-700 hover:to-gray-800 text-white px-6 py-3 rounded-lg transition-all duration-200 flex items-center justify-center">
            <i class="fas fa-times mr-2"></i>Close Details
          </button>
        </div>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const modal = document.getElementById('detailsModal');
        const closeModal = document.getElementById('closeModal');
        const closeModalBtn = document.getElementById('closeModalBtn');
        const detailButtons = document.querySelectorAll('.details-btn');

        function getStatusConfig(status) {
          switch(status) {
            case 'l2_approved':
              return { color: 'bg-emerald-100 text-emerald-800', text: 'L2 Approved', icon: 'fas fa-check-double' };
            case 'l1_approved':
              return { color: 'bg-green-100 text-green-800', text: 'L1 Approved', icon: 'fas fa-check-circle' };
            case 'l2_returned':
              return { color: 'bg-orange-100 text-orange-800', text: 'L2 Returned', icon: 'fas fa-exclamation-triangle' };
            case 'l1_returned':
              return { color: 'bg-red-100 text-red-800', text: 'L1 Returned', icon: 'fas fa-exclamation-triangle' };
            case 'submitted':
              return { color: 'bg-blue-100 text-blue-800', text: 'Submitted', icon: 'fas fa-paper-plane' };
            default:
              return { color: 'bg-yellow-100 text-yellow-800', text: 'Pending', icon: 'fas fa-clock' };
          }
        }

        function openModal(button) {
          const data = button.dataset;
          
          // Populate basic info
          document.getElementById('modalEmployeeName').textContent = data.employeeName || 'N/A';
          document.getElementById('modalDepartment').textContent = data.department || 'N/A';
          document.getElementById('modalActivityName').textContent = data.activityName || 'N/A';
          document.getElementById('modalQuarter').textContent = data.quarter || 'N/A';
          
          // Get quarterly data based on which quarter was clicked
          let quarterData = [];
          if (data.q3Data) {
            quarterData = JSON.parse(data.q3Data.replace(/&quot;/g, '"'));
          } else if (data.q4Data) {
            quarterData = JSON.parse(data.q4Data.replace(/&quot;/g, '"'));
          } else if (data.q1Data) {
            quarterData = JSON.parse(data.q1Data.replace(/&quot;/g, '"'));
          } else if (data.q2Data) {
            quarterData = JSON.parse(data.q2Data.replace(/&quot;/g, '"'));
          }
          
          const monthlyDetailsTable = document.getElementById('monthlyDetailsTable');
          monthlyDetailsTable.innerHTML = '';
          
          let totalTarget = 0;
          let totalAchievement = 0;
          let quarterStatuses = [];
          
          quarterData.forEach(monthData => {
            const target = parseFloat(monthData.target) || 0;
            const achievement = parseFloat(monthData.achievement) || 0;
            const percentage = target > 0 ? ((achievement / target) * 100).toFixed(1) : '0';
            
            totalTarget += target;
            totalAchievement += achievement;
            quarterStatuses.push(monthData.status);
            
            const monthCapitalized = monthData.month.charAt(0).toUpperCase() + monthData.month.slice(1);
            const statusConfig = getStatusConfig(monthData.status);
            
            const tr = document.createElement('tr');
            tr.className = 'hover:bg-gray-50';
            tr.innerHTML = `
              <td class="px-4 py-3 text-sm font-medium text-gray-800">${monthCapitalized}</td>
              <td class="px-4 py-3 text-sm text-center text-gray-800">${target || '-'}</td>
              <td class="px-4 py-3 text-sm text-center font-semibold text-green-700">${achievement || '-'}</td>
              <td class="px-4 py-3 text-sm text-center font-bold ${percentage >= 100 ? 'text-green-600' : percentage >= 75 ? 'text-blue-600' : percentage >= 50 ? 'text-yellow-600' : 'text-red-600'}">${percentage}%</td>
              <td class="px-4 py-3 text-sm text-center text-gray-600">${monthData.remarks || '-'}</td>
              <td class="px-4 py-3 text-sm text-center text-gray-600">${monthData.l1_remarks || '-'}</td>
              <td class="px-4 py-3 text-sm text-center text-gray-600">${monthData.l2_remarks || '-'}</td>
              <td class="px-4 py-3 text-sm text-center font-medium text-green-700">${monthData.l1_percentage ? monthData.l1_percentage + '%' : '-'}</td>
              <td class="px-4 py-3 text-sm text-center font-medium text-purple-700">${monthData.l2_percentage ? monthData.l2_percentage + '%' : '-'}</td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold ${statusConfig.color}">
                  <i class="${statusConfig.icon} mr-1"></i>
                  ${statusConfig.text}
                </span>
              </td>
            `;
            monthlyDetailsTable.appendChild(tr);
          });
          
          // Update quarter summary
          document.getElementById('quarterTotalTarget').textContent = totalTarget.toFixed(0);
          document.getElementById('quarterTotalAchievement').textContent = totalAchievement.toFixed(0);
          
          const quarterPercentage = totalTarget > 0 ? ((totalAchievement / totalTarget) * 100).toFixed(1) : '0';
          const quarterPercentageElement = document.getElementById('quarterPercentage');
          quarterPercentageElement.textContent = quarterPercentage + '%';
          
          if (quarterPercentage >= 100) {
            quarterPercentageElement.className = 'text-2xl font-bold text-green-600';
          } else if (quarterPercentage >= 75) {
            quarterPercentageElement.className = 'text-2xl font-bold text-blue-600';
          } else if (quarterPercentage >= 50) {
            quarterPercentageElement.className = 'text-2xl font-bold text-yellow-600';
          } else {
            quarterPercentageElement.className = 'text-2xl font-bold text-red-600';
          }
          
          // Determine overall quarter status
          let quarterStatus = 'pending';
          if (quarterStatuses.includes('l2_approved')) {
            quarterStatus = 'l2_approved';
          } else if (quarterStatuses.includes('l1_approved')) {
            quarterStatus = 'l1_approved';
          } else if (quarterStatuses.includes('l2_returned')) {
            quarterStatus = 'l2_returned';
          } else if (quarterStatuses.includes('l1_returned')) {
            quarterStatus = 'l1_returned';
          } else if (quarterStatuses.includes('submitted')) {
            quarterStatus = 'submitted';
          }
          
          const quarterStatusElement = document.getElementById('quarterStatus');
          const statusConfig = getStatusConfig(quarterStatus);
          
          quarterStatusElement.className = `inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold ${statusConfig.color}`;
          quarterStatusElement.innerHTML = `<i class="${statusConfig.icon} mr-1"></i>${statusConfig.text}`;
          
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }

        function closeModalFunction() {
          modal.classList.add('hidden');
          document.body.style.overflow = 'auto';
        }

        detailButtons.forEach(button => {
          button.addEventListener('click', function() {
            openModal(this);
          });
        });

        closeModal.addEventListener('click', closeModalFunction);
        closeModalBtn.addEventListener('click', closeModalFunction);

        modal.addEventListener('click', function(e) {
          if (e.target === modal) {
            closeModalFunction();
          }
        });

        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
            closeModalFunction();
          }
        });
      });
    </script>
<% end %>
</div>

