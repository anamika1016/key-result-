        // FIXED: Function to update status based on month filter
        function updateStatusBasedOnMonth() {
            const monthFilter = document.getElementById('monthFilter');
            if (!monthFilter) return;
            
            const selectedMonth = monthFilter.value;
            const submittedRows = document.querySelectorAll('.submitted-activity-row');
            
            submittedRows.forEach(row => {
                const statusColumn = row.querySelector('.status-column span');
                if (!statusColumn) return;
                
                if (selectedMonth) {
                    // Get status for the specific month
                    const monthStatus = row.getAttribute(`data-${selectedMonth}-status`);
                    
                    if (monthStatus && monthStatus !== 'no_data') {
                        // Update status display for specific month
                        let statusConfig;
                        
                        switch (monthStatus) {
                            case "pending":
                                statusConfig = { 
                                    color: "bg-yellow-100 text-yellow-800 border-yellow-300", 
                                    text: "Pending", 
                                    icon: "fas fa-clock" 
                                };
                                break;
                            case "l1_approved":
                                statusConfig = { 
                                    color: "bg-green-100 text-green-800 border-green-300", 
                                    text: "L1 Approved", 
                                    icon: "fas fa-check-circle" 
                                };
                                break;
                            case "l1_returned":
                                statusConfig = { 
                                    color: "bg-red-100 text-red-800 border-red-300", 
                                    text: "L1 Returned", 
                                    icon: "fas fa-exclamation-triangle" 
                                };
                                break;
                            case "l2_approved":
                                statusConfig = { 
                                    color: "bg-emerald-100 text-emerald-800 border-emerald-300", 
                                    text: "L2 Approved", 
                                    icon: "fas fa-check-double" 
                                };
                                break;
                            case "l2_returned":
                                statusConfig = { 
                                    color: "bg-orange-100 text-orange-800 border-orange-300", 
                                    text: "L2 Returned", 
                                    icon: "fas fa-exclamation-triangle" 
                                };
                                break;
                            case "submitted":
                                statusConfig = { 
                                    color: "bg-blue-100 text-blue-800 border-blue-300", 
                                    text: "Submitted", 
                                    icon: "fas fa-paper-plane" 
                                };
                                break;
                            default:
                                statusConfig = { 
                                    color: "bg-gray-100 text-gray-600 border-gray-300", 
                                    text: "No Data", 
                                    icon: "fas fa-question-circle" 
                                };
                        }
                        
                        // Update the status badge
                        statusColumn.className = `inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border ${statusConfig.color}`;
                        statusColumn.innerHTML = `<i class="${statusConfig.icon} mr-1 text-xs"></i>${statusConfig.text}`;
                        
                    } else {
                        // No data for this month
                        statusColumn.className = "inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border bg-gray-100 text-gray-600 border-gray-300";
                        statusColumn.innerHTML = '<i class="fas fa-question-circle mr-1 text-xs"></i>No Data';
                    }
                } else {
                    // Reset to original overall status when no month filter is applied
                    // Get all month statuses for this row
                    const allStatuses = [];
                    const months = ['april', 'may', 'june', 'july', 'august', 'september', 'october', 'november', 'december', 'january', 'february', 'march'];
                    
                    months.forEach(month => {
                        const monthStatus = row.getAttribute(`data-${month}-status`);
                        if (monthStatus && monthStatus !== 'no_data') {
                            allStatuses.push(monthStatus);
                        }
                    });
                    
                    // Determine overall status
                    let overallStatus = "pending";
                    if (allStatuses.includes("l2_approved")) {
                        overallStatus = "l2_approved";
                    } else if (allStatuses.includes("l1_approved")) {
                        overallStatus = "l1_approved";
                    } else if (allStatuses.includes("l2_returned")) {
                        overallStatus = "l2_returned";
                    } else if (allStatuses.includes("l1_returned")) {
                        overallStatus = "l1_returned";
                    } else if (allStatuses.includes("submitted")) {
                        overallStatus = "submitted";
                    }
                    
                    let statusConfig;
                    switch (overallStatus) {
                        case "pending":
                            statusConfig = { 
                                color: "bg-yellow-100 text-yellow-800 border-yellow-300", 
                                text: "Pending", 
                                icon: "fas fa-clock" 
                            };
                            break;
                        case "l1_approved":
                            statusConfig = { 
                                color: "bg-green-100 text-green-800 border-green-300", 
                                text: "L1 Approved", 
                                icon: "fas fa-check-circle" 
                            };
                            break;
                        case "l1_returned":
                            statusConfig = { 
                                color: "bg-red-100 text-red-800 border-red-300", 
                                text: "L1 Returned", 
                                icon: "fas fa-exclamation-triangle" 
                            };
                            break;
                        case "l2_approved":
                            statusConfig = { 
                                color: "bg-emerald-100 text-emerald-800 border-emerald-300", 
                                text: "L2 Approved", 
                                icon: "fas fa-check-double" 
                            };
                            break;
                        case "l2_returned":
                            statusConfig = { 
                                color: "bg-orange-100 text-orange-800 border-orange-300", 
                                text: "L2 Returned", 
                                icon: "fas fa-exclamation-triangle" 
                            };
                            break;
                        case "submitted":
                            statusConfig = { 
                                color: "bg-blue-100 text-blue-800 border-blue-300", 
                                text: "Submitted", 
                                icon: "fas fa-paper-plane" 
                            };
                            break;
                        default:
                            statusConfig = { 
                                color: "bg-gray-100 text-gray-600 border-gray-300", 
                                text: "No Status", 
                                icon: "fas fa-question-circle" 
                            };
                    }
                    
                    // Update the status badge
                    statusColumn.className = `inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border ${statusConfig.color}`;
                    statusColumn.innerHTML = `<i class="${statusConfig.icon} mr-1 text-xs"></i>${statusConfig.text}`;
                }
            });
        }
        
        // Modal functionality
        // Modal functionality - Simplified to avoid conflicts with quarterly modal
        function setupModal() {
            // This function is kept for compatibility but the quarterly modal handles its own functionality
            console.log('Basic modal setup completed - quarterly modal is handling details');
        }
        
        function filterTable() {
            const departmentFilter = document.getElementById('departmentFilter');
            const quarterFilter = document.getElementById('quarterFilter');
            if (!departmentFilter || !quarterFilter) return; // Guard clause

            const selectedDepartment = departmentFilter.value;
            const selectedQuarter = quarterFilter.value;
            
            // Filter activity rows by department
            document.querySelectorAll('.activity-row').forEach(row => {
                const rowDepartment = row.dataset.department;
                const shouldShowRow = !selectedDepartment || rowDepartment === selectedDepartment;
                row.style.display = shouldShowRow ? '' : 'none';
            });
            
            // Filter submitted activity rows
            document.querySelectorAll('.submitted-activity-row').forEach(row => {
                const rowDepartment = row.dataset.department;
                const shouldShowRow = !selectedDepartment || rowDepartment === selectedDepartment;
                row.style.display = shouldShowRow ? '' : 'none';
            });
            
            // Filter quarter columns
            if (selectedQuarter) {
                // Hide all quarter headers first
                document.querySelectorAll('.quarter-header').forEach(header => {
                    header.style.display = 'none';
                });
                
                // Show only the selected quarter header
                document.querySelectorAll(`.quarter-header[data-quarter="${selectedQuarter}"]`).forEach(header => {
                    header.style.display = '';
                });
                
                // Hide all quarter subheaders first
                document.querySelectorAll('.quarter-subheader').forEach(subheader => {
                    subheader.style.display = 'none';
                });
                
                // Show only the selected quarter subheaders (3 columns per quarter)
                const quarterIndex = ['q1', 'q2', 'q3', 'q4'].indexOf(selectedQuarter);
                const startIndex = quarterIndex * 3;
                const endIndex = startIndex + 3;
                
                document.querySelectorAll('.quarter-subheader').forEach((subheader, index) => {
                    if (index >= startIndex && index < endIndex) {
                        subheader.style.display = '';
                    }
                });
                
                // Hide all quarter cells first
                document.querySelectorAll('.quarter-cell').forEach(cell => {
                    cell.style.display = 'none';
                });
                
                // Show only the selected quarter cells
                document.querySelectorAll(`.quarter-cell[data-quarter="${selectedQuarter}"]`).forEach(cell => {
                    cell.style.display = '';
                });
                
                // Hide summary columns for non-selected quarters
                const quarters = ['q1', 'q2', 'q3', 'q4'];
                quarters.forEach(quarter => {
                    if (quarter !== selectedQuarter) {
                        // Hide all 3 summary columns for this quarter (achievement, remarks, score)
                        const achievementElement = document.getElementById(`${quarter}-total-achievement`);
                        const scoreElement = document.getElementById(`${quarter}-total-weightage-score`);
                        
                        if (achievementElement) {
                            achievementElement.closest('td').style.display = 'none';
                        }
                        if (scoreElement) {
                            scoreElement.closest('td').style.display = 'none';
                        }
                        
                        // Also hide the remarks column for this quarter
                        const remarksCell = achievementElement ? achievementElement.closest('td').nextElementSibling : null;
                        if (remarksCell) {
                            remarksCell.style.display = 'none';
                        }
                    } else {
                        // Show summary columns for selected quarter
                        const achievementElement = document.getElementById(`${quarter}-total-achievement`);
                        const scoreElement = document.getElementById(`${quarter}-total-weightage-score`);
                        
                        if (achievementElement) {
                            achievementElement.closest('td').style.display = '';
                        }
                        if (scoreElement) {
                            scoreElement.closest('td').style.display = '';
                        }
                        
                        // Also show the remarks column for this quarter
                        const remarksCell = achievementElement ? achievementElement.closest('td').nextElementSibling : null;
                        if (remarksCell) {
                            remarksCell.style.display = '';
                        }
                    }
                });
            } else {
                // Show all quarter columns
                document.querySelectorAll('.quarter-header, .quarter-subheader, .quarter-cell').forEach(el => {
                    el.style.display = '';
                });
                
                // Show all summary columns
                document.querySelectorAll('[id*="-total-"]').forEach(element => {
                    element.closest('td').style.display = '';
                });
            }
            
            // Update totals based on visible rows only
            updateSummaryTotals();
            
            // Check quarter status and update submit button visibility
            checkQuarterStatus(selectedQuarter);
        }

        function resetAllFilters() {
             const departmentFilter = document.getElementById('departmentFilter');
             const quarterFilter = document.getElementById('quarterFilter');
             if (departmentFilter) departmentFilter.value = '';
             if (quarterFilter) quarterFilter.value = '';
             
             // Show all quarter columns
             document.querySelectorAll('.quarter-header, .quarter-subheader, .quarter-cell').forEach(el => {
                 el.style.display = '';
             });
             
             // Show all summary columns
             document.querySelectorAll('[id*="-total-"]').forEach(element => {
                 element.closest('td').style.display = '';
             });
             
             // Show all rows
             document.querySelectorAll('.activity-row, .submitted-activity-row').forEach(row => {
                 row.style.display = '';
             });
             
             // Update totals based on all visible rows
             updateSummaryTotals();
        }

        // Function to calculate weightage score
        function calculateWeightageScore(input) {
            const achievement = parseFloat(input.value) || 0;
            const weight = parseFloat(input.dataset.weight) || 0;
            
            // Calculate: Weightage * Achievement = Weightage Score
            // If weightage is stored as percentage (e.g., 25), convert to decimal (0.25)
            // If weightage is already decimal (e.g., 0.25), use as is
            const weightDecimal = weight > 1 ? weight / 100 : weight;
            const weightageScore = (weightDecimal * achievement).toFixed(2);
            
            // Find the corresponding score display element
            const row = input.closest('tr');
            const quarter = input.name.match(/\[(q[1-4])\]/)[1];
            const detailId = input.name.match(/\[(\d+)\]/)[1];
            const scoreElement = document.getElementById(`${quarter}-score-${detailId}`);
            
            if (scoreElement) {
                scoreElement.value = weightageScore;
                console.log(`Calculated: ${weight}% * ${achievement} = ${weightDecimal} * ${achievement} = ${weightageScore}`);
            } else {
                console.log(`Score element not found: ${quarter}-score-${detailId}`);
            }
            
            // Update summary totals after calculating individual score
            updateSummaryTotals();
        }
        
        // Function to populate department dropdown
        function populateDepartmentDropdown() {
            const departmentFilter = document.getElementById('departmentFilter');
            if (!departmentFilter) return;

            // Clear existing options except "All Departments"
            const allDepartmentsOption = departmentFilter.querySelector('option[value=""]');
            departmentFilter.innerHTML = '';
            if (allDepartmentsOption) {
                departmentFilter.appendChild(allDepartmentsOption);
            }

            const departments = new Set();
            document.querySelectorAll('.activity-row').forEach(row => {
                const department = row.dataset.department;
                if (department) departments.add(department);
            });

            departments.forEach(department => {
                const option = document.createElement('option');
                option.value = department;
                option.textContent = department;
                departmentFilter.appendChild(option);
            });
        }

        // Function to initialize all weightage scores
        function initializeWeightageScores() {
            document.querySelectorAll('.achievement-input').forEach(input => {
                if (input.value) {
                    calculateWeightageScore(input);
                }
            });
            
            // Force recalculation for all visible inputs
            setTimeout(() => {
                document.querySelectorAll('.achievement-input').forEach(input => {
                    if (input.value && input.value !== '0') {
                        calculateWeightageScore(input);
                    }
                });
            }, 100);
        }

        // Global function to calculate weightage score (can be called from anywhere)
        window.calculateWeightageScore = function(input) {
            const achievement = parseFloat(input.value) || 0;
            const weight = parseFloat(input.dataset.weight) || 0;
            
            // Calculate: Weightage * Achievement = Weightage Score
            // If weightage is stored as percentage (e.g., 25), convert to decimal (0.25)
            // If weightage is already decimal (e.g., 0.25), use as is
            const weightDecimal = weight > 1 ? weight / 100 : weight;
            const weightageScore = (weightDecimal * achievement).toFixed(2);
            
            // Find the corresponding score display element
            const row = input.closest('tr');
            const quarter = input.name.match(/\[(q[1-4])\]/)[1];
            const detailId = input.name.match(/\[(\d+)\]/)[1];
            const scoreElement = document.getElementById(`${quarter}-score-${detailId}`);
            
            if (scoreElement) {
                scoreElement.value = weightageScore;
                console.log(`Calculated: ${weight}% * ${achievement} = ${weightDecimal} * ${achievement} = ${weightageScore}`);
                
                // Update summary totals after each calculation
                updateSummaryTotals();
            } else {
                console.log(`Score element not found: ${quarter}-score-${detailId}`);
            }
        };

        // Function to recalculate all weightage scores
        window.recalculateAllScores = function() {
            console.log('Recalculating all scores...');
            document.querySelectorAll('.achievement-input').forEach(input => {
                console.log('Processing input:', input.name, 'value:', input.value, 'weight:', input.dataset.weight);
                calculateWeightageScore(input);
            });
            updateSummaryTotals();
        };

        // Recalculate all scores when page loads
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Page loaded, recalculating all scores...');
            setTimeout(() => {
                recalculateAllScores();
            }, 100);
        });
        
        // Function to check all elements
        window.debugElements = function() {
            console.log('=== ELEMENT INFO ===');
            console.log('Achievement inputs found:', document.querySelectorAll('.achievement-input').length);
            console.log('Score elements found:', document.querySelectorAll('[id*="-score-"]').length);
            console.log('Summary elements found:', document.querySelectorAll('[id*="-total-"]').length);
            
            document.querySelectorAll('.achievement-input').forEach((input, index) => {
                console.log(`Input ${index}:`, {
                    name: input.name,
                    value: input.value,
                    weight: input.dataset.weight,
                    id: input.id
                });
            });
        };

        // Function to update summary totals
        function updateSummaryTotals() {
            // Calculate total weightage count (only for visible rows)
            let totalWeightage = 0;
            document.querySelectorAll('.activity-row').forEach(row => {
                // Only include visible rows (not hidden by department filter)
                if (row.style.display !== 'none') {
                    const weightageCell = row.querySelector('td:nth-child(6)'); // Weightage column
                    if (weightageCell) {
                        const weightageValue = parseFloat(weightageCell.textContent) || 0;
                        // Don't convert to decimal - use the raw weightage values
                        totalWeightage += weightageValue;
                    }
                }
            });
            
            // Update total weightage count
            const totalWeightageElement = document.getElementById('total-weightage-count');
            if (totalWeightageElement) {
                totalWeightageElement.textContent = Math.round(totalWeightage) + '%';
            }
            
            // Calculate totals for each quarter (only for visible rows)
            const quarters = ['q1', 'q2', 'q3', 'q4'];
            
            quarters.forEach(quarter => {
                // Calculate total achievement for this quarter
                let totalAchievement = 0;
                let achievementCount = 0;
                
                document.querySelectorAll(`input[name*="[${quarter}][achievement]"]`).forEach(input => {
                    // Only include inputs from visible rows
                    const row = input.closest('.activity-row');
                    if (row && row.style.display !== 'none') {
                        const value = parseFloat(input.value) || 0;
                        if (value > 0) {
                            totalAchievement += value;
                            achievementCount++;
                        }
                    }
                });
                
                // Calculate total weightage score for this quarter
                let totalWeightageScore = 0;
                
                document.querySelectorAll(`[id^="${quarter}-score-"]`).forEach(scoreElement => {
                    // Only include score elements from visible rows
                    const row = scoreElement.closest('.activity-row');
                    if (row && row.style.display !== 'none') {
                        const value = parseFloat(scoreElement.value) || 0;
                        totalWeightageScore += value;
                    }
                });
                
                // Update the summary row
                const achievementElement = document.getElementById(`${quarter}-total-achievement`);
                const scoreElement = document.getElementById(`${quarter}-total-weightage-score`);
                
                if (achievementElement) {
                    achievementElement.textContent = Math.round(totalAchievement) + '%';
                }
                
                if (scoreElement) {
                    scoreElement.textContent = totalWeightageScore.toFixed(2) + '%';
                }
            });
        }

        // Function to check if a quarter is already filled/submitted
        function checkQuarterStatus(selectedQuarter) {
            // FIXED: Always show submit button - users can submit data for multiple departments
            // The system now allows submission for different departments in the same quarter
            showSubmitButton();
            
            console.log(`Quarter ${selectedQuarter} status check: Always allowing submission for multiple departments`);
        }

        // Function to show submit button
        function showSubmitButton() {
            const submitBtn = document.getElementById('submitBtn');
            if (submitBtn) {
                submitBtn.style.display = 'inline-flex';
                submitBtn.disabled = false;
            }
        }

        // Function to hide submit button
        function hideSubmitButton() {
            const submitBtn = document.getElementById('submitBtn');
            if (submitBtn) {
                submitBtn.style.display = 'none';
                submitBtn.disabled = true;
            }
        }

        // Quarter status message functions removed - no longer blocking submissions

        // --- Setup ---
        // Populate dropdown immediately
        populateDepartmentDropdown();
        
        // Initialize weightage scores for existing values with a small delay
        setTimeout(() => {
            initializeWeightageScores();
            updateSummaryTotals();
        }, 100);
        
        // Initialize with Q1 selected by default
        setTimeout(() => {
            filterTable();
        }, 200);
        
        // Force recalculation after everything is loaded
        setTimeout(() => {
            console.log('Force recalculating all scores...');
            recalculateAllScores();
        }, 500);
        
        // Check quarter status on page load
        setTimeout(() => {
            const quarterFilter = document.getElementById('quarterFilter');
            if (quarterFilter) {
                checkQuarterStatus(quarterFilter.value);
            }
        }, 300);
        
        // Setup modal functionality
        setupModal();

        // Attach event listeners
        const showSelectedBtn = document.getElementById('showSelected');
        const clearFiltersBtn = document.getElementById('clearFilters');
        const departmentFilterSelect = document.getElementById('departmentFilter');
        const quarterFilterSelect = document.getElementById('quarterFilter');

        if (showSelectedBtn) showSelectedBtn.addEventListener('click', filterTable);
        if (clearFiltersBtn) clearFiltersBtn.addEventListener('click', resetAllFilters);
        if (departmentFilterSelect) departmentFilterSelect.addEventListener('change', filterTable);
        if (quarterFilterSelect) quarterFilterSelect.addEventListener('change', filterTable);
    }
    
    // Run the setup function for the page
    initializePage();
    
    // Initialize achievement form handling
    initializeAchievementForm();
    
    // DYNAMIC UPDATE: Listen for real-time updates from edit form
    setupDynamicUpdateListener();
  });
  
  // Function to set up dynamic update listener
  function setupDynamicUpdateListener() {
    try {
      // Listen for localStorage changes (from other tabs)
      window.addEventListener('storage', function(e) {
        if (e.key === 'dynamic_quarterly_update') {
          const updateData = JSON.parse(e.newValue);
          updateViewDynamically(updateData);
        }
      });
      
      // Listen for custom events (same tab)
      window.addEventListener('quarterlyDataUpdated', function(e) {
        updateViewDynamically(e.detail);
      });
      
      // Check for immediate updates on page load
      const liveUpdateData = sessionStorage.getItem('live_update_data');
      if (liveUpdateData) {
        const updateData = JSON.parse(liveUpdateData);
        updateViewDynamically(updateData);
        sessionStorage.removeItem('live_update_data');
      }
      
    } catch (error) {
      // Ignore errors
    }
  }
  
  // Function to update view dynamically with new data
  function updateViewDynamically(updateData) {
    try {
      const { quarter, detailId, achievement, inputValue } = updateData;
      
      // Find the corresponding input field in this view
      const inputSelector = `input[name*="[${detailId}][${quarter}][achievement]"]`;
      const achievementInput = document.querySelector(inputSelector);
      
      if (achievementInput) {
        // Update the input value
        achievementInput.value = inputValue;
        
        // Add visual feedback
        achievementInput.style.backgroundColor = '#d4edda';
        achievementInput.style.transition = 'background-color 0.3s ease';
        
        // Remove highlight after 2 seconds
        setTimeout(() => {
          achievementInput.style.backgroundColor = '';
        }, 2000);
        
        // Recalculate scores
        if (typeof recalculateAllScores === 'function') {
          recalculateAllScores();
        }
        
        // Show update notification
        showDynamicUpdateNotification(`Updated ${quarter.toUpperCase()} achievement: ${inputValue}%`);
      }
      
    } catch (error) {
      // Ignore errors
    }
  }
  
  // Function to show dynamic update notification
  function showDynamicUpdateNotification(message) {
    try {
      const notification = document.createElement('div');
      notification.className = 'fixed top-4 right-4 z-50 px-4 py-2 rounded-lg shadow-lg text-white font-medium bg-green-500 transition-all duration-300 text-sm';
      notification.textContent = message;
      document.body.appendChild(notification);
      
      setTimeout(() => {
        if (notification.parentNode) {
          notification.parentNode.removeChild(notification);
        }
      }, 2000);
    } catch (error) {
      // Ignore errors
    }
  }
</script>
