                    <th class="px-4 py-3 text-center text-sm font-medium text-gray-700">Employee Remarks</th>
                    <th class="px-4 py-3 text-center text-sm font-medium text-gray-700">L1 Remarks</th>
                    <th class="px-4 py-3 text-center text-sm font-medium text-gray-700">L2 Remarks</th>
                    <th class="px-4 py-3 text-center text-sm font-medium text-gray-700">L1 %</th>
