          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-5 rounded-lg border border-blue-200">
            <h4 class="font-semibold text-blue-800 mb-4 flex items-center">
              <i class="fas fa-chart-bar mr-2 text-blue-600"></i>
              Quarter Summary
            </h4>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div class="text-center">
                <div class="text-2xl font-bold text-gray-800" id="quarterTotalTarget">0</div>
                <div class="text-sm text-gray-600">Total Target</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-green-600" id="quarterTotalAchievement">0</div>
                <div class="text-sm text-gray-600">Total Achievement</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold" id="quarterPercentage">0%</div>
                <div class="text-sm text-gray-600">Overall %</div>
              </div>
              <div class="text-center">
                <span id="quarterStatus" class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold">
