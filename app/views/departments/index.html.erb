<body class="bg-gray-50">
    <div class="ml-64 p-6 bg-gray-50 min-h-screen">
        <div class="max-w-7xl mx-auto">
            <!-- Department Form Section -->
            <div class="bg-white p-6 rounded-lg shadow-md mb-6">
                <h2 class="text-2xl font-bold text-gray-800 mb-6">Department Management</h2>
                
                <!-- Error Display -->
                <div id="error-container" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 hidden">
                    <h4 id="error-title"></h4>
                    <ul id="error-list"></ul>
                </div>

                <form id="department-form">
                    <!-- Top Fields -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                        <div>
                            <label for="department_type" class="block text-sm font-medium text-gray-700">Department / Region</label>
                            <input type="text" id="department_type" name="department_type" class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent" placeholder="Enter department/region">
                        </div>
                        <div>
                            <label for="theme_id" class="block text-sm font-medium text-gray-700">Theme ID</label>
                            <input type="number" id="theme_id" name="theme_id" class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent" placeholder="Enter theme ID">
                        </div>
                        <div>
                            <label for="theme_name" class="block text-sm font-medium text-gray-700">Theme Name</label>
                            <input type="text" id="theme_name" name="theme_name" class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent" placeholder="Enter theme name">
                        </div>
                    </div>

                    <!-- Activities Section -->
                    <div class="mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-semibold text-gray-800">Activities</h3>
                            <button type="button" id="add-activity" class="inline-flex items-center px-4 py-2 bg-gray-600 text-white text-sm font-medium rounded-md hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                                </svg>
                                Add Activity
                            </button>
                        </div>
                        
                        <div id="activities-container"></div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex items-center gap-4">
                        <button type="button" id="cancel-btn" class="inline-flex items-center px-4 py-2 bg-gray-600 text-white text-sm font-medium rounded-md hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                            Cancel
                        </button>
                        
                        <button type="submit" id="submit-button" class="inline-flex items-center px-6 py-2 bg-gray-600 text-white text-sm font-medium rounded-md hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                            Save Department
                        </button>
                    </div>
                </form>
            </div>

            <!-- Department List Section -->
            <div class="bg-white rounded-lg shadow-md">
                <div class="p-6 border-b border-gray-200">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 16h6M7 8h6m-6 4h6m9 2V9a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                            </svg>
                            <h2 class="text-xl font-semibold text-gray-800">Department List</h2>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="relative">
                                <input type="text" id="search-input" placeholder="Search..." class="pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent">
                                <svg class="absolute left-3 top-2.5 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Department</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Theme ID</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Theme Name</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Activities</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200" id="departments-table">
                            <!-- Sample Data -->
                            <tr class="hover:bg-gray-50" data-department-id="1">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">DEPT1</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">111</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">11</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">23</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                        3 activities
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <button type="button" class="edit-btn text-gray-600 hover:text-gray-900 mr-4" data-department-id="1">
                                        Edit
                                    </button>
                                    <button type="button" class="delete-btn text-red-600 hover:text-red-900" data-department-id="1">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                            <tr class="hover:bg-gray-50" data-department-id="2">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">DEPT2</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">22ef</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">3</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">ff</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                        1 activities
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <button type="button" class="edit-btn text-gray-600 hover:text-gray-900 mr-4" data-department-id="2">
                                        Edit
                                    </button>
                                    <button type="button" class="delete-btn text-red-600 hover:text-red-900" data-department-id="2">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Department Management System
        class DepartmentManager {
            constructor() {
                this.activityIndex = 0;
                this.isEditing = false;
                this.editingId = null;
                this.departments = [
                    {
                        id: 1,
                        department_type: '111',
                        theme_id: 11,
                        theme_name: '23',
                        activities: [
                            { id: 1, activity_id: 1, activity_name: 'Activity 1', unit: 'Units', weight: 1.0 },
                            { id: 2, activity_id: 2, activity_name: 'Activity 2', unit: 'Units', weight: 2.0 },
                            { id: 3, activity_id: 3, activity_name: 'Activity 3', unit: 'Units', weight: 3.0 }
                        ]
                    },
                    {
                        id: 2,
                        department_type: '22ef',
                        theme_id: 3,
                        theme_name: 'ff',
                        activities: [
                            { id: 4, activity_id: 4, activity_name: 'Activity 4', unit: 'Units', weight: 1.0 }
                        ]
                    }
                ];
                this.init();
            }

            init() {
                this.bindEvents();
                this.addDefaultActivity();
            }

            bindEvents() {
                // Add Activity button
                document.getElementById('add-activity').addEventListener('click', (e) => {
                    e.preventDefault();
                    this.addActivity();
                });

                // Form submission
                document.getElementById('department-form').addEventListener('submit', (e) => {
                    e.preventDefault();
                    this.handleFormSubmit();
                });

                // Cancel button
                document.getElementById('cancel-btn').addEventListener('click', (e) => {
                    e.preventDefault();
                    this.resetForm();
                });

                // Search functionality
                document.getElementById('search-input').addEventListener('input', (e) => {
                    this.handleSearch(e.target.value);
                });

                // Event delegation for dynamic buttons
                document.addEventListener('click', (e) => {
                    if (e.target.classList.contains('remove-activity') || e.target.closest('.remove-activity')) {
                        e.preventDefault();
                        this.removeActivity(e.target.closest('.activity-fields'));
                    }

                    if (e.target.classList.contains('edit-btn')) {
                        e.preventDefault();
                        this.editDepartment(e.target.dataset.departmentId);
                    }

                    if (e.target.classList.contains('delete-btn')) {
                        e.preventDefault();
                        this.deleteDepartment(e.target.dataset.departmentId);
                    }
                });
            }

            addActivity() {
                const container = document.getElementById('activities-container');
                const activityHtml = this.getActivityTemplate(this.activityIndex);
                container.insertAdjacentHTML('beforeend', activityHtml);
                this.activityIndex++;
            }

            addDefaultActivity() {
                const container = document.getElementById('activities-container');
                if (container.children.length === 0) {
                    this.addActivity();
                }
            }

            getActivityTemplate(index) {
                return `
                    <div class="activity-fields border border-gray-200 rounded-md p-4 mb-4 bg-gray-50">
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Activity ID</label>
                                <input type="number" name="activities[${index}][activity_id]" class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent" placeholder="Enter activity ID">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Activity Name</label>
                                <input type="text" name="activities[${index}][activity_name]" class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent" placeholder="Enter activity name">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Unit</label>
                                <input type="text" name="activities[${index}][unit]" class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent" placeholder="Enter unit">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Weight</label>
                                <input type="number" name="activities[${index}][weight]" step="0.01" class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent" placeholder="Enter weight">
                            </div>
                        </div>
                        <div class="mt-3 flex justify-end">
                            <button type="button" class="remove-activity inline-flex items-center px-3 py-1 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                </svg>
                                Remove
                            </button>
                        </div>
                        <input type="hidden" name="activities[${index}][id]" value="">
                    </div>
                `;
            }

            removeActivity(activityElement) {
                const container = document.getElementById('activities-container');
                activityElement.remove();
                
                // Ensure at least one activity remains
                if (container.children.length === 0) {
                    this.addActivity();
                }
            }

            handleFormSubmit() {
                const formData = new FormData(document.getElementById('department-form'));
                const data = this.serializeFormData(formData);
                
                if (this.isEditing) {
                    this.updateDepartment(data);
                } else {
                    this.createDepartment(data);
                }
            }

            serializeFormData(formData) {
                const data = {
                    department_type: formData.get('department_type'),
                    theme_id: parseInt(formData.get('theme_id')),
                    theme_name: formData.get('theme_name'),
                    activities: []
                };

                // Collect activities
                const activities = {};
                for (let [key, value] of formData.entries()) {
                    if (key.startsWith('activities[')) {
                        const match = key.match(/activities\[(\d+)\]\[([^\]]+)\]/);
                        if (match) {
                            const index = match[1];
                            const field = match[2];
                            if (!activities[index]) activities[index] = {};
                            activities[index][field] = value;
                        }
                    }
                }

                // Convert to array and filter out empty activities
                for (let index in activities) {
                    const activity = activities[index];
                    if (activity.activity_name && activity.activity_name.trim()) {
                        data.activities.push({
                            id: activity.id || null,
                            activity_id: parseInt(activity.activity_id) || null,
                            activity_name: activity.activity_name,
                            unit: activity.unit || '',
                            weight: parseFloat(activity.weight) || 0
                        });
                    }
                }

                return data;
            }

            createDepartment(data) {
                // Simulate API call
                const newId = Math.max(...this.departments.map(d => d.id), 0) + 1;
                data.id = newId;
                this.departments.push(data);
                this.updateDepartmentList();
                this.resetForm();
                this.showSuccess('Department created successfully!');
            }

            updateDepartment(data) {
                // Simulate API call
                const index = this.departments.findIndex(d => d.id === parseInt(this.editingId));
                if (index !== -1) {
                    data.id = parseInt(this.editingId);
                    this.departments[index] = data;
                    this.updateDepartmentList();
                    this.resetForm();
                    this.showSuccess('Department updated successfully!');
                }
            }

            editDepartment(departmentId) {
                const department = this.departments.find(d => d.id === parseInt(departmentId));
                if (!department) return;

                // Fill form with department data
                document.getElementById('department_type').value = department.department_type || '';
                document.getElementById('theme_id').value = department.theme_id || '';
                document.getElementById('theme_name').value = department.theme_name || '';

                // Clear and populate activities
                const container = document.getElementById('activities-container');
                container.innerHTML = '';
                this.activityIndex = 0;

                if (department.activities && department.activities.length > 0) {
                    department.activities.forEach(activity => {
                        const activityHtml = this.getActivityTemplate(this.activityIndex);
                        container.insertAdjacentHTML('beforeend', activityHtml);
                        
                        const activityDiv = container.lastElementChild;
                        activityDiv.querySelector('input[name*="activity_id"]').value = activity.activity_id || '';
                        activityDiv.querySelector('input[name*="activity_name"]').value = activity.activity_name || '';
                        activityDiv.querySelector('input[name*="unit"]').value = activity.unit || '';
                        activityDiv.querySelector('input[name*="weight"]').value = activity.weight || '';
                        activityDiv.querySelector('input[name*="[id]"]').value = activity.id || '';
                        
                        this.activityIndex++;
                    });
                } else {
                    this.addActivity();
                }

                this.isEditing = true;
                this.editingId = departmentId;
                document.getElementById('submit-button').textContent = 'Update Department';
                
                // Scroll to form
                document.getElementById('department-form').scrollIntoView({ behavior: 'smooth' });
            }

            deleteDepartment(departmentId) {
                if (confirm('Are you sure you want to delete this department?')) {
                    this.departments = this.departments.filter(d => d.id !== parseInt(departmentId));
                    this.updateDepartmentList();
                    this.showSuccess('Department deleted successfully!');
                }
            }

            resetForm() {
                document.getElementById('department-form').reset();
                const container = document.getElementById('activities-container');
                container.innerHTML = '';
                this.activityIndex = 0;
                this.addActivity();
                
                this.isEditing = false;
                this.editingId = null;
                document.getElementById('submit-button').textContent = 'Save Department';
                this.hideError();
            }

            updateDepartmentList() {
                const tbody = document.getElementById('departments-table');
                tbody.innerHTML = '';
                
                this.departments.forEach(department => {
                    const row = document.createElement('tr');
                    row.className = 'hover:bg-gray-50';
                    row.dataset.departmentId = department.id;
                    
                    row.innerHTML = `
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                            DEPT${department.id}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            ${department.department_type}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            ${department.theme_id}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            ${department.theme_name}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                ${department.activities.length} activities
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                            <button type="button" class="edit-btn text-gray-600 hover:text-gray-900 mr-4" data-department-id="${department.id}">
                                Edit
                            </button>
                            <button type="button" class="delete-btn text-red-600 hover:text-red-900" data-department-id="${department.id}">
                                Delete
                            </button>
                        </td>
                    `;
                    
                    tbody.appendChild(row);
                });
            }

            handleSearch(searchTerm) {
              const term = searchTerm.toLowerCase();Employee DetEmployee Det

              this.updateDepartmentList(); // Re-render first to get full list before filtering

              const rows = document.querySelectorAll('#departments-table tr');

              rows.forEach(row => {
                  const cells = row.querySelectorAll('td');
                  const matchFound = Array.from(cells).some(cell => 
                      cell.textContent.toLowerCase().includes(term)
                  );

                  row.style.display = matchFound ? '' : 'none';
              });
          }

            showSuccess(message) {
                // You can implement a success message system here
                console.log('Success:', message);
            }

            showError(message) {
                const errorContainer = document.getElementById('error-container');
                const errorTitle = document.getElementById('error-title');
                const errorList = document.getElementById('error-list');
                
                errorTitle.textContent = 'Error occurred:';
                errorList.innerHTML = `<li>${message}</li>`;
                errorContainer.classList.remove('hidden');
            }

            hideError() {
                const errorContainer = document.getElementById('error-container');
                errorContainer.classList.add('hidden');
            }
        }

        // Initialize the department manager when DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            new DepartmentManager();
        });
    </script>
</body>
</html>