<div class="main-content sidebar-hidden">
  <body class="bg-gray-50">
    <div class="ml-64 p-6 bg-gray-50 min-h-screen">
      <div class="max-w-7xl mx-auto">
        <div class="bg-white p-6 rounded-lg shadow-md mb-6">
          <h2 class="text-2xl font-bold text-gray-800 mb-6">Department Management</h2>
          
          <div id="success-container" class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4 hidden">
            <div id="success-message"></div>
          </div>
   
          <div id="error-container" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 hidden">
            <h4 id="error-title"></h4>
            <ul id="error-list"></ul>
          </div>

          <!-- Bulk Upload Section -->
          <div class="bg-white p-6 rounded-lg shadow-md mb-6">
            <div class="mb-8">
              <h2 class="text-2xl font-semibold text-gray-800 mb-4">Bulk Upload Departments & Activities</h2>

              <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6 w-full">
                <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
                  
                  <form action="/departments/import" method="post" enctype="multipart/form-data" class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto">
                    <input type="file" name="file" accept=".xlsx,.xls,.csv" required class="border border-gray-300 p-2 rounded-md w-full sm:w-auto">
                    <input type="submit" value="Upload" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded shadow cursor-pointer">
                  </form>

                  <a href="/departments/export.xlsx" class="bg-green-500 hover:bg-green-600 text-white px-5 py-2 rounded shadow">Export Departments</a>
                </div>

                <p class="text-sm text-gray-500 mt-4 italic">
                  * Excel must have columns: <strong>Department</strong>, <strong>Employee Name</strong>, <strong>Theme Name</strong>, <strong>Activity Name</strong>, <strong>Unit</strong>, <strong>Weight</strong>
                </p>
              </div>
            </div>
            
            <!-- Form Section -->
            <form id="department-form" method="POST" action="/departments">
              <input type="hidden" name="authenticity_token" value="">
              <input type="hidden" name="_method" value="POST" id="form-method">
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <!-- Department Dropdown -->
                <div>
                  <label for="department_department_type" class="block text-sm font-medium text-gray-700">
                    Department / Region
                  </label>
                  <select id="department_department_type" name="department[department_type]" 
                    class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm 
                          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" required>
                    <option value="">Select Department / Region</option>
                    <% @employee_departments.each do |dept| %>
                      <option value="<%= dept %>"><%= dept %></option>
                    <% end %>
                  </select>
                </div>

                <!-- Employee Dropdown -->
                <div>
                  <label for="department_employee_reference" class="block text-sm font-medium text-gray-700">
                    Employee Name
                  </label>
                  <select id="department_employee_reference" name="department[employee_reference]" 
                    class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm 
                          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" required>
                    <option value="">Select Employee</option>
                    <% @employees.each do |employee| %>
                      <option value="<%= employee.employee_id %>" data-department="<%= employee.department %>">
                        <%= employee.employee_name %> (<%= employee.employee_id %>)
                      </option>
                    <% end %>
                  </select>
                </div>
              </div>

              <!-- Activities Section -->
              <div class="mb-6">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="text-lg font-semibold text-gray-800">Activities</h3>
                  <button type="button" id="add-activity" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Add Activity
                  </button>
                </div>
                
                <div id="activities-container">
                </div>
              </div>

              <div class="flex items-center gap-4">
                <button type="button" id="cancel-btn" class="inline-flex items-center px-4 py-2 bg-gray-600 text-white text-sm font-medium rounded-md hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                  Cancel
                </button>
                
                <button type="submit" id="submit-button" class="inline-flex items-center px-6 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                  Save Department
                </button>
              </div>
            </form>
          </div>

          <!-- Departments List -->
          <div class="bg-white rounded-lg shadow-md">
            <div class="p-6 border-b border-gray-200">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 16h6M7 8h6m-6 4h6m9 2V9a2 2 0 00-2-2H5a2 2 0 002 2v8a2 2 0 002 2z"></path>
                  </svg>
                  <h2 class="text-xl font-semibold text-gray-800">Department List</h2>
                </div>
                <div class="flex items-center gap-4">
                  <div class="relative">
                    <input type="text" id="search-input" placeholder="Search departments..." class="pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                    <svg class="absolute left-3 top-2.5 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                  </div>
                </div>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Department</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee Name</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Activities</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200" id="departments-table">
                </tbody>
              </table>
            </div>
            
            <div id="empty-state" class="text-center py-12 hidden">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No departments</h3>
              <p class="mt-1 text-sm text-gray-500">Get started by creating a new department.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</div>

<script>
class DepartmentManager {
  constructor() {
    console.log('DepartmentManager constructor called');
    this.activityIndex = 0;
    this.isEditing = false;
    this.editingId = null;
    this.isSubmitting = false;
    this.isAddingActivity = false;
    this.departments = [];
    this.employeeDepartments = [];
    this.employees = [];
    this.init();
  }

  async init() {
    this.bindEvents();
    this.addDefaultActivity();
    await this.loadEmployeeData();
    await this.loadDepartments();
  }

  async loadEmployeeData() {
    try {
      // For now, we'll use the data embedded in the page
      // since the dropdowns should be populated from ERB
      console.log('Employee departments:', window.employeeDepartments);
      console.log('Employees:', window.employees);
      
      if (window.employeeDepartments) {
        this.employeeDepartments = window.employeeDepartments;
      }

      if (window.employees) {
        this.employees = window.employees;
      }
    } catch (error) {
      console.error('Error loading employee data:', error);
    }
  }

  populateDropdownsFromPageData() {
    // This method is no longer needed since we populate directly in ERB
    console.log('Using ERB-populated dropdowns');
  }

  populateDepartmentDropdown() {
    // Department dropdown is now populated directly in ERB
    console.log('Department dropdown populated via ERB');
  }

  populateEmployeeDropdown() {
    // Employee dropdown is now populated directly in ERB
    console.log('Employee dropdown populated via ERB');
  }

  bindEvents() {
    // Remove any existing event listeners to prevent duplicates
    this.removeEventListeners();
    
    // Add event listeners with proper error handling
    const addActivityBtn = document.getElementById('add-activity');
    if (addActivityBtn) {
      addActivityBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        this.addActivity();
      });
    }

    const departmentForm = document.getElementById('department-form');
    if (departmentForm) {
      departmentForm.addEventListener('submit', (e) => {
        e.preventDefault();
        e.stopPropagation();
        this.handleFormSubmit();
      });
    }

    const cancelBtn = document.getElementById('cancel-btn');
    if (cancelBtn) {
      cancelBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        this.resetForm();
      });
    }

    const searchInput = document.getElementById('search-input');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        this.handleSearch(e.target.value);
      });
    }

    // Department change event to filter employees
    const deptSelect = document.getElementById('department_department_type');
    if (deptSelect) {
      deptSelect.addEventListener('change', (e) => {
        this.filterEmployeesByDepartment(e.target.value);
      });
    }

    // Use event delegation for dynamic elements
    document.addEventListener('click', (e) => {
      if (e.target.closest('.remove-activity')) {
        e.preventDefault();
        e.stopPropagation();
        this.removeActivity(e.target.closest('.activity-fields'));
      }

      if (e.target.classList.contains('edit-btn')) {
        e.preventDefault();
        e.stopPropagation();
        this.editDepartment(e.target.dataset.departmentId);
      }

      if (e.target.classList.contains('delete-btn')) {
        e.preventDefault();
        e.stopPropagation();
        this.deleteDepartment(e.target.dataset.departmentId);
      }
    });
  }

  removeEventListeners() {
    // This method can be used to clean up event listeners if needed
    // For now, we'll rely on the single instance approach
    console.log('Event listeners bound for DepartmentManager instance');
  }

  filterEmployeesByDepartment(selectedDept) {
    const employeeSelect = document.getElementById('department_employee_reference');
    if (!employeeSelect || !selectedDept) {
      // Show all employees if no department selected
      const options = employeeSelect.querySelectorAll('option[data-department]');
      options.forEach(option => option.style.display = '');
      return;
    }

    // Hide/show options based on department
    const options = employeeSelect.querySelectorAll('option[data-department]');
    options.forEach(option => {
      if (option.getAttribute('data-department') === selectedDept) {
        option.style.display = '';
      } else {
        option.style.display = 'none';
      }
    });

    // Reset employee selection
    employeeSelect.value = '';
  }

  addActivity() {
    // Prevent rapid clicking
    if (this.isAddingActivity) {
      console.log('Adding activity already in progress, ignoring...');
      return;
    }

    this.isAddingActivity = true;
    
    const container = document.getElementById('activities-container');
    const activityHtml = this.getActivityTemplate(this.activityIndex);
    container.insertAdjacentHTML('beforeend', activityHtml);
    this.activityIndex++;
    
    // Reset flag after a short delay
    setTimeout(() => {
      this.isAddingActivity = false;
    }, 300);
  }

  addDefaultActivity() {
    const container = document.getElementById('activities-container');
    if (container.children.length === 0) {
      this.addActivity();
    }
  }

  getActivityTemplate(index) {
    return `
      <div class="activity-fields border border-gray-200 rounded-md p-4 mb-4 bg-gray-50">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Theme Name</label>
            <input type="text" name="department[activities_attributes][${index}][theme_name]" class="mt-1 block w-full border rounded-md px-3 py-2 text-sm" placeholder="Enter theme name" required>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Activity Name</label>
            <input type="text" name="department[activities_attributes][${index}][activity_name]" class="mt-1 block w-full border rounded-md px-3 py-2 text-sm" placeholder="Enter activity name" required>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Unit</label>
            <input type="text" name="department[activities_attributes][${index}][unit]" class="mt-1 block w-full border rounded-md px-3 py-2 text-sm" placeholder="Enter unit" required>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Weight</label>
            <input type="number" name="department[activities_attributes][${index}][weight]" step="0.01" class="mt-1 block w-full border rounded-md px-3 py-2 text-sm" placeholder="Enter weight" required>
          </div>
        </div>
        <div class="mt-3 flex justify-end">
          <button type="button" class="remove-activity bg-red-600 text-white text-sm px-3 py-1 rounded-md hover:bg-red-700">
            Remove
          </button>
        </div>
        <input type="hidden" name="department[activities_attributes][${index}][id]" value="">
        <input type="hidden" name="department[activities_attributes][${index}][_destroy]" value="false">
      </div>
    `;
  }

  removeActivity(activityElement) {
    const container = document.getElementById('activities-container');

    if (container.children.length > 1) {
      const idInput = activityElement.querySelector('input[name*="[id]"]');
      if (idInput && idInput.value) {
        const destroyInput = activityElement.querySelector('input[name*="[_destroy]"]');
        if (destroyInput) {
          destroyInput.value = 'true';
          activityElement.style.display = 'none';
        }
      } else {
        activityElement.remove();
      }
    } else {
      const inputs = activityElement.querySelectorAll('input[type!="hidden"]');
      inputs.forEach(input => input.value = '');
      this.showError('At least one activity is required');
    }
  }

  async handleFormSubmit() {
    // Prevent multiple submissions
    if (this.isSubmitting) {
      console.log('Form submission already in progress, ignoring...');
      return;
    }

    this.isSubmitting = true;
    this.hideError();
    this.hideSuccess();

    // Disable submit button to prevent multiple clicks
    const submitBtn = document.getElementById('submit-button');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Saving...';
    }

    const form = document.getElementById('department-form');
    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: this.isEditing ? 'PATCH' : 'POST',
        body: formData,
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
        }
      });

      const result = await response.json();

      if (response.ok && result.success !== false) {
        this.showSuccess(this.isEditing ? 'Department updated successfully!' : 'Department created successfully!');
        this.resetForm();
        await this.loadDepartments();
      } else {
        const errors = result.errors || ['Error saving department. Please check your input.'];
        this.showError(errors.join(', '));
      }
    } catch (error) {
      console.error('Form submission error:', error);
      this.showError('Network error. Please try again.');
    } finally {
      // Re-enable submit button
      this.isSubmitting = false;
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = this.isEditing ? 'Update Department' : 'Save Department';
      }
    }
  }

  async loadDepartments() {
    try {
      const response = await fetch('/departments.json');
      if (response.ok) {
        this.departments = await response.json();
        this.updateDepartmentList();
      }
    } catch (error) {
      console.error('Error loading departments:', error);
    }
  }

  async editDepartment(departmentId) {
    try {
      const response = await fetch(`/departments/${departmentId}/edit_data`);
      if (response.ok) {
        const department = await response.json();
        this.populateForm(department);
      }
    } catch (error) {
      this.showError('Error loading department data');
    }
  }

  populateForm(department) {
    document.getElementById('department_department_type').value = department.department_type || '';
    
    // First filter employees by department, then set the employee
    if (department.department_type) {
      this.filterEmployeesByDepartment(department.department_type);
      // Wait a bit for the dropdown to be populated
      setTimeout(() => {
        document.getElementById('department_employee_reference').value = department.employee_reference || '';
      }, 100);
    }

    const form = document.getElementById('department-form');
    form.action = `/departments/${department.id}`;
    document.getElementById('form-method').value = 'PATCH';

    const container = document.getElementById('activities-container');
    container.innerHTML = '';
    
    this.activityIndex = 0;

    if (department.activities && department.activities.length > 0) {
      department.activities.forEach(activity => {
        const html = this.getActivityTemplate(this.activityIndex);
        container.insertAdjacentHTML('beforeend', html);

        const currentActivity = container.lastElementChild;
        
        currentActivity.querySelector('input[name*="[theme_name]"]').value = activity.theme_name || '';
        currentActivity.querySelector('input[name*="[activity_name]"]').value = activity.activity_name || '';
        currentActivity.querySelector('input[name*="[unit]"]').value = activity.unit || '';
        currentActivity.querySelector('input[name*="[weight]"]').value = activity.weight || '';
        currentActivity.querySelector('input[name*="[id]"]').value = activity.id || '';

        this.activityIndex++;
      });
    } else {
      this.addActivity();
    }

    this.isEditing = true;
    this.editingId = department.id;
    document.getElementById('submit-button').textContent = 'Update Department';
    
    document.getElementById('department-form').scrollIntoView({ behavior: 'smooth' });
  }

  async deleteDepartment(departmentId) {
    if (!confirm('Are you sure you want to delete this department?')) return;

    try {
      const response = await fetch(`/departments/${departmentId}`, {
        method: 'DELETE',
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
        }
      });

      if (response.ok) {
        this.showSuccess('Department deleted successfully!');
        await this.loadDepartments();
      } else {
        this.showError('Error deleting department');
      }
    } catch (error) {
      this.showError('Network error. Please try again.');
    }
  }

  resetForm() {
    const form = document.getElementById('department-form');
    form.reset();
    form.action = '/departments';
    document.getElementById('form-method').value = 'POST';

    const container = document.getElementById('activities-container');
    container.innerHTML = '';
    this.activityIndex = 0;
    this.addActivity();

    this.isEditing = false;
    this.editingId = null;
    document.getElementById('submit-button').textContent = 'Save Department';

    // Reset employee dropdown to show all employees
    const options = document.querySelectorAll('#department_employee_reference option[data-department]');
    options.forEach(option => option.style.display = '');

    this.hideError();
    this.hideSuccess();
  }

  updateDepartmentList() {
    const tbody = document.getElementById('departments-table');
    const emptyState = document.getElementById('empty-state');
    tbody.innerHTML = '';

    if (this.departments.length === 0) {
      emptyState?.classList.remove('hidden');
    } else {
      emptyState?.classList.add('hidden');
      this.departments.forEach(dept => {
        // Use the employee_display_name from backend if available, otherwise fallback to manual lookup
        let employeeDisplay = dept.employee_display_name || 'N/A';
        
        // Fallback: if backend doesn't provide employee_display_name, construct it manually
        if (employeeDisplay === 'N/A' && dept.employee_reference) {
          const employee = this.employees.find(emp => emp.employee_id === dept.employee_reference);
          if (employee) {
            employeeDisplay = `${employee.employee_name} (${employee.employee_code || dept.employee_reference})`;
          } else {
            employeeDisplay = `N/A (${dept.employee_reference})`;
          }
        }

        const row = document.createElement('tr');
        row.className = 'hover:bg-gray-50';
        row.dataset.departmentId = dept.id;

        row.innerHTML = `
          <td class="px-6 py-4 text-sm font-medium text-gray-900">DEPT${dept.id}</td>
          <td class="px-6 py-4 text-sm text-gray-900">${dept.department_type || 'N/A'}</td>
          <td class="px-6 py-4 text-sm text-gray-900">${employeeDisplay}</td>
          <td class="px-6 py-4 text-sm text-gray-900">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
              ${dept.activities ? dept.activities.length : 0} ${dept.activities && dept.activities.length === 1 ? 'activity' : 'activities'}
            </span>
          </td>
          <td class="px-6 py-4 text-sm font-medium">
            <button type="button" class="edit-btn text-blue-600 hover:text-blue-900 mr-4" data-department-id="${dept.id}">Edit</button>
            <button type="button" class="delete-btn text-red-600 hover:text-red-900" data-department-id="${dept.id}">Delete</button>
          </td>
        `;
        tbody.appendChild(row);
      });
    }
  }

  handleSearch(term) {
    const rows = document.querySelectorAll('#departments-table tr');
    term = term.toLowerCase();

    rows.forEach(row => {
      const cells = row.querySelectorAll('td');
      const match = Array.from(cells).some(cell => cell.textContent.toLowerCase().includes(term));
      row.style.display = match ? '' : 'none';
    });
  }

  showSuccess(message) {
    const container = document.getElementById('success-container');
    const messageSpan = document.getElementById('success-message');
    messageSpan.textContent = message;
    container.classList.remove('hidden');
    setTimeout(() => this.hideSuccess(), 5000);
  }

  hideSuccess() {
    document.getElementById('success-container')?.classList.add('hidden');
  }

  showError(message) {
    const container = document.getElementById('error-container');
    document.getElementById('error-title').textContent = 'Error occurred:';
    document.getElementById('error-list').innerHTML = `<li>${message}</li>`;
    container.classList.remove('hidden');
  }

  hideError() {
    document.getElementById('error-container')?.classList.add('hidden');
  }

  // Cleanup method to prevent memory leaks
  destroy() {
    // Remove event listeners if needed
    console.log('DepartmentManager instance destroyed');
    departmentManagerInstance = null;
  }
}

// Initialize only once to prevent duplicate event handlers
let departmentManagerInstance = null;

function initializeDepartmentManager() {
  console.log('initializeDepartmentManager called');
  
  // Prevent multiple initializations
  if (departmentManagerInstance) {
    console.log('DepartmentManager already initialized, skipping...');
    return;
  }

  // Debug: Check if data is available
  console.log('Initializing DepartmentManager...');
  
  // Embed employee data in page for JavaScript access
  <% if @employee_departments %>
    window.employeeDepartments = <%= raw @employee_departments.to_json %>;
    console.log('Employee departments loaded:', window.employeeDepartments);
  <% else %>
    window.employeeDepartments = [];
    console.log('No employee departments found');
  <% end %>
  
  <% if @employees %>
    window.employees = <%= raw @employees.map { |emp| { employee_name: emp.employee_name, employee_id: emp.employee_id, department: emp.department } }.to_json %>;
    console.log('Employees loaded:', window.employees);
  <% else %>
    window.employees = [];
    console.log('No employees found');
  <% end %>
  
  // Check if dropdowns are populated
  const deptSelect = document.getElementById('department_department_type');
  const empSelect = document.getElementById('department_employee_reference');
  
  console.log('Department dropdown options:', deptSelect ? deptSelect.options.length : 'not found');
  console.log('Employee dropdown options:', empSelect ? empSelect.options.length : 'not found');
  
  // Create single instance
  departmentManagerInstance = new DepartmentManager();
  console.log('DepartmentManager initialized successfully');
}

// Use only one event listener to prevent duplicates
document.addEventListener('DOMContentLoaded', initializeDepartmentManager);

// For Turbo compatibility, but only if not already initialized
document.addEventListener('turbo:load', () => {
  if (!departmentManagerInstance) {
    initializeDepartmentManager();
  }
});

// Remove turbo:render listener as it's not needed and causes duplicates
</script>

