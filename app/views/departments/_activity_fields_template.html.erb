<template id="activity-template">
  <div class="activity-fields grid grid-cols-1 md:grid-cols-5 gap-4 mb-4 p-4 bg-gray-50 rounded-lg border">
    <input type="hidden" name="department[activities_attributes][NEW_RECORD][_destroy]" value="false" />
    
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1" for="department_activities_attributes_NEW_RECORD_activity_id">Activity ID</label>
      <input type="number" name="department[activities_attributes][NEW_RECORD][activity_id]" id="department_activities_attributes_NEW_RECORD_activity_id" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="ID" />
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1" for="department_activities_attributes_NEW_RECORD_activity_name">Activity Name</label>
      <input type="text" name="department[activities_attributes][NEW_RECORD][activity_name]" id="department_activities_attributes_NEW_RECORD_activity_name" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Enter Indicator" />
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1" for="department_activities_attributes_NEW_RECORD_description">Theme Name</label>
      <input type="text" name="department[activities_attributes][NEW_RECORD][description]" id="department_activities_attributes_NEW_RECORD_description" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Description" />
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1" for="department_activities_attributes_NEW_RECORD_unit">Unit</label>
      <input type="text" name="department[activities_attributes][NEW_RECORD][unit]" id="department_activities_attributes_NEW_RECORD_unit" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Unit (optional)" />
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1" for="department_activities_attributes_NEW_RECORD_weight">Weightage</label>
      <input type="number" step="0.01" name="department[activities_attributes][NEW_RECORD][weight]" id="department_activities_attributes_NEW_RECORD_weight" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="0.00" />
    </div>

    <div class="flex items-end">
      <button type="button" class="remove-activity inline-flex items-center px-3 py-2 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
        Remove
      </button>
    </div>
  </div>
</template>