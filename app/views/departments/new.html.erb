<div class="ml-64 p-6 bg-gray-50 min-h-screen">
  <div class="bg-white p-6 rounded-lg shadow-md max-w-6xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Add Department with Activities</h1>

    <% if @department.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <h4><%= pluralize(@department.errors.count, "error") %> prohibited this department from being saved:</h4>
        <ul>
          <% @department.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @department, local: true, id: "department-form" do |f| %>
      <!-- Top Fields -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <div>
          <%= f.label :department_type, "Department / Region", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :department_type, class: "mt-1 block w-full border border-gray-300 rounded-md px-2 py-1 text-sm", required: true %>
        </div>
        <div>
          <%= f.label :theme_id, "Theme ID", class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :theme_id, class: "mt-1 block w-full border border-gray-300 rounded-md px-2 py-1 text-sm", required: true %>
        </div>
        <div>
          <%= f.label :theme_name, "Theme Name", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :theme_name, class: "mt-1 block w-full border border-gray-300 rounded-md px-2 py-1 text-sm", required: true %>
        </div>
      </div>

      <!-- Activity Rows -->
      <h3 class="text-lg font-semibold mb-2">Activities</h3>
      <div id="activities">
        <%= f.fields_for :activities do |a| %>
          <%= render 'activity_fields', f: a %>
        <% end %>
      </div>

      <!-- Add Button -->
      <div class="my-4">
        <button type="button" id="add-activity" class="inline-block bg-blue-600 text-white px-4 py-2 text-sm rounded-md hover:bg-blue-700">
          ➕ Add Activity
        </button>
      </div>

      <!-- Submit -->
      <div>
        <%= f.submit "Submit", class: "bg-green-600 text-white px-6 py-2 rounded-md hover:bg-green-700", id: "submit-button" %>
      </div>
    <% end %>
  </div>
</div>

<%= render 'activity_fields_template' %>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const addButton = document.getElementById("add-activity");
  const container = document.getElementById("activities");
  const template = document.getElementById("activity-template");
  let index = <%= @department.activities.size %>;

  console.log("JavaScript loaded, initial index:", index);

  addButton.addEventListener("click", function(e) {
    e.preventDefault();
    console.log("Add button clicked, current index:", index);
    
    const newRow = template.innerHTML.replace(/NEW_RECORD/g, index);
    container.insertAdjacentHTML("beforeend", newRow);
    index++;
  });

  container.addEventListener("click", function(e) {
    if (e.target.classList.contains("remove-activity")) {
      e.preventDefault();
      console.log("Remove button clicked");
      
      const activityField = e.target.closest(".activity-fields");
      const destroyField = activityField.querySelector('input[name*="_destroy"]');
      
      if (destroyField) {
        destroyField.value = "1";
        activityField.style.display = "none";
      } else {
        activityField.remove();
      }
    }
  });

  // Form submission logging
  const form = document.getElementById("department-form");
  form.addEventListener("submit", function(e) {
    console.log("Form submitted");
    const formData = new FormData(form);
    console.log("Form data:", Object.fromEntries(formData));
  });
});
</script> 