<div class="min-h-screen bg-gray-50">
  <div class="ml-64 p-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
    
    <!-- Header Section -->
    <div class="flex items-center justify-between mb-6 border-b pb-4">
      <h1 class="text-3xl font-bold text-gray-800 flex items-center">
        <i class="fas fa-tasks mr-3 text-indigo-600"></i>
        Activity List
      </h1>
      <%= link_to departments_path(year: @selected_year), class: "inline-flex items-center px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white font-semibold rounded-lg shadow-md transition duration-200" do %>
        <i class="fas fa-arrow-left mr-2"></i>
        Back to Departments
      <% end %>
    </div>

    <!-- Employee and Department Info -->
    <div class="bg-gray-50 rounded-lg p-6 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div>
          <h3 class="text-sm font-semibold text-gray-600 mb-1">Employee</h3>
          <p class="text-lg font-medium text-gray-800"><%= @employee.employee_name %></p>
          <p class="text-sm text-gray-500">Code: <%= @employee.employee_code %></p>
        </div>
        
        <div>
          <h3 class="text-sm font-semibold text-gray-600 mb-1">Department</h3>
          <p class="text-lg font-medium text-gray-800"><%= @department.department_type %></p>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-gray-600 mb-1">Year</h3>
          <p class="text-lg font-medium text-gray-800"><%= @selected_year %></p>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-gray-600 mb-1">Total KPI</h3>
          <p class="text-2xl font-bold text-indigo-600"><%= @activities.count %></p>
        </div>
      </div>

      <!-- Manager Information -->
      <div class="mt-4 pt-4 border-t border-gray-200">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <h4 class="text-sm font-semibold text-gray-600 mb-1">L1 Manager</h4>
            <% l1_display = @l1_info[:name] ? "#{@l1_info[:name]}#{@l1_info[:code] ? ' (' + @l1_info[:code] + ')' : ''}" : (@l1_info[:code] || 'N/A') %>
            <p class="text-sm <%= @l1_info[:name] ? 'text-green-700' : 'text-gray-500' %>"><%= l1_display %></p>
          </div>
          
          <div>
            <h4 class="text-sm font-semibold text-gray-600 mb-1">L2 Manager</h4>
            <% l2_display = @l2_info[:name] ? "#{@l2_info[:name]}#{@l2_info[:code] ? ' (' + @l2_info[:code] + ')' : ''}" : (@l2_info[:code] || 'N/A') %>
            <p class="text-sm <%= @l2_info[:name] ? 'text-green-700' : 'text-gray-500' %>"><%= l2_display %></p>
          </div>

          <div>
            <h4 class="text-sm font-semibold text-gray-600 mb-1">L3 Manager</h4>
            <% l3_display = @l3_info[:name] ? "#{@l3_info[:name]}#{@l3_info[:code] ? ' (' + @l3_info[:code] + ')' : ''}" : (@l3_info[:code] || 'N/A') %>
            <p class="text-sm <%= @l3_info[:name] ? 'text-green-700' : 'text-gray-500' %>"><%= l3_display %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Activities Table -->
    <% if @activities.any? %>
      <div class="bg-white rounded-lg border border-gray-200 shadow-sm">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 rounded-t-lg">
          <h2 class="text-xl font-semibold text-gray-800 flex items-center">
            <i class="fas fa-list mr-2 text-indigo-600"></i>
            KPI Details
          </h2>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">KPI</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Indicator</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Unit</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Weightage</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @activities.each_with_index do |activity, index| %>
                <tr class="hover:bg-gray-50 <%= index.even? ? 'bg-white' : 'bg-gray-25' %>">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <div class="flex items-center">
                      <div class="w-3 h-3 bg-blue-500 rounded-full mr-3"></div>
                      <%= activity.theme_name %>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-900">
                    <div class="max-w-xs">
                      <p class="font-medium text-gray-800"><%= activity.activity_name %></p>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      <%= activity.unit %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                      <%= activity.weight.present? ? "#{activity.weight.to_i}%" : "" %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <div class="mx-auto w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mb-4">
          <i class="fas fa-tasks text-gray-400 text-3xl"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">No KPI Found</h3>
        <p class="text-gray-500 mb-6">This employee doesn't have any activities assigned in this department.</p>
        <%= link_to departments_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-md transition duration-200" do %>
          <i class="fas fa-arrow-left mr-2"></i>
          Back to Departments
        <% end %>
      </div>
    <% end %>

    <!-- Summary Statistics -->
    <% if @activities.any? %>
      <div class="mt-6 grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-slate-50 rounded-lg p-4">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <i class="fas fa-calendar-alt text-2xl" style="color: #2d374b;"></i>
            </div>
            <div class="ml-4">
              <h3 class="text-sm font-medium text-slate-900">Active Year</h3>
              <p class="text-2xl font-bold" style="color: #2d374b;"><%= @selected_year %></p>
            </div>
          </div>
        </div>

        <div class="bg-blue-50 rounded-lg p-4">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <i class="fas fa-chart-bar text-2xl" style="color: #2d374b;"></i>
            </div>
            <div class="ml-4">
              <h3 class="text-sm font-medium text-blue-900">Total Weightage</h3>
              <p class="text-2xl font-bold" style="color: #2d374b;"><%= @activities.sum { |activity| activity.weight || 0 } %></p>
            </div>
          </div>
        </div>

        <div class="bg-green-50 rounded-lg p-4">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <i class="fas fa-tasks text-green-600 text-2xl"></i>
            </div>
            <div class="ml-4">
              <h3 class="text-sm font-medium text-green-900">Unique Themes</h3>
              <p class="text-2xl font-bold text-green-600"><%= @activities.map(&:theme_name).uniq.count %></p>
            </div>
          </div>
        </div>

        <div class="bg-purple-50 rounded-lg p-4">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <i class="fas fa-tags text-purple-600 text-2xl"></i>
            </div>
            <div class="ml-4">
              <h3 class="text-sm font-medium text-purple-900">Unique Units</h3>
              <p class="text-2xl font-bold text-purple-600"><%= @activities.map(&:unit).uniq.count %></p>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    </div>
  </div>
</div>
