<!-- L3 Employee View - Only L2+ Approved Records -->
<div class="main-content sidebar-hidden bg-gray-50 min-h-screen">
  <div class="min-h-screen pl-64 pr-4 pt-4 pb-12 overflow-x-auto bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="w-full max-w-7xl mx-auto bg-white p-8 rounded-xl shadow-xl border border-gray-200">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-8 pb-4 border-b-2 border-gray-200">
        <div class="flex items-center">
          <i class="fas fa-user-shield text-2xl text-emerald-600 mr-3"></i>
          <h2 class="text-3xl font-bold text-gray-800">L3 Employee View</h2>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 w-full lg:w-auto">
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fas fa-search text-gray-400"></i>
            </div>
            <input type="text"
                   id="searchInput"
                   placeholder="Search employees..."
                   class="block w-full sm:w-64 pl-10 pr-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all duration-200">
          </div>

          <%= form_with url: l3_employee_details_path, method: :get, local: true, class: "flex flex-col sm:flex-row gap-3", data: { turbo: false } do %>
            <%= select_tag :month,
                options_for_select([["All Months", ""]] + @month_options, @selected_review_month),
                class: "w-full sm:w-44 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500",
                onchange: "this.form.submit()" %>
            <%= select_tag :financial_year,
                options_for_select([["All Financial Years", ""]] + @financial_year_options, @selected_financial_year),
                class: "w-full sm:w-52 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500",
                onchange: "this.form.submit()" %>
          <% end %>
        </div>
      </div>

      <div class="overflow-x-auto bg-white rounded-lg shadow-sm border border-gray-200">
        <table id="employeeTable" class="min-w-full divide-y divide-gray-300 text-sm">
          <thead class="bg-gradient-to-r from-gray-800 to-gray-700">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Employee Code</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Name</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Department</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Financial Year</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Months</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">L1 Manager</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">L2 Manager</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">L3 Manager</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Status</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider">Action</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% row_index = 0 %>
            <% @monthly_employee_data.each do |_key, data| %>
              <%
                emp = data[:employee]
                month = data[:month]
                month_label = data[:month_label]
                quarter_name = data[:quarter_name]
                status_config = data[:status_config]
                row_index += 1
              %>

              <tr class="<%= row_index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-indigo-50 transition-colors duration-200">
                <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                  <%= emp.employee_code %>
                </td>
                <td class="px-6 py-4 text-sm font-medium text-gray-900 border-r border-gray-200">
                  <%= emp.employee_name %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                  <%= data[:department]&.department_type.presence || emp.department %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                  <%= data[:financial_year].presence || "N/A" %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                  <div class="font-semibold text-blue-700 text-base">
                    <%= month_label %>
                  </div>
                  <div class="text-xs text-gray-500 mt-1">
                    <%= quarter_name %>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                  <%= emp.l1_employer_name %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                  <%= emp.l2_employer_name %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                  <%= emp.l3_employer_name %>
                </td>
                <td class="px-6 py-4 text-sm border-r border-gray-200">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border <%= status_config[:color] %>">
                    <i class="<%= status_config[:icon] %> mr-1"></i>
                    <%= status_config[:text] %>
                  </span>
                </td>
                <td class="px-6 py-4 text-sm">
                  <%= link_to "View Details",
                      show_l3_employee_detail_path(emp, quarter: quarter_name, month: month, department_id: data[:department_id], year: data[:financial_year]),
                      class: "inline-flex items-center px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg shadow-sm transition-all duration-200 hover:shadow-md transform hover:scale-105" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <% if @monthly_employee_data.empty? %>
          <div class="text-center py-12 text-gray-500">
            <i class="fas fa-inbox text-4xl mb-4"></i>
            <h3 class="text-lg font-semibold mb-2">No L2+ Approved Records Found</h3>
            <p class="text-sm">There are no employee records ready for L3 review.</p>
          </div>
        <% end %>
      </div>

      <%
        monthly_statuses = @monthly_employee_data.values.map { |data| data[:status] }
        total_months = @monthly_employee_data.size
        l2_approved_count = monthly_statuses.count("l2_approved")
        l3_approved_count = monthly_statuses.count("l3_approved")
        l3_returned_count = monthly_statuses.count("l3_returned") + monthly_statuses.count("returned_to_employee")
      %>

      <div class="mt-6 grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-blue-50 p-4 rounded-lg border border-blue-200">
          <div class="flex items-center">
            <i class="fas fa-calendar-check text-blue-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-blue-800">L2+ Approved Months</p>
              <p class="text-2xl font-bold text-blue-900"><%= total_months %></p>
            </div>
          </div>
        </div>

        <div class="bg-yellow-50 p-4 rounded-lg border border-yellow-200">
          <div class="flex items-center">
            <i class="fas fa-clock text-yellow-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-yellow-800">Ready for L3 Review</p>
              <p class="text-2xl font-bold text-yellow-900"><%= l2_approved_count %></p>
            </div>
          </div>
        </div>

        <div class="bg-green-50 p-4 rounded-lg border border-green-200">
          <div class="flex items-center">
            <i class="fas fa-check-circle text-green-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-green-800">L3 Approved</p>
              <p class="text-2xl font-bold text-green-900"><%= l3_approved_count %></p>
            </div>
          </div>
        </div>

        <div class="bg-red-50 p-4 rounded-lg border border-red-200">
          <div class="flex items-center">
            <i class="fas fa-exclamation-triangle text-red-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-red-800">L3 Returned</p>
              <p class="text-2xl font-bold text-red-900"><%= l3_returned_count %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .min-h-screen {
    padding-left: 16rem;
  }

  .sidebar-hidden .min-h-screen {
    padding-left: 1rem !important;
    padding-right: 1rem !important;
  }

  @media (max-width: 768px) {
    .min-h-screen {
      padding-left: 1rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', initializeL3EmployeeSearch);
  document.addEventListener('turbo:load', initializeL3EmployeeSearch);

  function initializeL3EmployeeSearch() {
    const searchInput = document.getElementById('searchInput');
    const table = document.getElementById('employeeTable');
    if (!searchInput || !table) return;

    searchInput.addEventListener('input', function() {
      const searchTerm = this.value.toLowerCase();
      const rows = table.querySelectorAll('tbody tr');

      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(searchTerm) ? '' : 'none';
      });
    });
  }
</script>
