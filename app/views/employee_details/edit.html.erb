<style>
  .main-content {
    margin-left: 300px !important;
    padding: 1.5rem;
    min-height: 100vh;
  }
  
  @media (max-width: 768px) {
    .main-content {
      margin-left: 0 !important;
      padding: 1rem;
    }
  }
</style>

<div class="main-content">
  <h2 class="text-3xl font-bold text-indigo-600 mb-6">✏️ Edit Employee</h2>

  <%= form_with(model: @employee_detail, local: true, class: "w-full") do |form| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      
      <!-- Employee ID -->
      <div>
        <%= form.label :employee_id, "Employee ID", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :employee_id, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <!-- Employee Name -->
      <div>
        <%= form.label :employee_name, "Employee Name", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :employee_name, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <!-- Employee Email -->
      <div>
        <%= form.label :employee_email, "Employee Email", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.email_field :employee_email, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <!-- Employee Code -->
      <div>
        <%= form.label :employee_code, "Employee Code", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :employee_code, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <!-- L1 Code -->
      <div>
        <%= form.label :l1_code, "L1 Code", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :l1_code, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <!-- L1 Employer Name -->
      <div>
        <%= form.label :l1_employer_name, "L1 Employer Name", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :l1_employer_name, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <!-- L2 Code -->
      <div>
        <%= form.label :l2_code, "L2 Code", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :l2_code, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <!-- L2 Employer Name -->
      <div>
        <%= form.label :l2_employer_name, "L2 Employer Name", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :l2_employer_name, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <!-- Post -->
      <div>
        <%= form.label :post, "Post", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :post, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <!-- Department -->
      <div>
        <%= form.label :department, "Department", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :department, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="mt-8 flex gap-4">
      <%= form.submit "Update Employee", class: "px-6 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 shadow-md transition-colors duration-200" %>
      <%= link_to 'Cancel', employee_details_path, class: "px-6 py-3 bg-gray-200 text-gray-800 font-semibold rounded-lg hover:bg-gray-300 shadow-md transition-colors duration-200" %>
    </div>

    <!-- Error handling (optional) -->
    <% if @employee_detail.errors.any? %>
      <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <h3 class="text-red-800 font-semibold mb-2">Please fix the following errors:</h3>
        <ul class="text-red-700 list-disc list-inside">
          <% @employee_detail.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>
</div>