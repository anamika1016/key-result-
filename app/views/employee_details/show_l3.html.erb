<!-- L3 Manager Detail Quarterly View with L3 Remarks Display -->
<meta name="csrf-token" content="<%= form_authenticity_token %>">
<div class="main-content bg-gray-50 min-h-screen">
<div class="p-8 bg-white rounded-xl shadow-lg border border-gray-200 mx-4">
  <div class="border-b border-gray-200 pb-6 mb-8">
    <h2 class="text-3xl font-bold text-gray-800 flex items-center">
      <i class="fas fa-user-shield mr-3 text-gray-600"></i>
      Employee Detail - L3 Review
    </h2>
    
    <!-- Vertical Filter - Only show if coming from specific vertical -->
    <% if @selected_department.present? %>
      <% 
        # Get the specific department being viewed
        current_department = Department.find(@selected_department)
      %>
      <div class="mt-4">
        <div class="inline-flex items-center px-4 py-2 bg-blue-100 text-blue-800 rounded-lg text-sm font-medium">
          <i class="fas fa-building mr-2"></i>
          Vertical: <%= current_department.department_type %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Status Message Container -->
  <div id="statusMessage" class="hidden mb-4 p-4 rounded-lg"></div>

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 tracking-wide mb-1">Employee Code</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.employee_code.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 tracking-wide mb-1">Employee Name</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.employee_name.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 tracking-wide mb-1">Department</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.department.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 tracking-wide mb-1">Post</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.post.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 tracking-wide mb-1">Location</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.office_name.presence || @employee_detail.office_type.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 tracking-wide mb-1">Financial Year</p>
      <p class="text-sm font-semibold text-gray-900"><%= @selected_financial_year.presence || "All" %></p>
    </div>
  </div>

  <%
    # Define months to display based on month/quarter, matching L1/L2 review pages.
    display_months = if params[:month].present?
                     [[params[:month].to_s.downcase.to_sym, short_month_label(params[:month])]]
                     else
                     case params[:quarter]
                     when 'Q1'
                       [[:april, 'APR'], [:may, 'MAY'], [:june, 'JUN']]
                     when 'Q2'
                       [[:july, 'JUL'], [:august, 'AUG'], [:september, 'SEP']]
                     when 'Q3'
                       [[:october, 'OCT'], [:november, 'NOV'], [:december, 'DEC']]
                     when 'Q4'
                       [[:january, 'JAN'], [:february, 'FEB'], [:march, 'MAR']]
                     else
                       []
                     end
                     end

    # FIXED: Calculate quarterly data - collect statuses and data ONLY for the selected department
    quarterly_statuses = []
    quarter_l1_total = 0
    quarter_l2_total = 0
    quarter_l3_total = 0
    quarter_achievement_count = 0
    quarter_remarks_l1 = Set.new
    quarter_remarks_l2 = Set.new
    quarter_remarks_l3 = Set.new
    
    if @user_details.any? && (params[:quarter].present? || params[:month].present?)
      @user_details.each do |detail|
        quarter_achievements = detail.achievements.select { |a| display_months.map { |m| m[0].to_s.downcase }.include?(a.month.to_s.downcase) }
        quarter_achievements.each do |achievement|
          quarterly_statuses << (achievement.status || "pending")
          
          if achievement.achievement_remark.present?
            quarter_achievement_count += 1
            
            # Collect L1 data
            if achievement.achievement_remark.l1_percentage.present?
              quarter_l1_total += achievement.achievement_remark.l1_percentage.to_f
            end
            
            # Add unique L1 remarks only
            if achievement.achievement_remark.l1_remarks.present?
              quarter_remarks_l1.add(achievement.achievement_remark.l1_remarks)
            end
            
            # Collect L2 data
            if achievement.achievement_remark.l2_percentage.present?
              quarter_l2_total += achievement.achievement_remark.l2_percentage.to_f
            end
            
            # Add unique L2 remarks only
            if achievement.achievement_remark.l2_remarks.present?
              quarter_remarks_l2.add(achievement.achievement_remark.l2_remarks)
            end

            # FIXED: Only collect L3 data if L3 has actually acted (approved or returned)
            if (achievement.status == "l3_approved" || achievement.status == "l3_returned") && achievement.achievement_remark.l3_percentage.present?
              quarter_l3_total += achievement.achievement_remark.l3_percentage.to_f
            end
            
            # FIXED: Only add L3 remarks if L3 has actually acted (approved or returned)
            if (achievement.status == "l3_approved" || achievement.status == "l3_returned") && achievement.achievement_remark.l3_remarks.present?
              quarter_remarks_l3.add(achievement.achievement_remark.l3_remarks)
            end
          end
        end
      end
    end
    
    # FIXED: Simplified status logic - check achievement status directly
    overall_quarter_status = "pending"
    l3_status = "pending"  # Separate L3 status tracking
    has_l2_data = quarter_l2_total > 0 || quarter_remarks_l2.any?
    has_l3_data = quarter_l3_total > 0 || quarter_remarks_l3.any?
    
    if quarterly_statuses.any?
      # FIXED: Check achievement status directly, not data availability
      if quarterly_statuses.any? { |s| s == "l3_approved" }
        # If any achievement is L3 approved, show as L3 approved
        overall_quarter_status = "l3_approved"
        l3_status = "approved"
      elsif quarterly_statuses.any? { |s| s == "l3_returned" }
        # If any achievement is L3 returned, show as L3 returned
        overall_quarter_status = "l3_returned"
        l3_status = "returned"
      elsif quarterly_statuses.any? { |s| s == "returned_to_employee" }
        # If any achievement is returned to employee, show as returned to employee
        overall_quarter_status = "returned_to_employee"
        l3_status = "returned"
      elsif quarterly_statuses.all? { |s| s == "l2_approved" }
        # If all achievements are L2 approved, ready for L3 review
        overall_quarter_status = "l2_approved"
        l3_status = "pending"
      elsif quarterly_statuses.any? { |s| s == "l2_returned" }
        overall_quarter_status = "l2_returned"
        l3_status = "pending"
      elsif quarterly_statuses.any? { |s| s == "l1_approved" }
        overall_quarter_status = "l1_approved"
        l3_status = "pending"
      elsif quarterly_statuses.any? { |s| s == "l1_returned" }
        overall_quarter_status = "l1_returned"
        l3_status = "pending"
      elsif quarterly_statuses.any? { |s| s == "submitted" }
        overall_quarter_status = "submitted"
        l3_status = "pending"
      else
        overall_quarter_status = "pending"
        l3_status = "pending"
      end
    end

    return_to_val = nil
    if ["returned_to_employee", "l1_returned", "l2_returned", "l3_returned"].include?(overall_quarter_status)
      all_quarter_achievements = []
      period_month_keys = if params[:month].present?
                          [params[:month].to_s.downcase]
                          else
                          case @selected_quarter
                          when 'Q1' then ['april', 'may', 'june']
                          when 'Q2' then ['july', 'august', 'september']
                          when 'Q3' then ['october', 'november', 'december']
                          when 'Q4' then ['january', 'february', 'march']
                          else ['april', 'may', 'june']
                          end
                          end
      @user_details.each do |detail|
        all_quarter_achievements.concat(detail.achievements.select { |a| period_month_keys.include?(a.month.to_s.downcase) })
      end
      matching_ach = all_quarter_achievements.find { |a| a.status == overall_quarter_status }
      return_to_val = matching_ach&.return_to
    end

    status_config = case overall_quarter_status
    when "pending"
      { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
    when "l1_approved"
      { color: "bg-sky-100 text-sky-800 border-sky-300", text: "L1 Approved", icon: "fas fa-check-circle" }
    when "l1_returned"
      { color: "bg-red-100 text-red-800 border-red-300", text: "L1_Return_Employee", icon: "fas fa-exclamation-triangle" }
    when "l2_approved"
      { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
    when "l2_returned"
      text_val = (return_to_val == 'employee') ? "L2_Return_Employee" : "L2_Return_L1"
      { color: "bg-red-100 text-red-800 border-red-300", text: text_val, icon: "fas fa-clock" }
    when "l3_approved"
      { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L3 Approved", icon: "fas fa-check-double" }
    when "l3_returned"
      text_val = case return_to_val
                 when 'employee' then "L3_Return_Employee"
                 when 'l1' then "L3_Return_L1"
                 else "L3_Return_L2"
                 end
      { color: "bg-orange-100 text-orange-800 border-orange-300", text: text_val, icon: "fas fa-exclamation-triangle" }
    when "returned_to_employee"
      # Determine if L3 or L2 returned it to employee based on remarks
      sample_matching_ach = all_quarter_achievements.find { |a| a.status == "returned_to_employee" }
      remark = sample_matching_ach&.achievement_remark
      
      text_val = if remark&.l3_remarks.present?
                   "L3_Return_Employee"
                 elsif remark&.l2_remarks.present?
                   "L2_Return_Employee"
                 else
                   "L1_Return_Employee"
                 end
      { color: "bg-red-100 text-red-800 border-red-300", text: text_val, icon: "fas fa-undo" }
    when "submitted"
      { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
    else
      { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status", icon: "fas fa-question-circle" }
    end
    
    # Calculate averages
    quarter_l1_average = quarter_achievement_count > 0 ? (quarter_l1_total / quarter_achievement_count).round(1) : 0.0
    quarter_l2_average = quarter_achievement_count > 0 ? (quarter_l2_total / quarter_achievement_count).round(1) : 0.0
    quarter_l3_average = quarter_achievement_count > 0 ? (quarter_l3_total / quarter_achievement_count).round(1) : 0.0
    
    # Convert Sets to Arrays for display
    quarter_remarks_l1_array = quarter_remarks_l1.to_a
    quarter_remarks_l2_array = quarter_remarks_l2.to_a
    quarter_remarks_l3_array = quarter_remarks_l3.to_a
  %>

  <% if @user_details.any? %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm mt-8">
      <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
        <h2 class="text-2xl font-bold text-gray-800 flex items-center">
          <i class="fas fa-trophy mr-3 text-gray-600"></i>
          <%= @selected_month.present? ? @selected_month.titleize : @selected_quarter %> Achievement Details (<%= display_financial_year(@selected_year) %>)
        </h2>
      </div>

      <div class="p-6">
        <%
          # Define months to display based on selected month/quarter
          display_months = if @selected_month.present?
            [[@selected_month.to_sym, @selected_month.first(3).titleize]]
          else
            case @selected_quarter
                          when 'Q1'
                            [[:april, 'Apr'], [:may, 'May'], [:june, 'Jun']]
                          when 'Q2'
                            [[:july, 'Jul'], [:august, 'Aug'], [:september, 'Sep']]
                          when 'Q3'
                            [[:october, 'Oct'], [:november, 'Nov'], [:december, 'Dec']]
                          when 'Q4'
                            [[:january, 'Jan'], [:february, 'Feb'], [:march, 'Mar']]
                          else
                            # Default to Q1
                            [[:april, 'Apr'], [:may, 'May'], [:june, 'Jun']]
                          end
          end
        %>
        
        <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200">
          <table class="table table-hover w-full min-w-full">
            <thead class="bg-gray-800">
              <tr>
                <th class="serial-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">S.No</th>
                <th class="kri-column px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600">Key result areas</th>
                <th class="measurement-column px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600">Measurement description</th>
                <th class="unit-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Unit of Measurement</th>
                <th class="annual-target-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600"><%= annual_target_fy_label(@selected_financial_year) %></th>

                <% display_months.each do |month_symbol, month_name| %>
                  <th class="month-target-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name.titleize %> Target</th>
                  <th class="month-achievement-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name.titleize %> Achievement</th>
                  <th class="month-progress-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700">% Progress</th>
                  <th class="employee-remarks-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700">Employee <%= month_name.titleize %> Remarks</th>
                  <th class="reporting-manager-remarks-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700"><%= manager_remarks_column_label("L1", month_name.titleize) %></th>
                  <th class="reporting-manager-remarks-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700"><%= manager_remarks_column_label("L2", month_name.titleize) %></th>
                  <th class="reporting-manager-remarks-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700"><%= manager_remarks_column_label("L3", month_name.titleize) %></th>
                <% end %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <%
                target_present_for_display = lambda do |detail, month_symbol|
                  target_value = detail.public_send(month_symbol)
                  target_text = target_value.to_s.delete(",").strip
                  target_is_numeric = target_text.match?(/\A-?\d+(?:\.\d+)?\z/)
                  target_value.present? && (!target_is_numeric || target_text.to_f.positive?)
                end
                row_present_for_display = lambda do |detail, display_months|
                  display_months.any? { |month_symbol, _| target_present_for_display.call(detail, month_symbol) }
                end
                visible_detail_index = 0
              %>
              <% @user_details.each do |detail| %>
                <%
                  existing_achievements = detail.achievements.index_by { |achievement| achievement.month.to_s.downcase }
                  has_month_data = detail.activity.present? && row_present_for_display.call(detail, display_months)
                %>
                <% if has_month_data %>
                  <% visible_detail_index += 1 %>
                  <tr class="<%= visible_detail_index.odd? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200">
                    <td class="serial-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= visible_detail_index %>
                    </td>
                    <td class="kri-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200">
                      <%= detail.activity&.theme_name.presence || detail.activity&.activity_name || 'N/A' %>
                    </td>
                    <td class="measurement-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200">
                      <%= detail.activity&.activity_name || 'N/A' %>
                    </td>
                    <td class="unit-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= detail.activity&.unit || '' %>
                    </td>
                    <td class="annual-target-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= annual_target_display(detail) %>
                    </td>

                    <% display_months.each do |month_symbol, month_name| %>
                      <%
                        target_value = detail.public_send(month_symbol)
                        achievement_record = existing_achievements[month_symbol.to_s.downcase]
                        achievement_value = achievement_record&.achievement
                        employee_remarks = achievement_record&.employee_remarks
                        l1_manager_remarks = achievement_record&.achievement_remark&.l1_remarks
                        l2_manager_remarks = achievement_record&.achievement_remark&.l2_remarks
                        l3_manager_remarks = achievement_record&.achievement_remark&.l3_remarks
                        l3_can_edit_month_remark = @can_l3_approve_or_return && achievement_record.present? && achievement_record.status.to_s != "l3_approved"
                        target_number = target_value.to_s.delete(",").to_f
                        achievement_number = achievement_value.to_s.delete(",").to_f
                        progress_percentage = target_value.present? && target_number.positive? && achievement_value.present? ? (((achievement_number / target_number) * 100.0 * 100).floor / 100.0) : nil
                      %>
                      <td class="month-target-cell px-4 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      <td class="achievement-cell px-4 py-3 text-sm text-center border-r border-gray-200">
                        <span class="<%= achievement_value.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement_value.presence || '-' %>
                        </span>
                      </td>
                      <td class="progress-cell px-4 py-3 text-sm text-center border-r border-gray-200">
                        <span class="<%= progress_percentage ? 'text-emerald-700 font-semibold bg-emerald-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= progress_percentage ? "#{format('%.2f', progress_percentage)}%" : '-' %>
                        </span>
                      </td>
                      <td class="remarks-cell px-4 py-3 text-sm text-center border-r border-gray-200">
                        <% if employee_remarks.present? %>
                          <div class="text-blue-700 font-medium bg-blue-50 px-2 py-1 rounded text-xs break-words">
                            <%= employee_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>
                      <td class="reporting-manager-remarks-cell px-4 py-3 text-sm text-center border-r border-gray-200">
                        <% if l1_manager_remarks.present? %>
                          <div class="text-indigo-700 font-medium bg-indigo-50 px-2 py-1 rounded text-xs break-words">
                            <%= l1_manager_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>
                      <td class="reporting-manager-remarks-cell px-4 py-3 text-sm text-center border-r border-gray-200">
                        <% if l2_manager_remarks.present? %>
                          <div class="text-indigo-700 font-medium bg-indigo-50 px-2 py-1 rounded text-xs break-words">
                            <%= l2_manager_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>
                      <td class="reporting-manager-remarks-cell px-4 py-3 text-sm text-center border-r border-gray-200">
                        <% if l3_can_edit_month_remark %>
                          <textarea
                            class="l3-reporting-manager-remarks-input w-full min-w-[220px] rounded border border-gray-300 p-2 text-xs focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                            rows="2"
                            maxlength="500"
                            data-user-detail-id="<%= detail.id %>"
                            data-month="<%= month_symbol %>"
                            placeholder="L3 remarks"><%= l3_manager_remarks %></textarea>
                        <% elsif l3_manager_remarks.present? %>
                          <div class="text-indigo-700 font-medium bg-indigo-50 px-2 py-1 rounded text-xs break-words">
                            <%= l3_manager_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
          
          <!-- NEW: Simplified table matching the screen you described -->
          <table class="hidden min-w-full divide-y divide-gray-300 text-sm">
            <thead class="bg-gradient-to-r from-gray-800 to-gray-700">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600">KRA</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600">Measurement Description</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600">Unit of Measurement</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600">Annual Target (FY <%= display_financial_year_short(@selected_year) %>)</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600">Monthly Target <%= display_months.map(&:last).join("/") %></th>
                <th class="px-6 py-4 text-center text-xs font-semibold text-white tracking-wider border-r border-gray-600" colspan="3">
                  <%= @selected_month.present? ? @selected_month.titleize : @selected_quarter %> - <%= display_financial_year(@selected_year) %> (<%= display_months.map(&:last).join('-') %>)
                </th>
              </tr>
              <tr class="bg-gray-700">
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600"></th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600"></th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600"></th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600"></th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white tracking-wider border-r border-gray-600"></th>
                <th class="px-6 py-4 text-center text-xs font-semibold text-white tracking-wider border-r border-gray-600">Achievement (%)</th>
                <th class="px-6 py-4 text-center text-xs font-semibold text-white tracking-wider border-r border-gray-600">Remarks</th>
                <th class="px-6 py-4 text-center text-xs font-semibold text-white tracking-wider">Weightage Score</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% 
                total_weightage = 0
                total_quarter_weightage = 0
                total_achievement = 0
                total_weightage_score = 0
                row_count = 0
                
                # FIXED: Group user_details by activity name to prevent duplicates
                grouped_details = @user_details.group_by { |detail| detail.activity&.activity_name }
                processed_activities = Set.new
              %>
              <% grouped_details.each_with_index do |(activity_name, details), detail_index| %>
                <% 
                  # Skip if we've already processed this activity
                  next if processed_activities.include?(activity_name)
                  processed_activities.add(activity_name)
                  
                  # Use the first detail for this activity (they should all have the same activity data)
                  detail = details.first
                %>
                <% 
                  selected_quarter_key = @selected_quarter.to_s.downcase.presence || "q1"
                  selected_achievement_key = @selected_month.presence || selected_quarter_key
                  direct_quarter_achievement = detail.achievements.find { |a| a.month.to_s.downcase == selected_achievement_key }
                  quarter_achievements = detail.achievements.select { |a| display_months.map(&:first).map(&:to_s).include?(a.month.to_s.downcase) }
                  weightage = detail.weight.to_f
                  quarter_weightage = detail.weightage_for_quarter(selected_quarter_key).to_f
                  total_weightage += weightage
                  total_quarter_weightage += quarter_weightage
                  
                  if direct_quarter_achievement&.achievement.present?
                    avg_achievement = direct_quarter_achievement.achievement.to_f
                  else
                    quarter_achievement_values = quarter_achievements.filter_map { |a| a.achievement.present? ? a.achievement.to_f : nil }
                    avg_achievement = quarter_achievement_values.any? ? (quarter_achievement_values.sum / quarter_achievement_values.size) : 0
                  end
                  
                  
                  # Calculate weightage score
                  weightage_score = (quarter_weightage * avg_achievement / 100).round(2)
                  total_weightage_score += weightage_score
                  
                  remarks = direct_quarter_achievement&.employee_remarks.presence || quarter_achievements.map { |a| a.employee_remarks }.compact.first
                  
                  # Don't set default remarks - show empty if no remarks provided
                  remarks = remarks.present? ? remarks : ""
                  target_text = display_months.map { |month, label| "#{label}: #{detail.public_send(month).presence || '-'}" }.join(" | ")
                  
                  row_count += 1
                %>
                <tr class="<%= detail_index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200">
                  <td class="px-6 py-4 text-sm text-gray-800 font-medium border-r border-gray-200">
                    <%= detail.activity&.theme_name || 'N/A' %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-800 border-r border-gray-200">
                    <%= detail.activity&.activity_name || 'N/A' %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-800 border-r border-gray-200">
                    <%= detail.activity&.unit || 'N/A' %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-800 border-r border-gray-200">
                    <%= detail.annual_target.presence || "-" %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-800 border-r border-gray-200">
                    <%= target_text %>
                  </td>
                  <td class="px-6 py-4 text-sm text-center border-r border-gray-200">
                    <span class="text-green-700 font-semibold bg-green-50 px-2 py-1 rounded">
                      <%= avg_achievement.to_i == avg_achievement ? avg_achievement.to_i : avg_achievement.round(2) %>%
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-center border-r border-gray-200">
                    <% if remarks.present? %>
                      <span class="text-blue-700 font-medium bg-blue-50 px-2 py-1 rounded text-xs">
                        <%= remarks %>
                      </span>
                    <% else %>
                      <span class="text-gray-500 font-medium bg-gray-50 px-2 py-1 rounded text-xs">
                        No remarks
                      </span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-sm text-center">
                    <span class="text-green-700 font-semibold bg-green-50 px-2 py-1 rounded">
                      <%= weightage_score %>
                    </span>
                  </td>
                </tr>
              <% end %>
              
              <!-- TOTAL COUNT ROW -->
              <tr class="bg-green-100 font-semibold">
                <td class="px-6 py-4 text-sm text-gray-800 border-r border-gray-200">TOTAL COUNT</td>
                <td class="px-6 py-4 text-sm text-gray-800 border-r border-gray-200">-</td>
                <td class="px-6 py-4 text-sm text-gray-800 border-r border-gray-200">-</td>
                <td class="px-6 py-4 text-sm text-gray-800 border-r border-gray-200">-</td>
                <td class="px-6 py-4 text-sm text-gray-800 border-r border-gray-200">-</td>
                <td class="px-6 py-4 text-sm text-center border-r border-gray-200">
                  <span class="text-green-800 font-bold">
                    <% total_achievement_percentage = total_quarter_weightage > 0 ? ((total_weightage_score / total_quarter_weightage) * 100).round(2) : 0 %>
                    <%= total_achievement_percentage.to_i == total_achievement_percentage ? total_achievement_percentage.to_i : total_achievement_percentage %>%
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-center border-r border-gray-200">
                  <span class="text-gray-600">-</span>
                </td>
                <td class="px-6 py-4 text-sm text-center">
                  <span class="text-green-800 font-bold">
                    <%= total_weightage_score.round(2) %>
                  </span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-12">
      <i class="fas fa-exclamation-triangle text-6xl text-gray-400 mb-4"></i>
      <h3 class="text-xl font-semibold text-gray-600 mb-2">No Data Available</h3>
      <p class="text-gray-500">No achievement data found for this quarter.</p>
    </div>
  <% end %>

<!-- Single Overall Status Display for Quarter -->
<% if params[:quarter].present? || params[:month].present? %>
  <% if quarterly_statuses.any? || @user_details.any? %>
    <div class="mt-8 pt-6 border-t border-gray-200" id="quarterStatusSection">
      <div class="text-center mb-6">
        <h3 class="text-xl font-bold text-gray-800 mb-4">
           <%= params[:month].present? ? "#{short_month_label(params[:month])} Overall Status" : "Quarter Overall Status" %>
           <span class="block mt-2 text-sm font-semibold text-gray-600">
             L1: <%= @employee_detail.l1_employer_name.presence || "N/A" %> |
             L2: <%= @employee_detail.l2_employer_name.presence || "N/A" %> |
             L3: <%= @employee_detail.l3_employer_name.presence || "N/A" %>
           </span>
        </h3>
        <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium border <%= status_config[:color] %>" id="quarterStatusBadge">
          <i class="<%= status_config[:icon] %> mr-2"></i>
          <%= status_config[:text] %>
        </span>
      </div>
    </div>
  <% end %>

  <!-- L1, L2 & L3 Summary for Quarter -->
  <% if @user_details.any? %>
    <%
      # Calculate SINGLE average for entire quarter
      all_quarter_achievements = []
      @user_details.each do |detail|
        quarter_achievements = detail.achievements.select { |a| display_months.map { |m| m[0].to_s.downcase }.include?(a.month.to_s.downcase) && a.achievement_remark.present? }
        all_quarter_achievements.concat(quarter_achievements)
      end

      # SINGLE L1 calculation for quarter
      l1_percentages = all_quarter_achievements.filter_map { |a| a.achievement_remark&.l1_percentage&.to_f }
      final_l1_average = l1_percentages.any? ? (l1_percentages.sum / l1_percentages.size).round(1) : 0.0

      # SINGLE L2 calculation for quarter  
      l2_percentages = all_quarter_achievements.filter_map { |a| a.achievement_remark&.l2_percentage&.to_f }
      final_l2_average = l2_percentages.any? ? (l2_percentages.sum / l2_percentages.size).round(1) : 0.0

      # SINGLE L3 calculation for quarter  
      l3_percentages = all_quarter_achievements.filter_map { |a| a.achievement_remark&.l3_percentage&.to_f }
      final_l3_average = l3_percentages.any? ? (l3_percentages.sum / l3_percentages.size).round(1) : 0.0

      # SINGLE remark per level per quarter (take first non-empty remark)
      unique_l1_remarks = [all_quarter_achievements.filter_map { |a| a.achievement_remark&.l1_remarks }.compact.first].compact
      unique_l2_remarks = [all_quarter_achievements.filter_map { |a| a.achievement_remark&.l2_remarks }.compact.first].compact
      unique_l3_remarks = [all_quarter_achievements.filter_map { |a| a.achievement_remark&.l3_remarks }.compact.first].compact
      final_l1_average_display = format('%.2f', final_l1_average.to_f)
      final_l2_average_display = format('%.2f', final_l2_average.to_f)
      final_l3_average_display = format('%.2f', final_l3_average.to_f)
      l3_data_available = overall_quarter_status == "l3_approved" ||
                           overall_quarter_status == "l3_returned" ||
                           (overall_quarter_status == "returned_to_employee" && (final_l3_average.to_f.positive? || unique_l3_remarks.any?))
      
    %>

    <div id="employeeSummarySections" class="review-summary-grid review-summary-grid--three mt-6">

      <!-- L1 Quarterly Summary - ALWAYS SHOW -->
      <div id="l1-summary-section" class="review-summary-card bg-gradient-to-r from-blue-50 via-blue-50 to-blue-100 border border-blue-200 rounded-xl p-6 shadow-md">
        <h3 class="text-xl font-bold text-blue-700 mb-6 flex items-center gap-2">
          <i class="fas fa-user-check text-blue-500"></i>
          <%= params[:month].present? ? "L1 #{short_month_label(params[:month])} Summary" : "L1 Quarter Summary" %> - <%= @employee_detail.l1_employer_name.presence || "N/A" %>
        </h3>

        <!-- Quarter Average Percentage -->
        <div class="mb-6 text-center">
          <div class="summary-percent-box bg-blue-200 p-4 rounded-lg inline-block">
            <p class="text-blue-600 font-semibold text-sm mb-1"><%= params[:month].present? ? "Month Average Percentage" : "Quarter Average Percentage" %></p>
            <p class="text-3xl font-bold text-blue-800"><%= final_l1_average_display %>%</p>
          </div>
        </div>

        <!-- UNIQUE L1 Remarks -->
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <h4 class="text-blue-600 font-semibold text-sm"><%= params[:month].present? ? "Month Remarks:" : "Quarter Remarks:" %></h4>
          </div>
          <div id="l1-display-section">
            <% if unique_l1_remarks.any? %>
              <div class="stealth-edit-wrap">
                <div class="summary-remarks-box bg-white p-4 rounded border max-h-40 overflow-y-auto" id="l1-remarks-display">
                  <% unique_l1_remarks.each_with_index do |remark, index| %>
                    <div class="text-gray-700 text-sm mb-3 pb-3 <%= 'border-b border-gray-100' unless index == unique_l1_remarks.length - 1 %>">
                      <div class="flex items-start gap-2">
                        <span class="bg-blue-100 text-blue-600 text-xs px-2 py-1 rounded font-medium flex-shrink-0">
                          Remark <%= index + 1 %>
                        </span>
                        <span class="text-gray-700"><%= remark %></span>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% else %>
              <div class="stealth-edit-wrap">
                <div class="summary-remarks-box bg-white p-4 rounded border" id="l1-remarks-container">
                  <p class="text-gray-500 text-sm">No remarks for this <%= params[:month].present? ? "month" : "quarter" %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- L2 Quarterly Summary -->
      <div id="l2-summary-section" class="review-summary-card bg-gradient-to-r from-green-50 via-green-50 to-green-100 border border-green-200 rounded-xl p-6 shadow-md">
        <h3 class="text-xl font-bold text-green-700 mb-6 flex items-center gap-2">
          <i class="fas fa-user-shield text-green-500"></i>
          <%= params[:month].present? ? "L2 #{short_month_label(params[:month])} Summary" : "L2 Quarter Summary" %> - <%= @employee_detail.l2_employer_name.presence || "N/A" %>
        </h3>

        <!-- Quarter Average Percentage -->
        <div class="mb-6 text-center">
          <div class="summary-percent-box bg-green-200 p-4 rounded-lg inline-block">
            <p class="text-green-600 font-semibold text-sm mb-1"><%= params[:month].present? ? "Month Average Percentage" : "Quarter Average Percentage" %></p>
            <p class="text-3xl font-bold text-green-800" id="l2-percentage-display"><%= final_l2_average_display %>%</p>
          </div>
        </div>

        <!-- L2 Remarks Display -->
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <h4 class="text-green-600 font-semibold text-sm"><%= params[:month].present? ? "Month Remarks:" : "Quarter Remarks:" %></h4>
          </div>
          <div id="l2-display-section">
            <div class="stealth-edit-wrap">
              <div class="summary-remarks-box bg-white p-4 rounded border max-h-40 overflow-y-auto" id="l2-remarks-container">
                <% if unique_l2_remarks.any? %>
                  <div id="l2-remarks-display">
                    <% unique_l2_remarks.each_with_index do |remark, index| %>
                      <div class="text-gray-700 text-sm mb-3 pb-3 <%= 'border-b border-gray-100' unless index == unique_l2_remarks.length - 1 %>">
                        <div class="flex items-start gap-2">
                          <span class="bg-green-100 text-green-600 text-xs px-2 py-1 rounded font-medium flex-shrink-0">
                            Remark <%= index + 1 %>
                          </span>
                          <span class="text-gray-700"><%= remark %></span>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <p class="text-gray-500 text-sm">
                    <% if overall_quarter_status == 'l2_approved' && has_l2_data %>
                      <i class="fas fa-check-circle text-green-500 mr-1"></i>
                      Quarter approved - no additional remarks needed
                    <% else %>
                      No remarks for this <%= params[:month].present? ? "month" : "quarter" %>
                    <% end %>
                  </p>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- FIXED: L3 Quarterly Summary - Show if L3 has acted (approved or returned) -->
      <div id="l3-summary-section" class="review-summary-card <%= l3_data_available ? 'bg-gradient-to-r from-green-50 via-green-50 to-green-100 border-green-200' : 'bg-gradient-to-r from-gray-50 via-gray-50 to-gray-100 border-gray-200' %> border rounded-xl p-6 shadow-md">
        <% if l3_data_available %>
          <h3 class="text-xl font-bold text-green-700 mb-6 flex items-center gap-2">
            <i class="fas fa-user-crown text-green-500"></i>
            <%= params[:month].present? ? "L3 #{short_month_label(params[:month])} Summary" : "L3 Quarter Summary" %> - <%= @employee_detail.l3_employer_name.presence || "N/A" %>
          </h3>

          <!-- Quarter Average Percentage -->
          <div class="mb-6 text-center">
            <div class="summary-percent-box bg-green-200 p-4 rounded-lg inline-block">
              <p class="text-green-600 font-semibold text-sm mb-1"><%= params[:month].present? ? "Month Average Percentage" : "Quarter Average Percentage" %></p>
              <p class="text-3xl font-bold text-green-800" id="l3-percentage-display"><%= final_l3_average_display %>%</p>
            </div>
          </div>

          <!-- L3 Remarks Display -->
          <div class="space-y-3">
            <h4 class="text-green-600 font-semibold text-sm"><%= params[:month].present? ? "Month Remarks:" : "Quarter Remarks:" %></h4>
            <div class="summary-remarks-box bg-white p-4 rounded border max-h-40 overflow-y-auto" id="l3-remarks-container">
              <% if unique_l3_remarks.any? %>
                <% unique_l3_remarks.each_with_index do |remark, index| %>
                  <div class="text-gray-700 text-sm mb-3 pb-3 <%= 'border-b border-gray-100' unless index == unique_l3_remarks.length - 1 %>">
                    <div class="flex items-start gap-2">
                      <span class="bg-green-100 text-green-600 text-xs px-2 py-1 rounded font-medium flex-shrink-0">
                        Remark <%= index + 1 %>
                      </span>
                      <span class="text-gray-700"><%= remark %></span>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <p class="text-gray-500 text-sm">
                  <i class="fas fa-check-circle text-green-500 mr-1"></i>
                  Quarter approved - no additional remarks needed
                </p>
              <% end %>
            </div>
          </div>
        <% else %>
          <h3 class="text-xl font-bold text-gray-700 mb-6 flex items-center gap-2">
            <i class="fas fa-user-crown text-gray-500"></i>
            <%= params[:month].present? ? "L3 #{short_month_label(params[:month])} Summary" : "L3 Quarter Summary" %> - <%= @employee_detail.l3_employer_name.presence || "N/A" %>
          </h3>
          <div class="mb-6 text-center">
            <div class="summary-percent-box bg-gray-200 p-4 rounded-lg inline-block">
              <p class="text-gray-600 font-semibold text-sm mb-1"><%= params[:month].present? ? "Month Average Percentage" : "Quarter Average Percentage" %></p>
              <p class="text-lg font-bold text-gray-700">L3 data not available</p>
            </div>
          </div>
          <div class="summary-remarks-box bg-white p-4 rounded border text-center text-gray-600">
            <p class="text-sm mt-2">This department is not yet L3 approved</p>
          </div>
        <% end %>
      </div>

    </div>
  <% end %>
<% end %>

<!-- FIXED: L3 approve/return buttons - Show when L3 can take action -->
<% if @can_l3_approve_or_return && @user_details.any? && params[:quarter].present? %>
  <%
    # FIXED: Show buttons dynamically based on actual status
    # Show buttons when L3 can take action (not already processed by L3)
    can_take_action = overall_quarter_status != "l3_approved" && overall_quarter_status != "l3_returned"
    show_buttons = can_take_action && (overall_quarter_status == "l2_approved" || overall_quarter_status == "l2_returned" || overall_quarter_status == "l1_approved" || overall_quarter_status == "l1_returned" || overall_quarter_status == "submitted" || overall_quarter_status == "pending")
  %>
  
  <% if show_buttons %>
    <div class="mt-8 pt-6 border-t border-gray-200">
      <div class="flex flex-col sm:flex-row gap-4 justify-center" id="actionButtons">
        <button onclick="openModal('l3_approve')" class="px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          L3 Approve <%= params[:month].present? ? short_month_label(params[:month]) : "Quarter" %>
        </button>
        <button onclick="openModal('l3_reject')" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          L3 Return <%= params[:month].present? ? short_month_label(params[:month]) : "Quarter" %>
        </button>
      </div>
    </div>
  <% else %>
    <div class="mt-8 pt-6 border-t border-gray-200 text-center text-gray-600 font-medium">
      <% if overall_quarter_status == "l3_approved" %>
        <i class="fas fa-check-circle text-green-500 mr-2"></i>
        This Quarter has been L3 approved and cannot be modified.
      <% elsif overall_quarter_status == "l3_returned" %>
        <i class="fas fa-undo text-orange-500 mr-2"></i>
        This Quarter has been returned by L3.
      <% elsif overall_quarter_status == "returned_to_employee" %>
        <i class="fas fa-user-undo text-red-500 mr-2"></i>
        This Quarter has been returned to the employee for corrections.
      <% elsif overall_quarter_status != "l2_approved" %>
        This Quarter is not ready for L3 review (Status: <%= overall_quarter_status %>).
      <% else %>
        This Quarter has been processed and cannot be modified.
      <% end %>
    </div>
  <% end %>
<% end %>

<!-- Modal for L3 Actions - same positioning pattern as L1/L2 -->
<div id="decisionModal" class="hidden fixed inset-0 flex items-start justify-center z-50 pt-20">
  <div class="bg-white rounded-xl p-6 shadow-xl w-full max-w-md relative mx-4 overflow-y-auto" style="max-height: calc(100vh - 7rem);">
    <!-- Loading overlay -->
    <div id="modalLoading" class="hidden absolute inset-0 bg-white bg-opacity-75 flex items-center justify-center rounded-xl">
      <div class="flex items-center space-x-2">
        <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-emerald-600"></div>
        <span class="text-gray-600">Processing...</span>
      </div>
    </div>

    <h2 class="text-xl font-bold mb-4" id="modalTitle">L3 Decision</h2>

    <form id="modalForm" onsubmit="return false;" action="javascript:void(0);" method="post" novalidate>
      <!-- Hidden inputs for form submission -->
      <input type="hidden" id="action_type" name="action_type" value="">
      <input type="hidden" id="selected_quarter" name="selected_quarter" value="<%= params[:quarter] %>">
      <input type="hidden" id="selected_month" name="selected_month" value="<%= params[:month] %>">
      <input type="hidden" id="department_id" name="department_id" value="<%= params[:department_id] %>">
      <input type="hidden" name="selected_financial_year" value="<%= @selected_financial_year %>">
      
      <!-- Return Level Dropdown - Only show for return actions -->
      <div id="returnLevelSection" class="mb-4 hidden">
        <label for="return_level" class="block font-semibold mb-1">Return to:</label>
        <select id="return_level" name="return_level" class="w-full border border-gray-300 rounded-md p-2">
          <option value="">Select return level...</option>
          <option value="l2">L3_Return_L2</option>
          <option value="l1">L3_Return_L1</option>
          <option value="employee">L3_Return_Employee</option>
        </select>
      </div>
      
      <div class="mb-4">
        <label for="l3_remarks" class="block font-semibold mb-1">L3 Remarks</label>
        <textarea id="l3_remarks" name="l3_remarks" rows="3" class="w-full border border-gray-300 rounded-md p-2" required></textarea>
      </div>
      <div class="mb-4">
        <label for="l3_percentage" class="block font-semibold mb-1">L3 Percentage</label>
        <input type="number" id="l3_percentage" name="l3_percentage" step="0.01" min="0" max="100" class="w-full border border-gray-300 rounded-md p-2 bg-gray-100 cursor-not-allowed" readonly required>
      </div>
      
      <!-- Hidden fields for quarterly tracking -->
      <% if params[:user_detail_id].present? %>
        <input type="hidden" name="user_detail_id" value="<%= params[:user_detail_id] %>">
      <% end %>
      <input type="hidden" name="selected_quarter" value="<%= params[:quarter] %>">
      <input type="hidden" name="selected_month" value="<%= params[:month] %>">
      <input type="hidden" name="selected_financial_year" value="<%= @selected_financial_year %>">
      <input type="hidden" name="apply_to_all_activities" value="true">
      
      <div class="flex justify-end gap-2">
        <button type="button" onclick="closeModal()" class="px-4 py-2 bg-gray-200 rounded-lg hover:bg-gray-300">Cancel</button>
        <button type="button" id="submitButton" class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700">Submit</button>
      </div>
    </form>
  </div>
</div>

<!-- JavaScript with improved update logic and modal positioning -->
<script>
  // Use window object to store state and prevent issues with Turbo re-execution
  if (typeof window.l3DecisionData === 'undefined') {
    window.l3DecisionData = {
      currentActionType: '',
      currentActionUrl: ''
    };
  }

  function resetL3ModalState(options = {}) {
    const modal = document.getElementById('decisionModal');
    const modalLoading = document.getElementById('modalLoading');
    const submitButton = document.getElementById('submitButton');

    if (modal && options.hideModal !== false) {
      modal.classList.add('hidden');
      modal.style.display = 'none';
      modal.style.paddingTop = '';
    }

    if (modalLoading) modalLoading.classList.add('hidden');
    if (submitButton) submitButton.disabled = false;

    document.body.style.overflow = '';
    document.body.classList.remove('modal-open');
  }

  // Unify initialization into a function that runs on load and Turbo visits
  function initializeL3Decision() {
    console.log('Initializing L3 Decision JS...');
    const form = document.getElementById('modalForm');
    const modal = document.getElementById('decisionModal');
    const returnLevelSection = document.getElementById('returnLevelSection');

    if (modal && modal.classList.contains('hidden')) {
      resetL3ModalState();
    }
    
    if (form) {
      form.action = 'javascript:void(0);';
      form.method = 'post';
      form.setAttribute('novalidate', 'novalidate');
      form.removeAttribute('data-remote');
      form.removeAttribute('data-turbo');
      
      // Ensure dropdown is hidden initially
      if (returnLevelSection) {
        returnLevelSection.classList.add('hidden');
        returnLevelSection.style.display = 'none';
      }
      
      // Clear any existing submit listeners to avoid duplicates
      const newForm = form.cloneNode(true);
      form.parentNode.replaceChild(newForm, form);
      
      newForm.addEventListener('submit', function(e) {
        e.preventDefault();
        return false;
      }, true);
      
      // Re-get elements from the new form
      const newSubmitButton = document.getElementById('submitButton');
      if (newSubmitButton) {
        newSubmitButton.addEventListener('click', function(e) {
          console.log('Submit button clicked');
          submitDecision(e);
        });
      }
    }
  }

  // Bind to both events for maximum compatibility
  document.addEventListener('DOMContentLoaded', initializeL3Decision);
  document.addEventListener('turbo:load', initializeL3Decision);
  document.addEventListener('turbo:before-cache', () => resetL3ModalState());
  window.addEventListener('pageshow', () => resetL3ModalState());

  function parseReviewNumber(value) {
    const normalizedValue = String(value || '').replace(/,/g, '').replace(/[^0-9.-]/g, '');
    const number = parseFloat(normalizedValue);
    return Number.isFinite(number) ? number : null;
  }

  function calculateReviewProgress() {
    let targetTotal = 0;
    let achievementTotal = 0;

    document.querySelectorAll('.month-target-cell').forEach((targetCell) => {
      const achievementCell = targetCell.nextElementSibling;
      const targetValue = parseReviewNumber(targetCell.textContent);
      const achievementValue = parseReviewNumber(achievementCell?.textContent);

      if (targetValue !== null && targetValue > 0 && achievementValue !== null) {
        targetTotal += targetValue;
        achievementTotal += achievementValue;
      }
    });

    if (targetTotal <= 0 || achievementTotal <= 0) return '';
    const percentage = (achievementTotal / targetTotal) * 100;
    return (Math.floor(percentage * 100) / 100).toFixed(2);
  }

  function openModal(actionType) {
    console.log('openModal called with actionType:', actionType);
    
    const modal = document.getElementById("decisionModal");
    const modalTitle = document.getElementById("modalTitle");
    const returnLevelSection = document.getElementById('returnLevelSection');
    const returnLevelSelect = document.getElementById('return_level');
    
    if (!modal) return;
    resetL3ModalState();
    
    window.l3DecisionData.currentActionType = actionType;
    
    // Set the action type in the hidden input
    const actionTypeInput = document.getElementById('action_type');
    if (actionTypeInput) actionTypeInput.value = actionType;

    modal.classList.remove("hidden");
    modal.style.paddingTop = "5rem";
    modal.style.display = "flex";
    document.body.style.overflow = 'hidden';
    document.body.classList.add('modal-open');

    if (actionType === "l3_approve") {
      <% if @employee_detail.present? %>
        window.l3DecisionData.currentActionUrl = "<%= l3_approve_employee_detail_path(@employee_detail) %>";
      <% end %>
      modalTitle.innerText = "L3 Approve <%= params[:month].present? ? short_month_label(params[:month]) : 'Quarter' %>";
      
      if (returnLevelSection) {
        returnLevelSection.classList.add('hidden');
        returnLevelSection.style.display = 'none';
      }
      if (returnLevelSelect) returnLevelSelect.required = false;
      
    } else if (actionType === "l3_reject") {
      <% if @employee_detail.present? %>
        window.l3DecisionData.currentActionUrl = "<%= l3_return_employee_detail_path(@employee_detail) %>";
      <% end %>
      modalTitle.innerText = "L3 Return <%= params[:month].present? ? short_month_label(params[:month]) : 'Quarter' %>";
      
      if (returnLevelSection) {
        returnLevelSection.classList.remove('hidden');
        returnLevelSection.style.display = 'block';
      }
      if (returnLevelSelect) returnLevelSelect.required = true;
    }

    // Clear form fields
    const remarksField = document.getElementById('l3_remarks');
    const percentageField = document.getElementById('l3_percentage');
    if (remarksField) remarksField.value = '';
    if (percentageField) percentageField.value = calculateReviewProgress();
  }

  function closeModal() {
    resetL3ModalState();
    window.l3DecisionData.currentActionType = '';
    window.l3DecisionData.currentActionUrl = '';
  }

  function showStatusMessage(message, isSuccess) {
    const statusDiv = document.getElementById('statusMessage');
    if (!statusDiv) return;
    statusDiv.className = `mb-4 p-4 rounded-lg ${isSuccess ? 'bg-green-100 text-green-800 border border-green-200' : 'bg-red-100 text-red-800 border border-red-200'}`;
    statusDiv.textContent = message;
    statusDiv.classList.remove('hidden');
    
    // Scroll to status message
    statusDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    
    setTimeout(() => {
      statusDiv.classList.add('hidden');
    }, 5000);
  }

  function updateStatusBadge(newStatus) {
    const statusBadge = document.getElementById('quarterStatusBadge');
    if (!statusBadge) return;

    let statusConfig = {};
    switch(newStatus) {
      case 'l3_approved':
        statusConfig = { color: 'bg-emerald-100 text-emerald-800 border-emerald-300', text: 'L3 Approved', icon: 'fas fa-check-double' };
        break;
      case 'l3_returned':
        statusConfig = { color: 'bg-orange-100 text-orange-800 border-orange-300', text: 'L3 Returned', icon: 'fas fa-exclamation-triangle' };
        break;
      default:
        statusConfig = { color: 'bg-yellow-100 text-yellow-800 border-yellow-300', text: 'Pending', icon: 'fas fa-clock' };
    }

    statusBadge.className = `inline-flex items-center px-4 py-2 rounded-full text-sm font-medium border ${statusConfig.color}`;
    statusBadge.innerHTML = `<i class="${statusConfig.icon} mr-2"></i>${statusConfig.text}`;
  }

  function hideActionButtons() {
    const actionButtons = document.getElementById('actionButtons');
    if (actionButtons) {
      actionButtons.style.display = 'none';
      const processedMessage = document.createElement('div');
      processedMessage.className = 'mt-8 pt-6 border-t border-gray-200 text-center text-gray-600 font-medium';
      processedMessage.textContent = 'This Quarter has been processed and cannot be modified.';
      actionButtons.parentNode.appendChild(processedMessage);
    }
  }

  function submitDecision(event) {
    if (event) event.preventDefault();
    const actionUrl = window.l3DecisionData.currentActionUrl;
    
    if (!actionUrl) {
      showStatusMessage('❌ Error: Initialization failed. Please refresh.', false);
      return;
    }
    
    const form = document.getElementById('modalForm');
    const modalLoading = document.getElementById('modalLoading');
    const submitButton = document.getElementById('submitButton');
    const formData = new FormData(form);

    document.querySelectorAll('.l3-reporting-manager-remarks-input').forEach((input) => {
      const userDetailId = input.dataset.userDetailId;
      const month = input.dataset.month;
      if (userDetailId && month) {
        formData.append(`manager_remarks[${userDetailId}][${month}]`, input.value || '');
      }
    });
    
    // Validation
    const remarks = document.getElementById('l3_remarks').value;
    const percentage = document.getElementById('l3_percentage').value;
    const returnLevel = document.getElementById('return_level');
    
    if (!remarks.trim()) { resetL3ModalState({ hideModal: false }); alert('Please enter remarks'); return; }
    if (!percentage) { resetL3ModalState({ hideModal: false }); alert('Percentage could not be calculated. Please check target and achievement values.'); return; }
    if (window.l3DecisionData.currentActionType === 'l3_reject' && (!returnLevel || !returnLevel.value)) {
      resetL3ModalState({ hideModal: false }); alert('Please select return level'); return;
    }

    if (modalLoading) modalLoading.classList.remove('hidden');
    if (submitButton) submitButton.disabled = true;
    
    fetch(actionUrl, {
      method: 'PATCH',
      body: formData,
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      }
    })
    .then(response => response.json())
    .then(data => {
      if (modalLoading) modalLoading.classList.add('hidden');
      if (submitButton) submitButton.disabled = false;
      if (data.success) {
        closeModal();
        showStatusMessage(data.message, true);
        if (data.updated_status) {
          updateStatusBadge(data.updated_status);
          hideActionButtons();
        }
        // Refresh faster for better UX
        setTimeout(() => { window.location.reload(); }, 1000);
      } else {
        resetL3ModalState({ hideModal: false });
        showStatusMessage(data.message || 'Error occurred', false);
      }
    })
    .catch(error => {
      if (modalLoading) modalLoading.classList.add('hidden');
      if (submitButton) submitButton.disabled = false;
      resetL3ModalState({ hideModal: false });
      showStatusMessage('Network error occurred. Please try again.', false);
    });
  }

  // Update logic and listeners
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  
  // Close on outside click
  window.addEventListener('click', (e) => {
    const modal = document.getElementById('decisionModal');
    if (e.target === modal) closeModal();
  });


</script>

