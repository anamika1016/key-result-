  min-width: 900px;
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  table-layout: auto;
}

.table th, .table td {
  padding: 8px 12px;
  text-align: center;
  border-right: 1px solid #e5e7eb;
  white-space: nowrap;
