<!-- Fixed Employee Detail show l1 View -->
<div class="main-content bg-gray-50 min-h-screen">
<div class="p-8 bg-white rounded-xl shadow-lg border border-gray-200 mx-4">
  <div class="border-b border-gray-200 pb-6 mb-8">
    <h2 class="text-3xl font-bold text-gray-800 flex items-center">
      <i class="fas fa-user-circle mr-3 text-gray-600"></i>
      Employee Detail
      <% if params[:month].present? %>
        <span class="ml-4 text-lg bg-blue-100 text-blue-800 px-3 py-1 rounded-full">
          <%= params[:month].titleize %> Activity
        </span>
      <% end %>
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
      <p class="text-gray-600 text-sm font-medium mb-1">Name</p>
      <p class="text-gray-800 font-semibold text-lg"><%= @employee_detail.employee_name %></p>
    </div>
    <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
      <p class="text-gray-600 text-sm font-medium mb-1">Email</p>
      <p class="text-gray-800 font-semibold text-lg"><%= @employee_detail.employee_email %></p>
    </div>
    <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
      <p class="text-gray-600 text-sm font-medium mb-1">Department</p>
      <p class="text-gray-800 font-semibold text-lg"><%= @employee_detail.department %></p>
    </div>
    <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
     <p class="text-gray-600 text-sm font-medium mb-1">Status</p>
      <%
        # Calculate the overall status based on achievements
        overall_status = "pending"
        if @user_details.any?
          achievement_statuses = []
          @user_details.each do |detail|
            detail.achievements.each do |ach|
              if params[:month].present?
                # If filtering by month, only consider that specific month
                if ach.month == params[:month]
                  achievement_statuses << (ach.status || "pending")
                end
              else
                # Consider all achievements
                achievement_statuses << (ach.status || "pending")
              end
            end
          end
          
          # Determine overall status priority
          if achievement_statuses.include?("l2_approved")
            overall_status = "l2_approved"
          elsif achievement_statuses.include?("l1_approved")
            overall_status = "l1_approved"
          elsif achievement_statuses.include?("l2_returned")
            overall_status = "l2_returned"
          elsif achievement_statuses.include?("l1_returned")
            overall_status = "l1_returned"
          elsif achievement_statuses.include?("submitted")
            overall_status = "submitted"
          else
            overall_status = "pending"
          end
        end
        
        status_config = case overall_status
        when "pending"
          { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending Review", icon: "fas fa-clock" }
        when "l1_approved"
          { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved", icon: "fas fa-check-circle" }
        when "l1_returned"
          { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
        when "l2_approved"
          { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved", icon: "fas fa-check-double" }
        when "l2_returned"
          { color: "bg-orange-100 text-orange-800 border-orange-300", text: "L2 Returned", icon: "fas fa-exclamation-triangle" }
        when "submitted"
          { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
        else
          { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status", icon: "fas fa-question-circle" }
        end
      %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium border <%= status_config[:color] %>">
        <i class="<%= status_config[:icon] %> mr-1"></i>
        <%= status_config[:text] %>
      </span>
    </div>
  </div>

  <% if @user_details.any? && @user_details.any? { |detail| detail.achievements.any?(&:achievement?) } %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm mt-8">
      <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
        <h2 class="text-2xl font-bold text-gray-800 flex items-center">
          <i class="fas fa-trophy mr-3 text-gray-600"></i>
          <% if params[:month].present? %>
            <%= params[:month].titleize %> Achievement Details
          <% else %>
            Submitted Achievements
          <% end %>
        </h2>
      </div>

      <div class="p-6">
        <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200">
          <table class="table table-hover w-full min-w-full">
            <thead class="bg-gray-800">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Department</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Employee Name</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Activity</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Unit</th>
                
                <% if params[:month].present? %>
                  <!-- Show only selected month -->
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700">
                    Target
                  </th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700">
                    Achievement
                  </th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700">
                    Employee Remarks
                  </th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700">
                    Status
                  </th>
                <% else %>
                  <!-- Show all months (existing behavior) -->
                  <% ["April", "May", "June", "July", "August", "September", "October", "November", "December", "January", "February", "March"].each do |month| %>
                    <th colspan="4" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month %></th>
                  <% end %>
                <% end %>
              </tr>
              
              <% unless params[:month].present? %>
              <tr class="bg-gray-700">
                <% 12.times do %>
                  <th class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Target</th>
                  <th class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Achievement</th>
                  <th class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Remarks</th>
                  <th class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Status</th>
                <% end %>
              </tr>
              <% end %>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @user_details.each_with_index do |detail, index| %>
                <% existing_achievements = detail.achievements.index_by(&:month) %>
                <% if existing_achievements.values.any? { |a| a.achievement.present? } %>
                  <tr class="<%= index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200">
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200"><%= detail.department&.department_type || 'N/A' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200"><%= detail.employee_detail&.employee_name || 'N/A' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity&.activity_name || 'N/A' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= detail.activity&.unit || 'N/A' %></td>

                    <% if params[:month].present? %>
                      <!-- Show only selected month data -->
                      <% month_symbol = params[:month].to_sym %>
                      <% target_value = detail.send(month_symbol) %>
                      <% achievement_record = existing_achievements[params[:month]] %>
                      <% achievement_value = achievement_record&.achievement %>
                      <% employee_remarks = achievement_record&.employee_remarks %>
                      <% achievement_status = achievement_record&.status || "pending" %>
                      
                      <td class="px-3 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200">
                        <span class="<%= achievement_value.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement_value.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200 max-w-xs">
                        <% if employee_remarks.present? %>
                          <div class="text-blue-700 font-medium bg-blue-50 px-2 py-1 rounded text-xs break-words">
                            <%= employee_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">No remarks</span>
                        <% end %>
                      </td>
                      <td class="px-3 py-3 text-sm text-center border-r border-gray-200">
                        <%
                          status_config = case achievement_status
                          when "pending"
                            { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
                          when "l1_approved"
                            { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved", icon: "fas fa-check-circle" }
                          when "l1_returned"
                            { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
                          when "l2_approved"
                            { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved", icon: "fas fa-check-double" }
                          when "l2_returned"
                            { color: "bg-orange-100 text-orange-800 border-orange-300", text: "L2 Returned", icon: "fas fa-exclamation-triangle" }
                          when "submitted"
                            { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
                          else
                            { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status", icon: "fas fa-question-circle" }
                          end
                        %>
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border <%= status_config[:color] %>">
                          <i class="<%= status_config[:icon] %> mr-1"></i>
                          <%= status_config[:text] %>
                        </span>
                      </td>
                    <% else %>
                      <!-- Show all months (existing behavior) -->
                      <% [:april, :may, :june, :july, :august, :september, :october, :november, :december, :january, :february, :march].each do |month| %>
                        <% target_value = detail.send(month) %>
                        <% achievement_record = existing_achievements[month.to_s] %>
                        <% achievement_value = achievement_record&.achievement %>
                        <% employee_remarks = achievement_record&.employee_remarks %>
                        <% achievement_status = achievement_record&.status || "pending" %>
                        
                        <td class="px-2 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50">
                          <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                            <%= target_value.presence || '-' %>
                          </span>
                        </td>
                        <td class="px-2 py-3 text-sm text-center border-r border-gray-200">
                          <span class="<%= achievement_value.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded text-xs' : 'text-gray-400' %>">
                            <%= achievement_value.presence || '-' %>
                          </span>
                        </td>
                        <td class="px-2 py-3 text-sm text-center border-r border-gray-200 max-w-24">
                          <% if employee_remarks.present? %>
                            <div class="text-blue-700 font-medium bg-blue-50 px-1 py-1 rounded text-xs break-words overflow-hidden" title="<%= employee_remarks %>">
                              <%= employee_remarks.length > 20 ? employee_remarks[0..17] + "..." : employee_remarks %>
                            </div>
                          <% else %>
                            <span class="text-gray-400 text-xs">-</span>
                          <% end %>
                        </td>
                        <td class="px-2 py-3 text-sm text-center border-r border-gray-200">
                          <%
                            status_config = case achievement_status
                            when "pending"
                              { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
                            when "l1_approved"
                              { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved", icon: "fas fa-check-circle" }
                            when "l1_returned"
                              { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
                            when "l2_approved"
                              { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved", icon: "fas fa-check-double" }
                            when "l2_returned"
                              { color: "bg-orange-100 text-orange-800 border-orange-300", text: "L2 Returned", icon: "fas fa-exclamation-triangle" }
                            when "submitted"
                              { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
                            else
                              { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status", icon: "fas fa-question-circle" }
                            end
                          %>
                          <span class="inline-flex items-center px-1 py-1 rounded-full text-xs font-medium border <%= status_config[:color] %>">
                            <i class="<%= status_config[:icon] %> mr-1"></i>
                            <%= status_config[:text] %>
                          </span>
                        </td>
                      <% end %>
                    <% end %>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>

<% if @can_approve_or_return && @user_details.any? { |detail| detail.achievements.any?(&:achievement?) } && params[:month].present? %>
  <%
    can_take_action = false
    current_achievement_status = "pending"
    
    @user_details.each do |detail|
      achievement = detail.achievements.find { |a| a.month == params[:month] }
      if achievement
        current_achievement_status = achievement.status || "pending"
        can_take_action = ['pending', 'l1_returned'].include?(current_achievement_status)
        break
      end
    end
  %>
  
  <% if can_take_action %>
    <div class="mt-8 pt-6 border-t border-gray-200">
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button onclick="openModal('approve')" class="px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          Approve <%= params[:month].titleize %> Activity
        </button>
        <button onclick="openModal('reject')" class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          Return <%= params[:month].titleize %> Activity
        </button>
      </div>
    </div>
  <% else %>
    <div class="mt-8 pt-6 border-t border-gray-200 text-center text-gray-600 font-medium">
      This <%= params[:month].titleize %> activity is currently "<%= current_achievement_status.titleize %>" and cannot be modified.
    </div>
  <% end %>

<% elsif @can_approve_or_return && @user_details.any? { |detail| detail.achievements.any?(&:achievement?) } %>
  <%
    can_take_bulk_action = false
    @user_details.each do |detail|
      detail.achievements.each do |achievement|
        if ['pending', 'l1_returned'].include?(achievement.status || "pending")
          can_take_bulk_action = true
          break
        end
      end
      break if can_take_bulk_action
    end
  %>

  <% if can_take_bulk_action %>
    <div class="mt-8 pt-6 border-t border-gray-200">
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button onclick="openModal('approve')" class="px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          Approve All Activities
        </button>
        <button onclick="openModal('reject')" class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          Return All Activities
        </button>
      </div>
    </div>
  <% else %>
    <div class="mt-8 pt-6 border-t border-gray-200 text-center text-gray-600 font-medium">
      All activities have been processed and cannot be modified.
    </div>
  <% end %>
<% end %>

<!-- Modal -->
<div id="decisionModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
  <div class="bg-white rounded-xl p-6 shadow-xl w-full max-w-md">
    <h2 class="text-xl font-bold mb-4" id="modalTitle">Decision</h2>

    <%= form_with url: '', method: :patch, id: 'modalForm', local: true do |f| %>
      <div class="mb-4">
        <%= f.label :remarks, "Remarks", class: "block font-semibold mb-1" %>
        <%= f.text_area :remarks, rows: 3, class: "w-full border border-gray-300 rounded-md" %>
      </div>
      <div class="mb-4">
        <%= f.label :percentage, "Percentage", class: "block font-semibold mb-1" %>
        <%= f.number_field :percentage, step: 0.1, class: "w-full border border-gray-300 rounded-md" %>
      </div>

      <% if params[:user_detail_id].present? %>
        <%= f.hidden_field :user_detail_id, value: params[:user_detail_id] %>
      <% end %>
      <% if params[:month].present? %>
        <%= f.hidden_field :selected_month, value: params[:month] %>
      <% end %>

      <div class="flex justify-end gap-2">
        <button type="button" onclick="closeModal()" class="px-4 py-2 bg-gray-200 rounded-lg hover:bg-gray-300">Cancel</button>
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Submit</button>
      </div>
    <% end %>
  </div>
</div>

<!-- JS -->
<script>
  function openModal(actionType) {
    const modal = document.getElementById("decisionModal");
    const form = document.getElementById("modalForm");
    const modalTitle = document.getElementById("modalTitle");

    modal.classList.remove("hidden");

    if (actionType === "approve") {
      form.action = "<%= approve_employee_detail_path(@employee_detail) %>";
      modalTitle.innerText = "Approve with Remarks";
    } else {
      form.action = "<%= return_employee_detail_path(@employee_detail) %>";
      modalTitle.innerText = "Return with Remarks";
    }
  }

  function closeModal() {
    document.getElementById("decisionModal").classList.add("hidden");
  }
</script>

<!-- Month-wise L1 Remarks Display -->
<!-- Month-wise L1 & L2 Remarks Display -->
<% if params[:month].present? %>
  <% @user_details.each do |detail| %>
    <% achievement = detail.achievements.find { |a| a.month == params[:month] } %>
    <% if achievement && achievement.achievement_remark.present? %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
        
        <!-- L1 Remarks & Percentage -->
        <div class="bg-gradient-to-r from-blue-50 via-blue-50 to-blue-100 border border-blue-200 rounded-xl p-6 shadow-md">
          <h3 class="text-xl font-bold text-blue-700 mb-6 flex items-center gap-2">
            <i class="fas fa-user-check text-blue-500"></i>
            L1 Remarks & Percentage
          </h3>

          <div class="space-y-4">
            <div class="bg-white border-l-4 border-blue-500 rounded-lg p-4 shadow-sm">
              <p class="text-sm text-blue-600 font-semibold mb-2 uppercase tracking-wide">
                <%= params[:month].titleize %>
              </p>
              <p class="text-xs text-blue-500 font-medium mb-1">Activity: <%= detail.activity&.activity_name || 'N/A' %></p>
              
              <div class="mt-3">
                <p class="text-xs text-blue-600 font-semibold mb-1">L1 Remarks</p>
                <div class="bg-blue-50 p-3 rounded border">
                  <p class="text-gray-700 text-sm whitespace-pre-line">
                    <%= achievement.achievement_remark.l1_remarks.presence || "No Remarks" %>
                  </p>
                </div>
              </div>
              
              <div class="mt-3">
                <p class="text-xs text-blue-600 font-semibold mb-1">L1 Percentage</p>
                <div class="bg-blue-100 px-3 py-2 rounded border inline-block">
                  <p class="text-blue-800 text-sm font-bold">
                    <%= achievement.achievement_remark.l1_percentage.present? ? "#{achievement.achievement_remark.l1_percentage}%" : "0.0%" %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- L2 Remarks & Percentage -->
        <div class="bg-gradient-to-r from-green-50 via-green-50 to-green-100 border border-green-200 rounded-xl p-6 shadow-md">
          <h3 class="text-xl font-bold text-green-700 mb-6 flex items-center gap-2">
            <i class="fas fa-user-shield text-green-500"></i>
            L2 Remarks & Percentage
          </h3>

          <div class="space-y-4">
            <div class="bg-white border-l-4 border-green-500 rounded-lg p-4 shadow-sm">
              <p class="text-sm text-green-600 font-semibold mb-2 uppercase tracking-wide">
                <%= params[:month].titleize %>
              </p>
              <p class="text-xs text-green-500 font-medium mb-1">Activity: <%= detail.activity&.activity_name || 'N/A' %></p>
              
              <div class="mt-3">
                <p class="text-xs text-green-600 font-semibold mb-1">L2 Remarks</p>
                <div class="bg-green-50 p-3 rounded border">
                  <p class="text-gray-700 text-sm whitespace-pre-line">
                    <%= achievement.achievement_remark.l2_remarks.presence || "No Remarks" %>
                  </p>
                </div>
              </div>
              
              <div class="mt-3">
                <p class="text-xs text-green-600 font-semibold mb-1">L2 Percentage</p>
                <div class="bg-green-100 px-3 py-2 rounded border inline-block">
                  <p class="text-green-800 text-sm font-bold">
                    <%= achievement.achievement_remark.l2_percentage.present? ? "#{achievement.achievement_remark.l2_percentage}%" : "0.0%" %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    <% end %>
  <% end %>
<% end %>

<!-- Keep existing styles -->
<style>
.main-content {
  margin-left: 240px;
  padding: 2rem;
  overflow-x: auto;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
}

.table-wrapper {
  overflow-x: auto;
  border-radius: 0.75rem;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.table {
  min-width: 1800px;
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  table-layout: fixed;
}

.table th, .table td {
  padding: 8px 12px;
  text-align: center;
  border-right: 1px solid #e5e7eb;
  white-space: nowrap;
  vertical-align: middle;
}

