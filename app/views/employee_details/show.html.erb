<!-- Employee Detail show l1 View - Quarterly Support -->
<div class="main-content bg-gray-50 min-h-screen">
<div class="p-8 bg-white rounded-xl shadow-lg border border-gray-200 mx-4">
  <div class="border-b border-gray-200 pb-6 mb-8">
    <h2 class="text-3xl font-bold text-gray-800 flex items-center">
      <i class="fas fa-user-circle mr-3 text-gray-600"></i>
      Employee Detail
      <% if params[:quarter].present? %>
        <span class="ml-4 text-lg bg-blue-100 text-blue-800 px-3 py-1 rounded-full">
          <%= params[:quarter] %> Quarter Activity
        </span>
      <% end %>
    </h2>
  </div>

  <% if @user_details.any? && @user_details.any? { |detail| detail.achievements.any?(&:achievement?) } %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm mt-8">
      <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
        <h2 class="text-2xl font-bold text-gray-800 flex items-center">
          <i class="fas fa-trophy mr-3 text-gray-600"></i>
          <% if params[:quarter].present? %>
            <%= params[:quarter] %> Quarter Achievement Details
          <% else %>
            Submitted Achievements
          <% end %>
        </h2>
      </div>

      <div class="p-6">
        <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200">
          <%
            # Define months to display based on quarter or all months if no quarter is specified
            display_months = if params[:quarter].present?
                              case params[:quarter]
                              when 'Q1'
                                [[:january, 'Jan'], [:february, 'Feb'], [:march, 'Mar']]
                              when 'Q2'
                                [[:april, 'Apr'], [:may, 'May'], [:june, 'Jun']]
                              when 'Q3'
                                [[:july, 'Jul'], [:august, 'Aug'], [:september, 'Sep']]
                              when 'Q4'
                                [[:october, 'Oct'], [:november, 'Nov'], [:december, 'Dec']]
                              else
                                []
                              end
                            else
                              # Fallback to a default or all months if needed
                              [[:april, 'Apr'], [:may, 'May'], [:june, 'Jun']] # Defaulting to Q2 for example
                            end
          %>
          <table class="table table-hover w-full min-w-full">
            <thead class="bg-gray-800">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Department</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Employee Name</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Activity</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Unit</th>

                <!-- DYNAMIC MONTH COLUMNS -->
                <% display_months.each do |month_symbol, month_name| %>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name %> Target</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name %> Achievement</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name %> Remarks</th>
                <% end %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @user_details.each_with_index do |detail, detail_index| %>
                <% 
                  existing_achievements = detail.achievements.index_by(&:month)
                  # Only render the row if there is at least one achievement in the selected quarter for this activity
                  has_quarterly_data = display_months.any? do |month_symbol, _|
                    existing_achievements[month_symbol.to_s]&.achievement.present? || detail.send(month_symbol).present?
                  end
                %>
                <% if has_quarterly_data %>
                  <tr class="<%= detail_index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200">
                    <!-- Static Columns -->
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200">
                      <%= detail.department&.department_type || 'N/A' %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200">
                      <%= detail.employee_detail&.employee_name || 'N/A' %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200">
                      <%= detail.activity&.activity_name || 'N/A' %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= detail.activity&.unit || 'N/A' %>
                    </td>

                    <!-- Dynamic Month Data Columns -->
                    <% display_months.each do |month_symbol, month_name| %>
                      <%
                        target_value = detail.send(month_symbol)
                        achievement_record = existing_achievements[month_symbol.to_s]
                        achievement_value = achievement_record&.achievement
                        employee_remarks = achievement_record&.employee_remarks
                      %>
                      <!-- Target -->
                      <td class="px-4 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      
                      <!-- Achievement -->
                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200">
                        <span class="<%= achievement_value.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement_value.presence || '-' %>
                        </span>
                      </td>
                      
                      <!-- Remarks -->
                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 max-w-xs">
                        <% if employee_remarks.present? %>
                          <div class="text-blue-700 font-medium bg-blue-50 px-2 py-1 rounded text-xs break-words">
                            <%= employee_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>

<!-- FIXED: Single Overall Status Display for Quarter -->
<% if params[:quarter].present? %>
  <%
    quarter_months = case params[:quarter]
                   when 'Q1'
                     ['january', 'february', 'march']
                   when 'Q2'
                     ['april', 'may', 'june']
                   when 'Q3'
                     ['july', 'august', 'september']
                   when 'Q4'
                     ['october', 'november', 'december']
                   else
                     []
                   end

    # Calculate quarterly data - collect all statuses for the quarter
    quarterly_statuses = []
    quarter_l1_total = 0
    quarter_l2_total = 0
    quarter_achievement_count = 0
    quarter_remarks_l1 = Set.new
    quarter_remarks_l2 = Set.new
    
    @user_details.each do |detail|
      quarter_achievements = detail.achievements.select { |a| quarter_months.include?(a.month) }
      quarter_achievements.each do |achievement|
        quarterly_statuses << (achievement.status || "pending")
        
        if achievement.achievement_remark.present?
          quarter_achievement_count += 1
          
          # Collect L1 data
          if achievement.achievement_remark.l1_percentage.present?
            quarter_l1_total += achievement.achievement_remark.l1_percentage.to_f
          end
          
          # Add unique L1 remarks only
          if achievement.achievement_remark.l1_remarks.present?
            quarter_remarks_l1.add(achievement.achievement_remark.l1_remarks)
          end
          
          # Collect L2 data
          if achievement.achievement_remark.l2_percentage.present?
            quarter_l2_total += achievement.achievement_remark.l2_percentage.to_f
          end
          
          # Add unique L2 remarks only
          if achievement.achievement_remark.l2_remarks.present?
            quarter_remarks_l2.add(achievement.achievement_remark.l2_remarks)
          end
        end
      end
    end
    
    # Determine overall quarter status (single status for entire quarter)
    overall_quarter_status = "pending"
    if quarterly_statuses.any?
      if quarterly_statuses.all? { |s| s == "l2_approved" }
        overall_quarter_status = "l2_approved"
      elsif quarterly_statuses.all? { |s| s == "l1_approved" }
        overall_quarter_status = "l1_approved"
      elsif quarterly_statuses.any? { |s| s == "l2_returned" }
        overall_quarter_status = "l2_returned"
      elsif quarterly_statuses.any? { |s| s == "l1_returned" }
        overall_quarter_status = "l1_returned"
      elsif quarterly_statuses.any? { |s| s == "submitted" }
        overall_quarter_status = "submitted"
      end
    end

    status_config = case overall_quarter_status
    when "pending"
      { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
    when "l1_approved"
      { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved", icon: "fas fa-check-circle" }
    when "l1_returned"
      { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
    when "l2_approved"
      { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved", icon: "fas fa-check-double" }
    when "l2_returned"
      { color: "bg-orange-100 text-orange-800 border-orange-300", text: "L2 Returned", icon: "fas fa-exclamation-triangle" }
    when "submitted"
      { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
    else
      { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status", icon: "fas fa-question-circle" }
    end
    
    # Calculate averages
    quarter_l1_average = quarter_achievement_count > 0 ? (quarter_l1_total / quarter_achievement_count).round(1) : 0.0
    quarter_l2_average = quarter_achievement_count > 0 ? (quarter_l2_total / quarter_achievement_count).round(1) : 0.0
    
    # Convert Sets to Arrays for display
    quarter_remarks_l1_array = quarter_remarks_l1.to_a
    quarter_remarks_l2_array = quarter_remarks_l2.to_a
  %>

  <!-- SINGLE OVERALL STATUS DISPLAY -->
  <% if quarterly_statuses.any? %>
    <div class="mt-8 pt-6 border-t border-gray-200">
      <div class="text-center mb-6">
        <h3 class="text-xl font-bold text-gray-800 mb-4">
          <%= params[:quarter] %> Quarter Overall Status
        </h3>
        <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium border <%= status_config[:color] %>">
          <i class="<%= status_config[:icon] %> mr-2"></i>
          <%= status_config[:text] %>
        </span>
      </div>
    </div>
  <% end %>

  <!-- FIXED: Single L1 & L2 Summary for Quarter - NO DUPLICATES -->
  <% if quarter_achievement_count > 0 %>
    <%
      # Calculate SINGLE average for entire quarter (not per month)
      all_quarter_achievements = []
      @user_details.each do |detail|
        quarter_achievements = detail.achievements.select { |a| quarter_months.include?(a.month) && a.achievement_remark.present? }
        all_quarter_achievements.concat(quarter_achievements)
      end

      # SINGLE L1 calculation for quarter
      l1_percentages = all_quarter_achievements.filter_map { |a| a.achievement_remark&.l1_percentage&.to_f }
      final_l1_average = l1_percentages.any? ? (l1_percentages.sum / l1_percentages.size).round(1) : 0.0

      # SINGLE L2 calculation for quarter  
      l2_percentages = all_quarter_achievements.filter_map { |a| a.achievement_remark&.l2_percentage&.to_f }
      final_l2_average = l2_percentages.any? ? (l2_percentages.sum / l2_percentages.size).round(1) : 0.0

      # UNIQUE remarks collection (no duplicates)
      unique_l1_remarks = all_quarter_achievements.filter_map { |a| a.achievement_remark&.l1_remarks }.uniq.compact
      unique_l2_remarks = all_quarter_achievements.filter_map { |a| a.achievement_remark&.l2_remarks }.uniq.compact
    %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
      
      <!-- L1 Quarterly Summary - SINGLE DISPLAY -->
      <div class="bg-gradient-to-r from-blue-50 via-blue-50 to-blue-100 border border-blue-200 rounded-xl p-6 shadow-md">
        <h3 class="text-xl font-bold text-blue-700 mb-6 flex items-center gap-2">
          <i class="fas fa-user-check text-blue-500"></i>
          L1 <%= params[:quarter] %> Quarter Summary
        </h3>

        <!-- SINGLE Quarter Average Percentage -->
        <div class="mb-6 text-center">
          <div class="bg-blue-200 p-4 rounded-lg inline-block">
            <p class="text-blue-600 font-semibold text-sm mb-1">Quarter Average Percentage</p>
            <p class="text-3xl font-bold text-blue-800"><%= final_l1_average %>%</p>
          </div>
        </div>

        <!-- UNIQUE L1 Remarks - NO DUPLICATES -->
        <div class="space-y-3">
          <h4 class="text-blue-600 font-semibold text-sm">Quarter Remarks:</h4>
          <% if unique_l1_remarks.any? %>
            <div class="bg-white p-4 rounded border max-h-40 overflow-y-auto">
              <% unique_l1_remarks.each_with_index do |remark, index| %>
                <div class="text-gray-700 text-sm mb-3 pb-3 <%= 'border-b border-gray-100' unless index == unique_l1_remarks.length - 1 %>">
                  <div class="flex items-start gap-2">
                    <span class="bg-blue-100 text-blue-600 text-xs px-2 py-1 rounded font-medium flex-shrink-0">
                      Remark <%= index + 1 %>
                    </span>
                    <span class="text-gray-700"><%= remark %></span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="bg-white p-4 rounded border">
              <p class="text-gray-500 text-sm">No remarks for this quarter</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- L2 Quarterly Summary - SINGLE DISPLAY -->
      <div class="bg-gradient-to-r from-green-50 via-green-50 to-green-100 border border-green-200 rounded-xl p-6 shadow-md">
        <h3 class="text-xl font-bold text-green-700 mb-6 flex items-center gap-2">
          <i class="fas fa-user-shield text-green-500"></i>
          L2 <%= params[:quarter] %> Quarter Summary
        </h3>

        <!-- SINGLE Quarter Average Percentage -->
        <div class="mb-6 text-center">
          <div class="bg-green-200 p-4 rounded-lg inline-block">
            <p class="text-green-600 font-semibold text-sm mb-1">Quarter Average Percentage</p>
            <p class="text-3xl font-bold text-green-800"><%= final_l2_average %>%</p>
          </div>
        </div>

        <!-- UNIQUE L2 Remarks - NO DUPLICATES -->
        <div class="space-y-3">
          <h4 class="text-green-600 font-semibold text-sm">Quarter Remarks:</h4>
          <% if unique_l2_remarks.any? %>
            <div class="bg-white p-4 rounded border max-h-40 overflow-y-auto">
              <% unique_l2_remarks.each_with_index do |remark, index| %>
                <div class="text-gray-700 text-sm mb-3 pb-3 <%= 'border-b border-gray-100' unless index == unique_l2_remarks.length - 1 %>">
                  <div class="flex items-start gap-2">
                    <span class="bg-green-100 text-green-600 text-xs px-2 py-1 rounded font-medium flex-shrink-0">
                      Remark <%= index + 1 %>
                    </span>
                    <span class="text-gray-700"><%= remark %></span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="bg-white p-4 rounded border">
              <p class="text-gray-500 text-sm">No remarks for this quarter</p>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  <% end %>
<% end %>

<!-- FIXED: Quarterly Approval/Return Process -->
<% if @can_approve_or_return && @user_details.any? { |detail| detail.achievements.any?(&:achievement?) } && params[:quarter].present? %>
  <%
    can_take_action = false
    quarter_months = case params[:quarter]
                   when 'Q1'
                     ['january', 'february', 'march']
                   when 'Q2'
                     ['april', 'may', 'june']
                   when 'Q3'
                     ['july', 'august', 'september']
                   when 'Q4'
                     ['october', 'november', 'december']
                   else
                     []
                   end
    
    @user_details.each do |detail|
      quarter_achievements = detail.achievements.select { |a| quarter_months.include?(a.month) }
      quarter_statuses = quarter_achievements.map { |a| a.status || "pending" }
      
      # Can take action if any achievement in quarter is pending or l1_returned
      if quarter_statuses.any? { |s| ['pending', 'l1_returned'].include?(s) }
        can_take_action = true
        break
      end
    end
  %>
  
  <% if can_take_action %>
    <div class="mt-8 pt-6 border-t border-gray-200">
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button onclick="openModal('approve')" class="px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          Approve <%= params[:quarter] %> Quarter
        </button>
        <button onclick="openModal('reject')" class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          Return <%= params[:quarter] %> Quarter
        </button>
      </div>
    </div>
  <% else %>
    <div class="mt-8 pt-6 border-t border-gray-200 text-center text-gray-600 font-medium">
      This <%= params[:quarter] %> Quarter has been processed and cannot be modified.
    </div>
  <% end %>

<% elsif @can_approve_or_return && @user_details.any? { |detail| detail.achievements.any?(&:achievement?) } %>
  <%
    can_take_bulk_action = false
    @user_details.each do |detail|
      detail.achievements.each do |achievement|
        if ['pending', 'l1_returned'].include?(achievement.status || "pending")
          can_take_bulk_action = true
          break
        end
      end
      break if can_take_bulk_action
    end
  %>

  <% if can_take_bulk_action %>
    <div class="mt-8 pt-6 border-t border-gray-200">
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button onclick="openModal('approve')" class="px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          Approve All Activities
        </button>
        <button onclick="openModal('reject')" class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          Return All Activities
        </button>
      </div>
    </div>
  <% else %>
    <div class="mt-8 pt-6 border-t border-gray-200 text-center text-gray-600 font-medium">
      All activities have been processed and cannot be modified.
    </div>
  <% end %>
<% end %>

<!-- Modal -->
<div id="decisionModal" class="hidden fixed inset-0 flex items-center justify-center z-50">
  <div class="bg-white rounded-xl p-6 shadow-xl w-full max-w-md">
    <h2 class="text-xl font-bold mb-4" id="modalTitle">Decision</h2>

    <%= form_with url: '', method: :patch, id: 'modalForm', local: true do |f| %>
      <div class="mb-4">
        <%= f.label :remarks, "Remarks", class: "block font-semibold mb-1" %>
        <%= f.text_area :remarks, rows: 3, class: "w-full border border-gray-300 rounded-md" %>
      </div>
      <div class="mb-4">
        <%= f.label :percentage, "Percentage", class: "block font-semibold mb-1" %>
        <%= f.number_field :percentage, step: 0.1, class: "w-full border border-gray-300 rounded-md" %>
      </div>

      <% if params[:user_detail_id].present? %>
        <%= f.hidden_field :user_detail_id, value: params[:user_detail_id] %>
      <% end %>
      <% if params[:quarter].present? %>
        <%= f.hidden_field :selected_quarter, value: params[:quarter] %>
      <% end %>

      <div class="flex justify-end gap-2">
        <button type="button" onclick="closeModal()" class="px-4 py-2 bg-gray-200 rounded-lg hover:bg-gray-300">Cancel</button>
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Submit</button>
      </div>
    <% end %>
  </div>
</div>

<!-- JS -->
<script>
  function openModal(actionType) {
    const modal = document.getElementById("decisionModal");
    const form = document.getElementById("modalForm");
    const modalTitle = document.getElementById("modalTitle");

    modal.classList.remove("hidden");

    if (actionType === "approve") {
      form.action = "<%= approve_employee_detail_path(@employee_detail) %>";
      modalTitle.innerText = "Approve with Remarks";
    } else {
      form.action = "<%= return_employee_detail_path(@employee_detail) %>";
      modalTitle.innerText = "Return with Remarks";
    }
  }

  function closeModal() {
    document.getElementById("decisionModal").classList.add("hidden");
  }
</script>

