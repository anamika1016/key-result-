
<!-- L2 Employee Detail Quarterly View with Single Overall Status -->
<div class="main-content bg-gray-50 min-h-screen">
<div class="p-8 bg-white rounded-xl shadow-lg border border-gray-200 mx-4">
  <div class="border-b border-gray-200 pb-6 mb-8">
    <h2 class="text-3xl font-bold text-gray-800 flex items-center">
      <i class="fas fa-user-circle mr-3 text-gray-600"></i>
      Employee Detail - L2 Review
    </h2>
  </div>

  <!-- Status Message Container -->
  <div id="statusMessage" class="hidden mb-4 p-4 rounded-lg"></div>

  <% if @user_details.any? && params[:quarter].present? %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm mt-8">
      <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
        <h2 class="text-2xl font-bold text-gray-800 flex items-center">
          <i class="fas fa-trophy mr-3 text-gray-600"></i>
           Quarter Achievement Details
        </h2>
      </div>

      <div class="p-6">
        <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200">
          <%
            # Define months to display based on quarter
            display_months = case params[:quarter]
                             when 'Q1'
                               [[:january, 'Jan'], [:february, 'Feb'], [:march, 'Mar']]
                             when 'Q2'
                               [[:april, 'Apr'], [:may, 'May'], [:june, 'Jun']]
                             when 'Q3'
                               [[:july, 'Jul'], [:august, 'Aug'], [:september, 'Sep']]
                             when 'Q4'
                               [[:october, 'Oct'], [:november, 'Nov'], [:december, 'Dec']]
                             else
                               []
                             end

            # Calculate overall quarterly status once - FIXED for correct status display
            all_quarterly_statuses = []
            @user_details.each do |detail|
              existing_achievements = detail.achievements.index_by(&:month)
              display_months.each do |month_symbol, _|
                achievement_record = existing_achievements[month_symbol.to_s]
                if achievement_record
                  # Ensure we get the actual status from the database
                  status = achievement_record.status.presence || "pending"
                  all_quarterly_statuses << status
                  Rails.logger.info "Month: #{month_symbol}, Status: #{status}, Achievement ID: #{achievement_record.id}"
                else
                  all_quarterly_statuses << "pending"
                  Rails.logger.info "Month: #{month_symbol}, No achievement record found"
                end
              end
            end

            # Determine single overall quarterly status - FIXED priority logic
            overall_quarterly_status = "pending"
            if all_quarterly_statuses.any?
              Rails.logger.info "All quarterly statuses: #{all_quarterly_statuses}"
              
              # Priority order: L2 actions take precedence
              if all_quarterly_statuses.any? { |s| s == "l2_approved" }
                overall_quarterly_status = "l2_approved"
              elsif all_quarterly_statuses.any? { |s| s == "l2_returned" }
                overall_quarterly_status = "l2_returned"
              elsif all_quarterly_statuses.all? { |s| s == "l1_approved" }
                overall_quarterly_status = "l1_approved"
              elsif all_quarterly_statuses.any? { |s| s == "l1_returned" }
                overall_quarterly_status = "l1_returned"
              elsif all_quarterly_statuses.any? { |s| s == "submitted" }
                overall_quarterly_status = "submitted"
              elsif all_quarterly_statuses.all? { |s| s == "pending" }
                overall_quarterly_status = "pending"
              end
            end
            
            Rails.logger.info "Final overall quarterly status: #{overall_quarterly_status}"
          %>

          <table class="table table-hover w-full min-w-full">
            <thead class="bg-gray-800">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Department</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Employee Name</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Activity</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Unit</th>

                <!-- DYNAMIC MONTH COLUMNS -->
                <% display_months.each do |month_symbol, month_name| %>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name %> Target</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name %> Achievement</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700">Remarks</th>
                <% end %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @user_details.each_with_index do |detail, detail_index| %>
                <% 
                  existing_achievements = detail.achievements.index_by(&:month)
                  # Only render the row if there is at least one achievement in the selected quarter for this activity
                  has_quarterly_data = display_months.any? do |month_symbol, _|
                    existing_achievements[month_symbol.to_s]&.achievement.present? || detail.send(month_symbol).present?
                  end
                %>
                <% if has_quarterly_data %>
                  <tr class="<%= detail_index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200">
                    <!-- Static Columns -->
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200">
                      <%= detail.department&.department_type || 'N/A' %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-800 font-medium border-r border-gray-200">
                      <%= detail.employee_detail&.employee_name || 'N/A' %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200">
                      <%= detail.activity&.activity_name || 'N/A' %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= detail.activity&.unit || 'N/A' %>
                    </td>

                    <!-- Dynamic Month Data Columns -->
                    <% display_months.each do |month_symbol, month_name| %>
                      <%
                        target_value = detail.send(month_symbol)
                        achievement_record = existing_achievements[month_symbol.to_s]
                        achievement_value = achievement_record&.achievement
                        employee_remarks = achievement_record&.employee_remarks
                      %>
                      <!-- Target -->
                      <td class="px-4 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      
                      <!-- Achievement -->
                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 achievement-cell">
                        <span class="<%= achievement_value.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement_value.presence || '-' %>
                        </span>
                      </td>
                      
                      <!-- Remarks -->
                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 remarks-cell">
                        <span class="<%= employee_remarks.presence ? 'text-blue-700 font-medium bg-blue-50 px-2 py-1 rounded text-xs break-words' : 'text-gray-400 text-xs' %>">
                          <%= employee_remarks.presence || '-' %>
                        </span>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Single Overall Status Display -->
        <div class="mt-6 bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div class="flex items-center justify-center">
            <h3 class="text-lg font-semibold text-gray-700 mr-4">Overall Quarterly Status:</h3>
            <%
              # FIXED: Enhanced status configuration with better status mapping
              status_config = case overall_quarterly_status
              when "pending"
                { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
              when "submitted"
                { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
              when "l1_approved"
                { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved", icon: "fas fa-check-circle" }
              when "l1_returned"
                { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
              when "l2_approved"
                { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved", icon: "fas fa-check-double" }
              when "l2_returned"
                { color: "bg-orange-100 text-orange-800 border-orange-300", text: "L2 Returned", icon: "fas fa-exclamation-triangle" }
              else
                { color: "bg-gray-100 text-gray-600 border-gray-300", text: "Unknown Status: #{overall_quarterly_status}", icon: "fas fa-question-circle" }
              end
              
              Rails.logger.info "Status config for '#{overall_quarterly_status}': #{status_config.inspect}"
            %>
            <span id="quarterlyStatusBadge" class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium border <%= status_config[:color] %>">
              <i class="<%= status_config[:icon] %> mr-2"></i>
              <%= status_config[:text] %>
            </span>
          </div>
        </div>
      </div>
    </div>
  <% end %>

<!-- Show L2 approve/return buttons only if L2 can take action -->
<% if @can_l2_approve_or_return && @user_details.any? && params[:quarter].present? %>
  <%
    # Check if the current quarter's achievements can be approved/returned by L2
    can_take_l2_action = false
    
    # Define quarter months
    quarter_months = case params[:quarter]
    when 'Q1'
      ['january', 'february', 'march']
    when 'Q2'
      ['april', 'may', 'june']
    when 'Q3'
      ['july', 'august', 'september']
    when 'Q4'
      ['october', 'november', 'december']
    else
      []
    end
    
    @user_details.each do |detail|
      quarter_months.each do |month|
        achievement = detail.achievements.find { |a| a.month == month }
        if achievement
          current_status = achievement.status || "pending"
          if ['l1_approved', 'l2_returned'].include?(current_status)
            can_take_l2_action = true
            break
          end
        end
      end
      break if can_take_l2_action
    end
  %>
  
  <% if can_take_l2_action %>
    <!-- L2 Buttons for quarterly activity -->
    <div class="mt-8 pt-6 border-t border-gray-200" id="actionButtons">
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <!-- L2 Approve Button for quarterly activity -->
        <button onclick="openModal('l2_approve')" class="px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          L2 Approve  Quarter 
        </button>

        <!-- L2 Reject Button for quarterly activity -->
        <button onclick="openModal('l2_reject')" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white font-semibold rounded-lg shadow-md transition duration-200">
          L2 Return  Quarter 
        </button>
      </div>
    </div>
  <% else %>
    <div class="mt-8 pt-6 border-t border-gray-200">
      <div class="text-center">
        <p class="text-gray-600 font-medium">
          This Quarter activities cannot be modified by L2.
        </p>
      </div>
    </div>
  <% end %>
<% end %>

<!-- FIXED Modal with AJAX for L2 Actions -->
<div id="decisionModal" class="hidden fixed inset-0 flex items-center justify-center z-50">
  <div class="bg-white rounded-xl p-6 shadow-xl w-full max-w-md relative">
    <!-- Loading overlay -->
    <div id="modalLoading" class="hidden absolute inset-0 bg-white bg-opacity-75 flex items-center justify-center rounded-xl">
      <div class="flex items-center space-x-2">
        <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-emerald-600"></div>
        <span class="text-gray-600">Processing...</span>
      </div>
    </div>

    <h2 class="text-xl font-bold mb-4" id="modalTitle">L2 Decision - All Activities</h2>

    <form id="modalForm" onsubmit="submitDecision(event)">
      <div class="mb-4">
        <label for="l2_remarks" class="block font-semibold mb-1">L2 Quarterly Remarks (All Activities)</label>
        <textarea id="l2_remarks" name="l2_remarks" rows="3" class="w-full border border-gray-300 rounded-md p-2" placeholder="Enter remarks for all activities in this quarter" required></textarea>
      </div>
      <div class="mb-4">
        <label for="l2_percentage" class="block font-semibold mb-1">L2 Quarterly Percentage (All Activities)</label>
        <input type="number" id="l2_percentage" name="l2_percentage" step="0.1" min="0" max="100" class="w-full border border-gray-300 rounded-md p-2" placeholder="Enter percentage for all activities" required>
      </div>
      
      <!-- Hidden fields for quarterly tracking -->
      <% if params[:user_detail_id].present? %>
        <input type="hidden" name="user_detail_id" value="<%= params[:user_detail_id] %>">
      <% end %>
      <input type="hidden" name="selected_quarter" value="<%= params[:quarter] %>">
      <input type="hidden" name="apply_to_all_activities" value="true">
      
      <div class="flex justify-end gap-2">
        <button type="button" onclick="closeModal()" class="px-4 py-2 bg-gray-200 rounded-lg hover:bg-gray-300">Cancel</button>
        <button type="submit" class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700">Apply to All Activities</button>
      </div>
    </form>
  </div>
</div>

<!-- FIXED JavaScript with AJAX for L2 Actions -->
<script>
  let currentActionType = '';
  let currentActionUrl = '';

  function openModal(actionType) {
    const modal = document.getElementById("decisionModal");
    const modalTitle = document.getElementById("modalTitle");
    
    currentActionType = actionType;
    
    modal.classList.remove("hidden");
    document.body.style.overflow = 'hidden'; // Prevent background scroll

    if (actionType === "l2_approve") {
      currentActionUrl = "<%= l2_approve_employee_detail_path(@employee_detail) %>";
      modalTitle.innerText = "L2 Approve All Quarterly Activities";
    } else if (actionType === "l2_reject") {
      currentActionUrl = "<%= l2_return_employee_detail_path(@employee_detail) %>";
      modalTitle.innerText = "L2 Return All Quarterly Activities";
    }

    // Clear form
    document.getElementById('l2_remarks').value = '';
    document.getElementById('l2_percentage').value = '';
  }

  function closeModal() {
    document.getElementById("decisionModal").classList.add("hidden");
    document.body.style.overflow = 'auto'; // Restore background scroll
    currentActionType = '';
    currentActionUrl = '';
  }

  function showStatusMessage(message, isSuccess) {
    const statusDiv = document.getElementById('statusMessage');
    statusDiv.className = `mb-4 p-4 rounded-lg ${isSuccess ? 'bg-green-100 text-green-800 border border-green-200' : 'bg-red-100 text-red-800 border border-red-200'}`;
    statusDiv.textContent = message;
    statusDiv.classList.remove('hidden');
    
    // Auto hide after 5 seconds
    setTimeout(() => {
      statusDiv.classList.add('hidden');
    }, 5000);
  }

  function updateQuarterlyStatus(newStatus) {
    console.log('updateQuarterlyStatus called with:', newStatus);
    
    // Find the status badge and update it
    const statusBadge = document.getElementById('quarterlyStatusBadge');
    console.log('Status badge found:', statusBadge);
    
    if (!statusBadge) {
      console.error('Status badge not found!');
      return;
    }

    let statusConfig = {};
    
    // FIXED: Enhanced status configuration mapping to match the view logic
    switch(newStatus) {
      case 'l2_approved':
        statusConfig = {
          color: 'bg-emerald-100 text-emerald-800 border-emerald-300',
          text: 'L2 Approved',
          icon: 'fas fa-check-double'
        };
        break;
      case 'l2_returned':
        statusConfig = {
          color: 'bg-orange-100 text-orange-800 border-orange-300',
          text: 'L2 Returned',
          icon: 'fas fa-exclamation-triangle'
        };
        break;
      case 'l1_approved':
        statusConfig = {
          color: 'bg-green-100 text-green-800 border-green-300',
          text: 'L1 Approved',
          icon: 'fas fa-check-circle'
        };
        break;
      case 'l1_returned':
        statusConfig = {
          color: 'bg-red-100 text-red-800 border-red-300',
          text: 'L1 Returned',
          icon: 'fas fa-exclamation-triangle'
        };
        break;
      case 'submitted':
        statusConfig = {
          color: 'bg-blue-100 text-blue-800 border-blue-300',
          text: 'Submitted',
          icon: 'fas fa-paper-plane'
        };
        break;
      case 'pending':
        statusConfig = {
          color: 'bg-yellow-100 text-yellow-800 border-yellow-300',
          text: 'Pending',
          icon: 'fas fa-clock'
        };
        break;
      default:
        statusConfig = {
          color: 'bg-gray-100 text-gray-600 border-gray-300',
          text: `Unknown Status: ${newStatus}`,
          icon: 'fas fa-question-circle'
        };
    }

    console.log('Updating status badge with config:', statusConfig);
    statusBadge.className = `inline-flex items-center px-4 py-2 rounded-full text-sm font-medium border ${statusConfig.color}`;
    statusBadge.innerHTML = `<i class="${statusConfig.icon} mr-2"></i>${statusConfig.text}`;
    
    console.log('Status badge updated successfully');
  }

  function hideActionButtons() {
    const actionButtons = document.getElementById('actionButtons');
    if (actionButtons) {
      actionButtons.style.display = 'none';
      
      // Add processed message
      const processedMessage = document.createElement('div');
      processedMessage.className = 'mt-8 pt-6 border-t border-gray-200 text-center text-gray-600 font-medium';
      processedMessage.textContent = 'This Quarter has been processed and cannot be modified.';
      actionButtons.parentNode.appendChild(processedMessage);
    }
  }

  function submitDecision(event) {
    event.preventDefault();
    
    const modalLoading = document.getElementById('modalLoading');
    const form = document.getElementById('modalForm');
    const formData = new FormData(form);
    
    // Add action_type to indicate this is an AJAX request
    formData.append('action_type', currentActionType);
    
    // Show loading state
    modalLoading.classList.remove('hidden');
    
    // Make AJAX request
    fetch(currentActionUrl, {
      method: 'PATCH',
      body: formData,
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || ''
      }
    })
    .then(response => response.json())
    .then(data => {
      modalLoading.classList.add('hidden');
      console.log('Server response:', data);
      
      if (data.success) {
        // Close modal immediately
        closeModal();
        
        // Show success message
        showStatusMessage(data.message, true);
        
        // Update UI with real data from server if provided
        if (data.updated_status) {
          console.log('Updating status to:', data.updated_status);
          
          // Check if status badge exists
          const statusBadge = document.getElementById('quarterlyStatusBadge');
          if (statusBadge) {
            updateQuarterlyStatus(data.updated_status);
            hideActionButtons();
            
            // Reload page after status update to ensure consistency
            setTimeout(() => {
              window.location.reload();
            }, 2000);
          } else {
            console.error('Status badge not found, reloading page immediately');
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          }
        } else {
          // If no status data provided, reload immediately
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        }
        
        // Scroll to status message
        document.getElementById('statusMessage').scrollIntoView({ 
          behavior: 'smooth', 
          block: 'center' 
        });
        
      } else {
        // Show error message but keep modal open
        showStatusMessage(data.message || 'An error occurred', false);
      }
    })
    .catch(error => {
      modalLoading.classList.add('hidden');
      console.error('Error:', error);
      showStatusMessage('Network error occurred. Please try again.', false);
    });
  }

  // Close modal when clicking outside
  document.getElementById('decisionModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeModal();
    }
  });

  // Close modal with Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeModal();
    }
  });
</script>

<!-- Single Quarterly L1 and L2 Remarks Section -->
<% if @user_details.any? && params[:quarter].present? %>
  <%
    # Collect quarterly L1 and L2 remarks data (get first available)
    quarter_months = case params[:quarter]
    when 'Q1'
      ['january', 'february', 'march']
    when 'Q2'
      ['april', 'may', 'june']
    when 'Q3'
      ['july', 'august', 'september']
    when 'Q4'
      ['october', 'november', 'december']
    else
      []
    end
    
    quarterly_l1_remarks = nil
    quarterly_l2_remarks = nil
    activity_name = "All Activities"
    
    # Get the first available quarterly remarks (should be same for all)
    @user_details.each do |detail|
      quarter_months.each do |month|
        achievement = detail.achievements.find { |a| a.month == month }
        if achievement&.achievement_remark
          if quarterly_l1_remarks.nil? && (achievement.achievement_remark.l1_remarks.present? || achievement.achievement_remark.l1_percentage.present?)
            quarterly_l1_remarks = {
              remarks: achievement.achievement_remark.l1_remarks,
              percentage: achievement.achievement_remark.l1_percentage
            }
          end
          if quarterly_l2_remarks.nil? && (achievement.achievement_remark.l2_remarks.present? || achievement.achievement_remark.l2_percentage.present?)
            quarterly_l2_remarks = {
              remarks: achievement.achievement_remark.l2_remarks,
              percentage: achievement.achievement_remark.l2_percentage
            }
          end
        end
      end
    end
  %>
  
  <% if quarterly_l1_remarks || quarterly_l2_remarks %>
    <div class="bg-white border border-gray-200 rounded-xl mt-6 shadow-lg overflow-hidden">
      <!-- Header -->
      <div class="bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-4">
        <h3 class="text-xl font-bold text-white flex items-center gap-2">
          <i class="fas fa-comments"></i>
          Quarterly Remarks & Percentage - All Activities 
        </h3>
      </div>

      <!-- Combined L1 and L2 Content -->
      <div class="flex flex-col lg:flex-row min-h-96">
        <!-- L1 Remarks Section -->
        <div class="flex-1 bg-gradient-to-br from-blue-50 to-indigo-50 p-6">
          <div class="flex items-center gap-2 mb-4">
            <i class="fas fa-user-check text-blue-600 text-lg"></i>
            <h4 class="text-lg font-bold text-blue-700">L1 Quarterly Remarks & Percentage</h4>
          </div>
          
          <% if quarterly_l1_remarks %>
            <div class="bg-white border-l-4 border-blue-500 rounded-lg p-4 shadow-sm">
              <h5 class="text-sm font-bold text-blue-600 mb-2 uppercase">
                Quarter - All Activities
              </h5>
              
              <div class="mb-3">
                <p class="text-xs text-blue-600 font-semibold mb-1">L1 Quarterly Remarks</p>
                <p class="text-gray-700 text-sm whitespace-pre-line bg-blue-50 p-2 rounded border">
                  <%= quarterly_l1_remarks[:remarks].presence || "No Remarks" %>
                </p>
              </div>
              
              <div>
                <p class="text-xs text-blue-600 font-semibold mb-1">L1 Quarterly Percentage</p>
                <div class="bg-blue-100 p-2 rounded text-center border">
                  <span class="text-blue-800 font-bold text-lg">
                    <%= quarterly_l1_remarks[:percentage].present? ? "#{quarterly_l1_remarks[:percentage]}%" : "No Percentage" %>
                  </span>
                </div>
              </div>
            </div>
          <% else %>
            <div class="flex items-center justify-center h-32 bg-white rounded-lg border-2 border-dashed border-blue-200">
              <p class="text-blue-400 font-medium">No L1 Quarterly Remarks Available</p>
            </div>
          <% end %>
        </div>

        <!-- Dividing Line -->
        <div class="w-px bg-gradient-to-b from-gray-200 via-gray-400 to-gray-200 lg:block hidden"></div>
        <div class="h-px bg-gradient-to-r from-gray-200 via-gray-400 to-gray-200 lg:hidden block"></div>

        <!-- L2 Remarks Section -->
        <div class="flex-1 bg-gradient-to-br from-emerald-50 to-teal-50 p-6">
          <div class="flex items-center gap-2 mb-4">
            <i class="fas fa-user-shield text-emerald-600 text-lg"></i>
            <h4 class="text-lg font-bold text-emerald-700">L2 Quarterly Remarks & Percentage</h4>
          </div>
          
          <% if quarterly_l2_remarks %>
            <div class="bg-white border-l-4 border-emerald-500 rounded-lg p-4 shadow-sm">
              <h5 class="text-sm font-bold text-emerald-600 mb-2 uppercase">
               Quarter - All Activities
              </h5>
              
              <div class="mb-3">
                <p class="text-xs text-emerald-600 font-semibold mb-1">L2 Quarterly Remarks</p>
                <p class="text-gray-700 text-sm whitespace-pre-line bg-emerald-50 p-2 rounded border">
                  <%= quarterly_l2_remarks[:remarks].presence || "No Remarks" %>
                </p>
              </div>
              
              <div>
                <p class="text-xs text-emerald-600 font-semibold mb-1">L2 Quarterly Percentage</p>
                <div class="bg-emerald-100 p-2 rounded text-center border">
                  <span class="text-emerald-800 font-bold text-lg">
                    <%= quarterly_l2_remarks[:percentage].present? ? "#{quarterly_l2_remarks[:percentage]}%" : "No Percentage" %>
                  </span>
                </div>
              </div>
            </div>
          <% else %>
            <div class="flex items-center justify-center h-32 bg-white rounded-lg border-2 border-dashed border-emerald-200">
              <p class="text-emerald-400 font-medium">No L2 Quarterly Remarks Available</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>


