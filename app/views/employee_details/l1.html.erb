<!-- L1 Employee View - Quarterly Support -->
<div class="main-content sidebar-hidden bg-gray-50 min-h-screen">
  <div class="min-h-screen pl-64 pr-4 pt-4 pb-12 overflow-x-auto bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="w-full max-w-7xl mx-auto bg-white p-8 rounded-xl shadow-xl border border-gray-200">
      <div class="flex items-center mb-8 pb-4 border-b-2 border-gray-200">
        <i class="fas fa-users text-2xl text-indigo-600 mr-3"></i>
        <h2 class="text-3xl font-bold text-gray-800">L1 Employee View</h2>
      </div>

      <div class="overflow-x-auto bg-white rounded-lg shadow-sm border border-gray-200">  
        <table class="min-w-full divide-y divide-gray-300 text-sm">
          <thead class="bg-gradient-to-r from-gray-800 to-gray-700">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Name</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Employee Code</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Department</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Quarter</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">L1 Manager</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">L2 Manager</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Status</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider">Action</th>
            </tr>
          </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% row_index = 0 %>
              <% @employee_details.each do |emp| %>
                <% 
                  # Define quarters to group achievements
                  quarters = {
                    'Q1' => ['january', 'february', 'march'],
                    'Q2' => ['april', 'may', 'june'], 
                    'Q3' => ['july', 'august', 'september'],
                    'Q4' => ['october', 'november', 'december']
                  }
                  
                  quarters.each do |quarter_name, quarter_months|
                    # Collect ALL achievements for this employee across ALL their activities for the specific quarter
                    all_quarter_achievements = emp.user_details.flat_map(&:achievements).select { |ach| quarter_months.include?(ach.month) }
                    
                    # If there are no achievements for this employee in this quarter, skip to the next one
                    next if all_quarter_achievements.empty?
                    
                    row_index += 1
                    
                    # FIXED: Improved status calculation logic for quarterly status
                    quarter_statuses = all_quarter_achievements.map { |ach| ach.status || "pending" }
                    
                    # Check for achievement remarks to determine if L1/L2 has actually processed
                    has_l1_approval = all_quarter_achievements.any? { |ach| ach.achievement_remark&.l1_percentage.present? && ach.achievement_remark&.l1_remarks.present? }
                    has_l2_approval = all_quarter_achievements.any? { |ach| ach.achievement_remark&.l2_percentage.present? && ach.achievement_remark&.l2_remarks.present? }
                    
                    # FIXED: More accurate status calculation - check actual data, not just status strings
                    current_status = if quarter_statuses.any? { |s| s == "l2_returned" }
                                      "l2_returned"
                                    elsif quarter_statuses.all? { |s| s == "l2_approved" } || has_l2_approval
                                      "l2_approved"
                                    elsif quarter_statuses.any? { |s| s == "l1_returned" }
                                      "l1_returned"
                                    elsif quarter_statuses.all? { |s| s == "l1_approved" } || has_l1_approval
                                      "l1_approved"
                                    elsif quarter_statuses.any? { |s| s == "submitted" }
                                      "submitted"
                                    elsif quarter_statuses.any? { |s| s == "pending" }
                                      "pending"
                                    else
                                      "pending"
                                    end

                    status_config = case current_status
                    when "pending"
                      { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending Review" }
                    when "l1_approved"
                      { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved" }
                    when "l1_returned"
                      { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned" }
                    when "l2_approved"
                      { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved" }
                    when "l2_returned"
                      { color: "bg-orange-100 text-orange-800 border-orange-300", text: "L2 Returned" }
                    when "submitted"
                      { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted" }
                    else
                      { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status" }
                    end
                %>
                  <tr class="<%= row_index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-indigo-50 transition-colors duration-200">
                    <td class="px-6 py-4 text-sm font-medium text-gray-900 border-r border-gray-200"><%= emp.employee_name %></td>
                    <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200"><%= emp.employee_code %></td>
                    <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200"><%= emp.department %></td>
                   <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                      <span class="font-semibold text-indigo-700"><%= quarter_months.map(&:capitalize).join(", ") %></span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200"><%= emp.l1_employer_name %></td>
                    <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200"><%= emp.l2_employer_name %></td>
                    <td class="px-6 py-4 text-sm border-r border-gray-200">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border <%= status_config[:color] %>">
                        <% if ["l1_approved", "l2_approved"].include?(current_status) %>
                          <i class="fas fa-check-circle mr-1"></i>
                        <% elsif ["l1_returned", "l2_returned"].include?(current_status) %>
                          <i class="fas fa-exclamation-triangle mr-1"></i>
                        <% elsif current_status == "pending" %>
                          <i class="fas fa-clock mr-1"></i>
                        <% elsif current_status == "submitted" %>
                          <i class="fas fa-paper-plane mr-1"></i>
                        <% end %>
                        <%= status_config[:text] %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-sm">
                      <%= link_to "View Details", 
                          employee_detail_path(emp, quarter: quarter_name), 
                          class: "inline-flex items-center px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg shadow-sm transition-all duration-200 hover:shadow-md transform hover:scale-105" %>
                    </td>
                  </tr>
                <% end %>
              <% end %>
           </tbody>
        </table>
      </div>

      <!-- FIXED: Refactored Summary Cards Logic with Improved Status Calculation -->
      <%
        total_quarterly_records = 0
        l1_approved_count = 0
        l2_approved_count = 0
        pending_count = 0
        returned_count = 0
        submitted_count = 0

        quarters = {
          'Q1' => ['january', 'february', 'march'],
          'Q2' => ['april', 'may', 'june'], 
          'Q3' => ['july', 'august', 'september'],
          'Q4' => ['october', 'november', 'december']
        }

        @employee_details.each do |emp|
          quarters.each do |quarter_name, quarter_months|
            all_quarter_achievements = emp.user_details.flat_map(&:achievements).select { |ach| quarter_months.include?(ach.month) }
            
            next if all_quarter_achievements.empty?
            
            total_quarterly_records += 1
            
            # FIXED: Improved status calculation for summary cards
            quarter_statuses = all_quarter_achievements.map { |ach| ach.status || "pending" }
            
            # Check for actual approval data in achievement remarks
            has_l1_approval = all_quarter_achievements.any? { |ach| ach.achievement_remark&.l1_percentage.present? && ach.achievement_remark&.l1_remarks.present? }
            has_l2_approval = all_quarter_achievements.any? { |ach| ach.achievement_remark&.l2_percentage.present? && ach.achievement_remark&.l2_remarks.present? }
            
            # FIXED: More accurate status calculation - check actual data, not just status strings
            current_status = if quarter_statuses.any? { |s| s == "l2_returned" }
                              "l2_returned"
                            elsif quarter_statuses.all? { |s| s == "l2_approved" } || has_l2_approval
                              "l2_approved"
                            elsif quarter_statuses.any? { |s| s == "l1_returned" }
                              "l1_returned"
                            elsif quarter_statuses.all? { |s| s == "l1_approved" } || has_l1_approval
                              "l1_approved"
                            elsif quarter_statuses.any? { |s| s == "submitted" }
                              "submitted"
                            elsif quarter_statuses.any? { |s| s == "pending" }
                              "pending"
                            else
                              "pending"
                            end
            
            # DEBUG: Log summary status calculation
            Rails.logger.debug "Summary - Employee: #{emp.employee_name}, Quarter: #{quarter_name}, Statuses: #{quarter_statuses}, Final Status: #{current_status}"

            case current_status
            when "l1_approved"
              l1_approved_count += 1
            when "l2_approved"
              l2_approved_count += 1
            when "submitted"
              submitted_count += 1
            when "l1_returned", "l2_returned"
              returned_count += 1
            when "pending"
              pending_count += 1
            end
          end
        end
      %>

      <div class="mt-6 grid grid-cols-1 md:grid-cols-5 gap-4">
        <!-- Total Quarterly Records -->
        <div class="bg-blue-50 p-4 rounded-lg border border-blue-200">
          <div class="flex items-center">
            <i class="fas fa-layer-group text-blue-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-blue-800">Total Quarterly Records</p>
              <p class="text-2xl font-bold text-blue-900"><%= total_quarterly_records %></p>
            </div>
          </div>
        </div>

        <!-- Pending Review -->
        <div class="bg-yellow-50 p-4 rounded-lg border border-yellow-200">
          <div class="flex items-center">
            <i class="fas fa-clock text-yellow-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-yellow-800">Pending Review</p>
              <p class="text-2xl font-bold text-yellow-900"><%= pending_count %></p>
            </div>
          </div>
        </div>

        <!-- L1 Approved -->
        <div class="bg-green-50 p-4 rounded-lg border border-green-200">
          <div class="flex items-center">
            <i class="fas fa-check-circle text-green-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-green-800">L1 Approved</p>
              <p class="text-2xl font-bold text-green-900"><%= l1_approved_count %></p>
            </div>
          </div>
        </div>

        <!-- L2 Approved -->
        <div class="bg-emerald-50 p-4 rounded-lg border border-emerald-200">
          <div class="flex items-center">
            <i class="fas fa-check-double text-emerald-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-emerald-800">L2 Approved</p>
              <p class="text-2xl font-bold text-emerald-900"><%= l2_approved_count %></p>
            </div>
          </div>
        </div>

        <!-- Returned -->
        <div class="bg-red-50 p-4 rounded-lg border border-red-200">
          <div class="flex items-center">
            <i class="fas fa-exclamation-triangle text-red-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-red-800">Returned</p>
              <p class="text-2xl font-bold text-red-900"><%= returned_count %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

