<script>
  // Department filter functionality
  document.addEventListener('DOMContentLoaded', function() {
    const departmentFilter = document.getElementById('department_filter');
    const tableRows = document.querySelectorAll('tbody tr');
    
    if (departmentFilter) {
      departmentFilter.addEventListener('change', function() {
        const selectedDepartment = this.value;
        
        tableRows.forEach(row => {
          const departmentCell = row.querySelector('td:nth-child(3)'); // Vertical column
          if (departmentCell) {
            const departmentText = departmentCell.textContent.trim();
            
            if (selectedDepartment === '' || departmentText === selectedDepartment) {
              row.style.display = '';
            } else {
              row.style.display = 'none';
            }
          }
        });
        
        // Update counters based on visible rows
        updateCounters();
      });
    }
    
    // Static status display - no dynamic updates
    
    // Static counter updates - no animations
    function updateCounters() {
      const visibleRows = document.querySelectorAll('tbody tr[style=""], tbody tr:not([style*="display: none"])');
      const totalRecords = visibleRows.length;
      
      let l1Approved = 0;
      let l1Returned = 0;
      let pendingReview = 0;
      
      visibleRows.forEach(row => {
        const statusCell = row.querySelector('td:nth-child(7)'); // Status column
        if (statusCell) {
          const statusText = statusCell.textContent.trim();
          if (statusText.includes('L1 Approved')) {
            l1Approved++;
          } else if (statusText.includes('L1 Returned')) {
            l1Returned++;
          } else if (statusText.includes('Pending')) {
            pendingReview++;
          }
        }
      });
      
      // Update counter displays statically
      const totalElement = document.querySelector('.text-2xl.font-bold.text-blue-900');
      const approvedElement = document.querySelector('.text-2xl.font-bold.text-sky-900');
      const returnedElement = document.querySelector('.text-2xl.font-bold.text-red-900');
      const pendingElement = document.querySelector('.text-2xl.font-bold.text-yellow-900');
      
      if (totalElement) {
        totalElement.textContent = totalRecords;
      }
      if (approvedElement) {
        approvedElement.textContent = l1Approved;
      }
      if (returnedElement) {
        returnedElement.textContent = l1Returned;
      }
      if (pendingElement) {
        pendingElement.textContent = pendingReview;
      }
    }
  });
</script>
