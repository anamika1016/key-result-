            </div>
          </div>
        </div>

        <!-- L1 Approved -->
        <div class="bg-sky-50 p-4 rounded-lg border border-sky-200">
          <div class="flex items-center">
            <i class="fas fa-check-circle text-sky-600 mr-3"></i>
            <div>
              <p class="text-sm font-medium text-sky-800">L1 Approved</p>
              <p class="text-2xl font-bold text-sky-900"><%= l1_approved_count %></p>
