<!-- L1 Manager View - Quarterly Support -->
<div class="main-content sidebar-hidden bg-gray-50 min-h-screen">
  <div class="min-h-screen pl-64 pr-4 pt-4 pb-12 overflow-x-auto bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="w-full max-w-7xl mx-auto bg-white p-8 rounded-xl shadow-xl border border-gray-200">
      <div class="flex items-center justify-between mb-8 pb-4 border-b-2 border-gray-200">
        <div class="flex items-center">
          <i class="fas fa-users text-2xl text-indigo-600 mr-3"></i>
          <h2 class="text-3xl font-bold text-gray-800">L1 Manager View</h2>
        </div>
        
        <!-- Department Filter -->
        <div class="flex items-center space-x-4">
          <label for="department_filter" class="text-sm font-medium text-gray-700">Filter by Department:</label>
          <%= form_with url: l1_employee_details_path, method: :get, local: true, class: "flex items-center space-x-2" do |form| %>
            <%= form.select :department_filter, 
                options_for_select([["All Departments", ""]] + Department.distinct.pluck(:department_type).map { |dept| [dept, dept] }, @selected_department),
                { include_blank: false },
                { 
                  id: "department_filter",
                  class: "px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500",
                  onchange: "this.form.submit()"
                } %>
          <% end %>
        </div>
      </div>


      <div class="overflow-x-auto bg-white rounded-lg shadow-sm border border-gray-200">  
        <table class="min-w-full divide-y divide-gray-300 text-sm">
          <thead class="bg-gradient-to-r from-gray-800 to-gray-700">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Name</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Employee Code</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Vertical</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Quarter</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">L1 Manager</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">L2 Manager</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">L3 Manager</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider border-r border-gray-600">Status</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider">Action</th>
            </tr>
          </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% row_index = 0 %>
              <% 
                # FIXED: Create a global deduplication hash to prevent duplicate entries across all employees
                # This must be outside the employee loop to work across all employees
                global_processed_combinations = {}
              %>
              <% 
                # FIXED: Group employees by name to aggregate achievements across all EmployeeDetail records
                employee_groups = @employee_details.group_by(&:employee_name)
              %>
              <% employee_groups.each do |employee_name, employee_records| %>
                <% 
                  # Use the first employee record for basic info, but aggregate achievements from all records
                  emp = employee_records.first
                  
                  # Define quarters to group achievements
                  quarters = {
                    'Q1' => ['april', 'may', 'june'],
                    'Q2' => ['july', 'august', 'september'], 
                    'Q3' => ['october', 'november', 'december'],
                    'Q4' => ['january', 'february', 'march']
                  }
                  
                  # Group by department and quarter to show separate rows for each department
                  department_quarter_data = []
                  
                  # FIXED: Get all departments from ALL employee records for this employee name
                  all_user_details = employee_records.flat_map(&:user_details)
                  employee_departments = all_user_details.map(&:department).uniq
                  
                  employee_departments.each do |department|
                    quarters.each do |quarter_name, quarter_months|
                      # FIXED: Create unique key for employee name + department + quarter combination
                      # This prevents duplicates when same employee has multiple EmployeeDetail records
                      unique_key = "#{emp.employee_name}_#{department.department_type}_#{quarter_name}"
                      
                      # Skip if we've already processed this combination
                      next if global_processed_combinations[unique_key]
                      
                      # FIXED: Get achievements from ALL employee records for this employee name in this department
                      department_user_details = all_user_details.select { |ud| ud.department_id == department.id }
                      
                      # FIXED: Handle both monthly achievements (april, may, june) and quarterly achievements (q1, q2, q3, q4)
                      monthly_achievements = department_user_details.flat_map(&:achievements).select { |ach| quarter_months.include?(ach.month) }
                      
                      # Also check for quarterly format achievements (q1, q2, q3, q4)
                      quarterly_achievements = department_user_details.flat_map(&:achievements).select do |ach|
                        case quarter_name
                        when 'Q1'
                          ach.month == 'q1'
                        when 'Q2'
                          ach.month == 'q2'
                        when 'Q3'
                          ach.month == 'q3'
                        when 'Q4'
                          ach.month == 'q4'
                        else
                          false
                        end
                      end
                      
                      # Combine both types of achievements
                      all_quarter_achievements = monthly_achievements + quarterly_achievements
                      
                      # FIXED: Only show quarters where user has actually SUBMITTED their quarterly achievement
                      # Check if user has submitted quarterly achievement (month = 'q1', 'q2', 'q3', 'q4') with actual data
                      quarterly_submission = all_quarter_achievements.find do |ach|
                        case quarter_name
                        when 'Q1'
                          ach.month == 'q1' && ach.achievement.present?
                        when 'Q2'
                          ach.month == 'q2' && ach.achievement.present?
                        when 'Q3'
                          ach.month == 'q3' && ach.achievement.present?
                        when 'Q4'
                          ach.month == 'q4' && ach.achievement.present?
                        else
                          false
                        end
                      end
                      
                      # Only show if user has actually submitted quarterly achievement with data
                      if quarterly_submission.present?
                        # Mark this combination as processed
                        global_processed_combinations[unique_key] = true
                        
                        # Add new entry (no need to check for existing since we're using global deduplication)
                        department_quarter_data << { 
                          quarter_name: quarter_name, 
                          quarter_months: quarter_months, 
                          achievements: all_quarter_achievements,
                          department: department,
                          department_id: department.id,
                          department_type: department.department_type
                        }
                      end
                    end
                  end
                  
                  # Only show quarters where employees have actually submitted achievement data
                  # No fallback logic - only show quarters with actual data
                  
                  # Only show this employee if they have submitted data in any quarter
                  next if department_quarter_data.empty?
                  
                  # Show one row per department-quarter combination for this employee
                  department_quarter_data.each do |data|
                    quarter_name = data[:quarter_name]
                    quarter_months = data[:quarter_months]
                    all_quarter_achievements = data[:achievements]
                    department = data[:department]
                    department_id = data[:department_id]
                    department_type = data[:department_type]
                    
                    # FIXED: Use EXACT same logic as show.html.erb
                    # Filter user_details by department_id from ALL employee records (same as show.html.erb)
                    filtered_user_details = all_user_details.select { |ud| ud.department_id.to_s == department_id.to_s }
                    
                    # FIXED: If no user_details found for this department, force pending status (same as show.html.erb)
                    if filtered_user_details.empty?
                      current_status = "pending"
                    else
                      
                      # Get achievements only from this specific department (same as show.html.erb)
                      department_quarter_achievements = []
                      filtered_user_details.each do |detail|
                        
                        # FIXED: Double-check that this user_detail belongs to the correct department (same as show.html.erb)
                        next unless detail.department_id.to_s == department_id.to_s
                        
                        # FIXED: Include BOTH monthly and quarterly achievements for status calculation
                        # Monthly achievements (april, may, june, etc.)
                        monthly_achievements = detail.achievements.select { |ach| quarter_months.include?(ach.month) }
                        
                        # Quarterly achievements (q1, q2, q3, q4)
                        quarterly_achievements = detail.achievements.select do |ach|
                          case quarter_name
                          when 'Q1'
                            ach.month == 'q1'
                          when 'Q2'
                            ach.month == 'q2'
                          when 'Q3'
                            ach.month == 'q3'
                          when 'Q4'
                            ach.month == 'q4'
                          else
                            false
                          end
                        end
                        
                        # Add both monthly and quarterly achievements to department collection
                        department_quarter_achievements.concat(monthly_achievements)
                        department_quarter_achievements.concat(quarterly_achievements)
                      end
                      
                      # FIXED: Use same logic as controller - check if there are any achievements with data
                      # The controller only checks monthly achievements, so we do the same
                      quarterly_submission = department_quarter_achievements.any? { |ach| ach.achievement.present? }
                      
                      if quarterly_submission.present?
                        row_index += 1
                        
                        quarter_statuses = department_quarter_achievements.map { |ach| ach.status || "pending" }
                      
                        # FIXED: Calculate L1 remarks and percentage like show.html.erb
                        quarter_l1_total = 0
                        quarter_remarks_l1 = Set.new
                        
                        department_quarter_achievements.each do |achievement|
                          if achievement.achievement_remark.present?
                            # Collect L1 data
                            if achievement.achievement_remark.l1_percentage.present?
                              quarter_l1_total += achievement.achievement_remark.l1_percentage.to_f
                            end
                            
                            # Add unique L1 remarks only
                            if achievement.achievement_remark.l1_remarks.present?
                              quarter_remarks_l1.add(achievement.achievement_remark.l1_remarks)
                            end
                          end
                        end
                        
                        has_l1_remarks = quarter_remarks_l1.any? { |remark| remark.present? && remark != "No remarks for this quarter" }
                        has_l1_percentage = quarter_l1_total > 0
                      
                        # FIXED: Use EXACT same logic as show.html.erb
                        # Check if no achievements found for this department, default to pending
                        if quarter_statuses.empty?
                          current_status = "pending"
                        elsif filtered_user_details.empty?
                          current_status = "pending"
                        elsif !has_l1_remarks && !has_l1_percentage
                          current_status = "pending"
                        else
                          # FIXED: Use EXACT same status calculation as show.html.erb
                          # But prioritize returned_to_employee over l3_approved for department-specific status
                          current_status = if quarter_statuses.include?("returned_to_employee")
                                            "returned_to_employee"
                                          elsif quarter_statuses.include?("l3_approved")
                                            "l3_approved"
                                          elsif quarter_statuses.include?("l3_returned")
                                            "l3_returned"
                                          elsif quarter_statuses.include?("l2_approved")
                                            "l2_approved"
                                          elsif quarter_statuses.include?("l2_returned")
                                            "l2_returned"
                                          elsif quarter_statuses.include?("l1_returned")
                                            "l1_returned"
                                          elsif quarter_statuses.include?("l1_approved")
                                            "l1_approved"
                                          elsif quarter_statuses.include?("submitted")
                                            "submitted"
                                          elsif quarter_statuses.include?("pending")
                                            "pending"
                                          else
                                            "pending"
                                          end
                        end
                      
                        
                      else
                        # No quarterly submission - this should not happen due to our filtering
                        current_status = "pending"
                      end
                    end

                    return_to_val = nil
                    if ["returned_to_employee", "l2_returned", "l3_returned"].include?(current_status)
                      matching_ach = department_quarter_achievements.find { |a| a.status == current_status }
                      return_to_val = matching_ach&.return_to
                    end

                    status_config = case current_status
                    when "pending"
                      { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
                    when "l1_approved"
                      { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved", icon: "fas fa-check-circle" }
                    when "l1_returned"
                      { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
                    when "returned_to_employee"
                      sample_matching_ach = department_quarter_achievements.find { |a| a.status == "returned_to_employee" }
                      remark = sample_matching_ach&.achievement_remark
                      text_val = if remark&.l3_remarks.present?
                                   "L3_Return_Employee"
                                 elsif remark&.l2_remarks.present?
                                   "L2_Return_Employee"
                                 else
                                   "L1_Return_Employee"
                                 end
                      { color: "bg-red-100 text-red-800 border-red-300", text: text_val, icon: "fas fa-undo" }
                    when "l2_approved"
                      { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved", icon: "fas fa-check-double" }
                    when "l2_returned"
                      text_val = (return_to_val == 'employee') ? "L2_Return_Employee" : "L2_Return_L1"
                      { color: "bg-red-100 text-red-800 border-red-300", text: text_val, icon: "fas fa-exclamation-triangle" }
                    when "l3_approved"
                      { color: "bg-green-100 text-green-800 border-green-300", text: "L3 Approved", icon: "fas fa-crown" }
                    when "l3_returned"
                      text_val = case return_to_val
                                 when 'employee' then "L3_Return_Employee"
                                 when 'l1' then "L3_Return_L1"
                                 else "L3_Return_L2"
                                 end
                      { color: "bg-red-100 text-red-800 border-red-300", text: text_val, icon: "fas fa-exclamation-triangle" }
                    when "submitted"
                      { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
                    else
                      { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status", icon: "fas fa-question" }
                    end
                %>
                  <tr class="<%= row_index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-indigo-50 transition-colors duration-200">
                    <td class="px-6 py-4 text-sm font-medium text-gray-900 border-r border-gray-200"><%= emp.employee_name %></td>
                    <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200"><%= emp.employee_code %></td>
                    <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                      <%= department_type %>
                    </td>
                   <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200">
                      <span class="font-semibold text-indigo-700">
                        <% 
                          # Show only quarter names (Q1, Q2, Q3, Q4)
                          quarter_display = quarter_name
                        %>
                        <%= quarter_display %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200"><%= emp.l1_employer_name %></td>
                    <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200"><%= emp.l2_employer_name %></td>
                    <td class="px-6 py-4 text-sm text-gray-700 border-r border-gray-200"><%= emp.l3_employer_name %></td>
                    <td class="px-6 py-4 text-sm border-r border-gray-200">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border <%= status_config[:color] %>">
                        <i class="<%= status_config[:icon] %> mr-1"></i>
                        <%= status_config[:text] %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-sm">
                      <%= link_to "View Details", 
                          employee_detail_path(emp, quarter: quarter_name, department_id: department_id), 
                          class: "inline-flex items-center px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg shadow-sm transition-all duration-200 hover:shadow-md transform hover:scale-105" %>
                    </td>
                  </tr>
                  <% end %>
                <% end %>
           </tbody>
        </table>
      </div>

      <!-- DYNAMIC L1 Manager Counting Logic -->
      <%
        # Initialize counters
        total_l1_records = 0
        l1_approved_count = 0
        l1_returned_count = 0
        pending_l1_review_count = 0
        processed_quarters = {}
        
        quarters = {
          'Q1' => ['april', 'may', 'june'],
          'Q2' => ['july', 'august', 'september'], 
          'Q3' => ['october', 'november', 'december'],
          'Q4' => ['january', 'february', 'march']
        }

        # FIXED: Use the same global deduplication hash from the view logic
        global_processed_combinations = {}
        
        # FIXED: Process each employee group (grouped by name) to aggregate achievements
        employee_groups = @employee_details.group_by(&:employee_name)
        employee_groups.each do |employee_name, employee_records|
          # Use the first employee record for basic info
          emp = employee_records.first
          
          # FIXED: Get all departments from ALL employee records for this employee name
          all_user_details = employee_records.flat_map(&:user_details)
          employee_departments = all_user_details.map(&:department).uniq
          
          employee_departments.each do |department|
            quarters.each do |quarter_name, quarter_months|
              # FIXED: Create unique key for employee name + department + quarter combination (same as view logic)
              unique_key = "#{emp.employee_name}_#{department.department_type}_#{quarter_name}"
              next if global_processed_combinations[unique_key]
              
              # FIXED: Get achievements from ALL employee records for this employee name in this department
              department_user_details = all_user_details.select { |ud| ud.department_id == department.id }
              
              # Get all achievements for this employee in this department for this quarter
              monthly_achievements = department_user_details.flat_map(&:achievements).select { |ach| quarter_months.include?(ach.month) }
              
              # Also check for quarterly format achievements (q1, q2, q3, q4)
              quarterly_achievements = department_user_details.flat_map(&:achievements).select do |ach|
                case quarter_name
                when 'Q1'
                  ach.month == 'q1'
                when 'Q2'
                  ach.month == 'q2'
                when 'Q3'
                  ach.month == 'q3'
                when 'Q4'
                  ach.month == 'q4'
                else
                  false
                end
              end
              
              # Combine both types of achievements
              all_quarter_achievements = monthly_achievements + quarterly_achievements
              
              # FIXED: Only process quarters where user has actually SUBMITTED their quarterly achievement
              # Check if user has submitted quarterly achievement (month = 'q1', 'q2', 'q3', 'q4') with actual data
              quarterly_submission = all_quarter_achievements.find do |ach|
                case quarter_name
                when 'Q1'
                  ach.month == 'q1' && ach.achievement.present?
                when 'Q2'
                  ach.month == 'q2' && ach.achievement.present?
                when 'Q3'
                  ach.month == 'q3' && ach.achievement.present?
                when 'Q4'
                  ach.month == 'q4' && ach.achievement.present?
                else
                  false
                end
              end
              
              # Only process if user has actually submitted quarterly achievement with data
              if quarterly_submission.present?
                # Mark this combination as processed (same as view logic)
                global_processed_combinations[unique_key] = true
                total_l1_records += 1
              
              # FIXED: Calculate department-specific status for counting consistency
              # Use the same logic as show.html.erb - filter user_details first, then get achievements
              if quarterly_submission.present?
                # FIXED: Calculate status ONLY from achievements in THIS specific department
                # Use the same logic as show.html.erb - filter user_details first, then get achievements
                # FIXED: Use the same filtering approach as the main view - get from ALL employee records
                department_user_details = all_user_details.select { |ud| ud.department_id == department.id }
                
                # Get achievements only from this specific department
                department_quarter_achievements = []
                department_user_details.each do |ud|
                  # FIXED: Include BOTH monthly and quarterly achievements for status calculation
                  # Monthly achievements (april, may, june, etc.)
                  monthly_achievements = ud.achievements.select { |ach| quarter_months.include?(ach.month) }
                  
                  # Quarterly achievements (q1, q2, q3, q4)
                  quarterly_achievements = ud.achievements.select do |ach|
                    case quarter_name
                    when 'Q1'
                      ach.month == 'q1'
                    when 'Q2'
                      ach.month == 'q2'
                    when 'Q3'
                      ach.month == 'q3'
                    when 'Q4'
                      ach.month == 'q4'
                    else
                      false
                    end
                  end
                  
                  # Add both monthly and quarterly achievements to department collection
                  department_quarter_achievements.concat(monthly_achievements)
                  department_quarter_achievements.concat(quarterly_achievements)
                end
                
                quarter_statuses = department_quarter_achievements.map { |ach| ach.status || "pending" }
                
                # FIXED: Use the EXACT same status calculation logic as show.html.erb AND table display
                # Check for empty statuses first, just like show.html.erb
                if quarter_statuses.empty?
                  employee_status = "pending"
                else
                  # FIXED: Check if L1 has actually provided remarks and percentage for this department
                  # This matches the logic in show.html.erb
                  quarter_l1_total = 0
                  quarter_remarks_l1 = Set.new
                  
                  department_quarter_achievements.each do |achievement|
                    if achievement.achievement_remark.present?
                      # Collect L1 data
                      if achievement.achievement_remark.l1_percentage.present?
                        quarter_l1_total += achievement.achievement_remark.l1_percentage.to_f
                      end
                      
                      # Add unique L1 remarks only
                      if achievement.achievement_remark.l1_remarks.present?
                        quarter_remarks_l1.add(achievement.achievement_remark.l1_remarks)
                      end
                    end
                  end
                  
                  has_l1_remarks = quarter_remarks_l1.any? { |remark| remark.present? && remark != "No remarks for this quarter" }
                  has_l1_percentage = quarter_l1_total > 0
                  
                  # FIXED: Use EXACT same logic as show.html.erb
                  # Check if no achievements found for this department, default to pending
                  if quarter_statuses.empty?
                    employee_status = "pending"
                  elsif department_user_details.empty?
                    employee_status = "pending"
                  elsif !has_l1_remarks && !has_l1_percentage
                    employee_status = "pending"
                  else
                    # FIXED: Use EXACT same status calculation as show.html.erb
                    # But prioritize returned_to_employee over l3_approved for department-specific status
                    employee_status = if quarter_statuses.include?("returned_to_employee")
                                      "returned_to_employee"
                                    elsif quarter_statuses.include?("l3_approved")
                                      "l3_approved"
                                    elsif quarter_statuses.include?("l3_returned")
                                      "l3_returned"
                                    elsif quarter_statuses.include?("l2_approved")
                                      "l2_approved"
                                    elsif quarter_statuses.include?("l2_returned")
                                      "l2_returned"
                                    elsif quarter_statuses.include?("l1_returned")
                                      "l1_returned"
                                    elsif quarter_statuses.include?("l1_approved")
                                      "l1_approved"
                                    elsif quarter_statuses.include?("submitted")
                                      "submitted"
                                    elsif quarter_statuses.include?("pending")
                                      "pending"
                                    else
                                      "pending"
                                    end
                  end
                end
              else
                employee_status = "pending"
              end
              
              # DYNAMIC COUNTING LOGIC FOR L1 MANAGER
              # Determine what L1 manager needs to see and act on
              
              # Check if L1 has already taken action on this record OR if it has been processed by higher levels
              # L1 has acted if the record shows L1 approved/returned OR if it has been processed by L2/L3 (which means L1 must have approved it first)
              l1_has_acted = ["l1_approved", "l1_returned"].include?(employee_status)
              processed_by_higher_levels = ["l2_approved", "l2_returned", "l3_approved", "l3_returned"].include?(employee_status)
              
              if l1_has_acted || processed_by_higher_levels
                # L1 has already acted OR record has been processed by higher levels (which means L1 approved it)
                if employee_status == "l1_returned"
                  l1_returned_count += 1
                else
                  # All other cases (l1_approved, l2_approved, l2_returned, l3_approved, l3_returned) count as L1 approved
                  # because L1 must have approved it for it to reach higher levels
                  l1_approved_count += 1
                end
              else
                # Record is truly pending L1 review - L1 needs to act on it
                pending_l1_review_count += 1
              end
            end
          end
        end
      end
      %>


      <!-- L1 Manager Summary Cards -->
      <div class="mt-6 grid grid-cols-1 md:grid-cols-4 gap-4">
        <!-- Total L1 Records -->
        <div class="bg-blue-50 p-4 rounded-lg border border-blue-200">
          <div class="flex items-center">
            <i class="fas fa-users mr-3" style="color: #2d374b;"></i>
