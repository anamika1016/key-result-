<!-- Main Content Area - Full Screen Layout -->
<div class="min-h-screen bg-gray-50">
  <!-- Content Area -->
  <div class="ml-64 p-8">
  <!-- Settings Header -->
  <div class="flex items-center gap-3 mb-8">
    <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
      <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
    <div>
      <h1 class="text-3xl font-bold text-gray-900">User Profile</h1>
      <p class="text-gray-600">Manage your account settings and preferences</p>
    </div>
  </div>


  <!-- User Profile Section -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-10 mb-8">
    <div class="flex items-start justify-between mb-6">
      <div class="flex items-center gap-6">
        <!-- Profile Picture -->
        <div class="relative w-fit">
          <div id="profileImageContainer" class="w-56 h-56 rounded-full overflow-hidden border-4 border-gray-200">
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar, 
                            alt: "Profile Picture", 
                            class: "w-full h-full object-cover",
                            id: "profileImage" %>
            <% else %>
              <%= image_tag "business_female_male_users.svg", 
                            alt: "Profile Picture", 
                            class: "w-full h-full object-cover",
                            id: "profileImage" %>
            <% end %>
          </div>
          
          <!-- Camera Icon - Clickable -->
          <label for="avatarInput" class="absolute bottom-2 right-2 bg-green-500 hover:bg-green-600 hover:scale-110 rounded-full p-3.5 border-4 border-white cursor-pointer transition-all duration-200 shadow-lg hover:shadow-xl group" title="Click to upload profile picture">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <!-- Tooltip -->
            <div class="absolute bottom-full right-0 mb-2 px-3 py-2 bg-gray-800 text-white text-sm rounded opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap">
              Upload Profile Picture
            </div>
          </label>
          
          <!-- Hidden File Input -->
          <%= form_with model: @user, url: settings_profile_path, method: :patch, local: true, multipart: true, id: "avatarForm" do |form| %>
            <%= form.file_field :avatar, 
                                id: "avatarInput", 
                                accept: "image/*", 
                                class: "hidden",
                                onchange: "uploadAvatar(this)" %>
          <% end %>
        </div>

        <!-- User Info -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-2">
            <%= user_display_name(@user) %>
          </h2>
          <p class="text-lg text-gray-600 mb-3"><%= @user.email %></p>
          <span class="inline-flex items-center px-4 py-2 rounded-full text-base font-medium <%= user_role_badge_class(@user.role) %>">
            <%= display_role_name(@user.role) %>
          </span>
        </div>
      </div>

    </div>

    <!-- User Details Grid -->
    <div class="grid grid-cols-2 gap-8">
      <div class="space-y-6">
        <div>
          <label class="text-base font-medium text-gray-500">Full Name</label>
          <p class="text-lg text-gray-900 font-medium"><%= user_display_name(@user) %></p>
        </div>
        <div>
          <label class="text-base font-medium text-gray-500">Email Address</label>
          <p class="text-lg text-gray-900 font-medium"><%= @user.email %></p>
        </div>
        <div>
          <label class="text-base font-medium text-gray-500">Role</label>
          <p class="text-lg text-gray-900 font-medium"><%= display_role_name(@user.role) %></p>
        </div>
      </div>
      <div class="space-y-6">
        <div>
          <label class="text-base font-medium text-gray-500">Employee Code</label>
          <p class="text-lg text-gray-900 font-medium"><%= @user.employee_code.present? ? @user.employee_code : 'Not assigned' %></p>
        </div>
        <div>
          <label class="text-base font-medium text-gray-500">Member Since</label>
          <p class="text-lg text-gray-900 font-medium"><%= format_date(@user.created_at) %></p>
        </div>
        <div>
          <label class="text-base font-medium text-gray-500">Last Updated</label>
          <p class="text-lg text-gray-900 font-medium"><%= format_date(@user.updated_at) %></p>
        </div>
      </div>
    </div>

    <!-- Edit Profile Form (Hidden by default) -->
    <div id="editProfileForm" class="hidden mt-8 pt-8 border-t border-gray-200">
      <%= form_with model: @user, url: settings_profile_path, method: :patch, local: true, class: "space-y-6" do |form| %>
        <% if @user.errors.any? %>
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4">
            <ul class="list-disc list-inside">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        
        <div class="grid grid-cols-2 gap-6">
          <div>
            <%= form.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.email_field :email, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent #{'border-red-500' if @user.errors[:email].any?}" %>
          </div>
          <div>
            <%= form.label :employee_code, "Employee Code", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :employee_code, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent #{'border-red-500' if @user.errors[:employee_code].any?}" %>
          </div>
        </div>
        
        <div class="flex gap-4">
          <%= form.submit "Save Changes", class: "text-white px-6 py-2 rounded-lg font-medium transition duration-200", style: "background-color: #2d374b;", onmouseover: "this.style.backgroundColor='#1a202c'", onmouseout: "this.style.backgroundColor='#2d374b'" %>
          <button type="button" onclick="toggleEditMode()" class="bg-gray-300 hover:bg-gray-400 text-gray-700 px-6 py-2 rounded-lg font-medium transition duration-200">
            Cancel
          </button>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Security Settings Section -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-10">
    <h3 class="text-xl font-bold text-gray-900 mb-6">Security Settings</h3>
    
    <!-- Change Password Form -->
    <div id="changePasswordForm" class="hidden">
      <%= form_with model: @user, url: settings_password_path, method: :patch, local: true, class: "space-y-6" do |form| %>
        <% if @user.errors.any? %>
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4">
            <ul class="list-disc list-inside">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        
        <div class="grid grid-cols-1 gap-6 max-w-md">
          <div>
            <%= form.label :current_password, "Current Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.password_field :current_password, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent #{'border-red-500' if @user.errors[:current_password].any?}" %>
          </div>
          <div>
            <%= form.label :password, "New Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.password_field :password, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent #{'border-red-500' if @user.errors[:password].any?}" %>
          </div>
          <div>
            <%= form.label :password_confirmation, "Confirm New Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.password_field :password_confirmation, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent #{'border-red-500' if @user.errors[:password_confirmation].any?}" %>
          </div>
        </div>
        
        <div class="flex gap-4">
          <%= form.submit "Change Password", class: "text-white px-6 py-2 rounded-lg font-medium transition duration-200", style: "background-color: #2d374b;", onmouseover: "this.style.backgroundColor='#1a202c'", onmouseout: "this.style.backgroundColor='#2d374b'" %>
          <button type="button" onclick="togglePasswordForm()" class="bg-gray-300 hover:bg-gray-400 text-gray-700 px-6 py-2 rounded-lg font-medium transition duration-200">
            Cancel
          </button>
        </div>
      <% end %>
    </div>

    <!-- Change Password Button -->
    <button id="changePasswordBtn" onclick="togglePasswordForm()" class="bg-red-600 hover:bg-red-700 text-white px-8 py-3 rounded-lg font-medium text-lg transition duration-200">
      Change Password
    </button>
  </div>
</div>

<script>
function toggleEditMode() {
  const form = document.getElementById('editProfileForm');
  const isHidden = form.classList.contains('hidden');
  
  if (isHidden) {
    form.classList.remove('hidden');
  } else {
    form.classList.add('hidden');
  }
}

function togglePasswordForm() {
  const form = document.getElementById('changePasswordForm');
  const button = document.getElementById('changePasswordBtn');
  const isHidden = form.classList.contains('hidden');
  
  if (isHidden) {
    form.classList.remove('hidden');
    button.classList.add('hidden');
  } else {
    form.classList.add('hidden');
    button.classList.remove('hidden');
  }
}

async function uploadAvatar(input) {
  if (!input.files || !input.files[0]) return;
  
  const file = input.files[0];
  const cameraIcon = document.querySelector('label[for="avatarInput"]');
  const originalContent = cameraIcon.innerHTML;
  const profileImage = document.getElementById('profileImage');
  const sidebarAvatar = document.querySelector('.sidebar-avatar');
  const originalProfileSrc = profileImage ? profileImage.src : '';
  const originalSidebarSrc = sidebarAvatar ? sidebarAvatar.src : '';

  // 1. Client-side Validation
  if (!file.type.startsWith('image/')) {
    showMessage('Please select a valid image file.', 'error');
    input.value = '';
    return;
  }
  
  // Max size check - hint at Nginx config if it fails later
  if (file.size > 10 * 1024 * 1024) {
    showMessage('Image size is too large (max 10MB).', 'error');
    input.value = '';
    return;
  }

  try {
    // 2. Show Preview
    const reader = new FileReader();
    reader.onload = (e) => {
      if (profileImage) profileImage.src = e.target.result;
    };
    reader.readAsDataURL(file);

    // 3. Prepare Submission
    const form = document.getElementById('avatarForm');
    const formData = new FormData(form);
    
    // Show loading state
    cameraIcon.innerHTML = '<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>';

    // 4. Fetch Request
    const response = await fetch(form.action, {
      method: 'PATCH',
      body: formData,
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
        'X-Requested-With': 'XMLHttpRequest'
      }
    });

    // 5. Handle Nginx Errors (413, 502, etc.)
    if (response.status === 413) {
      throw new Error('Image is too large for the server. (Nginx: client_max_body_size limit)');
    }

    if (!response.ok) {
      const errorText = await response.text();
      // If server returned HTML (likely an error page), don't try to parse as JSON
      if (errorText.trim().startsWith('<')) {
        throw new Error(`Server Error (${response.status}): Please contact Administrator to increase upload limit.`);
      }
    }

    // 6. Parse JSON Response
    const data = await response.json().catch(() => {
      throw new Error('Invalid server response. Please try again.');
    });

    if (data.success) {
      if (data.avatar_url) {
        if (profileImage) profileImage.src = data.avatar_url;
        if (sidebarAvatar) sidebarAvatar.src = data.avatar_url;
      }
      showMessage(data.message || 'Profile picture updated successfully!', 'success');
    } else {
      throw new Error(data.errors ? data.errors.join(', ') : 'Upload failed.');
    }

  } catch (error) {
    console.error('Avatar upload error:', error);
    
    // Provide a helpful message for the 413 case specifically
    let userMessage = error.message;
    if (userMessage.includes('413') || userMessage.includes('too large')) {
      userMessage = "Image is too large for the server. Please compress it or ask Admin to increase 'client_max_body_size' in Nginx.";
    }
    
    showMessage(userMessage || 'Failed to update profile picture.', 'error');
    
    // Revert previews on error
    if (profileImage) profileImage.src = originalProfileSrc;
    if (sidebarAvatar) sidebarAvatar.src = originalSidebarSrc;
    input.value = '';
  } finally {
    // Restore camera icon
    cameraIcon.innerHTML = originalContent;
  }
}

function showMessage(message, type) {
  // Remove existing messages
  const existingMessages = document.querySelectorAll('.flash-message');
  existingMessages.forEach(msg => msg.remove());
  
  // Create new message
  const messageDiv = document.createElement('div');
  messageDiv.className = `flash-message fixed top-4 right-4 z-50 px-6 py-3 rounded-lg shadow-lg ${
    type === 'success' ? 'bg-green-100 border border-green-400 text-green-700' : 'bg-red-100 border border-red-400 text-red-700'
  }`;
  messageDiv.textContent = message;
  
  document.body.appendChild(messageDiv);
  
  // Auto remove after 3 seconds
  setTimeout(() => {
    messageDiv.remove();
  }, 3000);
}
</script>
