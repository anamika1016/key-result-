<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Required Meta Tags Always Come First -->
  <meta charset="utf-8">
  <meta name="robots" content="max-snippet:-1, max-image-preview:large, max-video-preview:-1">
  <link rel="canonical" href="https://preline.co/">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="description" content="Comprehensive overview with charts, tables, and a streamlined dashboard layout for easy data visualization and analysis.">

  <meta name="twitter:site" content="@preline">
  <meta name="twitter:creator" content="@preline">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Tailwind CSS Admin Template | Preline UI, crafted with Tailwind CSS">
  <meta name="twitter:description" content="Comprehensive overview with charts, tables, and a streamlined dashboard layout for easy data visualization and analysis.">
  <meta name="twitter:image" content="https://preline.co/assets/img/og-image.png">

  <meta property="og:url" content="https://preline.co/">
  <meta property="og:locale" content="en_US">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Preline">
  <meta property="og:title" content="Tailwind CSS Admin Template | Preline UI, crafted with Tailwind CSS">
  <meta property="og:description" content="Comprehensive overview with charts, tables, and a streamlined dashboard layout for easy data visualization and analysis.">
  <meta property="og:image" content="https://preline.co/assets/img/og-image.png">

  <!-- Title -->
  <title>Tailwind CSS Admin Template | Preline UI, crafted with Tailwind CSS</title>

  <!-- Favicon -->
  <link rel="shortcut icon" href="../../favicon.ico">

  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- CSS HS -->
  <link rel="stylesheet" href="https://preline.co/assets/css/main.css?v=3.1.0">
  
  <!-- UI FIX - Force proper sidebar layout -->
  <style>
    /* Force proper sidebar layout immediately */
    #hs-application-sidebar {
      min-width: 15.25rem !important;
      width: 15.25rem !important;
    }
    
    /* Force proper link layout */
    #hs-application-sidebar .flex.items-center {
      display: flex !important;
      align-items: center !important;
      gap: 0.82rem !important;
      padding: 0.52rem 0.65rem !important;
      border-radius: 0.5rem !important;
    }
    
    /* Force icon size */
    #hs-application-sidebar svg {
      width: 1.43rem !important;
      height: 1.43rem !important;
      flex-shrink: 0 !important;
    }

    #hs-application-sidebar a,
    #hs-application-sidebar summary {
      font-size: 1rem !important;
    }

    #hs-application-sidebar .text-base,
    #hs-application-sidebar .text-lg {
      font-size: 1rem !important;
      line-height: 1.35rem !important;
    }
    
    /* Force text to show inline */
    #hs-application-sidebar span {
      display: inline !important;
      white-space: nowrap !important;
    }
    
    /* Force navigation to be visible */
    #hs-application-sidebar nav {
      display: flex !important;
      flex-direction: column !important;
      padding: 0.55rem !important;
    }
    
    #hs-application-sidebar ul {
      display: flex !important;
      flex-direction: column !important;
      gap: 0.12rem !important;
    }
    
    #hs-application-sidebar li {
      display: block !important;
    }

    #hs-application-sidebar details > summary {
      list-style: none !important;
      cursor: pointer;
    }

    #hs-application-sidebar details > summary::-webkit-details-marker {
      display: none !important;
    }

    #hs-application-sidebar .sidebar-submenu {
      margin-top: 0.25rem !important;
      margin-left: 1.75rem !important;
      padding-left: 0.5rem !important;
      border-left: 1px solid #e5e7eb !important;
      gap: 0.125rem !important;
    }

    #hs-application-sidebar .sidebar-submenu .flex.items-center {
      padding: 0.375rem 0.625rem !important;
      gap: 0.5rem !important;
      font-size: 0.9rem !important;
    }

    #hs-application-sidebar .sidebar-submenu svg {
      width: 1rem !important;
      height: 1rem !important;
    }

    #hs-application-sidebar details[open] .sidebar-menu-chevron {
      transform: rotate(180deg);
    }
  </style>
</head>

<body class="bg-gray-50">
  <!-- Sidebar -->
  <div id="hs-application-sidebar" class="hs-overlay  [--auto-close:lg]
    hs-overlay-open:translate-x-0
    -translate-x-full transition-all duration-300 transform
    w-64 h-full
    hidden
    fixed inset-y-0 start-0 z-60
    bg-white border-e border-gray-200
    lg:block lg:translate-x-0 lg:end-auto lg:bottom-0" role="dialog" tabindex="-1" aria-label="Sidebar">
    <div class="relative flex flex-col h-full max-h-full">
      <div class="px-4 pt-3 flex items-center">
        <!-- Logo -->
        <a class="d-inline-block rounded-xl text-xl font-weight-semibold" href="#" aria-label="Preline">
          <%= image_tag "asa.jpeg", alt: "ASA Logo", class: "img-fluid", style: "width: 168px; height: 74px" %>
        </a>
        <!-- End Logo -->
      </div>

      <!-- Content -->    
    <div class="h-full overflow-y-auto [&::-webkit-scrollbar]:w-2 [&::-webkit-scrollbar-thumb]:rounded-full [&::-webkit-scrollbar-track]:bg-gray-100 [&::-webkit-scrollbar-thumb]:bg-gray-300">
      <nav class="hs-accordion-group p-3 w-full flex flex-col flex-wrap" data-hs-accordion-always-open>
        <ul class="flex flex-col space-y-1">

          <!-- Dashboard - Show for HOD only -->
          <% if current_user.hod? %>
            <li class="hs-accordion" id="dashboard-accordion">
              <%= link_to dashboard_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(dashboard_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M3 4h18l-1 4H4L3 4z" />
                  <path d="M4 8h16v12a2 2 0 01-2 2H6a2 2 0 01-2-2V8z" />
                </svg>
                <span class="font-semibold">Dashboard</span>
              <% end %>
            </li>
          <% end %>

          <!-- Employee Forms - Show for all employee types -->
          <% if current_user.employee? || current_user.l1_employer? || current_user.l2_employer? %>
          <li class="hs-accordion" id="users-accordion">
            <%= link_to user_details_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(user_details_path)} text-base text-gray-800 rounded-lg" do %>
              <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
                <circle cx="12" cy="12" r="6" />
                <circle cx="12" cy="12" r="2" />
              </svg>
              <span class="font-semibold">Target Form</span>
            <% end %>
          </li>

          <li class="hs-accordion" id="users-accordion">
            <%= link_to get_user_detail_user_details_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(get_user_detail_user_details_path)} text-base text-gray-800 rounded-lg" do %>
              <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" />
                <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" />
                <path d="M4 22h16" />
                <path d="M10 14.66V17c0 .55-.47.98-.97 1.21l-1.5.5c-.5.17-1.03.17-1.53 0l-1.5-.5C4.47 17.98 4 17.55 4 17v-2.34" />
                <path d="M20 14.66V17c0 .55.47.98.97 1.21l1.5.5c.5.17 1.03.17 1.53 0l1.5-.5C25.53 17.98 26 17.55 26 17v-2.34" />
                <path d="M12 2v13" />
                <path d="M8 8l4-4 4 4" />
              </svg>
              <span class="font-semibold">Achievement Form</span>
            <% end %>
          </li>

          <!-- Submitted View Data - Show for employees only, NOT for HOD -->
          <% unless current_user.hod? %>
            <li class="hs-accordion" id="users-accordion">
              <%= link_to submitted_view_data_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(submitted_view_data_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M3 3v18h18" />
                  <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3" />
                </svg>
                <span class="font-semibold">Submitted View Data</span>
              <% end %>
            </li>
          <% end %>
          <% end %>

          <!-- HOD Only - Admin Functions -->
          <% if current_user.hod? %>
            <li class="hs-accordion" id="users-accordion">
              <%= link_to employee_details_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(employee_details_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                  <rect x="8" y="6" width="8" height="4" rx="1" />
                  <path d="M12 14h.01" />
                </svg>
                <span class="font-semibold">Employee Details</span>
              <% end %>
            </li>

            <li class="hs-accordion" id="users-accordion">
              <%= link_to departments_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(departments_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" />
                  <path d="M6 12H4a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2" />
                  <path d="M18 9h2a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-2" />
                  <path d="M10 6h4" />
                  <path d="M10 10h4" />
                  <path d="M10 14h4" />
                  <path d="M10 18h4" />
                </svg>
                <span class="font-semibold">KPI Details</span>
              <% end %>
            </li>

            <li class="hs-accordion" id="users-accordion">
              <%= link_to new_user_detail_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(new_user_detail_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M19 8v6" />
                  <path d="M22 11l-3-3-3 3" />
                </svg>
                <span class="font-semibold">Bulk Import Users</span>
              <% end %>
            </li>
          <% end %>

          <!-- L1 Employee Details - Show if user has L1 responsibilities -->
          <% if current_user.hod? || EmployeeDetail.exists?(l1_code: current_user.employee_code) %>
            <li class="hs-accordion" id="users-accordion">
              <%= link_to l1_employee_details_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(l1_employee_details_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M19 8v6" />
                  <path d="M22 11l-3-3-3 3" />
                  <path d="M19 8v6" />
                  <path d="M22 11l-3-3-3 3" />
                </svg>
                <span class="font-semibold">L1 Manager Details</span>
              <% end %>
            </li>
          <% end %>

          <!-- L2 Employee Details - Show if user has L2 responsibilities -->
          <% if current_user.hod? || EmployeeDetail.exists?(l2_code: current_user.employee_code) || EmployeeDetail.exists?(l2_employer_name: current_user.email) %>
            <li class="hs-accordion" id="users-accordion">
              <%= link_to l2_employee_details_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(l2_employee_details_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
                <span class="font-semibold">L2 Manager Details</span>
              <% end %>
            </li>
          <% end %>

          <!-- L3 Employee Details - Show if user has L3 responsibilities -->
          <% if current_user.hod? || EmployeeDetail.exists?(l3_code: current_user.employee_code) || EmployeeDetail.exists?(l3_employer_name: current_user.email) %>
            <li class="hs-accordion" id="users-accordion">
              <%= link_to l3_employee_details_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(l3_employee_details_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M6 3h12l4 6-10 13L2 9l4-6z" />
                  <path d="M11 3L8 9l4 13 4-13-3-6" />
                </svg>
                <span class="font-semibold">L3 Manager Details</span>
              <% end %>
            </li>
          <% end %>
          <% training_menu_active = controller_name == "trainings" || controller_name == "employee_trainings" %>
          <li>
            <details class="group" <%= "open" if training_menu_active %>>
              <summary class="flex items-center gap-x-3.5 py-2 px-2.5 <%= 'bg-gray-100' if training_menu_active %> text-base text-gray-800 rounded-lg cursor-pointer list-none">
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M12 6v6l4 2" /><circle cx="12" cy="12" r="10" />
                </svg>
                <span class="font-semibold text-base">Training</span>
                <svg class="ms-auto size-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </summary>
              <ul class="pt-1 ps-8 space-y-1">
                <li>
                  <%= link_to employee_trainings_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if controller_name == 'employee_trainings' && action_name != 'new'} text-sm text-gray-800 rounded-lg" do %>
                    <span class="font-semibold">Training Record</span>
                  <% end %>
                </li>
                <li>
                  <%= link_to new_employee_training_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(new_employee_training_path)} text-sm text-gray-800 rounded-lg" do %>
                    <span class="font-semibold">TOT Training</span>
                  <% end %>
                </li>
                <li>
                  <%= link_to trainings_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if controller_name == 'trainings'} text-sm text-gray-800 rounded-lg" do %>
                    <span class="font-semibold">Online Training</span>
                  <% end %>
                </li>
                <% if current_user.hod? %>
                  <li>
                    <%= link_to employee_training_thematics_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if controller_name == 'employee_training_thematics'} text-sm text-gray-800 rounded-lg" do %>
                      <span class="font-semibold">Thematic Master</span>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to employee_training_topics_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if controller_name == 'employee_training_topics'} text-sm text-gray-800 rounded-lg" do %>
                      <span class="font-semibold">Topic Master</span>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </details>
          </li>

          <% if current_user.hod? %>
            <li>
              <%= link_to user_training_assignments_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(user_training_assignments_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
                <span class="font-semibold text-base">Assign Trainings</span>
              <% end %>
            </li>
          <% end %>
          <% if current_user.hod? %>
            <li>
              <%= link_to quizzes_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if controller_name == 'quizzes'} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                  <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                  <path d="M8 7h8" />
                  <path d="M8 11h8" />
                </svg>
                <span class="font-semibold text-base">Quiz Details</span>
              <% end %>
            </li>
          <% end %>
          <% if current_user.hod? %>
            <li>
              <%= link_to user_quizzes_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(user_quizzes_path)} text-base text-gray-800 rounded-lg" do %>
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
                <span class="font-semibold text-base">User Quiz Details</span>
              <% end %>
            </li>
          <% end %>
          <li>
            <% guest_house_menu_open = %w[guest_house_bookings guest_houses guest_house_notifications].include?(controller_name) %>
            <% guest_house_unread_count = current_user.guest_house_notifications.unread.count %>
            <details <%= "open" if guest_house_menu_open %>>
              <summary class="flex items-center gap-x-3.5 py-2 px-2.5 <%= 'bg-gray-100' if guest_house_menu_open %> text-base text-gray-800 rounded-lg">
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M3 21h18" />
                  <path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16" />
                  <path d="M9 8h1" />
                  <path d="M14 8h1" />
                  <path d="M9 12h1" />
                  <path d="M14 12h1" />
                  <path d="M10 21v-5h4v5" />
                </svg>
                <span class="font-semibold text-base">Guest House</span>
                <% if guest_house_unread_count.positive? %>
                  <span class="inline-flex min-w-5 h-5 items-center justify-center rounded-full bg-red-600 px-1.5 text-xs font-bold text-white"><%= [ guest_house_unread_count, 99 ].min %><%= "+" if guest_house_unread_count > 99 %></span>
                <% end %>
                <svg class="sidebar-menu-chevron ml-auto h-4 w-4 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </summary>
              <ul class="sidebar-submenu flex flex-col space-y-1">
                <li>
                  <%= link_to guest_house_bookings_path, class: "flex items-center gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'guest_house_bookings' && action_name.in?(%w[index create])} text-sm text-gray-800 rounded-lg" do %>
                    <span class="font-semibold">Guest House Form</span>
                  <% end %>
                </li>
                <li>
                  <%= link_to guest_house_notifications_path, class: "flex items-center justify-between gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'guest_house_notifications'} text-sm text-gray-800 rounded-lg" do %>
                    <span class="font-semibold">Notifications</span>
                    <% if guest_house_unread_count.positive? %>
                      <span class="inline-flex min-w-5 h-5 items-center justify-center rounded-full bg-red-600 px-1.5 text-xs font-bold text-white"><%= [ guest_house_unread_count, 99 ].min %><%= "+" if guest_house_unread_count > 99 %></span>
                    <% end %>
                  <% end %>
                </li>
                <li>
                  <%= link_to records_guest_house_bookings_path, class: "flex items-center gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'guest_house_bookings' && action_name == 'records'} text-sm text-gray-800 rounded-lg" do %>
                    <% records_label = if current_user.hod?
                                         "All Booking Records"
                                       elsif current_user.managed_guest_houses.exists?
                                         "Guest House Records"
                                       else
                                         "My Booking Records"
                                       end %>
                    <span class="font-semibold"><%= records_label %></span>
                  <% end %>
                </li>
                <% if current_user.hod? || current_user.managed_guest_houses.exists? %>
                  <li>
                    <%= link_to admin_guest_house_bookings_path, class: "flex items-center gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'guest_house_bookings' && action_name == 'admin'} text-sm text-gray-800 rounded-lg" do %>
                      <span class="font-semibold">Admin Bookings</span>
                    <% end %>
                  </li>
                <% end %>
                <% if current_user.hod? %>
                  <li>
                    <%= link_to guest_houses_path, class: "flex items-center gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'guest_houses'} text-sm text-gray-800 rounded-lg" do %>
                      <span class="font-semibold">Guest House Master</span>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </details>
          </li>
          <li>
            <%
              help_desk_user_badge_count = help_desk_user_action_count
              help_desk_assigned_badge_count = helpdesk_reviewer? ? help_desk_assigned_count : 0
              help_desk_menu_badge_count = help_desk_user_badge_count + help_desk_assigned_badge_count
              help_desk_menu_open = %w[help_desk_tickets help_desk_reports help_desk_question_masters helpdesk_escalation_matrices].include?(controller_name)
            %>
            <details <%= "open" if help_desk_menu_open %>>
              <summary class="flex items-center gap-x-3.5 py-2 px-2.5 <%= 'bg-gray-100' if help_desk_menu_open %> text-base text-gray-800 rounded-lg">
                <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M4 5h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-5l-3 3-3-3H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" />
                  <path d="M8 10h8" />
                  <path d="M8 14h5" />
                </svg>
                <span class="font-semibold text-base">Help Desk</span>
                <% if help_desk_menu_badge_count.positive? %>
                  <span class="ml-auto inline-flex min-w-6 items-center justify-center rounded-full bg-red-500 px-2 py-0.5 text-xs font-bold text-white">
                    <%= help_desk_notification_label(help_desk_menu_badge_count) %>
                  </span>
                <% end %>
                <svg class="sidebar-menu-chevron <%= help_desk_menu_badge_count.positive? ? '' : 'ml-auto' %> h-4 w-4 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </summary>

              <ul class="sidebar-submenu flex flex-col space-y-1">
                <li>
                  <%= link_to help_desk_tickets_path, class: "flex items-center gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'help_desk_tickets' && action_name != 'assigned_queue'} text-sm text-gray-800 rounded-lg" do %>
                    <span class="font-semibold">Help Desk Ticket</span>
                    <% if help_desk_user_badge_count.positive? %>
                      <span class="ml-auto inline-flex min-w-6 items-center justify-center rounded-full bg-red-500 px-2 py-0.5 text-xs font-bold text-white"
                            data-helpdesk-menu-badge="<%= help_desk_user_badge_count %>">
                        <%= help_desk_notification_label(help_desk_user_badge_count) %>
                      </span>
                    <% end %>
                  <% end %>
                </li>

                <% if helpdesk_reviewer? %>
                  <li>
                    <%= link_to assigned_queue_help_desk_tickets_path, class: "flex items-center gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'help_desk_tickets' && action_name == 'assigned_queue'} text-sm text-gray-800 rounded-lg" do %>
                      <span class="font-semibold">Assigned Queue</span>
                      <% if help_desk_assigned_badge_count.positive? %>
                        <span class="ml-auto inline-flex min-w-6 items-center justify-center rounded-full bg-red-500 px-2 py-0.5 text-xs font-bold text-white">
                          <%= help_desk_notification_label(help_desk_assigned_badge_count) %>
                        </span>
                      <% end %>
                    <% end %>
                  </li>
                <% end %>

                <li>
                  <%= link_to help_desk_reports_path, class: "flex items-center gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'help_desk_reports'} text-sm text-gray-800 rounded-lg" do %>
                    <span class="font-semibold">Help Desk Report</span>
                  <% end %>
                </li>

                <% if current_user.hod? %>
                  <li>
                    <%= link_to help_desk_question_masters_path, class: "flex items-center gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'help_desk_question_masters'} text-sm text-gray-800 rounded-lg" do %>
                      <span class="font-semibold">Question Master</span>
                    <% end %>
                  </li>

                  <li>
                    <%= link_to helpdesk_escalation_matrices_path, class: "flex items-center gap-x-2 py-1.5 px-2.5 #{'bg-gray-100' if controller_name == 'helpdesk_escalation_matrices'} text-sm text-gray-800 rounded-lg" do %>
                      <span class="font-semibold">Escalation Matrix</span>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </details>
          </li>


          <!-- Settings - Show for all roles -->
          <li class="hs-accordion" id="settings-accordion">
            <%= link_to settings_path, class: "flex items-center gap-x-3.5 py-2 px-2.5 #{'bg-gray-100' if current_page?(settings_path)} text-base text-gray-800 rounded-lg" do %>
              <svg class="shrink-0 size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
              <span class="font-semibold">User Profile</span>
            <% end %>
          </li>

          <!-- Logout -->
          
        </ul>
      </nav>
    </div>
    <!-- Logout Button ABOVE the line -->
    <div class="p-3">
      <%= button_to destroy_user_session_path,
          method: :delete,
          data: { confirm: "Are you sure you want to sign out?" },
          class: "w-full flex items-center gap-x-3 py-3 px-4 text-base text-white bg-red-500 rounded-xl hover:bg-red-600 transition duration-200 shadow-md",
          form: { style: "display: inline;" } do %>
        <svg class="shrink-0 w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
          <polyline points="10 17 15 12 10 7" />
          <line x1="15" y1="12" x2="3" y2="12" />
        </svg>
        <span class="font-bold">Sign Out</span>
      <% end %>
    </div>

    <div class="flex-shrink-0 border-t border-gray-200 p-3 bg-gray-50">
      <div class="flex items-center space-x-2 text-gray-700 overflow-hidden"> <!-- changed space-x-3 to space-x-2 -->

        <!-- User Avatar -->
        <% if current_user.avatar.attached? %>
          <%= image_tag current_user.avatar,
                        alt: "User Avatar",
                        class: "rounded-full object-cover shadow-sm border border-gray-300 sidebar-avatar",
                        style: "width: 52px; height: 52px;" %>
        <% else %>
          <%= image_tag "business_female_male_users.svg",
                        alt: "User Avatar",
                        class: "rounded-full object-cover shadow-sm border border-gray-300 sidebar-avatar",
                        style: "width: 52px; height: 52px;" %>
        <% end %>

        <!-- Email inside fixed width -->
        <div class="flex flex-col overflow-hidden">
          <span class="font-semibold text-base text-gray-900 truncate max-w-[160px]">
            <%= current_user.email %>
          </span>
          <span class="text-xs text-gray-500">Logged in</span>
        </div>
      </div>
    </div>
      <!-- End Content -->
    </div>
  </div>
  <!-- End Sidebar -->
